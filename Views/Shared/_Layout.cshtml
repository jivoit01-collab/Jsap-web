@using Newtonsoft.Json
@using JSAPNEW.Controllers
@{
    Layout = null;

    // Safe access to session values with null checks
    var companyJson = Context.Session.GetString("companyList");
    var selectedCompanyId = Context.Session.GetInt32("selectedCompanyId");
    var username = Context.Session.GetString("username") ?? "Guest";
    var userId = Context.Session.GetInt32("userId"); // Get userId from session

    List<CompanyDto> companies = new List<CompanyDto>();
    if (!string.IsNullOrEmpty(companyJson))
    {
        try
        {
            companies = JsonConvert.DeserializeObject<List<CompanyDto>>(companyJson);
        }
        catch (Exception ex)
        {
            // Could log the error here
            // For now, just ensure companies is initialized
            companies = new List<CompanyDto>();
        }
    }

    // If companies list is empty or session is invalid, you might want to redirect
    if (companies.Count == 0)
    {
        // Option 1: Redirect to login
        // return Redirect("/Account/Login");

        // Option 2: Just display a message (we'll handle with JS later)
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-..." crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />

    <style>
        /* ============================================
                           ROOT VARIABLES
                           ============================================ */
        :root {
            --primary-color: #0b2c4d;
            --primary-light: #1c3f5d;
            --primary-dark: #051626;
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 70px;
            --header-height: 60px;
        }

        /* ============================================
                           COMPANY DROPDOWN STYLING
                           ============================================ */
        #companyDropdown {
            color: var(--primary-color);
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            padding: 2px 30px 8px 12px;
            background-image: url("data:image/svg+xml;utf8,<svg fill='%230b2c4d' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>");
            background-repeat: no-repeat;
            background-position: right 8px center;
            background-size: 18px;
            border: 2px solid #e2e8f0;
            font-weight: 600;
            font-size: 14px;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

            #companyDropdown:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 3px rgba(11, 44, 77, 0.1);
            }

            #companyDropdown option {
                color: var(--primary-color);
                font-weight: 600;
                padding: 10px;
            }

        .company-section {
            padding: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ============================================
                           BASE STYLES
                           ============================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background-color: #f8f9fa;
            overflow-x: hidden;
        }

        /* ============================================
                           HEADER STYLING
                           ============================================ */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: var(--header-height);
            background-color: #ffffff;
            border-bottom: 2px solid #e2e8f0;
            box-shadow: 0 2px 8px rgba(11, 44, 77, 0.08);
            z-index: 1001;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
        }

            .header h4 {
                color: var(--primary-color);
                margin: 0;
                font-size: 20px;
                font-weight: 700;
            }

        /* ============================================
                           HAMBURGER MENU BUTTON
                           ============================================ */
        .hamburger-btn {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--primary-color);
            margin-right: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            width: 28px;
            height: 22px;
            padding: 0;
            transition: all 0.3s ease;
        }

            .hamburger-btn:hover {
                opacity: 0.7;
            }

            .hamburger-btn span {
                display: block;
                height: 3px;
                width: 100%;
                background-color: var(--primary-color);
                border-radius: 2px;
                transition: all 0.3s ease;
            }

            .hamburger-btn:hover span {
                background-color: var(--primary-light);
            }

        /* ============================================
                           SIDEBAR STYLING - FIXED VERSION
                           ============================================ */
        .sidebar {
            position: fixed;
            top: var(--header-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--header-height));
            background-color: var(--primary-color);
            color: white;
            z-index: 1000;
            padding: 0;
            transition: width 0.3s ease;
            overflow-y: auto;
            overflow-x: hidden;
        }

            /* Collapsed sidebar */
            .sidebar.collapsed {
                width: var(--sidebar-collapsed-width);
            }

        /* Sidebar Content Container */
        .sidebar-content {
            padding: 20px 0;
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }

        .sidebar-menu {
            flex: 1;
            padding: 10px 0;
        }

        /* ============================================
                           MENU ITEM STYLING - ENLARGED
                           ============================================ */
        .sidebar .menu-item {
            padding: 16px 20px;
            cursor: pointer;
            position: relative;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
            color: rgba(255, 255, 255, 0.9);
            font-size: 15px;
            font-weight: 500;
            border-left: 4px solid transparent;
        }

            .sidebar .menu-item:hover {
                background-color: var(--primary-light);
                border-left-color: #3498db;
                padding-left: 25px;
            }

            .sidebar .menu-item.active {
                background-color: var(--primary-light);
                border-left-color: #3498db;
                color: white;
                font-weight: 600;
            }

            /* Menu Icons - LARGER SIZE */
            .sidebar .menu-item i {
                font-size: 20px;
                min-width: 30px;
                width: 30px;
                margin-right: 15px;
                text-align: center;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* Menu Text - LARGER FONT */
            .sidebar .menu-item .menu-text {
                flex: 1;
                font-size: 15px;
                font-weight: 500;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        /* Arrow Icon */
        .arrow {
            position: absolute;
            right: 20px;
            font-size: 12px;
            transition: transform 0.3s ease;
            color: rgba(255, 255, 255, 0.7);
        }

        .menu-item.active .arrow {
            transform: rotate(90deg);
            color: white;
        }

        /* ============================================
                           SUBMENU STYLING - ENLARGED
                           ============================================ */
        .submenu {
            display: none;
            background-color: rgba(0, 0, 0, 0.2);
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .menu-item.active + .submenu {
            display: block;
            max-height: 500px;
        }

        .submenu a {
            display: flex;
            align-items: center;
            padding: 14px 20px 14px 60px;
            text-decoration: none;
            color: rgba(255, 255, 255, 0.85);
            font-size: 14px;
            font-weight: 400;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .submenu a:hover {
                background-color: rgba(255, 255, 255, 0.1);
                color: white;
                padding-left: 65px;
                border-left-color: rgba(255, 255, 255, 0.3);
            }

            .submenu a:active,
            .submenu a.active {
                background-color: rgba(255, 255, 255, 0.15);
                color: white;
                font-weight: 500;
            }

        /* Badge Styling */
        .badge {
            background-color: #e74c3c;
            border-radius: 12px;
            padding: 3px 9px;
            font-size: 11px;
            font-weight: 700;
            color: white;
            margin-left: auto;
            min-width: 20px;
            text-align: center;
        }

        /* ============================================
                           COLLAPSED SIDEBAR STYLES
                           ============================================ */
        .sidebar.collapsed .menu-text,
        .sidebar.collapsed .arrow,
        .sidebar.collapsed .submenu,
        .sidebar.collapsed .badge {
            display: none;
        }

        .sidebar.collapsed .menu-item {
            padding: 18px 0;
            text-align: center;
            justify-content: center;
            border-left: none;
        }

            .sidebar.collapsed .menu-item:hover {
                padding-left: 0;
            }

            .sidebar.collapsed .menu-item i {
                margin-right: 0;
                font-size: 24px;
            }

        /* ============================================
                           SIDEBAR USER SECTION
                           ============================================ */
        .sidebar-user {
            margin-top: auto;
            padding: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            background-color: rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .sidebar-user i {
                font-size: 24px;
                color: rgba(255, 255, 255, 0.9);
            }

            .sidebar-user h6 {
                margin: 0;
                font-size: 14px;
                font-weight: 600;
                color: white;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        .sidebar.collapsed .sidebar-user {
            padding: 20px 10px;
            justify-content: center;
        }

            .sidebar.collapsed .sidebar-user h6 {
                display: none;
            }

            .sidebar.collapsed .sidebar-user i {
                font-size: 28px;
            }

        /* ============================================
                           MAIN CONTENT AREA
                           ============================================ */
        .main-body {
            margin-left: var(--sidebar-width);
            margin-top: var(--header-height);
            padding: 25px;
            transition: margin-left 0.3s ease;
            min-height: calc(100vh - var(--header-height));
        }

            .main-body.collapsed {
                margin-left: var(--sidebar-collapsed-width);
            }

        /* ============================================
                           CARDS AND INFO SECTIONS
                           ============================================ */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .info-card {
            background-color: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(11, 44, 77, 0.08);
            transition: all 0.3s ease;
        }

            .info-card:hover {
                box-shadow: 0 4px 12px rgba(11, 44, 77, 0.15);
                transform: translateY(-3px);
            }

            .info-card h3 {
                margin: 0 0 12px 0;
                color: var(--primary-color);
                font-size: 18px;
                font-weight: 700;
            }

            .info-card p {
                margin: 8px 0;
                color: #64748b;
                font-size: 14px;
            }

        /* ============================================
                           FOOTER
                           ============================================ */
        footer {
            background-color: var(--primary-color);
            color: white;
            text-align: center;
            padding: 15px;
            margin-left: var(--sidebar-width);
            transition: margin-left 0.3s ease;
        }

        .main-body.collapsed ~ footer {
            margin-left: var(--sidebar-collapsed-width);
        }

        /* ============================================
                           BOOTSTRAP OVERRIDES
                           ============================================ */
        .card {
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(11, 44, 77, 0.08);
            border: 1px solid #e2e8f0;
        }

        .card-header {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            color: white;
            font-weight: 600;
            border-radius: 10px 10px 0 0 !important;
        }

        .alert {
            border-radius: 8px;
        }

        .btn-outline-danger {
            border-width: 2px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-outline-danger:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(220, 53, 69, 0.3);
            }

        /* ============================================
                           LOADING STATES
                           ============================================ */
        .menu-loading {
            text-align: center;
            padding: 30px 20px;
            color: rgba(255, 255, 255, 0.9);
        }

            .menu-loading p {
                margin-top: 15px;
                font-size: 14px;
            }

        .spinner {
            border: 3px solid rgba(255, 255, 255, 0.2);
            border-top: 3px solid white;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        /* ============================================
                           PERMISSION DENIED OVERLAY
                           ============================================ */
        .permission-denied-overlay {
            display: none;
            position: fixed;
            top: var(--header-height);
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }

        .permission-denied-content {
            background: white;
            padding: 50px 40px;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(11, 44, 77, 0.3);
            text-align: center;
            max-width: 500px;
            margin: 0 20px;
            animation: slideUp 0.4s ease;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .permission-denied-icon {
            font-size: 72px;
            color: #e74c3c;
            margin-bottom: 25px;
            animation: shake 0.5s ease;
        }

        @@keyframes shake {
            0%, 100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-10px);
            }

            75% {
                transform: translateX(10px);
            }
        }

        .permission-denied-content h2 {
            color: var(--primary-color);
            margin-bottom: 15px;
            font-size: 28px;
            font-weight: 700;
        }

        .permission-denied-content p {
            color: #64748b;
            margin-bottom: 30px;
            font-size: 16px;
            line-height: 1.6;
        }

        .permission-denied-content .company-name {
            color: #3498db;
            font-weight: 700;
        }

        .btn-back-dashboard {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .btn-back-dashboard:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(11, 44, 77, 0.3);
            }

            .btn-back-dashboard i {
                font-size: 18px;
            }

        /* ============================================
                           SCROLLBAR STYLING
                           ============================================ */
        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
        }

            .sidebar::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.3);
            }

        /* ============================================
                           RESPONSIVE DESIGN
                           ============================================ */
        @@media (max-width: 1024px) {
            .sidebar {
                transform: translateX(-100%);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .main-body,
            footer {
                margin-left: 0 !important;
            }

            .mobile-menu-toggle {
                display: block;
            }
        }

        @@media (max-width: 768px) {
            .header {
                padding: 0 15px;
            }

                .header h4 {
                    font-size: 16px;
                }

            #companyDropdown {
                width: 180px !important;
                font-size: 12px;
            }

            .main-body {
                padding: 15px;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- HEADER -->
        <div class="header">
            <div style="display: flex; align-items: center;">
                <button class="hamburger-btn" id="sidebarToggle">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <img src="~/images/JSAP-LOGO.png" height="35" width="35" style="margin-right:10px" alt="Logo">
                <h4><strong>Jivo Infotech</strong></h4>
            </div>

            <div id="sessionError" class="alert alert-danger" style="display:none; margin:0; padding:10px;">
                Session expired or invalid. Please <a href="/Account/Login">login again</a>.
            </div>

            <div style="display: flex; align-items: center; gap: 15px;">
                <div>
                    <div style="display: flex; align-items: center;">
                        <label for="companyDropdown" style="margin-right: 10px; font-weight: 650; font-size: 15px; color: var(--primary-color);">Company:</label>
                        <select id="companyDropdown" class="form-control form-control-sm" style="width: 250px;">
                            @if (companies != null && companies.Count > 0)
                            {
                                foreach (var company in companies)
                                {
                                    if (company.id == selectedCompanyId)
                                    {
                                        <option value="@company.id" data-name="@company.company" selected>@company.company</option>
                                    }
                                    else
                                    {
                                        <option value="@company.id" data-name="@company.company">@company.company</option>
                                    }
                                }
                            }
                            else
                            {
                                <option value="">No companies available</option>
                            }
                        </select>
                    </div>
                </div>
                <button id="logoutBtn" class="btn btn-outline-danger btn-sm">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-content">
                <div class="sidebar-menu" id="dynamicMenu">
                    <!-- Loading indicator -->
                    <div class="menu-loading" id="menuLoading">
                        <div class="spinner"></div>
                        <p>Loading menu...</p>
                    </div>
                    <!-- Menu will be generated here dynamically -->
                </div>

                <!-- User section at bottom -->
                <div class="sidebar-user">
                    <i class="fas fa-user-circle"></i>
                    <h6>@username</h6>
                </div>
            </div>
        </div>

        <!-- Permission Denied Overlay -->
        <div class="permission-denied-overlay" id="permissionDeniedOverlay">
            <div class="permission-denied-content">
                <div class="permission-denied-icon">
                    <i class="fas fa-lock"></i>
                </div>
                <h2>Access Denied</h2>
                <p>You don't have permission to access this page in <span class="company-name" id="deniedCompanyName"></span></p>
                <button class="btn-back-dashboard" onclick="redirectToDashboard()">
                    <i class="fas fa-home"></i> Go to Dashboard
                </button>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="main-body" id="mainBody">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // ============================================================
        // MENU CONFIGURATION - CUSTOMIZE THIS SECTION
        // ============================================================
        const menuConfig = {
            // Map API module names to your custom menu configuration
            // Format: 'API_MODULE_NAME': { displayName: 'Your Menu Name', icon: 'icon-class', permissions: {...} }

            'Inventory Audit(Web)': {
                displayName: 'Inventory Audit',  // Custom display name
                icon: 'fas fa-clipboard-check',
                permissions: {
                    // Map API permission types to your custom submenu items
                    'Inventory_admin': {
                        displayName: 'All Session',  // Your custom submenu name
                        url: '@Url.Action("MyAllSession", "InventoryAuditWeb")'
                    },
                    'Inventory_creator': {
                        displayName: 'Add Session',
                        url: '@Url.Action("AddSession", "InventoryAuditWeb")'
                    },
                    'Inventory_viewer': {
                        displayName: 'Assigned Session',
                        url: '@Url.Action("SessionList", "InventoryAuditWeb")'
                    }
                }
            },

            'Document Dispatch': {
                displayName: 'Document Management',  // Custom display name
                icon: 'fa fa-file-alt',
                permissions: {
                    'Document_admin': {
                        displayName: 'Rejected Document',
                        url: '@Url.Action("RejectDocument", "UserManagement")'
                    },
                    'Document_creator': {
                        displayName: 'Document Dispatch',
                        url: '@Url.Action("DocumentDispatch", "UserManagement")'
                    },
                    'Document_viewer': {
                        displayName: 'Document Receive',
                        url: '@Url.Action("DocumentRecieve", "UserManagement")'
                    }
                }
            },

            'Dashboard': {
                displayName: 'Dashboard',
                icon: 'fas fa-tachometer-alt',
                permissions: {
                    'Dashboard_admin': {
                        displayName: 'Overview',
                        url: '@Url.Action("Index", "Dashboard")'
                    },
                    'Dashboard_creator': {
                        displayName: 'Notifications',
                        url: '@Url.Action("Index", "Dashboard")'
                    },
                    'Dashboard_viewer': {
                        displayName: 'Daily Stats',
                        url: '@Url.Action("Index", "Dashboard")'
                    },
                    'Dashboard_IT': {
                        displayName: 'IT Dashboard',
                        url: '@Url.Action("ITdashboard", "DashboardWeb")'
                    },
                    'Dashboard_Task': {
                        displayName: 'Task Dashboard',
                        url: '@Url.Action("TaskDashboard", "DashboardWeb")'
                    },
                    'Dashboard_Client': {
                        displayName: 'Client Dashboard',
                        url: '@Url.Action("ClientDashboard", "DashboardWeb")'
                    },
                    'Dashboard_Mom': {
                        displayName: 'Minute of Meeting Dashboard',
                        url: '@Url.Action("MomDashboard", "DashboardWeb")'
                    },
                    'Dashboard_Avtar': {
                        displayName: 'Budget Dashboard',
                        url: '@Url.Action("AvtarDashboard", "DashboardWeb")'
                    }
                }
            },

            'User Management': {
                displayName: 'User Management',
                icon: 'fas fa-users',
                permissions: {
                    'User_admin': {
                        displayName: 'All Users',
                        url: '@Url.Action("AllUsers", "UserManagement")'
                    },
                    'User_creator': {
                        displayName: 'User Registration',
                        url: '@Url.Action("UserRegistration", "UserManagement")'
                    },
                    'User_viewer': {
                        displayName: 'User Permission',
                        url: '@Url.Action("UserPermission", "UserManagement")'
                    }
                }
            },

            'Approval Management': {
                displayName: 'Approval Management',
                icon: 'fas fa-tasks',
                permissions: {
                    'Approval_admin': {
                        displayName: 'Template Manager',
                        url: '@Url.Action("TemplateManager", "ApprovalManagement")'
                    },
                    'Approval_creator': {
                        displayName: 'Stage Manager',
                        url: '@Url.Action("StageManager", "ApprovalManagement")'
                    },
                    'Approval_viewer': {
                        displayName: 'Query Generator',
                        url: '@Url.Action("QueryGenerator", "ApprovalManagement")'
                    }
