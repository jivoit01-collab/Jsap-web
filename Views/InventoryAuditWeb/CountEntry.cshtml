                        <div class="empty-state-icon">📦</div>
                        <h3>No items in table</h3>
                        <p>Search for an item and enter quantity, then click "Add Item"</p>
                    </div>
                `;
                itemsActions.style.display = 'none';
                return;
            }

            // ✅ Only show action buttons if session is NOT read-only
            if (isReadOnlySession) {
                itemsActions.style.display = 'none';
            } else {
                itemsActions.style.display = 'flex';
            }

            const tableHtml = `
                <table class="items-table">
                    <thead>
                        <tr>
                            <th>Item Code</th>
                            <th>Item Name</th>
                            <th>Warehouse</th>
                            <th>System Count</th>
                            <th>Last Count</th>
                            <th>Physical Count</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${tableItems.map(item => {
                            const rowClass = item.isManualEntry ? 'manual-entry-row' : (item.isMultiWarehouse ? 'multi-warehouse-row' : '');
                            return `
                                <tr id="row-${item.id}" class="${rowClass}">
                                    <td>
                                        <strong>${item.selectedItem.itemCode}</strong>
                                    </td>
                                    <td>
                                        ${item.selectedItem.itemName || 'N/A'}
                                    </td>
                                    <td>
                                        <strong style="color: var(--primary-color);">${item.warehouse}</strong>
                                    </td>
                                    <td class="system-count-cell">
                                        ${(parseFloat(item.systemCount) || 0).toFixed(2)}
                                    </td>
                                    <td class="last-count-cell">
                                        ${(parseFloat(item.lastCount) || 0).toFixed(2)}
                                    </td>
                                    <td class="text-center">
                                        ${isReadOnlySession
                                          ? `<span class="readonly-count" title="Session is closed; value is locked">${fmt2(item.physicalCount)}</span>`
                                          : `<input type="number" class="form-input text-center" id="count-${item.id}"
                                                    placeholder="0" min="0" step="0.01" value="${item.physicalCount}"
                                                    onchange="updateItemCount(${item.id}, this.value)">`
                                        }
                                    </td>
                                    <td>
                                      ${isReadOnlySession
                                        ? `<button class="btn btn-danger btn-sm" disabled title="Read-only">Remove</button>`
                                        : `<button class="btn btn-danger btn-sm" onclick="removeItemRow(${item.id})">Remove</button>`
                                      }
                                    </td>
                                </tr>
                            `;
                        }).join('')}
                    </tbody>
                </table>
            `;

            tableContainer.innerHTML = tableHtml;
        }

        function removeItemRow(itemId) {
            if (isReadOnlySession) { showTemporaryMessage('Session is closed. Removing items is disabled.', 'info'); return; }
            console.log(`Removing item row with ID: ${itemId}`);

            const itemToRemove = tableItems.find(item => item.id === itemId);
            if (itemToRemove) {
                console.log(`Removing: ${itemToRemove.selectedItem.itemCode} - ${itemToRemove.warehouse}`);
            }

            tableItems = tableItems.filter(item => item.id !== itemId);

            console.log(`Items remaining after removal: ${tableItems.length}`);

            updateItemsTable();
        }

        function clearAllItems() {
            if (isReadOnlySession) { showTemporaryMessage('Session is closed. Clearing is disabled.', 'info'); return; }
            if (confirm('Are you sure you want to clear all items from the table?')) {
                tableItems = [];
                itemCounter = 0;
                globalStockData = {};
                updateItemsTable();
            }
        }

        function clearEverything() {
            console.log('=== CLEARING EVERYTHING ===');

            tableItems = [];
            itemCounter = 0;
            globalStockData = {};
            updateItemsTable();

            document.getElementById('itemSearchInput').value = '';
            document.getElementById('physicalQuantityInput').value = '';
            hideSearchDropdown();

            // Reload the page to start fresh
            location.reload();

            console.log('Everything cleared - ready for new audit');
        }

        // Initialize application
        document.addEventListener('DOMContentLoaded', async function() {
            // Initialize page with URL parameters
            await initializePage();

            // Initialize other components
            updateItemsTable();
            setupItemSearch();
        });

        // Click outside to close dropdowns
        document.addEventListener('click', function(event) {
            if (!event.target.closest('.select-container') &&
                !event.target.closest('.search-dropdown') &&
                !event.target.closest('.item-search-container') &&
                !event.target.closest('.modal')) {
                document.querySelectorAll('.search-dropdown').forEach(dropdown => {
                    dropdown.classList.remove('show');
                });
            }
        });

        // Utility functions
        function hideProgressOverlay() {
            const overlay = document.getElementById('progressOverlay');
            if (overlay) {
                overlay.style.display = 'none';
            }
        }

        function showProgressOverlay(message = 'Loading...') {
            const overlay = document.getElementById('progressOverlay');
            const text = overlay.querySelector('.progress-text');
            if (overlay) {
                text.textContent = message;
                overlay.style.display = 'flex';
            }
        }

        function showGlobalError(message) {
            const existingError = document.querySelector('.global-error');
            if (existingError) {
                existingError.remove();
            }

            const errorDiv = document.createElement('div');
            errorDiv.className = 'alert alert-danger global-error';
            errorDiv.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
            errorDiv.innerHTML = `
                ${message}
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            `;
            document.body.appendChild(errorDiv);

            setTimeout(() => {
                if (errorDiv.parentElement) {
                    errorDiv.remove();
                }
            }, 10000);
        }

        // Make functions globally available
        window.removeItemRow = removeItemRow;
        window.processAddItem = processAddItem;
        window.saveAllItems = saveAllItems;
        window.clearAllItems = clearAllItems;
        window.cancelParameterSelection = cancelParameterSelection;
        window.confirmParameterSelection = confirmParameterSelection;
        window.handleModalOverlayClick = handleModalOverlayClick;
        window.selectSearchItem = selectSearchItem;
        window.updateItemCount = updateItemCount;

        console.log('✅ Inventory audit system with enhanced empty data handling initialized');
    </script>

</body>
</html>
