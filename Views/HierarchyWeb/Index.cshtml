            function isFrontendSalesDept(deptName){
                return (deptName || '').trim().toLowerCase() === SALES_DEPT_NAME.toLowerCase();
            }

            function getSalesTreeForDept(hod, deptName){
                return isFrontendSalesDept(deptName) && hod && hod.salesTree ? hod.salesTree : null;
            }

            function getSalesEmployeeCount(salesTree){
                var total = 0;
                (salesTree && salesTree.h2List || []).forEach(function(h2){
                    (h2.h3List || []).forEach(function(h3){
                        (h3.h4List || []).forEach(function(h4){
                            (h4.groups || []).forEach(function(group){
                                total += (group.employees || []).length;
                            });
                        });
                    });
                });
                return total;
            }

            function getSalesEmployeesWithContext(list){
                var rows = list || [];
                var out = [];
                rows.forEach(function(hod){
                    if(!hod || !hod.salesTree) return;
                    (hod.salesTree.h2List || []).forEach(function(h2){
                        (getSalesStateBuckets(h2) || []).forEach(function(stateBucket){
                            (stateBucket.combos || []).forEach(function(combo){
                                (combo.employees || []).forEach(function(emp){
                                    out.push({
                                        hodName: hod.name,
                                        hodCode: hod.code || '',
                                        h2Name: h2.h2Name || '',
                                        state: emp.state || stateBucket.state || '',
                                        designation: emp.designation || combo.designation || '',
                                        groupName: combo.groupName || '',
                                        comboLabel: combo.label || '',
                                        empName: emp.empName || '',
                                        empCode: emp.empCode || ''
                                    });
                                });
                            });
                        });
                    });
                });
                return out;
            }

            function buildSalesDesignationSummary(rows){
                var map = Object.create(null), order = [];
                getSalesEmployeesWithContext(rows).forEach(function(emp){
                    var key = (emp.designation || 'No Designation').trim() || 'No Designation';
                    if(!map[key]){
                        map[key] = { designation: key, count: 0, employees: [] };
                        order.push(key);
                    }
                    map[key].count++;
                    map[key].employees.push(emp);
                });
                return order.map(function(key){ return map[key]; }).sort(function(a,b){ return b.count - a.count || a.designation.localeCompare(b.designation); });
            }

            function buildHrNonHodEmployees(){
                var map = Object.create(null);
                (BASE_RAW_DATA || []).forEach(function(h){
                    (h.subs || []).forEach(function(s){
                        (s.subHods || []).forEach(function(sh){
                            var key = (sh.code || '').trim().toUpperCase() || ('NAME:' + (sh.name || '').trim().toUpperCase());
                            if(!key) return;
                            if(!map[key]){
                                map[key] = {
                                    empCode: sh.code || '',
                                    empName: sh.name || '',
                                    sources: []
                                };
                            }
                            map[key].sources.push({
                                type: 'HR',
                                role: 'Sub-HOD',
                                hod: h.name || '',
                                department: s.dept || h.depts[0] || '',
                                subDepartment: s.sdName || '',
                                designation: sh.desig || '',
                                state: ''
                            });
                            (sh.execs || []).forEach(function(ex){
                                var exKey = (ex.code || '').trim().toUpperCase() || ('NAME:' + (ex.name || '').trim().toUpperCase());
                                if(!exKey) return;
                                if(!map[exKey]){
                                    map[exKey] = {
                                        empCode: ex.code || '',
                                        empName: ex.name || '',
                                        sources: []
                                    };
                                }
                                map[exKey].sources.push({
                                    type: 'HR',
                                    role: 'Executive',
                                    hod: h.name || '',
                                    department: s.dept || h.depts[0] || '',
                                    subDepartment: s.sdName || '',
                                    designation: ex.desig || '',
                                    state: ''
                                });
                            });
                        });
                        (s.execs || []).forEach(function(ex){
                            var exKey = (ex.code || '').trim().toUpperCase() || ('NAME:' + (ex.name || '').trim().toUpperCase());
                            if(!exKey) return;
                            if(!map[exKey]){
                                map[exKey] = {
                                    empCode: ex.code || '',
                                    empName: ex.name || '',
                                    sources: []
                                };
                            }
                            map[exKey].sources.push({
                                type: 'HR',
                                role: 'Executive',
                                hod: h.name || '',
                                department: s.dept || h.depts[0] || '',
                                subDepartment: s.sdName || '',
                                designation: ex.desig || '',
                                state: ''
                            });
                        });
                    });
                });
                return map;
            }

            function buildSalesDuplicates(rows){
                var hrMap = buildHrNonHodEmployees();
                var salesMap = Object.create(null);
                getSalesEmployeesWithContext(rows).forEach(function(emp){
                    var key = (emp.empCode || '').trim().toUpperCase() || ('NAME:' + (emp.empName || '').trim().toUpperCase());
                    if(!key) return;
                    if(!salesMap[key]){
                        salesMap[key] = {
                            empCode: emp.empCode || '',
                            empName: emp.empName || '',
                            sources: []
                        };
                    }
                    salesMap[key].sources.push({
                        type: 'Sales',
                        role: 'Employee',
                        hod: emp.hodName || '',
                        department: SALES_DEPT_NAME,
                        subDepartment: emp.h2Name || '',
                        designation: emp.designation || '',
                        state: emp.state || '',
                        groupName: emp.groupName || ''
                    });
                });

                return Object.keys(salesMap).filter(function(key){ return !!hrMap[key]; }).map(function(key){
                    return {
                        empCode: salesMap[key].empCode || hrMap[key].empCode || '',
                        empName: salesMap[key].empName || hrMap[key].empName || '',
                        hrSources: hrMap[key].sources,
                        salesSources: salesMap[key].sources
                    };
                }).sort(function(a,b){ return (a.empName || '').localeCompare(b.empName || ''); });
            }

            function renderSalesInsights(){
                var grid = document.getElementById('salesInsightGrid');
                if(!grid) return;
                if(!SHOW_SALES || !SALES_DESIG_SUMMARY.length){
                    grid.innerHTML = '<div class="sd-empty" style="display:block">No sales designation data</div>';
                } else {
