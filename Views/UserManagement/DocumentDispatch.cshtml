@{
    ViewData["Title"] = "Document Dispatch";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Document Dispatch</title>
    <link rel="stylesheet" href="~/css/bosystyle.css">
    <!-- Add these CSS styles -->

    <style>
        /* CSS - Add this to your stylesheet */
        .search-filter-row {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #e9ecef;
            margin-bottom: 20px;
            flex-wrap: nowrap; /* Prevent wrapping */
        }

        .search-container {
            display: flex;
            align-items: center;
            background: white;
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 0 12px;
            flex: 1;
            min-width: 200px;
            height: 40px;
        }

            .search-container .search-icon {
                margin-right: 8px;
                color: #6c757d;
                font-size: 16px;
            }

            .search-container .search-input {
                border: none;
                outline: none;
                padding: 8px 5px;
                font-size: 14px;
                width: 100%;
                background: transparent;
                height: 100%;
            }

        .filter-buttons {
            display: flex;
            gap: 8px;
            flex-shrink: 0; /* Prevent shrinking */
        }

        .status-filter-btn {
            padding: 8px 16px;
            border: 2px solid #e0e0e0;
            background: #ffffff;
            color: #495057;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
            height: 40px;
            min-width: 90px;
            justify-content: center;
        }

            .status-filter-btn:hover {
                background: #e9ecef;
                border-color: #ced4da;
                transform: translateY(-1px);
            }

            .status-filter-btn.active {
                background: linear-gradient(135deg, #007bff, #0056b3);
                color: white;
                border-color: #007bff;
                box-shadow: 0 2px 4px rgba(0, 123, 255, 0.3);
            }

            .status-filter-btn[data-status="S"].active {
                background: linear-gradient(135deg, #ffc107, #e0a800);
                border-color: #ffc107;
                color: #000;
                box-shadow: 0 2px 4px rgba(255, 193, 7, 0.3);
            }

            .status-filter-btn[data-status="R"].active {
                background: linear-gradient(135deg, #28a745, #1e7e34);
                border-color: #28a745;
                box-shadow: 0 2px 4px rgba(40, 167, 69, 0.3);
            }

            .status-filter-btn[data-status="NR"].active {
                background: linear-gradient(135deg, #dc3545, #c82333);
                border-color: #dc3545;
                box-shadow: 0 2px 4px rgba(220, 53, 69, 0.3);
            }

            .status-filter-btn[data-status="InActive"].active {
                background: linear-gradient(135deg, #a6a4a4, #a6a4a4);
                border-color: #a6a4a4;
                box-shadow: 0 2px 4px rgba(220, 53, 69, 0.3);
            }

        /* Responsive - only break the line on very small screens */
        @@media (max-width: 640px) {
            .search-filter-row

        {
            flex-direction: column;
            align-items: stretch;
            gap: 12px;
        }

        .search-container {
            min-width: auto;
            width: 100%;
        }

        .filter-buttons {
            justify-content: center;
            flex-wrap: wrap;
        }

        .status-filter-btn {
            flex: 1;
            min-width: 70px;
        }

        }
        /* Add this CSS for the update button */
        #updateButton {
            background: linear-gradient(135deg, #0b2c4d, #0b2c4d);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            box-shadow: 0 2px 4px rgba(255, 193, 7, 0.3);
        }

            #updateButton:hover {
                background: linear-gradient(135deg, #0b2c4d, #0b2c4d);
                transform: translateY(-1px);
                box-shadow: 0 4px 8px rgba(255, 193, 7, 0.4);
            }

            #updateButton:disabled {
                background: #6c757d;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }
    </style>

</head>
<body>
   
    <input type="hidden" id="UpdatedBy" name="UpdatedBy" value="@ViewBag.UserId" />
    <input type="hidden" id="CompanyId" name="CompanyId" value="@ViewBag.CompanyId" />

    <div class="container">
        <!-- Mode Switcher -->
        <div id="modeButtons" class="mode-switcher">
            <button id="allBtn" class="mode-btn active" type="button">
                <span>📊</span>
                <span>All Documents</span>
            </button>
            <button id="createBundleBtn" class="mode-btn" type="button">
                <span>➕</span>
                <span>Create Bundle</span>
            </button>
        </div>

        <!-- Create Bundle Section -->
        <div id="createBundleSection" style="display: none;">
            <div class="filter-section">
                <div class="filter-row">
                    <span class="filter-label">Source Document:</span>
                    <div class="radio-group">
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="GRPO" id="grpo">
                            <label for="grpo">GRPO</label>
                        </div>
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="APDRAFT" id="apdraft">
                            <label for="apdraft">AP Draft</label>
                        </div>
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="PO" id="po">
                            <label for="po">PO</label>
                        </div>
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="RETURN" id="return">
                            <label for="return">Goods Return</label>
                        </div>
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="MANUAL" id="manual">
                            <label for="manual">Manual Entry</label>
                        </div>
                        <div class="radio-item">
                            <input type="radio" name="sourceDoc" value="REJECT" id="reject">
                            <label for="reject">Reject Entry</label>
                        </div>
                    </div>
                </div>
                <div class="search-container" style="display: none;margin-top:10px;" id="createSearchContainer">
                    <span class="search-icon">🔍</span>
                    <input type="text" id="searchBox" class="search-input" placeholder="Search CardCode, CardName">
                </div>
            </div>
        </div>

        <!-- HTML - Replace your allDocumentsSection with this -->
        <div id="allDocumentsSection">
            <div class="search-filter-row">
                <div class="search-container" style="margin-top:10px">
                    <span class="search-icon">🔍</span>
                    <input type="text" id="allSearchBox" class="search-input" placeholder="Search documents...">
                </div>

                <div class="filter-buttons" style="margin-left:200px;">
                    <button class="status-filter-btn active" data-status="all">📊 All</button>
                    <button class="status-filter-btn" data-status="S">⏳ Pending</button>
                    <button class="status-filter-btn" data-status="R">✅ Received</button>
                    <button class="status-filter-btn" data-status="NR">❌ Not Received</button>
                    <button class="status-filter-btn" data-status="InActive">InActive</button>
                </div>
            </div>
        </div>

        <div id="tableSection">
            <div class="table-wrapper">
                <table class="styled-table" id="resultTable">
                    <thead class="thead-dark">
                        <tr class="user-row" id="allTableHeader">
                            <th scope="col" role="columnheader" >🆔 Bundle ID</th>
                            <th scope="col" role="columnheader" >📄 Doc ID</th>
                            <th scope="col" role="columnheader" >📋 Doc Type</th>
                            <th scope="col" role="columnheader" >🏢 Branch</th>
                            <th scope="col" role="columnheader" >👤 Created By</th>
                            <th scope="col" role="columnheader" >📅 Created On</th>
                            <th scope="col" role="columnheader" >🔄 Status</th>
                            <th scope="col" role="columnheader" >👥 Received By</th>
                            <th scope="col" role="columnheader" >📅 Received On</th>
                            <th scope="col" role="columnheader" >❌ Rejected Reason</th>
                            <th scope="col" role="columnheader" >📎 Attachment</th>
                        </tr>
                        <tr class="user-row" id="createBundleHeader" style="display: none;">
                            <th>☑️ Select</th>
                            <th>🏢 Branch</th>
                            <th>📄 Doc No</th>
                            <th>📅 Doc Date</th>
                            <th>📅 Create Date</th>
                            <th>🏷️ Card Code</th>
                            <th>🏷️ Card Name</th>
                            <th>💰 Amount</th>
                            <th>📎 Attachments</th>
                            <th>📋 SAP Attachments</th>
                        </tr>
                        <tr class="user-row" id="rejectBundleHeader" style="display: none;">
                            <th>☑️ Select</th>
                            <th>🆔 Bundle ID</th>
                            <th>📄 Doc ID</th>
                            <th>📋 Doc Type</th>
                            <th>🏢 Branch</th>
                            <th>📎 Previous Attachments</th>
                            <th>👥 Received By</th>
                            <th>📅 Received On</th>
                            <th>❌ Rejected Reason</th>
                            <th>📎 Upload Attachments</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
        <div class="text-center mt-4">
            <button id="saveButton" class="custom-btn" style="display: none;">Save Bundle</button>
            <button id="updateButton" class="custom-btn" style="display: none;" onclick="updateRejectedStatus()">Update Status</button>
        </div>
    </div>

    <div id="loading">Loading Data...</div>
    <!-- FIND THIS IN YOUR HTML (around line 84): -->
    <div id="previewModal" style="display:none">
        <h3>Preview Before Save</h3>
        <div id="previewContent" style="margin-top: 10px;"></div>
        <div style="margin-top: 20px; text-align:right;" class="preview-buttons">
            <button onclick="closePreview()" class="cancel-btn">Cancel</button>
            <button onclick="confirmSave()" class="confirm-btn">Confirm Save</button>
        </div>
    </div>
    <div id="modalBackdrop"></div>
    <div id="filePreviewModal" style="display:none; position:fixed; top:5%; left:50%; transform:translateX(-50%);
    background:white; border:1px solid #ccc; padding:20px; box-shadow:0 0 10px rgba(0,0,0,0.3);
    z-index:2000; width:80%; max-height:80%; overflow:auto; border-radius:8px;">
        <div style="text-align:right;">
            <button onclick="closeFilePreview()" style="font-size:20px;color:black; border:none; background:none; cursor:pointer;">&times;</button>
        </div>
        <div id="filePreviewContent"></div>
    </div>

    <div id="filePreviewBackdrop" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:1999;"></div>

    <div id="loaderOverlay">
        <div class="loader"></div>
    </div>

</body>
</html>

<script>
    let currentMode = 'all';
    let allDispatchData = [];

    function showLoader() {
        document.getElementById("loaderOverlay").style.display = "flex";
    }

    function hideLoader() {
        document.getElementById("loaderOverlay").style.display = "none";
    }

    let currentStatusFilter = 'all';

    // Add this to the very beginning of your DOMContentLoaded function
    document.addEventListener("DOMContentLoaded", function() {
        // Force hide all overlays on page load
        document.getElementById("loaderOverlay").style.display = "none";
        document.getElementById("modalBackdrop").style.display = "none";
        document.getElementById("filePreviewBackdrop").style.display = "none";
        document.getElementById("previewModal").style.display = "none";
        document.getElementById("filePreviewModal").style.display = "none";
        document.getElementById("loading").style.display = "none";

        // Your existing code
        document.querySelector('#resultTable tbody').innerHTML = '';
        loadAllDispatchData();
        addClearFiltersButton();
    });

    // Mode switching
    document.getElementById('allBtn').addEventListener('click', function() {
        switchMode('all');
    });

    document.getElementById('createBundleBtn').addEventListener('click', function() {
        switchMode('create');
         document.getElementById('tableSection').style.display = 'none';
             // ✅ Deselect all source document radio buttons
        document.querySelectorAll('input[name="sourceDoc"]').forEach(r => r.checked = false);

    });

           function switchMode(mode) {
        currentMode = mode;

        // Toggle button active state
        document.getElementById('allBtn').classList.toggle('active', mode === 'all');
        document.getElementById('createBundleBtn').classList.toggle('active', mode === 'create');

        // Toggle visible sections
        document.getElementById('allDocumentsSection').style.display = mode === 'all' ? 'block' : 'none';
        document.getElementById('createBundleSection').style.display = mode === 'create' ? 'block' : 'none';

        // ✅ IMPROVED: Better header management
        if (mode === 'all') {
            // Show only all documents header
            document.getElementById('allTableHeader').style.display = '';
            document.getElementById('createBundleHeader').style.display = 'none';
            document.getElementById('rejectBundleHeader').style.display = 'none';
        } else if (mode === 'create') {
            // Hide all documents header
            document.getElementById('allTableHeader').style.display = 'none';

            // ✅ Only show headers if a document type is selected
            if (selectedDocType === 'REJECT') {
                document.getElementById('createBundleHeader').style.display = 'none';
                document.getElementById('rejectBundleHeader').style.display = '';
            } else if (selectedDocType && selectedDocType !== 'MANUAL') {
                document.getElementById('createBundleHeader').style.display = '';
                document.getElementById('rejectBundleHeader').style.display = 'none';
            } else {
                // No document type selected yet, hide both
                document.getElementById('createBundleHeader').style.display = 'none';
                document.getElementById('rejectBundleHeader').style.display = 'none';
            }
        }

        // Reset UI elements
        document.getElementById('createSearchContainer').style.display = 'none';
        document.getElementById('searchBox').style.display = 'none';
        document.getElementById('saveButton').style.display = 'none';
        document.getElementById('updateButton').style.display = 'none';

        if (mode === 'create') {
            document.querySelector('#resultTable tbody').innerHTML = '';
            document.getElementById('resultTable').style.display = 'none';
            document.getElementById('tableSection').style.display = 'none';

            // ✅ Deselect all source document radio buttons
            document.querySelectorAll('input[name="sourceDoc"]').forEach(r => r.checked = false);

            // ✅ Reset selectedDocType
            selectedDocType = null;
        } else if (mode === 'all') {
            // Re-render from cached data
            document.getElementById('resultTable').style.display = 'table';
            document.getElementById('tableSection').style.display = 'block';
            renderAllDispatchTable(allDispatchData);
        }
    }
    // Load all dispatch data
    function loadAllDispatchData() {
        showLoader();
        document.getElementById("loading").style.display = "block";
        const userId = document.getElementById("UpdatedBy").value;
        // In loadAllDispatchData() function, replace the fetch with:
        fetch(`/api/DocumentDispatch/GetUserDocuments?userId=${userId}`)
        .then(res => {
                if (!res.ok) {
                    throw new Error(`HTTP error! status: ${res.status}`);
                }
                return res.json();
        })
        .then(data => {
            if (!Array.isArray(data)) throw new Error("Invalid data format");
            allDispatchData = data;
            renderAllDispatchTable(data);
        })
        .catch(err => {
            console.error("API error", err);
            alert(`Failed to load dispatch data: ${err.message}`);
            // Show empty state instead of broken UI
            document.querySelector('#resultTable tbody').innerHTML =
                '<tr><td colspan="11" style="text-align:center; padding:20px; color:#666;">Failed to load data. Please refresh the page.</td></tr>';
        })
        .finally(() => {
            hideLoader();
            document.getElementById("loading").style.display = "none";
        });
    }

    // Render all dispatch data table
    function renderAllDispatchTable(data) {
         document.getElementById('tableSection').style.display = 'block';
        const tbody = document.querySelector('#resultTable tbody');

        tbody.innerHTML = '';

        const rows = data.map(item => {
            const statusClass = `status-${item.status || 'S'}`;

            const filePath = item.attachment || '';
            const fileName = filePath.split('/').pop();
            const fileIcon = getFileIcon(fileName);
            const attachmentLink = filePath
                ? `<a href="#" onclick="openFilePreview('${filePath}')" title="${fileName}" class="file-icon">${fileIcon}</a>`
                : '<i>No attachment</i>';

            return `
                <tr>
                    <td>${item.bundleId}</td>
                    <td>${item.docId}</td>
                    <td>${item.docType}</td>
                    <td>${item.branch}</td>
                    <td>${item.createdByName}</td>
                    <td>${formatDate(item.createdOn)}</td>
                    <td><span class="status-badge ${statusClass}">${getStatus(item.status)}</span></td>
                    <td>${item.receivedByName || '-'}</td>
                    <td>${formatDate(item.receivedOn) || '-'}</td>
                    <td>${item.rejectedReason || '-'}</td>
                     <td>${attachmentLink}</td>
                </tr>
            `;
        }).join('');

        tbody.innerHTML = rows;
    }

    // Render create bundle table (original function)
    function renderTable(data) {
         document.getElementById('tableSection').style.display = 'block';
        const tbody = document.querySelector('#resultTable tbody');
        tbody.innerHTML = '';

        const rows = data.map((item, index) => {
            // Determine company number
            let company = item.databaseName === "JIVO_OIL_HANADB" ? 1 :
                          item.databaseName === "JIVO_BEVERAGES_HANADB" ? 2 : 0;

            // Build attachment links
            const attachmentLinks = (item.link || '').split(':').filter(Boolean).map(fileName => {
                const encodedFile = encodeURIComponent(fileName.trim());
                const fileUrl = `/api/DocumentDispatch/SapDownloadFile?fileName=${encodedFile}&company=${company}`;
                const icon = getFileIcon(fileName.trim());
                return `<a href="#" onclick="handleZipPreview('${fileUrl}')" title="${fileName.trim()}" class="file-icon">${icon}</a>`;
            }).join('');



            return `
                <tr>
                    <td><input type="checkbox" name="selectRow" value="${index}" /></td>
                     <td>${getBranchDisplayName(item.databaseName)}</td>
                    <td>${item.docNum}</td>
                    <td>${formatDate(item.docDate)}</td>
                    <td>${formatDate(item.createDate)}</td>
                    <td>${item.cardCode}</td>
                    <td>${item.cardName}</td>
                    <td>${Math.round(item.docTotal)}</td>

                    <td class="attachment-column">
                        <label class="custom-upload-btn">
                            📎 Upload
                            <input type="file" name="attachments_${index}" id="attachments_${index}" multiple onchange="previewFiles(${index})" hidden />
                        </label>
                        <div id="preview_${index}" class="attachment-icons" style="margin-top: 6px;"></div>
                    </td>

                   <td class="sap-attachment-column">${attachmentLinks || '<i>No attachments</i>'}</td>

                </tr>
            `;
        }).join('');

        tbody.innerHTML = rows;
    }

    function getFileIcon(fileName) {
        const ext = fileName.split('.').pop().toLowerCase();

        const iconMap = {
            pdf: '📄',
            doc: '📝', docx: '📝',
            xls: '📊', xlsx: '📊', csv: '📊',
            jpg: '🖼️', jpeg: '🖼️', png: '🖼️', gif: '🖼️',
            zip: '🗜️', rar: '🗜️',
            txt: '📄', log: '📄',
            json: '💾', xml: '💾',
        };

        return iconMap[ext] || '📁'; // default icon
    }
    
    // Add status filter event listeners
    document.querySelectorAll('.status-filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            // Remove active class from all buttons
            document.querySelectorAll('.status-filter-btn').forEach(b => b.classList.remove('active'));
            
            // Add active class to clicked button
            this.classList.add('active');
            
            // Update current filter
            currentStatusFilter = this.dataset.status;
            
            // Apply filters
            applyAllFilters();
        });
    });

        // Enhanced search functionality that includes status filtering
    function applyAllFilters() {
        const searchValue = document.getElementById("allSearchBox").value.toLowerCase();
        const rows = document.querySelectorAll("#resultTable tbody tr");

        rows.forEach(row => {
            // Get row data
            const bundleId = row.cells[0].textContent.toLowerCase();
            const docId = row.cells[1].textContent.toLowerCase();
            const docType = row.cells[2].textContent.toLowerCase();
            const branch = row.cells[3].textContent.toLowerCase();
            const status = row.cells[6].querySelector('.status-badge').textContent.trim();

            // Get the actual status value from the badge classes
            const statusBadge = row.cells[6].querySelector('.status-badge');
            let actualStatus = 'S'; // default
            if (statusBadge.classList.contains('status-R')) actualStatus = 'R';
            else if (statusBadge.classList.contains('status-NR')) actualStatus = 'NR';
            else if (statusBadge.classList.contains('status-S')) actualStatus = 'S';
                else if (statusBadge.classList.contains('status-InActive')) actualStatus = 'InActive';

            // Check search match
            const searchMatch = searchValue === '' ||
                               bundleId.includes(searchValue) ||
                               docId.includes(searchValue) ||
                               docType.includes(searchValue) ||
                               branch.includes(searchValue);

            // Check status match
            const statusMatch = currentStatusFilter === 'all' || actualStatus === currentStatusFilter;

            // Show/hide row based on both filters
            row.style.display = (searchMatch && statusMatch) ? "" : "none";
        });
    }

    // Update the existing search box event listener
    document.getElementById("allSearchBox").addEventListener("keyup", function () {
        applyAllFilters();
    });

        // Add a function to reset filters
    function resetAllFilters() {
        // Reset search box
        document.getElementById("allSearchBox").value = '';

        // Reset status filter
        currentStatusFilter = 'all';
        document.querySelectorAll('.status-filter-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector('.status-filter-btn[data-status="all"]').classList.add('active');

        // Apply filters (will show all rows)
        applyAllFilters();
    }

        // Optional: Add a clear filters button
    function addClearFiltersButton() {
        const filterSection = document.querySelector('#allDocumentsSection .filter-section');
        if (filterSection) {
            const clearBtn = document.createElement('button');
            clearBtn.textContent = 'Clear Filters';
            clearBtn.className = 'clear-filters-btn';
            clearBtn.style.cssText = `
                margin-left: 20px;
                padding: 8px 16px;
                background: #6c757d;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                font-size: 14px;
            `;
            clearBtn.addEventListener('click', resetAllFilters);
            filterSection.querySelector('.filter-row').appendChild(clearBtn);
        }
    }

    // Preview attachment function
    function previewAttachment(attachmentPath) {
        if (!attachmentPath) {
            alert("No attachment available");
            return;
        }

        // You can implement file preview logic here
        // For now, just show the path or download
        const fileUrl = `/api/DocumentDispatch/DownloadFile?filePath=${encodeURIComponent(attachmentPath)}`;
        window.open(fileUrl, '_blank');
    }

    // Rest of your original code for create bundle functionality
    let selectedDocType = null;
    const filesMap = {};
    let collectedDataForSave = [];

        // Radio button change event listener - UPDATED with header logic
    document.querySelectorAll('input[name="sourceDoc"]').forEach(radio => {
        radio.addEventListener('change', () => {
            selectedDocType = radio.value;

            // ✅ ADD THIS: Update headers based on selected document type
            if (selectedDocType === 'REJECT') {
                // Show reject header, hide create header
                document.getElementById('createBundleHeader').style.display = 'none';
                document.getElementById('rejectBundleHeader').style.display = '';
            } else {
                // Show create header, hide reject header
                document.getElementById('createBundleHeader').style.display = '';
                document.getElementById('rejectBundleHeader').style.display = 'none';
            }

            // Determine the API endpoint based on selectedDocType
            let apiUrl = '';
            switch (selectedDocType) {
                case "GRPO":
                    apiUrl = '/api/DocumentDispatch/GetGRPO';
                    break;
                case "PO":
                    apiUrl = '/api/DocumentDispatch/GetPO';
                    break;
                case "APDRAFT":
                    apiUrl = '/api/DocumentDispatch/GetApDraft';
                    break;
                case "RETURN":
                    apiUrl = '/api/DocumentDispatch/GetGR';
                    break;
                case "REJECT":
                    // Get userId from the UpdatedBy field
                    const userId = document.getElementById("UpdatedBy").value;
                    apiUrl = `/api/DocumentDispatch/GetRejectedDataByUserId?userId=${userId}`;
                    break;
                case "MANUAL":
                    document.getElementById("saveButton").style.display = "none";
                    document.getElementById("updateButton").style.display = "none";
                    document.getElementById("searchBox").style.display = "none";

                    const tbody = document.querySelector('#resultTable tbody');
                    tbody.innerHTML = `<tr><td colspan="11" style="text-align:center; font-style:italic; color:gray;">Data is not available</td></tr>`;

                    document.getElementById("resultTable").style.display = "table";
                    document.getElementById('tableSection').style.display = 'block';
                    return;

                default:
                    return;
            }

            document.getElementById("loading").style.display = "block";

            // Call API dynamically
            showLoader();
            fetch(apiUrl)
                .then(res => res.json())
                .then(data => {
                    if (!Array.isArray(data)) throw new Error("Invalid data format");

                    // ✅ Show table & search box only after selection
                    document.getElementById("resultTable").style.display = "table";
                    document.getElementById("createSearchContainer").style.display = "block";
                    document.getElementById("searchBox").style.display = "block";

                    // Show different button based on document type
                    if (selectedDocType === "REJECT") {
                        document.getElementById("saveButton").style.display = "none";
                        document.getElementById("updateButton").style.display = "block";
                    } else {
                        document.getElementById("saveButton").style.display = "block";
                        document.getElementById("updateButton").style.display = "none";
                    }

                    // Use different render function for rejected data
                    if (selectedDocType === "REJECT") {
                        renderRejectedTable(data);
                    } else {
                        renderTable(data);
                    }

                    document.querySelector('.table-wrapper').scrollTop = 0;
                    document.querySelector('.table-wrapper').scrollLeft = 0;
                })
                .catch(err => {
                    console.error("API error", err);
                    alert("Failed to load document data.");
                })
                .finally(() => {
                    hideLoader();
                    document.getElementById("loading").style.display = "none";
                });
        });
    });

    // Add new function to render rejected data table
function renderRejectedTable(data) {
    document.getElementById('tableSection').style.display = 'block';
    const tbody = document.querySelector('#resultTable tbody');
    tbody.innerHTML = '';

    const rows = data.map((item, index) => {
        // Handle previous attachments
        const previousAttachment = item.attachment || '';
        const previousAttachmentDisplay = previousAttachment 
            ? `<a href="#" onclick="openFilePreview('${previousAttachment}')" title="View Previous Attachment" class="file-icon">📎</a>`
            : '<i>No previous attachment</i>';

        return `
            <tr>
                <td><input type="checkbox" name="selectRejectRow" value="${item.id}" data-index="${index}" /></td>
                <td>${item.bundleId}</td>
                <td>${item.docId}</td>
                <td>${item.docType}</td>
                <td>${item.branch}</td>
                <td>${previousAttachmentDisplay}</td>
                <td>${item.receivedName || '-'}</td>
                <td>${formatDate(item.receivedOn) || '-'}</td>
                <td>${item.rejectedReason || '-'}</td>
                <td class="attachment-column">
                    <label class="custom-upload-btn">
