                const formData = new FormData();
                formData.append("gateEntry", JSON.stringify(gateEntryData));

                // IMPORTANT: Use COMPLETELY different keys for different purposes
                let vehicleFileAdded = false;
                let generalFilesAdded = 0;

                // Prepare attachment data for viewing after save
                const attachmentData = [];

                // VEHICLE ATTACHMENT - SEPARATE KEY AND METADATA
                if (vehicleAttachmentFile) {
                    // Use unique key for vehicle attachment
                    formData.append("vehicle_attachment", vehicleAttachmentFile);

                    // Add vehicle metadata separately
                    const vehicleMetadata = {
                        fileName: vehicleAttachmentFile.name,
                        fileSize: vehicleAttachmentFile.size,
                        fileType: vehicleAttachmentFile.type || 'application/octet-stream',
                        attachmentCategory: 'VEHICLE_DOCUMENT',
                        uploadedBy: parseInt(createdBy) || 67
                    };

                    formData.append("vehicle_metadata", JSON.stringify(vehicleMetadata));
                    attachmentData.push({...vehicleMetadata, category: 'VEHICLE_DOCUMENT'});

                    vehicleFileAdded = true;
                    console.log("🚛 VEHICLE ATTACHMENT added with key 'vehicle_attachment':", vehicleAttachmentFile.name);
                } else {
                    console.log("❌ No vehicle attachment to add");
                }

                // GENERAL ATTACHMENTS - COMPLETELY SEPARATE KEY AND METADATA
                if (selectedGeneralFiles.length > 0) {
                    selectedGeneralFiles.forEach((file, index) => {
                        // Use unique key for general attachments
                        formData.append(`general_attachment_${index}`, file);

                        // Add to attachment data for viewing
                        attachmentData.push({
                            fileName: file.name,
                            fileSize: file.size,
                            fileType: file.type || 'application/octet-stream',
                            category: 'GENERAL_DOCUMENT'
                        });
                    });

                    // Add general files metadata separately
                    formData.append("general_metadata", JSON.stringify(
                        selectedGeneralFiles.map((file, index) => ({
                            fileName: file.name,
                            fileSize: file.size,
                            fileType: file.type || 'application/octet-stream',
                            attachmentCategory: 'GENERAL_DOCUMENT',
                            uploadedBy: parseInt(createdBy) || 67,
                            index: index
                        }))
                    ));

                    generalFilesAdded = selectedGeneralFiles.length;
                    console.log("📎 GENERAL ATTACHMENTS added:", selectedGeneralFiles.map(f => f.name));
                } else {
                    console.log("❌ No general attachments to add");
                }

                // FINAL DEBUG: Show exactly what's being sent
                console.log("🔍 FINAL CHECK - FormData Keys:");
                const formDataEntries = [];
                for (let [key, value] of formData.entries()) {
                    const entry = `${key}: ${value instanceof File ? `FILE(${value.name})` : 'JSON_DATA'}`;
                    formDataEntries.push(entry);
                    console.log(`- ${entry}`);
                }

                // Add summary counts to FormData for backend processing
                formData.append("attachment_summary", JSON.stringify({
                    vehicleAttachmentCount: vehicleFileAdded ? 1 : 0,
                    generalAttachmentCount: generalFilesAdded,
                    totalAttachments: (vehicleFileAdded ? 1 : 0) + generalFilesAdded
                }));

                updateProgressMessage('Submitting to server...');

                const response = await fetch("/api/GIGO/InsertGateEntryMaster", {
                    method: "POST",
                    body: formData,
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP ${response.status}: ${errorText}`);
                }

                const result = await response.json();

                if (result.success || result.Success) {
                    hideFullPageProgress();

                    // Show success modal with CORRECT attachment counts and viewing capability
                    const totalDocs = documentArrays.customerDocs.length + documentArrays.vendorDocs.length + documentArrays.bstDocs.length;

                    showSuccessModal({
                        entryType: `${gateEntryData.EntryType} Entry`,
                        vehicle: `${gateEntryData.VehicleNo} (${gateEntryData.DriverName})`,
                        contents: `${contentsData.length} items, ${totalDocs} records`,
                        attachments: `Vehicle: ${vehicleFileAdded ? 1 : 0}, General: ${generalFilesAdded}`,
                        attachmentData: attachmentData // Pass attachment data for viewing
                    });

                } else {
                    throw new Error(result.message || result.Message || 'Unknown save error');
                }

            } catch (err) {
                hideFullPageProgress();
                showAlert(`❌ Save failed: ${err.message}`, 'error');
                console.error("Full error details:", err);
            }
        }

        function collectLogisticsData() {
            const logisticsData = {
                transporterName: document.getElementById("transporterNameLogistics")?.value?.trim().toUpperCase() || '',
                driverName: document.getElementById("driverNameLogistics")?.value?.trim().toUpperCase() || '',
                driverMobile: document.getElementById("driverMobile")?.value?.trim() || '',
                vehicleNo: document.getElementById("vehicleNoLogistics")?.value?.trim().toUpperCase() || '',
                challanNo: document.getElementById("challanNo")?.value?.trim().toUpperCase() || '',
                challanDate: document.getElementById("challanDate")?.value || '',
                shipFrom: document.getElementById("shipFrom")?.value?.trim().toUpperCase() || '',
                biltyNo: document.getElementById("biltyNo")?.value?.trim().toUpperCase() || '',

                inTime: document.getElementById("inTime")?.value || '',
                grossWeight: parseFloat(document.getElementById("grossWeight")?.value) || 0,
                tareWeight: parseFloat(document.getElementById("tareWeight")?.value) || 0,
                netWeight: parseFloat(document.getElementById("netWeight")?.value) || 0
            };

            return logisticsData;
        }

        function addRow() {
            document.getElementById('addItemModal').style.display = 'flex';
        }

        function saveItem() {
            const itemCode = document.getElementById('modalItemCode')?.value?.trim().toUpperCase();
            const itemName = document.getElementById('modalItemName')?.value?.trim().toUpperCase();

            if (!itemCode || !itemName) {
                showAlert('❗ Please fill in Item Code and Item Description', 'warning');
                return;
            }

            if (itemCode.length < 2) {
                showAlert('❗ Item Code must be at least 2 characters', 'error');
                return;
            }

            if (itemName.length < 2) {
                showAlert('❗ Item Description must be at least 2 characters', 'error');
                return;
            }

            const table = document.getElementById('contentsTable');
            const tbody = table.getElementsByTagName('tbody')[0];
            const newRow = tbody.insertRow();
            const rowCount = tbody.rows.length;

            const recQuantity = document.getElementById('modalRecQuantity')?.value || '1';
            const poQuantity = document.getElementById('modalPOQuantity')?.value || '1';
            const openQuantity = document.getElementById('modalOpenQuantity')?.value || '0';
            const uom = document.getElementById('modalUoM')?.value.toUpperCase() || 'PCS';
            const remarks = document.getElementById('modalRemarks')?.value?.trim().toUpperCase() || '';

            if (parseFloat(recQuantity) <= 0) {
                showAlert('❗ Received quantity must be greater than 0', 'error');
                return;
            }

            if (parseFloat(poQuantity) <= 0) {
                showAlert('❗ PO quantity must be greater than 0', 'error');
                return;
            }

            newRow.innerHTML = `
                <td>${rowCount}</td>
                <td><input class="table-input uppercase-input" type="text" value="${itemName}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input uppercase-input" type="text" value="${itemCode}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input uppercase-input" type="text" value="${remarks}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input" type="number" value="${poQuantity}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input" type="number" value="${openQuantity}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input uppercase-input" type="text" value="${uom}" readonly style="background-color: #f8f9fa; cursor: not-allowed;"></td>
                <td><input class="table-input editable-field" type="number" value="${recQuantity}" step="0.0001" min="0" style="background-color: #fff3cd; border-color: #ffc107;"></td>
                <td><input class="table-input editable-field uppercase-input" type="text" value="" placeholder="USER REMARKS" style="background-color: #e8f4fd; border-color: #17a2b8;"></td>
            `;

            closeModal('addItemModal');
            clearModalFields();
        }

        function deleteRow() {
            const table = document.getElementById('contentsTable');
            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            let deletedCount = 0;
            for (let i = rows.length - 1; i >= 0; i--) {
                if (rows[i].classList.contains('selected')) {
                    rows[i].remove();
                    deletedCount++;
                }
            }

            if (deletedCount > 0) {
                updateRowNumbers();
                showAlert(`🗑️ Deleted ${deletedCount} row(s)`, 'success');
            } else {
                showAlert('Please select a row to delete', 'warning');
            }
        }

        function updateRowNumbers() {
            const rows = document.querySelectorAll('#contentsTable tbody tr');
            rows.forEach((row, index) => {
                row.cells[0].textContent = index + 1;
            });
        }

        function clearModalFields() {
            ['modalItemCode', 'modalItemName', 'modalRecQuantity', 'modalPOQuantity', 'modalOpenQuantity', 'modalRemarks'].forEach(id => {
                const element = document.getElementById(id);
                if (element) element.value = '';
            });
        }

        function triggerAttachmentsInput() {
            document.getElementById('attachmentsInput')?.click();
        }

        // UPDATED: Handle general attachments (renamed from selectedFiles to selectedGeneralFiles)
        function handleAttachmentsChange(event) {
            const newFiles = Array.from(event.target.files);
            const maxSize = 512 * 1024; // 512KB
            const allowedTypes = ['.pdf', '.jpg', '.jpeg', '.png', '.doc', '.docx'];

            clearMessages();

            for (let file of newFiles) {
                if (file.size > maxSize) {
                    showAlert(`❌ File "${file.name}" exceeds 512KB limit`, 'error');
                    return;
                }

                const fileExt = '.' + file.name.split('.').pop().toLowerCase();
                if (!allowedTypes.includes(fileExt)) {
                    showAlert(`❌ File "${file.name}" format not supported`, 'error');
                    return;
                }

                const isDuplicate = selectedGeneralFiles.some(existingFile =>
                    existingFile.name === file.name && existingFile.size === file.size
                );
                if (isDuplicate) {
                    showAlert(`❌ File "${file.name}" is already selected`, 'warning');
                    return;
                }
            }

            selectedGeneralFiles = selectedGeneralFiles.concat(newFiles);
            updateFileList();
            event.target.value = '';
        }

        function updateFileList() {
            const fileList = document.getElementById("fileList");
            if (!fileList) return;

            fileList.innerHTML = "";

            if (selectedGeneralFiles.length === 0) {
                fileList.innerHTML = '<li style="color: #999; font-style: italic; background: none; border: none;">No files selected</li>';
                return;
            }

            selectedGeneralFiles.forEach((file, index) => {
                const li = document.createElement("li");

                // Create clickable filename for preview
                const fileNameSpan = document.createElement("span");
                fileNameSpan.style.cursor = "pointer";
                fileNameSpan.style.color = "#007bff";
                fileNameSpan.style.textDecoration = "underline";
                fileNameSpan.title = "Click to preview file";
                fileNameSpan.innerHTML = `<strong>${file.name.toUpperCase()}</strong> <small>(${(file.size / 1024).toFixed(2)} KB)</small>`;

                // Add click handler for preview
                fileNameSpan.addEventListener('click', function() {
                    previewFile(file, file.name);
                });

                const removeButton = document.createElement("button");
                removeButton.textContent = "Remove";
                removeButton.title = "Remove file";
                removeButton.onclick = () => removeFile(index);

                li.appendChild(fileNameSpan);
                li.appendChild(removeButton);
                fileList.appendChild(li);
            });
        }

        function removeFile(index) {
            const removedFile = selectedGeneralFiles[index];
            selectedGeneralFiles.splice(index, 1);
            updateFileList();
            showAlert(`🗑️ Removed file: ${removedFile.name}`, 'info');
        }

        function clearMessages() {
            ['upload-error', 'upload-success'].forEach(id => {
                const element = document.getElementById(id);
                if (element) element.style.display = 'none';
            });
        }

        // UPDATED: Reset form including vehicle attachment
        function resetForm() {
            const allInputs = document.querySelectorAll('input:not([type="file"]), select, textarea');
            allInputs.forEach(input => {
                if (input.type === 'date') {
                    if (input.id === 'postingDate') {
                        input.value = new Date().toISOString().split('T')[0];
                    } else {
                        input.value = new Date().toISOString().split('T')[0];
                    }
                } else if (input.type === 'time') {
                    input.value = new Date().toLocaleTimeString('en-GB', { hour12: false }).slice(0, 5);
                } else if (input.type === 'number') {
                    input.value = '0.00';
                } else if (input.tagName === 'SELECT') {
                    input.selectedIndex = 0; // No default selection
                } else {
                    input.value = '';
                }
                ValidationManager.clearFieldError(input.id);
            });

            const poNumberGroup = document.getElementById('poNumberGroup');
            if (poNumberGroup) {
                poNumberGroup.style.display = 'none';
            }

            document.querySelector('#contentsTable tbody').innerHTML = '';

            // Reset both types of attachments
            vehicleAttachmentFile = null;
            selectedGeneralFiles = [];
            savedAttachments = []; // Clear saved attachments
            updateFileList();

            // Clear file inputs
            document.getElementById("attachmentsInput").value = '';
            document.getElementById("vehicleAttachment").value = '';

            // Clear vehicle attachment display
            document.getElementById('vehicle-attachment-display').innerHTML = '';

            // Reset vehicle attachment status
            const statusIndicator = document.getElementById('vehicleAttachmentStatus');
            if (statusIndicator) {
                statusIndicator.textContent = '📎 Required';
                statusIndicator.style.color = '#dc2626';
            }

            // Reset user name
            const receivedByField = document.getElementById('receivedBy');
            if (receivedByField) {
                const userName = sessionStorage.getItem("userName");
                receivedByField.value = userName || 'ADMIN';
            }

            switchTab('contents', document.querySelector('.tab'));
        }

        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }

        function copyToClipboard() {
            const cardCode = document.getElementById("cardCode")?.value?.trim();

            if (!cardCode) {
                showAlert('❗ Please enter CardCode first', 'warning');
                document.getElementById("cardCode").focus();
                return;
            }

            if (!ValidationManager.validateField('cardCode')) {
                showAlert('❗ Please enter a valid CardCode', 'error');
                return;
            }

            // Call WITH full page progress (showProgress = true)
            showPurchaseOrderPopup(cardCode, true);
        }

        function previewFile(file, fileName) {
            if (!file) {
                showAlert('File not available for preview', 'error');
                return;
            }

            const fileType = file.type.toLowerCase();
            const fileExtension = fileName.split('.').pop().toLowerCase();

            // Create file URL for preview
            const fileURL = URL.createObjectURL(file);

            let content = '';

            if (fileType.includes('image') || ['jpg', 'jpeg', 'png', 'gif', 'bmp'].includes(fileExtension)) {
                // Image preview
                content = `
                    <div style="text-align: center;">
                        <h4>📷 Image Preview: ${fileName}</h4>
                        <div style="margin: 20px 0;">
                            <img src="${fileURL}" alt="${fileName}" style="max-width: 100%; max-height: 60vh; border: 2px solid #ddd; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                        </div>
                        <div style="margin-top: 15px; padding: 10px; background: #f8f9fa; border-radius: 4px; font-size: 14px; color: #666;">
                            <strong>File Size:</strong> ${(file.size / 1024).toFixed(2)} KB<br>
                            <strong>File Type:</strong> ${file.type || 'Unknown'}
                        </div>
                    </div>
                `;
            } else if (fileType.includes('pdf')) {
                // PDF preview using iframe
                content = `
                    <div style="text-align: center;">
                        <h4>📄 PDF Preview: ${fileName}</h4>
                        <div style="margin: 20px 0;">
                            <iframe src="${fileURL}" width="100%" height="500px" style="border: 2px solid #ddd; border-radius: 8px;"></iframe>
                        </div>
                        <div style="margin-top: 15px; padding: 10px; background: #f8f9fa; border-radius: 4px; font-size: 14px; color: #666;">
                            <strong>File Size:</strong> ${(file.size / 1024).toFixed(2)} KB<br>
                            <strong>Note:</strong> If PDF doesn't display, your browser may not support inline PDF viewing.
                        </div>
                    </div>
                `;
            } else if (fileType.includes('text') || ['txt', 'log', 'csv'].includes(fileExtension)) {
                // Text file preview
                const reader = new FileReader();
                reader.onload = function(e) {
                    const textContent = e.target.result;
                    const preview = textContent.length > 2000 ? textContent.substring(0, 2000) + '...' : textContent;

                    const textPreviewContent = `
                        <div>
                            <h4>📝 Text Preview: ${fileName}</h4>
                            <div style="margin: 20px 0;">
                                <pre style="background: #f5f5f5; padding: 15px; border-radius: 8px; max-height: 400px; overflow: auto; text-align: left; white-space: pre-wrap; font-family: 'Courier New', monospace; font-size: 12px;">${preview}</pre>
                            </div>
                            <div style="margin-top: 15px; padding: 10px; background: #f8f9fa; border-radius: 4px; font-size: 14px; color: #666;">
                                <strong>File Size:</strong> ${(file.size / 1024).toFixed(2)} KB<br>
                                ${textContent.length > 2000 ? '<strong>Note:</strong> Preview truncated. Full content will be uploaded.' : ''}
                            </div>
                        </div>
                    `;
                    showAttachmentModal(`Preview: ${fileName}`, textPreviewContent);
                };
                reader.readAsText(file);
                return; // Exit early since we're handling this async
            } else {
                // Generic file info for unsupported types
                content = `
                    <div style="text-align: center;">
                        <h4>📎 File Information: ${fileName}</h4>
                        <div style="margin: 40px 0;">
                            <div style="font-size: 64px; margin-bottom: 20px;">📄</div>
                            <p style="font-size: 18px; color: #666; margin-bottom: 10px;">Preview not available for this file type</p>
                            <p style="font-size: 16px; color: #333;"><strong>${fileName}</strong></p>
                        </div>
                        <div style="margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px; text-align: left;">
                            <div style="font-size: 14px; color: #666;">
                                <strong>File Type:</strong> ${file.type || 'Unknown'}<br>
                                <strong>File Size:</strong> ${(file.size / 1024).toFixed(2)} KB<br>
                                <strong>File Extension:</strong> .${fileExtension}<br>
                                <strong>Status:</strong> Ready for upload
                            </div>
                        </div>
                        <div style="margin-top: 15px; padding: 10px; background: #e3f2fd; border-radius: 4px; font-size: 13px; color: #1976d2;">
                            💡 <strong>Supported Preview Types:</strong> Images, PDFs, Text files
                        </div>
                    </div>
                `;
            }

            showAttachmentModal(`Preview: ${fileName}`, content);

            // Clean up the URL after showing (with delay to allow viewing)
            setTimeout(() => {
                URL.revokeObjectURL(fileURL);
            }, 30000); // Clean up after 30 seconds
        }

        function printGatePass() {
            if (ValidationManager.validateAll()) {
                showAlert('🖨️ Printing Gate Pass...', 'info');
                window.print();
            }
        }

        function cancelInward() {
            if (confirm('⚠️ Are you sure you want to cancel this entry? All data will be lost.')) {
                resetForm();
                showAlert('Gate inward cancelled', 'info');
            }
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            const modals = document.querySelectorAll('.modal, .attachment-modal');
            modals.forEach(modal => {
                if (event.target === modal) {
                    modal.style.display = "none";
                }
            });
        }
    </script>
