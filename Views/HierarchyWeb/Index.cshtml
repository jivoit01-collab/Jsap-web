            function compactSalesMatchKey(value){
                return (value || '').toString().trim().toLowerCase().replace(/[^a-z0-9]+/g, '');
            }

            function firstSalesNameToken(value){
                var tokens = (value || '').toString().trim().toLowerCase().split(/[^a-z0-9]+/).filter(Boolean);
                return tokens.length ? tokens[0] : '';
            }

            function isSalesHodNameMatch(hodName, salesName){
                var hodKey = compactSalesMatchKey(hodName);
                var salesKey = compactSalesMatchKey(salesName);
                if(!hodKey || !salesKey) return false;
                if(hodKey === salesKey) return true;

                var hodFirst = firstSalesNameToken(hodName);
                var salesFirst = firstSalesNameToken(salesName);
                return hodFirst.length >= 4
                    && salesFirst.length >= 4
                    && (hodFirst.indexOf(salesFirst) === 0 || salesFirst.indexOf(hodFirst) === 0);
            }

            function findSalesHodMatch(salesHod, merged){
                var h1Code = (salesHod.h1Code || '').trim().toUpperCase();

                return merged.find(function(h){
                    var hodCode = (h.code || '').trim().toUpperCase();
                    if(h1Code && hodCode === h1Code) return true;
                    return isSalesHodNameMatch(h.name, salesHod.h1Name);
                });
            }

            function mergeSalesTreeIntoHod(hod, salesHod){
                var incomingH2 = salesHod.h2List || [];
                if(!hod.salesTree){
                    hod.salesTree = Object.assign({}, salesHod, { h2List: incomingH2.slice() });
                    return;
                }

                hod.salesTree.h2List = (hod.salesTree.h2List || []).concat(incomingH2);
            }

            function applyMergedData(){
                // Deep-clone BASE_RAW_DATA so we can safely inject without mutating original
                var merged = BASE_RAW_DATA.map(function(h){
                    return Object.assign({}, h,
                        { depts: h.depts.slice(), subs: h.subs.slice(), salesTree: null });
                });

                var injectedCount = 0;
                var DEPT = SALES_DEPT_NAME;

                SALES_RAW_DATA.forEach(function(salesHod){
                    var h1Code = (salesHod.h1Code || '').trim().toUpperCase();
                    var h2List = salesHod.h2List || [];
                    if(!h2List.length) return;

                    // Find matching HOD in merged by employee code first, then by name.
                    var hod = findSalesHodMatch(salesHod, merged);
                    if(!hod) return; // H1 not in main hierarchy - skip

                    if(hod.depts.indexOf(DEPT) === -1){
                        hod.depts.push(DEPT);
                        injectedCount++;
                    }
                    mergeSalesTreeIntoHod(hod, salesHod);
                });

                RAW_DATA = merged;
                SALES_DESIG_SUMMARY = buildSalesDesignationSummary(merged);
                SALES_DUPLICATES = buildSalesDuplicates(merged);
                var btn = document.getElementById('btnSalesToggle');
                btn.className = 'eh-btn eh-btn-sal-on';
                btn.innerHTML = '<i class="bi bi-diagram-3-fill"></i> Showing with Sales (' + injectedCount + ' HODs)';
                toggleSalesInsights(true);
                renderSalesInsights();
                v1_exp = {};
                updateStatCards();
                rerender();
                renderSalesTeamCards();
            }

            function toggleSalesInsights(show){
                var panel = document.getElementById('salesInsights');
                var btn = document.getElementById('btnSalesDuplicates');
                if(panel) panel.style.display = show ? '' : 'none';
                if(btn) btn.style.display = show ? '' : 'none';
