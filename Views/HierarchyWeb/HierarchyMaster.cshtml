        async function saveDeptEdit(id) {
            const input = document.getElementById(`edit_dept_${id}`);
            const name = input ? input.value.trim() : '';
            if (!name) { showDeptError('Enter department name'); return; }
            showDeptError('');
            try {
                const r = await api(`${API}/UpdateDepartment`, 'POST', { departmentId: id, departmentName: name, isActive: true });
                if (r.success) {
                    showDeptError(r.message || 'Department updated', 'ok');
                    editingDeptId = null;
                    await loadDeptsMeta();
                    renderDeptList();
                    renderDeptOptions('f_dept', deptsMeta);
                    const sel = document.getElementById('nsd_dept');
                    if (sel) sel.innerHTML = '<option value="">— Select —</option>' +
                        deptsMeta.map(d => `<option value="${d.departmentId}">${esc(d.departmentName)}</option>`).join('');
                } else { showDeptError(r.message || 'Failed'); }
            } catch (e) { showDeptError('Error: ' + e.message); }
        }

        async function addDept() {
            const name = document.getElementById('nd_name').value.trim();
            showDeptError('');
            if (!name) { showDeptError('Enter department name'); return; }
            try {
                const r = await api(`${API}/AddDepartment`, 'POST', { departmentName: name, isActive: true });
                if (r.success) {
                    showDeptError(r.message || `"${name}" created`, 'ok');
                    document.getElementById('nd_name').value = '';
                    await loadDeptsMeta();
                    renderDeptList();
                    await loadGrid();
                    renderDeptOptions('f_dept', deptsMeta);
