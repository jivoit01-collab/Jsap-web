}

function bulkToggleAll(checked) {
    const q = document.getElementById('bulkSearchEmp').value.toLowerCase().trim();
    const visible = allRows.filter(r => {
        if (!q) return true;
        return (r.empCode||'').toLowerCase().includes(q) || (r.empName||'').toLowerCase().includes(q)
