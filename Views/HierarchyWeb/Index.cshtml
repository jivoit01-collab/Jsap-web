            function v2_cellSH(h,st){ var selKeys=Object.keys(st.selSD||{}).filter(function(k){return st.selSD[k];});if(!selKeys.length){var c=h.color;return'<td><div class="cell cell-count-box" style="background:'+c.bg+';border-color:#e2e8f0" onclick="v2_clickSHCount('+h.idx+',event)"><span class="count-num" style="color:'+c.badge+'">'+h.subhodCount+'</span><span class="count-label">Sub-HODs</span></div></td>';}var r='<td><div class="cell-stack">';selKeys.sort().forEach(function(k){var s=h.subs[parseInt(k)];if(!s)return;var c=DEPT_COLORS[s.idx%DEPT_COLORS.length];var subHods=s.subHods||[];if(!subHods.length){r+='<div class="cell cell-static cell-muted" style="border-left:4px solid '+c.badge+';background:'+c.bg+'">No sub-HODs</div>';return;}subHods.forEach(function(sh){r+='<div class="cell" style="background:'+c.bg+';border-color:'+c.border+';border-left:4px solid '+c.badge+'"><div class="cell-row"><span class="cell-name" style="color:'+c.text+'" onclick="v2_showSHInfo2('+h.idx+','+s.idx+',\''+escAttr(sh.name)+'\',event)"><i class="bi bi-person-fill me-1"></i>'+esc(sh.name)+'</span><span class="cell-info-btn" onclick="v2_showSHInfo2('+h.idx+','+s.idx+',\''+escAttr(sh.name)+'\',event)"><i class="bi bi-info-circle"></i></span><span class="cell-badge" style="background:'+c.badge+'">'+(sh.execs||[]).length+'</span></div>';if(SHOW_SAL&&sh.sal)r+='<div class="cell-sal">₹'+fmtN(sh.sal)+'</div>';r+='</div>';});});return r+'</div></td>'; }
            function v2_cellEx(h,st){  var selKeys = Object.keys(st.selSD || {}).filter(function(k){
