        document.addEventListener('DOMContentLoaded', function() {
            console.log('Initializing Inventory Audit List page...');
            showLoadingOverlay('Loading initial data...');
            loadInitialData();
        });

        async function loadInitialData() {
            try {
                console.log('Loading initial API data...');
                getCurrentUser(); // Initialize current user

                // Load filters and initial stock count data in parallel
                await Promise.all([
                    loadUnits(),
                    loadItemGroups(),
                    loadSubGroups(),
                    loadInitialStockCountData()
                ]);

                // Initialize status dropdown
                initializeStatusDropdown();

                console.log('Initial API data loaded successfully');
                updateFilterSummary();
                hideLoadingOverlay();

            } catch (error) {
                console.error('Error loading initial data:', error);
                showGlobalError('Failed to load some initial data. Please refresh the page and try again.');
                hideLoadingOverlay();
            }
        }

        function initializeStatusDropdown() {
            const statusOptions = [
                { id: 'Pending', name: 'Pending', code: 'Pending' },
                { id: 'Completed', name: 'Completed', code: 'Completed' },
                { id: 'Closed', name: 'Closed', code: 'Closed' }
            ];

            populateSingleSelect('status-dropdown', statusOptions, 'status');
            setNormalState('status-container', 'status-selected', 'Select status...');
        }

        // Click outside to close dropdowns
        document.addEventListener('click', function(event) {
            if (!event.target.closest('.select-container')) {
                document.querySelectorAll('.select-dropdown').forEach(dropdown => {
                    dropdown.classList.remove('show');
                });
                document.querySelectorAll('.select-container').forEach(container => {
                    container.classList.remove('active');
                });
            }
        });

        // Make functions globally available
        window.removeMultiSelectItem = removeMultiSelectItem;
        window.searchStockCountData = searchStockCountData;
        window.editStockCount = editStockCount;
        window.downloadExcel = downloadExcel;
        window.toggleSingleSelect = toggleSingleSelect;
        window.toggleMultiSelect = toggleMultiSelect;
        window.clearAllFilters = clearAllFilters;
        window.resetFilters = resetFilters;
        window.handleLotNumberSearch = handleLotNumberSearch;
        window.clearLotNumberSearch = clearLotNumberSearch;

        // UPDATED: Filter management functions without lot number
        function clearAllFilters() {
            console.log('Clearing all filters...');

            // Reset all filter objects (excluding lot number)
            searchFilters = {
                unit: null,
                location: null,
                warehouse: [],
                itemGroup: [],
                subGroup: [],
                status: null
            };

            // Reset all UI elements
            resetFilterUI();
            updateFilterSummary();

            // Clear lot number search as well
            clearLotNumberSearch();

            // Reload data from API after clearing filters
            displayStockCountData(originalStockCountData);

            showTemporaryMessage('All filters cleared and data reloaded', 'info');
        }

        function resetFilters() {
            console.log('Resetting filters to default...');
            clearAllFilters();
        }

        function resetFilterUI() {
            // Reset single select dropdowns
            document.getElementById('unit-selected').innerHTML = '<div class="select-placeholder">Select unit...</div>';
            document.getElementById('location-selected').innerHTML = '<div class="select-placeholder">Select unit first...</div>';
            document.getElementById('status-selected').innerHTML = '<div class="select-placeholder">Select status...</div>';

            // Reset multi-select dropdowns
            document.getElementById('warehouse-selected').innerHTML = '<div class="select-placeholder">Select location first...</div>';
            document.getElementById('itemgroup-selected').innerHTML = '<div class="select-placeholder">Select item groups...</div>';
            document.getElementById('subgroup-selected').innerHTML = '<div class="select-placeholder">Select sub groups...</div>';

            // Remove selected classes from all options
            document.querySelectorAll('.select-option').forEach(option => {
                option.classList.remove('selected');
            });

            // Reset dependencies
            disableDropdown('location-container', 'Select unit first...');
            disableDropdown('warehouse-container', 'Select location first...');

            // Close all dropdowns
            document.querySelectorAll('.select-dropdown').forEach(dropdown => {
                dropdown.classList.remove('show');
            });
            document.querySelectorAll('.select-container').forEach(container => {
                container.classList.remove('active');
            });
        }

        function updateFilterSummary() {
            const summaryElement = document.querySelector('.summary-text');
            const filterCounts = [];

            // Count selected filters (excluding lot number)
            if (searchFilters.unit) filterCounts.push('Unit');
            if (searchFilters.location) filterCounts.push('Location');
            if (searchFilters.warehouse.length > 0) {
                const warehouseCount = isAllSelected('warehouse') ? 'All Warehouses' : `${searchFilters.warehouse.length} Warehouse(s)`;
                filterCounts.push(warehouseCount);
            }
            if (searchFilters.itemGroup.length > 0) {
                const groupCount = isAllSelected('itemGroup') ? 'All Item Groups' : `${searchFilters.itemGroup.length} Item Group(s)`;
                filterCounts.push(groupCount);
            }
            if (searchFilters.subGroup.length > 0) {
                const subGroupCount = isAllSelected('subGroup') ? 'All Sub Groups' : `${searchFilters.subGroup.length} Sub Group(s)`;
                filterCounts.push(subGroupCount);
            }
            if (searchFilters.status) filterCounts.push('Status');

            if (filterCounts.length === 0) {
                summaryElement.innerHTML = 'No filters selected';
            } else {
                summaryElement.innerHTML = `Active filters: <span class="summary-count">${filterCounts.length}</span> - ${filterCounts.join(', ')}`;
            }

            // Update button states
            const clearBtn = document.getElementById('clearFiltersBtn');
            const resetBtn = document.getElementById('resetFiltersBtn');

            if (filterCounts.length > 0) {
                clearBtn.classList.remove('disabled');
                resetBtn.classList.remove('disabled');
            } else {
                clearBtn.classList.add('disabled');
                resetBtn.classList.add('disabled');
            }
        }

        function showTemporaryMessage(message, type = 'info') {
            const existingMessage = document.querySelector('.temp-message');
            if (existingMessage) {
                existingMessage.remove();
            }

            const alertClass = type === 'success' ? 'alert-success' :
                             type === 'warning' ? 'alert-warning' :
                             type === 'danger' ? 'alert-danger' : 'alert-info';

            const messageDiv = document.createElement('div');
            messageDiv.className = `alert ${alertClass} temp-message`;
            messageDiv.style.cssText = 'position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999; max-width: 500px;';
            messageDiv.innerHTML = `
                ${message}
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            `;
            document.body.appendChild(messageDiv);

            setTimeout(() => {
                if (messageDiv.parentElement) {
                    messageDiv.remove();
                }
            }, 3000);
        }

        console.log('✅ Inventory Audit List page loaded successfully with Lot Number Omni Search functionality');
    </script>
</body>
</html>