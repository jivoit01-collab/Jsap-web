function exportToExcel() {
    if (!filtered.length) { showToast('No data to export', 'info'); return; }

    const isBlankOrHyphen = v => isDash(v) || String(v).trim() === '';

    // Exclude rows where empName is blank or hyphen (unassigned employees)
    const exportRows = filtered.filter(r => !isBlankOrHyphen(r.empName));

    if (!exportRows.length) { showToast('No valid records to export', 'info'); return; }

    const visibleCols = COLUMNS.filter(c => c.visible);
    const headers = ['#', ...visibleCols.map(c => c.label)];
    const rows = exportRows.map((r, i) => {
        const row = [i + 1];
        visibleCols.forEach(c => {
            let val = r[c.key];
            if (c.key === 'isActive') val = val ? 'Active' : 'Inactive';
            else if (c.key === 'dateOfJoining' && val) val = new Date(val).toLocaleDateString('en-IN');
            else if (isBlankOrHyphen(val)) val = '';
            row.push(val ?? '');
        });
        return row;
    });

    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Sales Hierarchy');

    ws['!cols'] = Array(headers.length).fill({ wch: 18 });

    XLSX.writeFile(wb, `Sales_Hierarchy_${new Date().toISOString().split('T')[0]}.xlsx`);
    showToast(`Exported ${exportRows.length} record(s) successfully`, 'success');
}

async function loadEmployees() {
    try {
        const res = await fetch(API.getEmployees);
        const json = normalizeApiResponse(await res.json());
        if (json.success) {
            allSalesEmployees = json.data || [];
            buildEmployeeDatalist();
        }
    } catch(e) {}
}

function buildEmployeeDatalist() {
    const seen = new Set();
    const fromRows = (hierarchyOptions.employees || []).filter(e => {
        const k = normalizeKey(e.value);
        if (!k || seen.has(k)) return false;
        seen.add(k); return true;
    });
    const extra = allSalesEmployees
        .map(e => ({
            value: (e.employeeCode ?? e.EmployeeCode ?? '').trim(),
            name:  (e.employeeName ?? e.EmployeeName ?? '').trim()
        }))
        .filter(e => {
            const k = normalizeKey(e.value || e.name);
            if (!k || seen.has(k)) return false;
            seen.add(k); return true;
        })
        .map(e => ({
            value: e.value || e.name,
            label: formatLevelFilterLabel(e.name, e.value),
            name:  e.name,
            code:  e.value
        }));
    hierarchyOptions.employees = [...fromRows, ...extra].sort((a, b) => a.label.localeCompare(b.label));
    fillEmployeeDatalist('newRel_empCode', hierarchyOptions.employees);
}

