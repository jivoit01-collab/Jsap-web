        function addAddressEntry() {
            const billingData = {
                line1: document.getElementById('billing-address1').value.trim(),
                line2: document.getElementById('billing-address2').value.trim(),
                city: document.getElementById('billing-city').value.trim(),
                state: document.getElementById('billing-state').value.trim(),
                country: document.getElementById('billing-country').value.trim(),
                zip: document.getElementById('billing-zip').value.trim(),
                gst: document.getElementById('billing-gst').value.trim()
            };

            const sameAsBilling = document.getElementById('same-as-billing').checked;
            const billAddress = formatAddressWithGST(billingData);

            const contactFirstName = document.querySelector("input[name='contactFirstName']").value.trim();
            const contactLastName = document.querySelector("input[name='contactLastName']").value.trim();
            const contactName = `${contactFirstName}${contactLastName}`;

            const billAddressId = generateAddressId(billingData.state, contactName);
            let shipAddressId = '';
            let shipAddress = '';

            if (sameAsBilling) {
                shipAddress = 'Same as Billing';
                shipAddressId = billAddressId;
            } else {
                const shippingData = {
                    line1: document.getElementById('shipping-address1').value.trim(),
                    line2: document.getElementById('shipping-address2').value.trim(),
                    city: document.getElementById('shipping-city').value.trim(),
                    state: document.getElementById('shipping-state').value.trim(),
                    country: document.getElementById('shipping-country').value.trim(),
                    zip: document.getElementById('shipping-zip').value.trim(),
                };
                shipAddress = formatAddressWithGST(shippingData);
                shipAddressId = generateAddressId(shippingData.state, contactName);
            }
            // Store data for passing into check function
            const billingInfo = {
                data: billingData,
                address: billAddress,
                id: billAddressId
            };

            if (sameAsBilling) {
                checkAndProcessAddressId(
                    billAddressId,
                    { billAddress, shipAddress: 'Same as Billing', type: 'billing' },
                    'both' // use 'both' as a signal that same ID is used for both
                );
            } else {
                const shippingData = {
                    line1: document.getElementById('shipping-address1').value.trim(),
                    line2: document.getElementById('shipping-address2').value.trim(),
                    city: document.getElementById('shipping-city').value.trim(),
                    state: document.getElementById('shipping-state').value.trim(),
                    country: document.getElementById('shipping-country').value.trim(),
                    zip: document.getElementById('shipping-zip').value.trim(),
                    gst: document.getElementById('shipping-gst').value.trim()
                };

                const shipAddress = formatAddressWithGST(shippingData);
                const shipAddressId = generateAddressId(shippingData.state, contactName);

                checkAndProcessAddressId(
                    billAddressId,
                    { billAddress, billAddressId, shipAddress, shipAddressId, type: 'billing' },
                    'billing'
                );

                checkAndProcessAddressId(
                    shipAddressId,
                    { billAddress, billAddressId, shipAddress, shipAddressId, type: 'shipping' },
                    'shipping'
                );
            }

            // addAddressRow(billAddress, billAddressId, shipAddress, shipAddressId);
            // resetAddressForm();
        }
                let editingAddressRow = null;

        function editAddress(button) {
            const row = button.closest('tr');
            if (!row) return;

            editingAddressRow = row;

            const billAddress = row.cells[0].textContent.trim();
            const billAddressId = row.cells[1].textContent.trim();
            const shipAddress = row.cells[2].textContent.trim();
            const shipAddressId = row.cells[3].textContent.trim();

            const billing = parseAddressString(billAddress);
            const shipping = shipAddress === 'Same as Billing' ? billing : parseAddressString(shipAddress);

            fillBillingFields(billing);
            fillShippingFields(shipping);

            document.getElementById("billing-address-id").value = billAddressId;
            document.getElementById("shipping-address-id").value = shipAddressId;

            // Always leave checkbox unchecked
            const checkbox = document.getElementById("same-as-billing");
            if (checkbox) {
                checkbox.checked = false;
                toggleShippingFields();
            }

            // Show Save / Cancel buttons
            const actions = document.getElementById("address-edit-actions");
            if (actions) actions.style.display = "block";
        }

        function saveEditedAddressFromInput() {
            const contactFirstName = document.querySelector("input[name='contactFirstName']").value.trim();
            const contactLastName = document.querySelector("input[name='contactLastName']").value.trim();
            const fullName = `${contactFirstName}${contactLastName}`;
            saveEditedAddress(fullName);
