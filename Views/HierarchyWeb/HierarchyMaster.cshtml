        }

        async function loadLogs() {
            const search = document.getElementById('logSearch').value.trim();
            const action = document.getElementById('logAction').value;
            let url = `${API}/GetAuditLogs?pageNumber=${logPage}&pageSize=30`;
            if (search) url += `&searchTerm=${encodeURIComponent(search)}`;
            if (action) url += `&actionType=${encodeURIComponent(action)}`;

            const el = document.getElementById('logBody');
            el.innerHTML = '<div class="dm-empty">Loading…</div>';

            try {
                const r = await api(url);
                if (!r.success) { el.innerHTML = '<div class="dm-empty">Error: ' + esc(r.message || '') + '</div>'; return; }
                const logs = r.data || [];
                if (!logs.length) { el.innerHTML = '<div class="dm-empty">No logs found</div>'; return; }

                el.innerHTML = logs.map(l => {
                    const d = new Date(l.createdOn);
                    const time = d.toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) + ' ' + d.toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'});
                    const actionBadge = getActionBadge(l.actionType);
                    return `<div class="log-row">
                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                            <span class="log-action ${actionBadge.cls}">${esc(l.actionType)}</span>
                            <span style="font-weight:700;color:var(--g1)">${esc(l.employeeName || '')}</span>
                            <span class="emp-code">${esc(l.employeeCode || '')}</span>
                        </div>
                        <div style="font-size:11px;color:var(--text);margin-top:4px">${esc(l.description || '')}</div>
                        <div style="display:flex;gap:12px;margin-top:4px;font-size:10px;color:var(--muted)">
                            <span>By: <strong>${esc(l.changedByName || 'System')}</strong></span>
                            <span>${time}</span>
                        </div>
                        ${l.oldValues || l.newValues ? `<div class="log-vals">
                            ${l.oldValues ? '<div><span style="color:var(--danger);font-weight:600">Old:</span> ' + esc(l.oldValues) + '</div>' : ''}
                            ${l.newValues ? '<div><span style="color:#059669;font-weight:600">New:</span> ' + esc(l.newValues) + '</div>' : ''}
                        </div>` : ''}
                    </div>`;
                }).join('');

                document.getElementById('logPageInfo').textContent = `Page ${logPage}`;
                document.getElementById('logPrev').disabled = logPage <= 1;
                document.getElementById('logNext').disabled = logs.length < 30;
            } catch (e) { el.innerHTML = '<div class="dm-empty">Network error</div>'; }
        }

        function getActionBadge(action) {
            if (!action) return { cls: '' };
            const a = action.toLowerCase();
            if (a.includes('create')) return { cls: 'la-create' };
            if (a.includes('deactivate') || a.includes('detach')) return { cls: 'la-danger' };
            if (a.includes('role') || a.includes('dept') || a.includes('move')) return { cls: 'la-warn' };
            if (a.includes('bulk') || a.includes('import')) return { cls: 'la-info' };
            return { cls: 'la-default' };
        }

        function logPrev() { if (logPage > 1) { logPage--; loadLogs(); } }
        function logNext() { logPage++; loadLogs(); }

</script>

