// ═══════════════════════════════════════════════════════════════
// FILTERS & SORT
// ═══════════════════════════════════════════════════════════════
const debouncedApplyFilters = debounce(applyFilters, 250);

function applyFilters() {
    const search = document.getElementById('searchInput').value.toLowerCase().trim();
    const h1     = document.getElementById('filterH1').value;
    const h2     = document.getElementById('filterH2').value;
    const h3     = document.getElementById('filterH3').value;
    const h4     = document.getElementById('filterH4').value;
    const state  = document.getElementById('filterState').value;
    const group  = document.getElementById('filterGroup').value;
    const desig  = document.getElementById('filterDesig').value;
    const status = document.getElementById('filterStatus').value;

    let active = 0;
    filtered = allRows.filter(r => {
        if (h1 && (r.h1Name || r.h1Code || '') !== h1) return false;
        if (h2 && (r.h2Name || r.h2Code || '') !== h2) return false;
        if (h3 && (r.h3Name || r.h3Code || '') !== h3) return false;
        if (h4 && (r.h4Name || r.h4Code || '') !== h4) return false;
        if (state && r.state !== state) return false;
        if (group && r.groupName !== group) return false;
        if (desig && r.designation !== desig) return false;
        if (status !== '') {
            const want = status === '1';
            if (r.isActive !== want) return false;
        }
        if (search) {
            const hay = [r.h1Name,r.h2Name,r.h3Name,r.h4Name,r.empCode,r.empName,r.state,r.groupName,r.designation,r.mobile].join(' ').toLowerCase();
            if (!hay.includes(search)) return false;
        }
        return true;
    });

    // Sort
    filtered.sort((a,b) => {
        const va = (a[sortKey] ?? '').toString().toLowerCase();
        const vb = (b[sortKey] ?? '').toString().toLowerCase();
        return va < vb ? -sortDir : va > vb ? sortDir : 0;
    });

    // Count active filters
    [h1,h2,h3,h4,state,group,desig,status,search].forEach(v => { if(v) active++; });
    const badge = document.getElementById('filterBadge');
    if (active > 0) { badge.textContent = active; badge.style.display = ''; }
    else badge.style.display = 'none';

    document.getElementById('statFiltered').textContent = filtered.length;
    currentPage = 1;
    renderPage();
}

function clearFilters() {
    document.getElementById('searchInput').value = '';
    ['filterH1','filterH2','filterH3','filterH4','filterState','filterGroup','filterDesig','filterStatus']
        .forEach(id => document.getElementById(id).value = '');
    applyFilters();
}

function sortBy(key) {
    if (sortKey === key) sortDir = -sortDir;
    else { sortKey = key; sortDir = 1; }
    document.querySelectorAll('.sales-table th[data-col]').forEach(th => {
        th.classList.toggle('sorted', th.dataset.col === key);
        if (th.dataset.col === key) {
            const icon = th.querySelector('.sort-icon');
            if (icon) icon.textContent = sortDir === 1 ? '↑' : '↓';
        } else {
            const icon = th.querySelector('.sort-icon');
            if (icon) icon.textContent = '↕';
        }
    });
    applyFilters();
}

// ═══════════════════════════════════════════════════════════════
// RENDER
// ═══════════════════════════════════════════════════════════════
function renderPage() {
    const fallback = document.getElementById('salesFallback');
    const main = document.getElementById('salesPageMain');
    if (main) main.style.display = '';
    if (fallback && filtered.length) fallback.style.display = 'none';

    const start = (currentPage - 1) * PAGE_SIZE;
    const page  = filtered.slice(start, start + PAGE_SIZE);
    const tbody = document.getElementById('tableBody');

    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="11" style="text-align:center;padding:40px;color:var(--muted)">No records found. Adjust filters or upload data.</td></tr>';
        renderPagination();
        return;
    }

    tbody.innerHTML = page.map((r, i) => {
        const rowNum = start + i + 1;
        return `<tr data-id="${r.salesHierarchyId}">
            <td style="color:var(--muted);font-size:11px">${rowNum}</td>
            ${colCell('h1Name',     r, levelCell(r.h1Name, r.h1Code, 'lvl-h1'))}
            ${colCell('h2Name',     r, levelCell(r.h2Name, r.h2Code, 'lvl-h2'))}
            ${colCell('h3Name',     r, levelCell(r.h3Name, r.h3Code, 'lvl-h3'))}
            ${colCell('h4Name',     r, levelCell(r.h4Name, r.h4Code, 'lvl-h4'))}
            ${colCell('empName',    r, personCell(r.empName, r.empCode))}
            ${colCell('state',      r, esc(r.state||'—'))}
            ${colCell('groupName',  r, esc(r.groupName||'—'))}
            ${colCell('designation',r, esc(r.designation||'—'))}
            ${colCell('isActive',   r, `<span class="badge ${r.isActive?'badge-active':'badge-inactive'}">${r.isActive?'Active':'Inactive'}</span>`)}
            <td style="text-align:center;white-space:nowrap">
                <button class="btn btn-ghost btn-icon btn-sm" onclick="openEditModal(${r.salesHierarchyId})" title="Edit">✏️</button>
                <button class="btn btn-ghost btn-icon btn-sm" onclick="openShiftModal(${r.salesHierarchyId})" title="Shift">↕️</button>
            </td>
        </tr>`;
    }).join('');

    renderPagination();
}

function colCell(key, r, html) {
    const col = COLUMNS.find(c => c.key === key);
    if (!col || !col.visible) return '';
    return `<td class="col-${key}" title="${esc((r[key]||'').toString())}">${html}</td>`;
}

function isDash(v) { return !v || v === '-' || v === '—' || v === '–' || v === '--'; }

function levelCell(name, code, badgeClass) {
    const n = isDash(name) ? '' : name;
    const c = isDash(code) ? '' : code;
    if (!n && !c) return `<div class="name-code"><span class="mini-code" style="color:var(--muted)"></span></div>`;
    return `
        <div class="name-code">
            <span class="level-badge ${badgeClass}">${esc(n || c)}</span>
            <span class="mini-code">${esc(c || '')}</span>
        </div>`;
}

function personCell(name, code) {
    const n = isDash(name) ? '' : name;
    const c = isDash(code) ? '' : code;
    return `
        <div class="name-code">
            <strong>${esc(n || '—')}</strong>
            <span class="mini-code">${esc(c || '')}</span>
        </div>`;
}

function renderPagination() {
    const total  = filtered.length;
    const pages  = Math.max(1, Math.ceil(total / PAGE_SIZE));
    const start  = Math.min((currentPage-1)*PAGE_SIZE+1, total);
    const end    = Math.min(currentPage*PAGE_SIZE, total);
    document.getElementById('pagInfo').textContent = `Showing ${start}–${end} of ${total} records`;

    let btns = '';
    btns += `<button class="pag-btn" onclick="gotoPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
    const range = paginationRange(currentPage, pages);
    range.forEach(p => {
        if (p === '…') btns += `<span style="padding:0 4px;color:var(--muted)">…</span>`;
        else btns += `<button class="pag-btn ${p===currentPage?'active':''}" onclick="gotoPage(${p})">${p}</button>`;
    });
    btns += `<button class="pag-btn" onclick="gotoPage(${currentPage+1})" ${currentPage>=pages?'disabled':''}>›</button>`;
    document.getElementById('pagButtons').innerHTML = btns;
}

function gotoPage(p) {
    const pages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
    if (p < 1 || p > pages) return;
    currentPage = p;
    renderPage();
    document.getElementById('gridWrap').scrollTop = 0;
}

function paginationRange(current, total) {
    if (total <= 7) return Array.from({length:total},(_,i)=>i+1);
    if (current <= 4) return [1,2,3,4,5,'…',total];
    if (current >= total-3) return [1,'…',total-4,total-3,total-2,total-1,total];
    return [1,'…',current-1,current,current+1,'…',total];
}

function showTableLoading() {
    document.getElementById('tableBody').innerHTML = '<tr class="loading-row"><td colspan="11"><span class="spinner"></span>Loading sales data…</td></tr>';
