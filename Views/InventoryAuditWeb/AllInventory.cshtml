        // Helper functions for loading states
        function setLoadingState(containerId, selectedId, message) {
            const container = document.getElementById(containerId);
            const selected = document.getElementById(selectedId);
            container.classList.add('loading');
            selected.innerHTML = `<div class="select-loading">${message}</div>`;
        }

        function setNormalState(containerId, selectedId, placeholder) {
            const container = document.getElementById(containerId);
            const selected = document.getElementById(selectedId);
            container.classList.remove('loading');
            const type = getTypeFromContainerId(containerId);

            if (Array.isArray(searchFilters[type])) {
                if (searchFilters[type].length === 0) {
                    selected.innerHTML = `<div class="select-placeholder">${placeholder}</div>`;
                }
            } else {
                if (!searchFilters[type]) {
                    selected.innerHTML = `<div class="select-placeholder">${placeholder}</div>`;
                }
            }
        }

        function enableDropdown(containerId, type) {
            const container = document.getElementById(containerId);
            container.classList.remove('disabled');

            if (type === 'multi') {
                container.setAttribute('onclick', `toggleMultiSelect('${getTypeFromContainerId(containerId)}-dropdown')`);
            } else {
                container.setAttribute('onclick', `toggleSingleSelect('${getTypeFromContainerId(containerId)}-dropdown')`);
            }
        }

        function disableDropdown(containerId, placeholder) {
            const container = document.getElementById(containerId);
            const selected = document.getElementById(containerId.replace('container', 'selected'));
            container.classList.add('disabled');
            container.removeAttribute('onclick');
            selected.innerHTML = `<div class="select-placeholder">${placeholder}</div>`;
        }

        function getTypeFromContainerId(containerId) {
            const mapping = {
                'unit-container': 'unit',
                'location-container': 'location',
                'warehouse-container': 'warehouse',
                'itemgroup-container': 'itemGroup',
                'subgroup-container': 'subGroup',
                'status-container': 'status'
            };
            return mapping[containerId];
        }

        // Dropdown population functions
        function populateSingleSelect(dropdownId, data, type) {
            const dropdown = document.getElementById(dropdownId);
            dropdown.innerHTML = '';

            const normalizeItem = (item, type) => {
                switch(type) {
                    case 'unit':
                        return {
                            id: item.u_Unit || item.code || item.id,
                            name: item.u_Unit || item.name,
                            code: item.u_Unit || item.code
                        };
                    case 'location':
                        return {
                            id: item.locationCode || item.code || item.id,
                            name: item.locationName || item.name,
                            code: item.locationCode || item.code
                        };
                    case 'status':
                        return {
                            id: item.status || item.code || item.id,
                            name: item.status || item.name,
                            code: item.status || item.code
                        };
                    default:
                        return {
                            id: item.id || item.code,
                            name: item.name,
                            code: item.code || item.id
                        };
                }
            };

            data.forEach(item => {
                const normalizedItem = normalizeItem(item, type);

                const div = document.createElement('div');
                div.className = 'select-option';
                div.textContent = normalizedItem.name;
                div.setAttribute('data-value', normalizedItem.id);
                div.setAttribute('data-name', normalizedItem.name);
                div.setAttribute('data-code', normalizedItem.code);
                div.onclick = (e) => {
                    e.stopPropagation();
                    selectSingleSelectItem(type, normalizedItem, div);
                };
                dropdown.appendChild(div);
            });

            console.log(`Populated ${data.length} items for ${type} dropdown`);
        }

        // Multi-select population with proper ID handling for warehouse, itemGroup, subGroup
        function populateMultiSelect(dropdownId, data, type, enableSelectAll = false) {
            const dropdown = document.getElementById(dropdownId);
            dropdown.innerHTML = '';

            // Add "Select All" option if enabled
            if (enableSelectAll && data.length > 1) {
                const selectAllDiv = document.createElement('div');
                selectAllDiv.className = 'select-option select-all';
                selectAllDiv.textContent = '✓ Select All';
                selectAllDiv.setAttribute('data-value', 'SELECT_ALL');
                selectAllDiv.setAttribute('data-name', 'Select All');
                selectAllDiv.setAttribute('data-code', 'SELECT_ALL');
                selectAllDiv.onclick = (e) => {
                    e.stopPropagation();
                    toggleSelectAll(type, selectAllDiv);
                };
                dropdown.appendChild(selectAllDiv);
            }

            const normalizeItem = (item, type) => {
                switch(type) {
                    case 'warehouse':
                        return {
                            id: item.warehouse || item.code || item.id,
                            name: item.warehouse || item.name,
                            code: item.warehouse || item.code
                        };
                    case 'itemGroup':
                        return {
                            id: item.itmsGrpNam || item.code || item.id,
                            name: item.itmsGrpNam || item.name,
                            code: item.itmsGrpNam || item.code
                        };
                    case 'subGroup':
                        return {
                            id: item.u_Sub_Group || item.code || item.id,
                            name: item.u_Sub_Group || item.name,
                            code: item.u_Sub_Group || item.code
                        };
                    default:
                        return {
                            id: item.id || item.code,
                            name: item.name,
                            code: item.code || item.id
                        };
                }
            };

            data.forEach(item => {
                const normalizedItem = normalizeItem(item, type);

                const div = document.createElement('div');
                div.className = 'select-option';
                div.textContent = normalizedItem.name;
                div.setAttribute('data-value', normalizedItem.id);
                div.setAttribute('data-name', normalizedItem.name);
                div.setAttribute('data-code', normalizedItem.code);
                div.onclick = (e) => {
                    e.stopPropagation();
                    toggleMultiSelectItem(type, normalizedItem, div);
                };
                dropdown.appendChild(div);
            });

            console.log(`Populated ${data.length} items for ${type} multi-select dropdown`);
