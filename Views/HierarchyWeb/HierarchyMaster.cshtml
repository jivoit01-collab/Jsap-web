    function validateHierarchySequence(role, prefix){
        const deptId=parseInt(document.getElementById(`${prefix}_dept`)?.value)||0;
        const subDeptId=parseInt(document.getElementById(`${prefix}_sdept`)?.value)||0;
        const hodId=role>=2 ? (parseInt(document.getElementById(`${prefix}_hod`)?.value)||0) : 0;
        const subHodId=role===3 ? (parseInt(document.getElementById(`${prefix}_sub`)?.value)||0) : 0;
        if(role>=2 && !hodId) return 'Select HOD first';
        if(!deptId) return 'Select Department after HOD';
        if(role===2 && !subDeptId) return 'Select Sub-Department before saving Sub-HOD';
        if(role===3 && subHodId && !subDeptId) return 'Select Sub-Department before choosing Sub-HOD';
        return '';
    }
    async function submitAdd(){
        const code=document.getElementById('f_code').value.trim(), name=document.getElementById('f_name').value.trim();
        const email = document.getElementById('f_email').value.trim();
        const phone = document.getElementById('f_phone').value.trim();
        showAddError('');
        if(!code||!name){showAddError('Code and Name are required');return;}
        const hierarchyError=validateHierarchySequence(addLvl,'f');
        if(hierarchyError){showAddError(hierarchyError);return;}
        if(email && !isValidEmail(email)){showAddError('Enter a valid email address');return;}
        if(phone && !isValidMobile(phone)){showAddError('Enter a valid 10-digit mobile number');return;}
        const btn=document.getElementById('addBtn');btn.disabled=true;btn.textContent='Creating…';
        const payload={employeeCode:code,employeeName:name,email:email||null,phone:phone?normalizePhone(phone):null,designation:document.getElementById('f_desig').value.trim()||null,
            dateOfJoining:document.getElementById('f_doj').value||null,
            roleTypeId:addLvl,primaryDepartmentId:document.getElementById('f_dept')?.value?parseInt(document.getElementById('f_dept').value):null,isActive:true};
        try{
            const r=await api(`${API}/CreateEmployee`,'POST',payload);
            if(!r.success || !r.data?.employeeId){showAddError(r.message||'Employee not created');return;}
            const nId=r.data?.employeeId;
            if(addLvl>=2&&nId){
                const hId=parseInt(document.getElementById('f_hod').value);
                const sId=document.getElementById('f_sub')?.value;
                const dId=parseInt(document.getElementById('f_dept').value);
                const sdId=document.getElementById('f_sdept')?.value?parseInt(document.getElementById('f_sdept').value):null;
                const relRes = await api(`${API}/AddRelationship`,'POST',{employeeId:nId,reportsToEmployeeId:sId?parseInt(sId):hId,departmentId:dId,subDepartmentId:sdId,isPrimary:true});
                if(!relRes.success){
                    showAddError(`Employee created but reporting link failed: ${relRes.message||'Unknown error'}`);
                    return;
                }
            }
            clearAddForm(false);
            showAddError(r.message||`${name} created successfully`,'ok');
            await loadGrid();
        }catch(e){showAddError('Error: '+e.message);}
        finally{btn.disabled=false;btn.textContent='Create Employee';}
    }

    async function api(url,method='GET',body=null){
        const o={method,headers:{'Content-Type':'application/json'}};
        if(body)o.body=JSON.stringify(body);
        return (await fetch(url,o)).json();
    }
    function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
    function escAttr(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
    function routeModalMessage(msg, type='err'){
        const text = String(msg || '');
        if(!text) return false;

        const editModal = document.getElementById('editModal');
        if(editModal?.classList.contains('open')){
            const errEl = document.getElementById('editErr');
            if(errEl){
                errEl.textContent = text;
                errEl.style.display = '';
                errEl.style.color = type==='ok' ? 'var(--g2)' : type==='info' ? 'var(--info)' : 'var(--danger)';
                return true;
            }
        }

        const addModal = document.getElementById('addModal');
        if(addModal?.classList.contains('open')){
            showAddError(text, type);
            return true;
        }

        const deptModal = document.getElementById('deptModal');
        if(deptModal?.classList.contains('open')){
            const deptTab2 = document.getElementById('deptTab2');
            if(deptTab2 && deptTab2.style.display !== 'none'){
                showSubDeptError(text, type);
            } else {
                showDeptError(text, type);
            }
            return true;
        }

        const bulkModal = document.getElementById('bulkModal');
        if(bulkModal?.classList.contains('open')){
            showBulkError(text, type);
            return true;
        }

        return false;
    }
    function toast(msg,type='ok',dur=3500){
        if(routeModalMessage(msg, type)) return;
        const w=document.getElementById('toastWrap'),t=document.createElement('div');
        t.className=`toast ${type}`;t.innerHTML=`<span>${type==='ok'?'✓':type==='err'?'✕':'ℹ'}</span> ${esc(String(msg))}`;
        w.appendChild(t);setTimeout(()=>t.remove(),dur);
    }
    // ── DEPARTMENT MOVE CONFIRMATION ─────────────────────────────
    let deptMoveResolve = null;
    function showDeptMoveModal(message) {
        document.getElementById('deptMoveMsg').innerHTML = message;
        document.getElementById('deptMoveModal').classList.add('open');
        return new Promise(resolve => {
            deptMoveResolve = (choice) => {
                document.getElementById('deptMoveModal').classList.remove('open');
                resolve(choice); // 'move' | 'detach' | 'abort'
            };
        });
    }

    // ── EDIT MODAL STATE ─────────────────────────────────────────
    let editEmpId = null;
    let editContextRow = null;

    async function openEdit(empId) {
        editEmpId = empId;
        editContextRow = null;
        showEditError('');
        updateEditFormLabels();
        document.getElementById('editSaveBtn').disabled = false;
        document.getElementById('editSaveBtn').textContent = 'Save Changes';
        document.getElementById('e_sdept_wrap').style.display = '';

        // Find the row where this empId appears — check all 3 positions
        const hodRow  = allRows.find(r => r.hodEmployeeId    === empId);
        const subRow  = allRows.find(r => r.subHodEmployeeId === empId);
        const execRow = allRows.find(r => r.execEmployeeId   === empId);

        if (!hodRow && !subRow && !execRow) {
            showToast('Employee not found in grid', 'err'); return;
        }

        // Determine role and row based on where the empId was found
        let empName, empCode, empDesig, roleTypeId, reportsToHodId, reportsToSubId, row;
        if (hodRow && hodRow.hodEmployeeId === empId && !subRow && !execRow) {
            // HOD — only appears as HOD
            row = hodRow;
            empName = row.hodName; empCode = row.hodCode;
            empDesig = row.hodDesignation || ''; roleTypeId = 1;
            reportsToHodId = null; reportsToSubId = null;
        } else if (subRow && subRow.subHodEmployeeId === empId) {
            row = subRow;
            empName = row.subHodName; empCode = row.subHodCode;
            empDesig = row.subHodDesignation || ''; roleTypeId = 2;
            reportsToHodId = row.hodEmployeeId; reportsToSubId = null;
        } else if (execRow && execRow.execEmployeeId === empId) {
            row = execRow;
            empName = row.execName; empCode = row.execCode;
            empDesig = row.execDesignation || ''; roleTypeId = 3;
            reportsToHodId = row.hodEmployeeId;
            reportsToSubId = row.subHodEmployeeId || null;
        } else {
            // Fallback: it's a HOD
            row = hodRow || subRow || execRow;
            empName = row.hodName; empCode = row.hodCode;
            empDesig = ''; roleTypeId = 1;
            reportsToHodId = null; reportsToSubId = null;
        }
        editContextRow = row;
        editCurrentDateOfJoining = roleTypeId === 1 ? row.hodDateOfJoining : roleTypeId === 2 ? row.subHodDateOfJoining : row.execDateOfJoining;

        let employeeDetail = null;
        try {
            const empRes = await api(`${API}/GetEmployee/${empId}`);
            if (empRes.success) employeeDetail = empRes.data || null;
        } catch (e) {}

        const detailDesig = employeeDetail?.designation ?? employeeDetail?.Designation ?? null;
        const detailPrimaryDeptId = employeeDetail?.primaryDepartmentId ?? employeeDetail?.PrimaryDepartmentId ?? null;

        if (detailDesig !== null && detailDesig !== undefined) empDesig = detailDesig || '';

        // Pre-fill fields
        document.getElementById('e_code').value  = empCode  || '';
        document.getElementById('e_name').value  = empName  || '';
        document.getElementById('e_desig').value = empDesig || '';
        document.getElementById('e_role').value  = String(roleTypeId);
        document.getElementById('e_active').checked = roleTypeId === 1 ? row.hodIsActive :
                                                       roleTypeId === 2 ? row.subHodIsActive : row.execIsActive;
        document.getElementById('e_activeLabel').textContent =
            document.getElementById('e_active').checked ? 'Active' : 'Inactive';
        document.getElementById('e_active').onchange = function(){
            document.getElementById('e_activeLabel').textContent = this.checked ? 'Active' : 'Inactive';
        };

        // Badge
        const roleNames = {1:'HOD', 2:'Sub-HOD', 3:'Executive'};
        document.getElementById('editEmpBadge').textContent = roleNames[roleTypeId] || '';

        // Load departments
        await ensureDepts();
        const deptSel = document.getElementById('e_dept');
        deptSel.innerHTML = '<option value="">— Select —</option>' +
            deptsMeta.map(d => `<option value="${d.departmentId}">${esc(d.departmentName)}</option>`).join('');

        // Set dept
        const deptId = roleTypeId === 1 ? (detailPrimaryDeptId || row.departmentId || '') : (row.departmentId || detailPrimaryDeptId || '');
        deptSel.value = String(deptId);
        await loadSubDepts(deptId, 'e_sdept');
        ensureSelectOption('e_sdept', row.subDepartmentId || '', row.subDepartmentName || 'Current Sub-Department');
        document.getElementById('e_sdept').value = roleTypeId === 1 ? '' : String(row.subDepartmentId || '');
        document.getElementById('e_sdept_wrap').style.display = roleTypeId >= 2 ? '' : 'none';

        // Load reporting dropdowns
        await onEditRoleChange(reportsToHodId, reportsToSubId, row.subDepartmentId || null);

        document.getElementById('editModal').classList.add('open');
    }

    async function onEditRoleChange(presetHodId, presetSubId, presetSubDeptId) {
        const role = parseInt(document.getElementById('e_role').value);
        const hodRow = document.getElementById('e_hod_row');
        const subRow = document.getElementById('e_sub_row');
        const subDeptWrap = document.getElementById('e_sdept_wrap');
        const hodSel = document.getElementById('e_hod');
        const subSel = document.getElementById('e_sub');
        hodRow.style.display = role >= 2 ? '' : 'none';
        subRow.style.display = role === 3 ? '' : 'none';
        subDeptWrap.style.display = role >= 2 ? '' : 'none';
        updateEditFormLabels();
        if (role < 2) {
            const deptSel = document.getElementById('e_dept');
            const currentDeptValue = deptSel?.value || '';
            if (hodSel) hodSel.value = '';
            if (subSel) subSel.innerHTML = '<option value="">— Direct to HOD —</option>';
            document.getElementById('e_sdept').value = '';
            renderDeptOptions('e_dept', deptsMeta);
            if (currentDeptValue) {
                ensureSelectOption('e_dept', currentDeptValue, editContextRow?.departmentName || 'Current Department');
                document.getElementById('e_dept').value = currentDeptValue;
            }
            return;
        }

        if (role >= 2) {
            await loadHodsMeta();
            renderHodOptions('e_hod', hodsMeta, editEmpId);
            if (presetHodId) {
                hodSel.value = String(presetHodId);
                await onEditHodChange(presetSubId, parseInt(document.getElementById('e_dept').value) || null, true, presetSubDeptId);
            } else {
                if (hodSel) hodSel.value = '';
                renderDeptOptions('e_dept', []);
                document.getElementById('e_sdept').innerHTML = '<option value="">— Select —</option>';
                if (subSel) subSel.innerHTML = '<option value="">— Direct to HOD —</option>';
            }
        }
    }

    async function onEditDeptChange(presetSubHod, keepCurrentSubDept = false, presetSubDeptId = null) {
        const role = parseInt(document.getElementById('e_role').value);
        const deptId = parseInt(document.getElementById('e_dept').value) || null;
        await loadSubDepts(deptId, 'e_sdept');
        if (keepCurrentSubDept && (presetSubDeptId || editContextRow?.subDepartmentId)) {
            const selectedSubDeptId = presetSubDeptId || editContextRow?.subDepartmentId;
            ensureSelectOption('e_sdept', selectedSubDeptId, editContextRow?.subDepartmentName || 'Current Sub-Department');
            document.getElementById('e_sdept').value = String(selectedSubDeptId);
        }
        if (!keepCurrentSubDept) document.getElementById('e_sdept').value = '';
        await populateEditSubHods(presetSubHod);
    }

    async function populateEditSubHods(presetSubHod) {
        const role = parseInt(document.getElementById('e_role').value);
        const hodId = parseInt(document.getElementById('e_hod').value) || null;
        const deptId = parseInt(document.getElementById('e_dept').value) || null;
        const subDeptId = parseInt(document.getElementById('e_sdept').value) || null;
        const subSel = document.getElementById('e_sub');
        subSel.innerHTML = '<option value="">— Direct to HOD —</option>';
        if (role !== 3 || !hodId || !deptId) return;
        getSubHodsForDepartment(hodId, deptId, subDeptId).forEach(s => {
            subSel.innerHTML += `<option value="${s.employeeId}">${esc(s.employeeName)} (${s.employeeCode})</option>`;
        });
        if (presetSubHod) document.getElementById('e_sub').value = String(presetSubHod);
    }

    async function onEditSubDeptChange() {
        await populateEditSubHods();
    }

    async function onEditHodChange(presetSubHod, presetDeptId, keepCurrentSubDept = false, presetSubDeptId = null) {
        const hodId = parseInt(document.getElementById('e_hod').value) || null;
        if (!hodId) {
            renderDeptOptions('e_dept', deptsMeta);
            document.getElementById('e_sub').innerHTML = '<option value="">— Direct to HOD —</option>';
            return;
        }
        try{
            const r = await api(`${API}/GetDepartmentsForHOD/${hodId}`);
            if(r.success){
                renderDeptOptions('e_dept', r.data||[]);
                if (presetDeptId && editContextRow?.departmentName) {
                    ensureSelectOption('e_dept', presetDeptId, editContextRow.departmentName);
                }
                if (presetDeptId) document.getElementById('e_dept').value = String(presetDeptId);
            }else{
                toast(r.message || 'Failed to load HOD departments','err');
            }
        }catch(e){
            toast('Error loading HOD departments','err');
        }
        await onEditDeptChange(presetSubHod, keepCurrentSubDept, presetSubDeptId);
    }

    function closeEdit() {
        document.getElementById('editModal').classList.remove('open');
        editEmpId = null;
        editContextRow = null;
        editCurrentDateOfJoining = null;
    }

    async function submitEdit() {
        const btn = document.getElementById('editSaveBtn');
        showEditError('');

        const code = document.getElementById('e_code').value.trim();
        const name = document.getElementById('e_name').value.trim();
        const role = parseInt(document.getElementById('e_role').value);

        if (!code || !name) { showEditError('Code and Name are required'); return; }
        const hierarchyError = validateHierarchySequence(role,'e');
        if (hierarchyError) { showEditError(hierarchyError); return; }
        // ReportsTo is optional — exec/subhod can report directly or have no manager

        const currentRow = editContextRow || allRows.find(r => r.hodEmployeeId===editEmpId || r.subHodEmployeeId===editEmpId || r.execEmployeeId===editEmpId);
        const deptRaw = document.getElementById('e_dept').value;
        const subDeptRaw = document.getElementById('e_sdept').value;
        const deptId = deptRaw !== ''
            ? (parseInt(deptRaw) || null)
            : (role >= 2 ? (currentRow?.departmentId || null) : null);
        const subDeptId = subDeptRaw !== ''
            ? (parseInt(subDeptRaw) || null)
            : (role >= 2 ? (currentRow?.subDepartmentId || null) : null);
        const hodRow2   = document.getElementById('e_hod_row');
        const hodRaw = document.getElementById('e_hod').value;
        const hodId = hodRow2.style.display !== 'none'
            ? (hodRaw !== '' ? (parseInt(hodRaw) || null) : (currentRow?.hodEmployeeId || null))
            : null;
        const subRow2   = document.getElementById('e_sub_row');
        const subRaw = document.getElementById('e_sub').value;
        const subHodId = subRow2.style.display !== 'none'
            ? (subRaw !== '' ? (parseInt(subRaw) || null) : (currentRow?.subHodEmployeeId || null))
            : null;
        const reportsTo = role === 3 ? (subHodId || hodId || null) : role === 2 ? (hodId || null) : null;
        let moveTeamWithDepartment = false;

        btn.disabled = true; btn.textContent = 'Saving…';
        try {
            const currentDeptId = currentRow?.departmentId || null;
            const currentSubDeptId = currentRow?.subDepartmentId || null;
            // Detect original role from grid context
            const originalRole = currentRow ? (currentRow.subHodEmployeeId === editEmpId ? 2 : currentRow.hodEmployeeId === editEmpId ? 1 : 3) : role;
            const roleChangedFromSubToHod = originalRole === 2 && role === 1;
            const changedDept = (currentDeptId !== deptId || currentSubDeptId !== subDeptId) && (role <= 2 || originalRole <= 2);
            if(changedDept || roleChangedFromSubToHod){
                const impactRes = await api(`${API}/GetDepartmentChangeImpact`, 'POST', {
                    employeeId: editEmpId,
                    roleTypeId: role,
                    departmentId: deptId,
                    subDepartmentId: subDeptId,
                    currentDepartmentId: currentDeptId,
                    currentSubDepartmentId: currentSubDeptId
                });
                const impact = impactRes?.data || impactRes?.Data;
                if(impactRes?.success && impact?.requiresMoveTeam){
                    const msg = impact.message || `This ${role===1?'HOD':'Sub-HOD'} has ${(impact.directReportCount||0)} linked employees. What would you like to do?`;
                    const choice = await showDeptMoveModal(msg);
                    if(choice === 'abort'){
                        btn.disabled = false; btn.textContent = 'Save Changes';
                        return;
                    }
                    moveTeamWithDepartment = (choice === 'move');
                }
            }
            const r = await fetch(`${API}/UpdateEmployeeFull`, {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({
                    employeeId:      editEmpId,
                    employeeCode:    code,
                    employeeName:    name,
                    designation:     document.getElementById('e_desig').value.trim() || null,
                    dateOfJoining:   editCurrentDateOfJoining,
                    roleTypeId:      role,
                    departmentId:    deptId,
                    subDepartmentId: subDeptId,
                    reportsToEmpId:  reportsTo,
                    isActive:        document.getElementById('e_active').checked,
                    moveTeamWithDepartment: moveTeamWithDepartment
                })
            });
            const d = await r.json();
            if (d.success) {
                showEditError(d.message || 'Employee updated successfully', 'ok');
                await loadGrid();
                btn.disabled = false; btn.textContent = 'Save Changes';
            } else {
                showEditError(d.message || 'Update failed');
                btn.disabled = false; btn.textContent = 'Save Changes';
            }
        } catch(ex) {
            showEditError('Network error: ' + ex.message);
            btn.disabled = false; btn.textContent = 'Save Changes';
        }
    }

    async function ensureDepts() {
        if (deptsMeta.length) return;
        const r = await fetch(`${API}/GetDepartments?includeSubDepartments=true`);
        const d = await r.json();
        if (d.success) {
            deptsMeta = d.data?.departments || d.data || [];
            // also populate add modal dept dropdown
            const addDept = document.getElementById('f_dept');
            if (addDept) {
                addDept.innerHTML = '<option value="">— Select —</option>' +
                    deptsMeta.map(d => `<option value="${d.departmentId}">${esc(d.departmentName)}</option>`).join('');
            }
        }
    }


    function showToast(msg, type='ok') {
        const wrap = document.getElementById('toastWrap');
        if (!wrap) { console.log(msg); return; }
        const t = document.createElement('div');
        t.className = `toast ${type}`;
        const icons = {ok:'✓', err:'✕', info:'ℹ'};
        t.innerHTML = `<span style="font-size:15px">${icons[type]||'ℹ'}</span><span>${msg}</span>`;
        wrap.appendChild(t);
        setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(()=>t.remove(), 400); }, 3000);
    }

