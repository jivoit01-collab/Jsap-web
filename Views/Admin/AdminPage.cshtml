@{
    ViewData["Title"] = "AdminPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-card {
        border-radius: 12px;
        padding: 20px 24px;
        text-align: center;
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .admin-card h6 {
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 8px;
        opacity: 0.85;
    }
    .admin-card h3 {
        font-size: 32px;
        font-weight: 700;
        margin: 0;
    }
    .card-total    { background: #f1f3f5; color: #002147; }
    .card-pending  { background: #fff3cd; color: #856404; }
    .card-approved { background: #d1e7dd; color: #0a5c36; }
    .card-paid     { background: #cfe2ff; color: #084298; }

    .admin-tabs { display: flex; gap: 8px; margin-bottom: 16px; }
    .admin-tab {
        padding: 8px 22px;
        border-radius: 8px;
        border: 1px solid #dee2e6;
        background: #fff;
        font-size: 13px;
        font-weight: 500;
        color: #555;
        cursor: pointer;
        transition: all 0.2s;
    }
    .admin-tab:hover  { background: #f8f9fa; }
    .admin-tab.active { background: #002147; color: #fff; border-color: #002147; }

    .admin-section        { display: none; }
    .admin-section.active { display: block; }

    .table-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        overflow: hidden;
        margin-bottom: 20px;
    }
    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid #f1f1f1;
        background: #fafafa;
    }
    .table-card-header h5 {
        margin: 0;
        font-size: 15px;
        font-weight: 600;
        color: #002147;
    }
    .table-search {
        padding: 6px 12px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        font-size: 13px;
        width: 210px;
        outline: none;
    }
    .table-search:focus { border-color: #002147; }

    .admin-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .admin-table thead tr { background: #002147; color: #fff; }
    .admin-table thead th {
        padding: 11px 14px;
        font-weight: 500;
        font-size: 12px;
        letter-spacing: .03em;
        white-space: nowrap;
    }
    .admin-table tbody tr { border-bottom: 1px solid #f1f3f5; }
    .admin-table tbody tr:last-child { border-bottom: none; }
    .admin-table tbody tr:hover { background: #f8f9ff; }
    .admin-table tbody td { padding: 10px 14px; color: #333; vertical-align: middle; }

    .badge-approved { background:#d1e7dd; color:#0a5c36; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; }
    .badge-pending  { background:#fff3cd; color:#856404; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; }
    .badge-rejected { background:#f8d7da; color:#842029; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; }
    .badge-paid     { background:#cfe2ff; color:#084298; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; }
    .badge-unpaid   { background:#fff3cd; color:#856404; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; }

    .btn-view {
        padding: 4px 12px;
        font-size: 12px;
        border: 1px solid #84b8eb;
        border-radius: 6px;
        background: transparent;
        color: #084298;
        cursor: pointer;
        text-decoration: none;
    }
    .btn-view:hover { background: #cfe2ff; }

    .btn-delete {
        padding: 4px 12px;
        font-size: 12px;
        border: 1px solid #ff8080;
        border-radius: 6px;
        background: #fff;
        color: #b42318;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-delete:hover {
        background: #fff1f1;
        border-color: #dc3545;
        color: #842029;
    }

    .btn-delete:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        background: #fff;
        color: #c98b8b;
    }

    .filter-card {
        background: #fff;
        border-radius: 12px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        margin-bottom: 20px;
    }
    .filter-card label { font-size: 12px; font-weight: 500; color: #555; margin-bottom: 4px; }

    .admin-title {
        font-size: 22px;
        font-weight: 700;
        color: #002147;
        margin-bottom: 20px;
    }
    .admin-title span {
        font-size: 13px;
        font-weight: 400;
        color: #888;
        margin-left: 10px;
    }

</style>

<div class="bill-ui">
<div class="container-fluid mt-4">

    <div class="admin-title">
        Admin Dashboard — Bill Verification
        <span>Full control over Maker · Checker · Invoice Payment</span>
    </div>
 
    <div id="pdfContainer" style="display:none; background:#fff; padding:10px; border-radius:8px;">

    <button onclick="closePdf()" 
            style="margin-bottom:10px; padding:6px 12px; border:none; background:#002147; color:#fff; border-radius:6px;">
        Back
    </button>

    <iframe id="pdfFrame" 
            style="width:100%; height:80vh; border:none; border-radius:8px;">
    </iframe>

</div>
    <!-- SUMMARY CARDS -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="admin-card card-total">
                <h6>Total Bills</h6>
                <h3 id="totalBills">—</h3>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="admin-card card-pending">
                <h6>Pending (Maker)</h6>
                <h3 id="pendingMaker">—</h3>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="admin-card card-approved">
                <h6>Approved (Checker)</h6>
                <h3 id="approvedChecker">—</h3>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="admin-card card-paid">
                <h6>Paid (Invoice)</h6>
                <h3 id="totalPaid">—</h3>
            </div>
        </div>
    </div>

    <!-- FILTER -->
    <div class="filter-card">
        <div class="row">
            <div class="col-md-3">
                <label>From Date</label>
                <input type="date" id="fromDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label>To Date</label>
                <input type="date" id="toDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label>Account Name</label>
                <input type="text" id="accountName" class="form-control form-control-sm"
                       placeholder="Search account..." />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="searchBtn" class="btn btn-sm w-100"
                        style="background:#002147;color:#fff;border-radius:8px;">
                    Search
                </button>
            </div>
        </div>
    </div>

    <!-- TABS -->
    <div class="admin-tabs">
        <button class="admin-tab active" onclick="switchTab('maker', this)">Maker Activity</button>
        <button class="admin-tab" onclick="switchTab('checker', this)">Checker Activity</button>
        <button class="admin-tab" onclick="switchTab('invoice', this)">Invoice Payment</button>
        <button class="admin-tab" onclick="switchTab('payment', this)">Payment Checker</button> 
    </div>

    <!-- MAKER TABLE -->
    <div class="admin-section active" id="section-maker">
        <div class="table-card">
            <div class="table-card-header">
                <h5>Maker Activity</h5>
                <input class="table-search" placeholder="Filter..."
                       oninput="filterTable('makerTable', this.value)" />
            </div>
            <div class="table-responsive">
                <table class="admin-table" id="makerTable">
                    <thead>
                        <tr>
                            <th>Account</th>
                            <th>Voucher</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Maker Remark</th>
                            <th>Status</th>
                            <th>Attachment</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody id="makerBody">
                        <tr><td colspan="8" class="text-center py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- CHECKER TABLE -->
    <div class="admin-section" id="section-checker">
        <div class="table-card">
            <div class="table-card-header">
                <h5>Checker Activity</h5>
                <input class="table-search" placeholder="Filter..."
                       oninput="filterTable('checkerTable', this.value)" />
            </div>
            <div class="table-responsive">
                <table class="admin-table" id="checkerTable">
                    <thead>
                        <tr>
                            <th>Account</th>
                            <th>Voucher</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Checker Remark</th>
                            <th>Checker Status</th>
                            <th>Attachment</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody id="checkerBody">
                        <tr><td colspan="8" class="text-center py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- INVOICE TABLE -->
    <div class="admin-section" id="section-invoice">
        <div class="table-card">
            <div class="table-card-header">
                <h5>Invoice Payment Activity</h5>
                <input class="table-search" placeholder="Filter..."
                       oninput="filterTable('invoiceTable', this.value)" />
            </div>
            <div class="table-responsive">
                <table class="admin-table" id="invoiceTable">
                    <thead>
                        <tr>
                            <th>Account</th>
                            <th>Voucher</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Due Date</th>
                            <th>Payment Status</th>
                            <th>Payment Date</th>
                            <th>Attachment</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceBody">
                        <tr><td colspan="9" class="text-center py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
       <!-- payment checker  TABLE -->
<div class="admin-section" id="section-payment">
    <div class="table-card">
        <div class="table-card-header">
            <h5>Payment Checker Activity</h5>
            <input class="table-search" placeholder="Filter..."
                   oninput="filterTable('paymentTable', this.value)" />
        </div>

        <div class="table-responsive">
            <table class="admin-table" id="paymentTable">
                <thead>
                    <tr>
                        <th>Account</th>
                        <th>Voucher</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Remark</th>
                        <th>Attachment</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody id="paymentBody">
                    <tr><td colspan="8" class="text-center">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>
</div>

