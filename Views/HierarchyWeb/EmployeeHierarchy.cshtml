    <div class="eh-modal-box" style="max-width:440px">
        <div class="eh-modal-title">
            <span id="ehAdminKeyTitle">Admin Key</span>
            <button type="button" class="eh-btn danger small" onclick="closeEhAdminKeyModal()">Close</button>
        </div>
        <p style="font-size:12px;color:#64748b;margin-bottom:16px">
            Minimum 6 characters with at least one uppercase letter and one special character. If a key already exists, enter the current key first.
        </p>
        <div id="ehAk_old_wrap" style="display:none;margin-bottom:12px">
            <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Current Key *</label>
            <input type="password" class="eh-input" id="ehAk_old" placeholder="Enter current admin key" />
        </div>
        <div style="margin-bottom:12px">
            <label id="ehAk_new_label" style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Admin Key *</label>
            <input type="password" class="eh-input" id="ehAk_new" placeholder="Example: Admin@1" />
        </div>
        <div style="margin-bottom:12px">
            <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Confirm Admin Key *</label>
            <input type="password" class="eh-input" id="ehAk_confirm" placeholder="Re-enter admin key" onkeydown="if(event.key==='Enter')submitEhAdminKey()" />
        </div>
        <div id="ehAdminKeyErr" style="display:none;color:#991b1b;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 12px;font-size:13px;font-weight:700;margin-bottom:10px"></div>
        <div class="eh-modal-actions">
            <button type="button" class="eh-btn secondary" onclick="closeEhAdminKeyModal()">Cancel</button>
            <button type="button" class="eh-btn" id="ehAdminKeySubmitBtn" onclick="submitEhAdminKey()">Save Key</button>
        </div>
    </div>
</div>

<!-- ══ SALARY PERMISSION MODAL ══ -->
<div class="eh-modal" id="salPermModal">
    <div class="eh-modal-box" style="max-width:560px">
        <div class="eh-modal-title">
            <span>Salary View Permission</span>
            <button type="button" class="eh-btn danger small" onclick="closeSalaryPermModal()">Close</button>
        </div>
        <p style="font-size:12px;color:#64748b;margin-bottom:14px">
            Check employees who should be allowed to view salary data. Uncheck to revoke access.
        </p>
        <div class="eh-search" style="margin-top:0;margin-bottom:12px">
            <input type="text" id="salPermSearch" placeholder="Search name, code, role, designation, department..." autocomplete="off" oninput="filterSalaryPermissionList()" />
        </div>
        <div id="salPermList" style="max-height:380px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:10px"></div>
        <div id="salPermErr" style="display:none;color:#991b1b;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 12px;font-size:13px;font-weight:700;margin-top:10px"></div>
        <div class="eh-modal-actions">
            <button type="button" class="eh-btn secondary" onclick="closeSalaryPermModal()">Cancel</button>
            <button type="button" class="eh-btn" id="salPermSubmitBtn" onclick="submitSalaryPerm()">Save Permissions</button>
        </div>
    </div>
</div>

<!-- ══ UNLOCK SALARY MODAL ══ -->
<div class="eh-modal" id="ehTankhaModal">
    <div class="eh-modal-box" style="max-width:420px">
        <div class="eh-modal-title">
            <span>Unlock Salary</span>
            <button type="button" class="eh-btn danger small" onclick="closeUnlockSalaryModal()">Close</button>
        </div>
        <p style="font-size:12px;color:#64748b;margin-bottom:16px">
            Enter your Tankha Payee portal credentials and select the employee category to load salary data.
        </p>
        <div style="margin-bottom:12px">
            <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Username *</label>
            <input type="text" class="eh-input" id="ehTankhaUsername" placeholder="Enter username" autocomplete="off" onkeydown="if(event.key==='Enter')document.getElementById('ehTankhaPassword').focus()" />
        </div>
        <div style="margin-bottom:12px">
            <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Password *</label>
            <input type="password" class="eh-input" id="ehTankhaPassword" placeholder="Enter password" autocomplete="new-password" onkeydown="if(event.key==='Enter')document.getElementById('ehTankhaAction').focus()" />
        </div>
        <div style="margin-bottom:12px">
            <label style="display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.35px;color:#475569;margin-bottom:6px">Action *</label>
            <select class="eh-input" id="ehTankhaAction" onkeydown="if(event.key==='Enter')submitTankhaFetch()">
                <option value="belowfourtyemployee">Below 40 Employees</option>
                <option value="equalandabovefourty">Equal and Above 40 Employees</option>
            </select>
