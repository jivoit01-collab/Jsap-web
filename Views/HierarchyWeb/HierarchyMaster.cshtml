@{
    ViewData["Title"] = "Hierarchy Master";
    bool isAdmin = ViewBag.IsAdmin is bool ia && ia;
    string empCode = ViewBag.EmpCode?.ToString() ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>
    :root {
        --page-font-size: 13px;
        --page-font-family: 'Sora',sans-serif;
        --page-font-weight: 400;
        --page-line-height: 1.5;
        --g1: #0b2c4d;
        --g2: #1a4a7a;
        --g3: #2563eb;
        --bg: #ffffff;
        --bg2: #f8fafc;
        --bg3: #f1f5f9;
        --border: #e2e8f0;
        --text: #0f172a;
        --muted: #64748b;
        --danger: #dc2626;
        --warn: #d97706;
        --info: #2563eb;
        --row-h: 44px
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--page-font-family);
        font-size: var(--page-font-size);
        font-weight: var(--page-font-weight);
        line-height: var(--page-line-height)
    }

    .topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        padding: 0;
        display: flex;
        flex-direction: column;
        box-shadow: 0 2px 8px rgba(0,0,0,.06)
    }

    .topbar-main {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 20px;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
    }

    .topbar-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--g1);
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 8px;
        letter-spacing: .3px
    }

    .topbar-title-icon {
        width: 30px; height: 30px;
        background: linear-gradient(135deg, var(--g1), var(--g2));
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 15px;
        color: #fff;
    }

    .topbar-actions {
        display: flex;
        gap: 6px;
        margin-left: auto;
        flex-wrap: wrap;
        align-items: center
    }

    .btn-sep {
        width: 1px;
        height: 22px;
        background: var(--border);
        margin: 0 2px;
        flex-shrink: 0;
    }

    .stat-bar {
        display: flex;
        gap: 0;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
        overflow-x: auto;
        scrollbar-width: none;
    }

    .stat-bar::-webkit-scrollbar { display: none }

    .stat-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 18px;
        border-right: 1px solid var(--border);
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .stat-pill-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .stat-pill b {
        color: var(--text);
        font-size: 14px;
        font-weight: 700;
    }

    .btn {
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-family: 'Sora',sans-serif;
        font-size: 12px;
        font-weight: 600;
        padding: 7px 14px;
        transition: all .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap
    }

    /* ── Global button defaults (used in modals) ── */
    .btn-primary {
        background: var(--g1);
        color: #fff;
        border: none;
    }

        .btn-primary:hover {
            background: var(--g2);
            transform: translateY(-1px)
        }

    .btn-add-employee {
        background: #0ea5e9;
        color: #fff;
        border: none;
    }

        .btn-add-employee:hover {
            background: #0284c7;
        }

    .btn-ghost {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--border)
    }

        .btn-ghost:hover {
            color: var(--text);
            border-color: var(--g1)
        }

    .btn-excel {
        background: rgba(21,128,61,.2);
        color: #4ade80;
        border: 1px solid rgba(74,222,128,.3)
    }

        .btn-excel:hover {
            background: rgba(21,128,61,.35);
        }

    /* ── Topbar-only overrides (light background) ── */
    .topbar-main .btn-primary {
        background: var(--g1);
        color: #fff;
    }

        .topbar-main .btn-primary:hover {
            background: var(--g2);
            transform: translateY(-1px);
        }

    .topbar-main .btn-add-employee {
        background: #16a34a;
        color: #fff;
    }

        .topbar-main .btn-add-employee:hover {
            background: #15803d;
        }

    .topbar-main .btn-ghost {
        background: var(--bg3);
        color: var(--muted);
        border: 1px solid var(--border)
    }

        .topbar-main .btn-ghost:hover {
            background: var(--bg2);
            color: var(--text);
            border-color: var(--g2)
        }

    .topbar-main .btn-excel {
        background: rgba(21,128,61,.12);
        color: #15803d;
        border: 1px solid rgba(21,128,61,.25)
    }

        .topbar-main .btn-excel:hover {
            background: rgba(21,128,61,.2);
            color: #14532d;
        }

    .filterbar {
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
        padding: 8px 20px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap
    }

    .search-box {
        background: var(--bg3);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 6px 12px;
        color: var(--text);
        font-family: 'Sora',sans-serif;
        font-size: 12px;
        outline: none;
        transition: border .2s;
        width: 220px
    }

        .search-box:focus {
            border-color: var(--g1)
        }

    .filter-sel {
        background: var(--bg3);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 5px 10px;
        color: var(--text);
        font-family: 'Sora',sans-serif;
        font-size: 12px;
        outline: none;
        cursor: pointer
    }

        .filter-sel:focus {
            border-color: var(--g1)
        }

    .row-count {
        font-size: 11px;
        color: var(--muted);
        margin-left: auto
    }

    .grid-wrap {
        overflow: auto;
        max-height: calc(100vh - 148px)
    }

    table.hm {
        border-collapse: collapse;
        width: max-content;
        min-width: 100%
    }

        table.hm thead tr.grp th {
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            padding: 6px 10px;
            text-align: center;
            color: var(--muted)
        }

            table.hm thead tr.grp th.g-hod {
                background: rgba(11,44,77,.07);
                color: var(--g1)
            }

            table.hm thead tr.grp th.g-dept {
                background: rgba(37,99,235,.05);
                color: #2563eb
            }

            table.hm thead tr.grp th.g-sub {
                background: rgba(11,44,77,.04);
                color: var(--g2)
            }

            table.hm thead tr.grp th.g-exec {
                background: rgba(255,255,255,.04);
                color: var(--muted)
            }

            table.hm thead tr.grp th.g-act {
                background: var(--bg)
            }

        table.hm thead tr.cols th {
            position: sticky;
            top: 0;
            z-index: 30;
            background: var(--bg3);
            border-bottom: 2px solid var(--border);
            padding: 7px 12px;
            font-size: 11px;
            font-weight: 700;
            color: var(--text);
            text-align: left;
            white-space: nowrap
        }

            table.hm thead tr.cols th.sk1 {
                position: sticky;
                left: 0;
                z-index: 35;
                background: var(--bg3);
                box-shadow: 2px 0 8px rgba(0,0,0,.5)
            }

        table.hm tbody tr {
            border-bottom: 1px solid rgba(42,52,65,.6);
            transition: background .1s;
            height: var(--row-h)
        }

            table.hm tbody tr:hover {
                background: #f1f5f9
            }

            table.hm tbody tr.hod-border {
                border-top: 2px solid rgba(14,125,75,.35)
            }

        table.hm tbody td {
            padding: 6px 12px;
            vertical-align: middle;
            border-right: 1px solid rgba(42,52,65,.4);
            white-space: nowrap;
            max-width: 200px
        }

            table.hm tbody td.sk1 {
                position: sticky;
                left: 0;
                z-index: 10;
                background: var(--bg);
                box-shadow: 2px 0 8px rgba(148,163,184,.18)
            }

        table.hm tbody tr:hover td {
            background: #f1f5f9
        }

            table.hm tbody tr:hover td.sk1 {
                background: #f1f5f9
            }

    .emp-cell {
        display: flex;
        flex-direction: column;
        gap: 2px
    }

    .emp-name {
        font-weight: 700;
        color: var(--g1);
        font-size: 12px
    }

    .emp-code {
        font-family: 'JetBrains Mono',monospace;
        font-size: 10px;
        color: var(--muted);
        background: rgba(11,44,77,.05);
        border-radius: 3px;
        padding: 1px 5px;
        display: inline-block;
        width: fit-content
    }

        .emp-code.temp-code {
            color: #dc2626;
            background: rgba(220,38,38,.08);
            border: 1px solid rgba(220,38,38,.2);
            font-weight: 700
        }

    .cell-empty {
        color: rgba(125,133,144,.3);
        font-style: italic;
        font-size: 11px
    }

    .dept-badge {
        font-size: 11px;
        font-weight: 600;
        color: #1d4ed8;
        background: rgba(37,99,235,.07);
        border-radius: 4px;
        padding: 2px 7px;
        display: inline-block;
        white-space: normal;
        word-break: break-word;
        line-height: 1.4
    }

    .subdept-text {
        font-size: 11px;
        color: var(--muted)
    }

    .desig-text {
        font-size: 11px;
        color: var(--muted);
        font-style: italic
    }

    .status-dot {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600
    }

        .status-dot::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block
        }

        .status-dot.active {
            color: #16a34a
        }

            .status-dot.active::before {
                background: #16a34a;
                box-shadow: 0 0 4px rgba(22,163,74,.4)
            }

        .status-dot.inactive {
            color: var(--danger)
        }

            .status-dot.inactive::before {
                background: var(--danger)
            }

    /* inline editing removed — use edit buttons instead */
    .btn-deact {
        border-color: rgba(220,38,38,.3);
        color: var(--danger)
    }

        .btn-deact:hover {
            background: rgba(220,38,38,.08)
        }

    .btn-pwd {
        border-color: rgba(11,44,77,.3);
        color: var(--g2)
    }

        .btn-pwd:hover {
            background: rgba(11,44,77,.08)
        }

    .act-cell {
        display: flex;
        gap: 3px;
        align-items: center;
        justify-content: flex-start;
        flex-wrap: nowrap
    }

    .btn-icon {
        width: 24px;
        height: 24px;
        border-radius: 5px;
        border: 1px solid;
        background: transparent;
        cursor: pointer;
        font-size: 11px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all .15s;
        flex-shrink: 0;
        padding: 0;
        font-family: 'Sora',sans-serif
    }

    .btn-edit-hod {
        border-color: rgba(11,44,77,.3);
        color: #0b2c4d
    }

        .btn-edit-hod:hover {
            background: rgba(11,44,77,.1)
        }

    .btn-edit-sub {
        border-color: rgba(37,99,235,.3);
        color: #2563eb
    }

        .btn-edit-sub:hover {
            background: rgba(37,99,235,.08)
        }

    .btn-edit-exec {
        border-color: rgba(100,116,139,.3);
        color: #64748b
    }

        .btn-edit-exec:hover {
            background: rgba(100,116,139,.08)
        }

    .btn-edit-hod, .btn-edit-sub, .btn-edit-exec {
        class: btn-icon
    }

    .grid-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 280px;
        gap: 12px;
        background: #fff
    }

    .ring {
        width: 36px;
        height: 36px;
        border: 3px solid var(--border);
        border-top-color: var(--g1);
        border-radius: 50%;
        animation: spinr .8s linear infinite
    }

    @@keyframes spinr {
        to {
            transform: rotate(360deg)
        }
    }

    .toast-wrap {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 6px
    }

    .toast {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 9px;
        padding: 10px 15px;
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 200px;
        max-width: 340px;
        animation: tin .25s ease;
        box-shadow: 0 8px 24px rgba(0,0,0,.4)
    }

        .toast.ok {
            border-left: 3px solid var(--g2)
        }

        .toast.err {
            border-left: 3px solid var(--danger)
        }

        .toast.info {
            border-left: 3px solid var(--info)
        }

    @@keyframes tin {
        from {
            opacity: 0;
            transform: translateX(20px)
        }

        to {
            opacity: 1;
            transform: none
        }
    }

    .hm-modal-overlay {
        position: fixed;
        inset: 0;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(11,44,77,.4);
        z-index: 99999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(3px)
    }

        .hm-modal-overlay.open {
            display: flex;
            animation: hmOverlayIn .2s ease forwards
        }

    @@keyframes hmOverlayIn { from { background: rgba(11,44,77,0); } to { background: rgba(11,44,77,.4); } }
    @@keyframes hmModalIn { from { opacity: 0; transform: scale(.96) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }

    .hm-modal-box {
        background: #fff !important;
        border: 1px solid var(--border) !important;
        border-radius: 18px !important;
        padding: 26px !important;
        width: 540px;
        max-width: min(96vw, 720px);
        max-height: calc(100vh - 40px);
        overflow-y: auto;
        box-shadow: 0 8px 40px rgba(11,44,77,.22) !important;
        position: relative;
        z-index: 100000 !important;
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        margin: 0 auto;
        animation: hmModalIn .22s cubic-bezier(.22,.61,.36,1)
    }

    .hm-modal-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--g1);
        margin-bottom: 18px
    }

    .fg {
        margin-bottom: 12px
    }

    .fl {
        font-size: 10px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 5px;
        display: block
    }

    .fi, .fs {
        width: 100%;
        background: var(--bg2);
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: 8px 11px;
        color: var(--text);
        font-family: 'Sora',sans-serif;
        font-size: 12px;
        outline: none;
        transition: border .2s
    }

        .fi:focus, .fs:focus {
            border-color: var(--g1)
        }

    .f2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px
    }

    .hm-modal-foot {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid var(--border)
    }

    .level-tabs {
        display: flex;
        border: 1px solid var(--border);
        border-radius: 7px;
        overflow: hidden;
        margin-bottom: 16px
    }

    .ltab {
        flex: 1;
        padding: 8px;
        text-align: center;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        transition: all .15s;
        background: transparent;
        color: var(--muted);
        border: none;
        font-family: 'Sora',sans-serif
    }

        .ltab:hover {
            color: var(--text);
            background: var(--bg3)
        }

        .ltab.on {
            background: var(--g1);
            color: #fff;
            font-weight: 700
        }

    .upload-panel {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 20px;
        margin: 0 0 0 0;
        border-top: none
    }

    .upload-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--g2);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 7px
    }

    .drop-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 24px;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        background: rgba(255,255,255,.015)
    }

        .drop-zone:hover, .drop-zone.drag-over {
            border-color: var(--g1);
            background: rgba(5,201,110,.05)
        }

        .drop-zone input[type=file] {
            display: none
        }

    .drop-icon {
        font-size: 26px;
        margin-bottom: 6px
    }

    .drop-label {
        color: var(--muted);
        font-size: 12px
    }

        .drop-label b {
            color: var(--g2);
            cursor: pointer
        }

    .import-preview {
        margin-top: 12px;
        background: var(--bg3);
        border-radius: 8px;
        padding: 12px 14px;
        border: 1px solid var(--border);
        display: none
    }

    .preview-sample {
        font-family: 'JetBrains Mono',monospace;
        font-size: 10px;
        color: var(--muted);
        max-height: 72px;
        overflow-y: auto;
        line-height: 1.7;
        margin-top: 6px
    }

    .import-result {
        margin-top: 10px;
        display: none;
        background: var(--bg3);
        border-radius: 8px;
        padding: 12px 14px;
        border: 1px solid var(--border)
    }

    .import-stat {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 6px
    }

        .import-stat span {
            font-size: 11px
        }

            .import-stat span b {
                font-size: 14px;
                display: block
            }

    .ic {
        color: var(--g2)
    }

    .iu {
        color: var(--info)
    }

    .ir {
        color: var(--g3)
    }

    .ie {
        color: var(--danger)
    }

    .err-list {
        font-size: 10px;
        color: var(--danger);
        max-height: 56px;
        overflow-y: auto;
        font-family: 'JetBrains Mono',monospace
    }
</style>

<!-- TOP BAR -->
<div class="topbar">
    <div class="topbar-main">
        <div class="topbar-title">
            <div class="topbar-title-icon">⊞</div>
            Hierarchy Master
        </div>
        <div class="topbar-actions">
            @if (isAdmin)
            {
                <button class="btn btn-excel" onclick="toggleUpload()" id="uploadBtn" title="Import from Excel">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12" /></svg>
                    Import Excel
                </button>
                <button class="btn btn-add-employee" onclick="openAdd()" title="Add new employee">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Add Employee
                </button>
                <div class="btn-sep"></div>
                <button class="btn btn-ghost" onclick="openBulkAssign()" title="Bulk assign team members">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="8.5" cy="7" r="4" /><path d="M20 8v6M23 11h-6" /></svg>
                    Bulk Assign
                </button>
                <button class="btn btn-ghost" onclick="openDeptManager()" title="Manage departments">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    Departments
                </button>
                <button class="btn btn-ghost" onclick="openColumnManager()" title="Manage visible columns">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                    Columns
                </button>
                <button class="btn btn-ghost" onclick="openLogs()" title="View audit logs">
