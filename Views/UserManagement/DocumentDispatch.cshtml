            // if (invalidRows.length > 0) {
            //     hideLoader();
            //     alert("One or more selected rows are missing attachments.");
            //     return;
            // }

            console.log("📦 Final attachmentData for rejected entries:", attachmentData);

            // Save all attachments if any were uploaded
            if (attachmentData.length > 0) {
                try {
                    const jsonBody = JSON.stringify(attachmentData);
                    const saveAllResp = await fetch("/api/DocumentDispatch/SaveAllAttachments", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: jsonBody
                    });

                    const responseText = await saveAllResp.text();

                    if (!saveAllResp.ok) {
                        console.error("❌ SaveAllAttachments failed:", saveAllResp.status, responseText);
                        hideLoader();
                        alert("Save failed: " + responseText);
                        return;
                    }
                } catch (err) {
                    console.error("🚨 JSON.stringify or fetch failed:", err);
                    hideLoader();
                    alert("Unexpected error: " + err.message);
                    return;
                }

                // Update bundle ID
                await fetch(`/api/DocumentDispatch/GetLastBundleId?lastBundleId=${lastId + 1}&mode=update`);
            }

            // ✅ SKIP THIS LOOP as requested
            // for (let row of collectedRejectData) {
            //     await fetch("/api/DocumentDispatch/SaveDocumentAttachmentsInHana", {
            //         method: "POST",
            //         headers: { "Content-Type": "application/json" },
            //         body: JSON.stringify({
            //             p_docId: row.DocNum,
            //             p_docType: row.docType,
            //             p_branch: row.branch
            //         })
            //     });
            // }
            // ===== END: Modified confirmSave logic =====

            // Now update the rejected status
            const updateResponse = await fetch(`/api/DocumentDispatch/UpdateNotRecievedStatus`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(selectedIds) // Send as array in body
            });

            if (!updateResponse.ok) {
                const errorText = await updateResponse.text();
                throw new Error(`Failed to update status: ${updateResponse.status} - ${errorText}`);
            }

            const result = await updateResponse.json();
            console.log("Update result:", result);

            hideLoader();
            alert(`✅ Successfully updated rejected entries! ${attachmentData.length > 0 ? `Bundle ID: ${bundleId}` : ''}`);

            // Switch back to All view and reload data (like confirmSave does)
            switchMode('all');

            // Reload the dispatch data to show the updated entries
            loadAllDispatchData();

