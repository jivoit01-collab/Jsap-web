                'tareWeight': { name: 'Tare Weight', section: 'Logistics', type: 'number', min: 0 }
            },

            validateField(fieldId) {
                const fieldConfig = this.mandatoryFields[fieldId];
                if (!fieldConfig) return true;

                const element = document.getElementById(fieldId);
                if (!element) return true;

                const value = element.value.trim();
                let isValid = true;
                let errorMessage = '';

                this.clearFieldError(fieldId);

                if (!value) {
                    errorMessage = `${fieldConfig.name} is required`;
                    isValid = false;
                } else {
                    switch (fieldConfig.type) {
                        case 'date':
                            const selectedDate = new Date(value);
                            const today = new Date();
                            const maxDate = new Date();
                            maxDate.setDate(today.getDate() + 7);

                            if (selectedDate > maxDate) {
                                errorMessage = `${fieldConfig.name} cannot be more than 7 days in the future`;
                                isValid = false;
                            }
                            break;

                        case 'number':
                            const numValue = parseFloat(value);
                            if (isNaN(numValue)) {
                                errorMessage = `${fieldConfig.name} must be a valid number`;
                                isValid = false;
                            } else if (fieldConfig.min !== undefined && numValue < fieldConfig.min) {
                                errorMessage = `${fieldConfig.name} cannot be less than ${fieldConfig.min}`;
                                isValid = false;
                            }
                            break;

                        default:
                            if (fieldConfig.pattern && !fieldConfig.pattern.test(value)) {
                                if (fieldId === 'driverMobile') {
                                    errorMessage = `${fieldConfig.name} must be a 10-digit number`;
                                } else if (fieldId === 'vehicleNoLogistics') {
                                    errorMessage = `${fieldConfig.name} invalid format (e.g., MH-12-AB-1234)`;
                                } else {
                                    errorMessage = `${fieldConfig.name} format is invalid`;
                                }
                                isValid = false;
                            } else if (fieldConfig.minLength && value.length < fieldConfig.minLength) {
                                errorMessage = `${fieldConfig.name} must be at least ${fieldConfig.minLength} characters`;
                                isValid = false;
                            }
                            break;
                    }
                }

                if (!isValid) {
                    this.showFieldError(fieldId, errorMessage);
                    return false;
                }

                if (fieldId === 'grossWeight' || fieldId === 'tareWeight') {
                    return this.validateWeights();
                }

                return true;
            },

            validateWeights() {
                const grossWeight = parseFloat(document.getElementById('grossWeight')?.value) || 0;
                const tareWeight = parseFloat(document.getElementById('tareWeight')?.value) || 0;

                if (grossWeight < tareWeight) {
                    this.showFieldError('grossWeight', 'Gross weight cannot be less than tare weight');
                    return false;
                }

                return true;
            },

            // UPDATED: Proper vehicle attachment validation with debug info
            validateVehicleAttachment() {
                const vehicleNo = document.getElementById('vehicleNoLogistics')?.value?.trim();

                console.log("🔍 VEHICLE VALIDATION:");
                console.log("- Vehicle number entered:", vehicleNo || 'None');
                console.log("- Vehicle file selected:", vehicleAttachmentFile ? vehicleAttachmentFile.name : 'None');

                if (vehicleNo) {
                    if (!vehicleAttachmentFile) {
                        this.errors.push('🚛 Vehicle attachment is MANDATORY when vehicle number is provided. Please upload vehicle documents in the Logistics tab.');

                        // Highlight the vehicle field
                        const vehicleInput = document.getElementById('vehicleNoLogistics');
                        if (vehicleInput) {
                            this.showFieldError('vehicleNoLogistics', 'Vehicle attachment is required');
                        }

                        // Update status indicator
