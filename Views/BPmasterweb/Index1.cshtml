        // GST Validation Functions
        function setupGSTValidation() {
            const billingGST = document.getElementById('billing-gst');
            const shippingGST = document.getElementById('shipping-gst');

            if (billingGST) {
                billingGST.addEventListener('input', function() {
                    validateGSTNumber('billing');
