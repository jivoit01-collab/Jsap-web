    async function setBulkMode(mode) {
        bulkMode = mode === 'reassign' ? 'reassign' : 'assign';
        const assignMode = bulkMode === 'assign';
        document.getElementById('bulkTabAssign').classList.toggle('on', assignMode);
        document.getElementById('bulkTabReassign').classList.toggle('on', !assignMode);
        document.getElementById('bulkModalTitle').textContent = assignMode ? 'Bulk Assign Team' : 'Bulk Change SubHOD';
        document.getElementById('bulkModeHelp').textContent = assignMode
            ? 'Pick a HOD, department and executives to assign in one action.'
            : 'Select a HOD, department and sub-department to move executives to a new SubHOD.';
        document.getElementById('bulkSubHodLabel').textContent = assignMode ? 'Sub-HOD' : 'New Sub-HOD';
        document.getElementById('bulkAssignBtn').textContent = assignMode ? 'Assign Team' : 'Change SubHOD';
        // Show/hide current sub-HOD dropdown
        document.getElementById('b_current_subhod_wrap').style.display = assignMode ? 'none' : '';
        // Re-fetch executives and sub-HODs based on the new mode
        await renderBulkSubHodOptions();
        await refreshBulkExecutives();
    }

    async function renderBulkSubHodOptions() {
        const hodId = parseInt(document.getElementById('b_hod').value) || 0;
        const deptId = parseInt(document.getElementById('b_dept').value) || 0;
        const subDeptId = parseInt(document.getElementById('b_sdept').value) || 0;
        const sel = document.getElementById('b_subhod');
        const currentSel = document.getElementById('b_current_subhod');
        sel.innerHTML = '<option value="">— Direct to HOD —</option>';
        if(!hodId || !deptId) return;

        if (bulkMode === 'reassign') {
            // CHANGE SUBHOD mode:
            // "Current Sub-HOD" = who currently manages executives in this HOD/Dept/SubDept
            // Find all unique sub-HODs from grid rows matching HOD+Dept+SubDept
            const currentSubHods = new Map();
            (allRows || []).forEach(r => {
                if (r.hodEmployeeId !== hodId) return;
                if (deptId && r.departmentId !== deptId) return;
                if (subDeptId && r.subDepartmentId !== subDeptId) return;
                if (r.subHodEmployeeId > 0 && !currentSubHods.has(r.subHodEmployeeId)) {
                    currentSubHods.set(r.subHodEmployeeId, { employeeId: r.subHodEmployeeId, employeeName: r.subHodName, employeeCode: r.subHodCode });
                }
            });
            currentSel.innerHTML = '<option value="">— Direct to HOD —</option>';
            currentSubHods.forEach(e => {
                currentSel.innerHTML += `<option value="${e.employeeId}">${esc(e.employeeName)} (${esc(e.employeeCode||'')})</option>`;
            });
            // Auto-select if only one sub-HOD
            if (currentSubHods.size === 1) {
                currentSel.value = String([...currentSubHods.keys()][0]);
            }

            // "New Sub-HOD" = all available sub-HODs under this HOD to move executives to
            const added = new Set();
            const allSubHods = getSubHodsForDepartment(hodId, 0, 0);
            allSubHods.forEach(e => {
                added.add(e.employeeId);
                sel.innerHTML += `<option value="${e.employeeId}">${esc(e.employeeName)} (${esc(e.employeeCode)})</option>`;
            });
            try {
                const r = await api(`${API}/SearchEmployees?roleTypeId=2&isActive=true&pageSize=500`);
                if (r.success) {
                    (r.data || []).forEach(e => {
                        if (!added.has(e.employeeId)) {
                            added.add(e.employeeId);
                            sel.innerHTML += `<option value="${e.employeeId}">${esc(e.employeeName)} (${esc(e.employeeCode||'')})</option>`;
                        }
                    });
                }
            } catch(e){}
        } else {
            // ASSIGN TEAM mode: show all sub-HODs from grid + all active from API
            const fromGrid = getSubHodsForDepartment(hodId, deptId, subDeptId);
            const added = new Set();
            fromGrid.forEach(e => {
                added.add(e.employeeId);
                sel.innerHTML += `<option value="${e.employeeId}">${esc(e.employeeName)} (${esc(e.employeeCode)})</option>`;
            });
            try {
                const r = await api(`${API}/SearchEmployees?roleTypeId=2&isActive=true&pageSize=500`);
                if(r.success) {
                    (r.data||[]).forEach(e=>{
                        if(!added.has(e.employeeId)){
                            added.add(e.employeeId);
                            sel.innerHTML += `<option value="${e.employeeId}">${esc(e.employeeName)} (${esc(e.employeeCode||'')})</option>`;
                        }
                    });
                }
            } catch(e){}
        }
    }

