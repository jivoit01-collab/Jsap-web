        async function saveAllItems(status = "Pending") {
            if (!isSessionActive()) {
                alert('Session is inactive. Changes are not allowed.');
                return;
            }
            console.log(`\n=== SMART SAVE (rows may be INSERT and/or UPDATE) — status: ${status} ===`);

            const normalizedStatus = (status || '').toLowerCase() === 'closed' ? 'Closed' : 'Pending';

            if (tableItems.length === 0) {
                alert('No items in table to save. Please add items first.');
                return;
            }

            const allInsert = tableItems.every(r => r.ActionType === 'INSERT');
            const hasUpdate = tableItems.some(r => r.ActionType === 'UPDATE');

            const confirmMsg = allInsert
                ? `Save ${tableItems.length} new items with status: ${normalizedStatus}?`
                : `Save changes:\n• INSERT: ${tableItems.filter(r=>r.ActionType==='INSERT').length}\n• UPDATE: ${tableItems.filter(r=>r.ActionType==='UPDATE').length}\n\nProceed with status: ${normalizedStatus}?`;

            if (!confirm(confirmMsg)) return;

            const lotNumber = document.getElementById('LotNumber').value;
            const userId = parseInt(document.getElementById('UpdatedBy').value) || null;
            const sessionId = parseInt(document.getElementById('SessionId').value) || null;

            showProgressOverlay(allInsert ? 'Uploading new items...' : 'Saving rows (insert + update)...');

            try {
                if (allInsert) {
                    // Bulk insert logic
                    const itemsToSave = tableItems.map(item => {
                        const physicalCount = parseFloat(item.physicalCount) || 0;
                        const systemCount = parseFloat(item.systemCount) || 0;

                        return {
                            ItemCode: String(item.selectedItem.itemCode),
                            ItemName: String(item.selectedItem.itemName),
                            WarehouseName: String(item.warehouse),
                            ItemGroupCode: String(item.itemDetails?.itmsGrpCod || ''),
                            SystemCount: systemCount,
                            LastCount: parseFloat(item.lastCount) || 0,
                            PhysicalCount: physicalCount,
                            StockValue: parseFloat(item.stockValue) || 0,
                            itmsGrpNam: String(item.itemDetails?.itmsGrpNam || ''),
                            u_Sub_Group: String(item.itemDetails?.u_Sub_Group || ''),
                            ActionType: 'INSERT',
                            UserId: userId,
                            salPackun: Number(parseFloat(item.salPackUn || 0).toFixed(5)),
                            isLitre: item.u_IsLitre || ''
                        };
                    });

                    const requestData = {
                        LotNumber: String(lotNumber),
                        CreatedBy: userId,
                        AllowDuplicates: true,
                        ActionType: "INSERT",
                        Items: itemsToSave
                    };

                    console.log('📤 Bulk Insert Request:', requestData);
                    const result = await postJson('/api/InventoryAudit/InsertItems', requestData);
                    if (!result?.success) throw new Error(result?.message || 'InsertItems failed');

                    console.log('✅ Bulk insert successful');

                } else {
                    // Process UPDATE rows
                    const updateRows = tableItems.filter(r => r.ActionType === 'UPDATE');
                    if (updateRows.length > 0) {
                        console.log(`📤 Processing ${updateRows.length} UPDATE rows...`);

                        for (const row of updateRows) {
                            const body = {
                                ItemId: row.ItemId,
                                NewPhysicalCount: parseFloat(row.physicalCount) || 0,
                                UpdatedBy: String(userId ?? ''),
                                Notes: row.notes || '',
                                status: normalizedStatus
                            };

                            if (!body.ItemId && body.ItemId !== 0) {
                                console.warn('⚠️ Skipping update row without ItemId:', row);
                                continue;
                            }

                            console.log('📤 Updating row via UpdatePhysicalCount:', body);
                            const res = await postJson('/api/InventoryAudit/UpdatePhysicalCount', body);
                            if (!res?.success) throw new Error(res?.message || 'UpdatePhysicalCount failed');
                        }

                        console.log('✅ All UPDATE rows processed');
                    }

                    // Process INSERT rows
                    const insertRows = tableItems.filter(r => r.ActionType === 'INSERT');
                    if (insertRows.length > 0) {
                        console.log(`📤 Processing ${insertRows.length} INSERT rows...`);

                        for (const row of insertRows) {
                            const body = {
                                LotNumber: String(lotNumber),
                                ItemCode: String(row.selectedItem.itemCode),
                                ItemName: String(row.selectedItem.itemName),
                                WarehouseName: String(row.warehouse),
                                ItemGroupCode: String(row.itemDetails?.itmsGrpCod || ''),
                                SystemCount: parseFloat(row.systemCount) || 0,
                                LastCount: parseFloat(row.lastCount) || 0,
                                PhysicalCount: parseFloat(row.physicalCount) || 0,
                                StockValue: parseFloat(row.stockValue) || 0,
                                itmsGrpNam: String(row.itemDetails?.itmsGrpNam || ''),
                                u_Sub_Group: String(row.itemDetails?.u_Sub_Group || ''),
                                CreatedBy: userId,
                                AllowDuplicates: true,
                                ActionType: "INSERT",
                                UserId: userId,
                                salPackun: Number(parseFloat(row.salPackUn || 0).toFixed(5)),
                                isLitre: row.u_IsLitre || ''
                            };

                            console.log('📤 Inserting single row via InsertSingleStockItem:', body);
                            const res = await postJson('/api/InventoryAudit/InsertSingleStockItem', body);
                            if (!res?.success) throw new Error(res?.message || 'InsertSingleStockItem failed');
                        }

                        console.log('✅ All INSERT rows processed');
                    }
                }

                // Update session status if closing
                const isClosing = (normalizedStatus === 'Closed');
                if (isClosing) {
                    if (!sessionId || !userId) {
                        alert('Items saved, but cannot close session: missing session/user id.');
                        // ✅ Reload page even if close failed
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        try {
                            const updateStatusRequest = {
                                sessionId: sessionId,
                                userId: userId
                            };

                            console.log('📤 Closing session:', updateStatusRequest);
                            const updateRes = await postJson('/api/InventoryAudit/UpdateStatus', updateStatusRequest);
                            if (!updateRes?.success) {
                                alert(`✅ Items saved, but closing failed: ${updateRes?.message || 'Unknown error'}`);
                            } else {
                                alert('✅ Items saved and session closed.');
                            }
                        } catch (e) {
                            console.error('UpdateStatus error:', e);
                            alert(`✅ Items saved, but closing failed: ${e.message}`);
                        }

                        // ✅ Reload page after close
                        setTimeout(() => location.reload(), 1000);
                    }
                } else {
                    // Just saving as Pending
                    alert('✅ Items saved successfully.');
                    // ✅ Reload page after save
                    setTimeout(() => location.reload(), 1000);
                }

                await callDeactivateIfAllInactive(sessionId);

            } catch (err) {
                console.error('❌ Save error:', err);
                alert(`❌ Save failed: ${err.message}`);
            } finally {
                hideProgressOverlay();
            }
        }

