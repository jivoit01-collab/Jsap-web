        function getNextItemNumber() {
            if (tableItems.length === 0) {
                return 1;
            }
            const usedNumbers = tableItems.map(item => item.id).sort((a, b) => a - b);
            for (let i = 1; i <= usedNumbers.length + 1; i++) {
                if (!usedNumbers.includes(i)) {
                    return i;
                }
            }
            return usedNumbers.length + 1;
        }

        function updateItemCount(itemId, count) {
            if (isReadOnlySession) { return; }
            const item = tableItems.find(item => item.id === itemId);
            if (!item) return;

            const enteredCount = parseFloat(count) || 0;

            if (item.isMultiWarehouse && item.selectedItem) {
                const itemCode = item.selectedItem.itemCode;
                const sameItemRows = tableItems.filter(row =>
                    row.selectedItem &&
                    row.selectedItem.itemCode === itemCode
                ).sort((a, b) => b.systemCount - a.systemCount);

                console.log(`Smart allocation for ${itemCode}: entered ${enteredCount}`);

                sameItemRows.forEach(row => {
                    row.physicalCount = '';
                });

                let remainingCount = enteredCount;

                for (let i = 0; i < sameItemRows.length; i++) {
                    const row = sameItemRows[i];
                    if (remainingCount <= 0) break;

                    const maxForThisRow = row.systemCount;
                    const allocatedToThisRow = Math.min(remainingCount, maxForThisRow);

                    row.physicalCount = allocatedToThisRow.toString();
                    remainingCount -= allocatedToThisRow;
                }

                if (remainingCount > 0) {
                    const firstRow = sameItemRows[0];
                    const currentFirstRowCount = parseFloat(firstRow.physicalCount) || 0;
                    firstRow.physicalCount = (currentFirstRowCount + remainingCount).toString();
                }

                const triggerInput = document.querySelector(`#count-${itemId}`);
                if (triggerInput) {
                    const updatedItem = tableItems.find(row => row.id === itemId);
                    if (updatedItem) {
                        triggerInput.value = updatedItem.physicalCount;
                    }
                }

                updateItemsTable();
            } else {
                item.physicalCount = count;
                updateItemsTable();
            }
        }

        async function postJson(url, body) {
            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(data?.message || `HTTP ${res.status}`);
            return data;
        }
