        async function addItemWithStockDetails(selectedItem, physicalQuantity, stockDetails) {
            console.log(`\n=== ADDING ITEM ${selectedItem.itemCode} ===`);
            console.log(`Physical Quantity: ${physicalQuantity}`);
            console.log(`Stock Details:`, stockDetails);

            let newItems = [];
            stockDetails.warehouseEntries.forEach((warehouseEntry, index) => {
                if (isDuplicateItemWarehouse(selectedItem.itemCode, warehouseEntry.warehouse)) {
                    console.warn(`Skipping duplicate: ${selectedItem.itemCode} + ${warehouseEntry.warehouse}`);
                    return;
                }

                const newItemId = getNextItemNumber();

                let calculatedLastCount = 0;
                if (index === 0) {
                    calculatedLastCount = 0;
                } else {
                    let cumulativeCount = 0;
                    for (let i = 0; i < index; i++) {
                        const prevEntry = stockDetails.warehouseEntries[i];
                        const prevSystemCount = parseFloat(prevEntry.onHand || 0);
                        if (i === 0) {
                            cumulativeCount += prevSystemCount + 0;
                        } else {
                            const prevLastCount = cumulativeCount;
                            cumulativeCount = prevSystemCount + prevLastCount;
                        }
                    }
                    calculatedLastCount = cumulativeCount;
                }

                const systemCount = parseFloat(warehouseEntry.onHand || 0);
                const stockValue = parseFloat(warehouseEntry.stockValue || 0);

                const newItem = {
                    id: newItemId,
                    selectedItem: selectedItem,
                    systemCount: systemCount,
                    lastCount: calculatedLastCount,
                    physicalCount: '',
                    notes: '',
                    warehouse: warehouseEntry.warehouse,
                    warehouseEntry: warehouseEntry,
                    itemCode: selectedItem.itemCode,
                    ActionType: 'INSERT',  // ✅ New items are INSERT
                    ItemId: null,
                    isMultiWarehouse: stockDetails.warehouseEntries.length > 1,
                    warehouseIndex: index,
                    totalWarehouses: stockDetails.warehouseEntries.length,
                    unitRate: systemCount > 0 ? stockValue / systemCount : 0,
                    stockValue: stockValue,
                    isManualEntry: warehouseEntry.isManualEntry || false,
                    itemDetails: {
                        u_Sub_Group: warehouseEntry.u_Sub_Group || '',
                        itmsGrpCod: warehouseEntry.itmsGrpCod || '',
                        itmsGrpNam: warehouseEntry.itmsGrpNam || ''
                    },
                    // ✅ ADD THESE FIELDS for saving later
                    salPackUn: warehouseEntry.salPackUn || 0,
                    u_IsLitre: warehouseEntry.u_IsLitre || ''
                };
                newItems.push(newItem);
            });

            if (newItems.length === 0) {
                console.warn('No new items to add - all were duplicates');
                alert('This item and warehouse combination already exists in the table');
                return;
            }

            tableItems.push(...newItems);

            if (newItems.length > 1) {
                let remainingQuantity = physicalQuantity;
                const sortedItems = [...newItems].sort((a, b) => b.systemCount - a.systemCount);

                for (let i = 0; i < sortedItems.length; i++) {
                    const item = sortedItems[i];
                    if (remainingQuantity <= 0) break;

                    const maxForThis = item.systemCount;
                    const allocatedToThis = Math.min(remainingQuantity, maxForThis);

                    item.physicalCount = allocatedToThis.toString();
                    remainingQuantity -= allocatedToThis;
                }

                if (remainingQuantity > 0) {
                    const firstItem = sortedItems[0];
                    const currentCount = parseFloat(firstItem.physicalCount) || 0;
                    firstItem.physicalCount = (currentCount + remainingQuantity).toString();
                }
            } else {
                newItems[0].physicalCount = physicalQuantity.toString();
            }

            console.log(`Added ${newItems.length} new warehouse entries`);
            updateItemsTable();
        }
