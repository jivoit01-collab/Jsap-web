        document.addEventListener('DOMContentLoaded', function () {

            // Utility to collect all values from inputs of a given class
            function getAllValues(selector) {
                return Array.from(document.querySelectorAll(selector)).map(i => i.value.trim());
            }

            // Validate uniqueness of the current input among all others
            function validateUniqueness(inputSelector, errorSelector) {
                document.querySelectorAll(inputSelector).forEach(input => {
                    input.addEventListener('input', () => {
                        const currentVal = input.value.trim();
                        const allValues = getAllValues(inputSelector);

                        const count = allValues.filter(val => val === currentVal).length;
                        const errorDiv = input.closest('tr').querySelector(errorSelector);

                        if (currentVal !== '' && count > 1) {
                            errorDiv.style.display = 'block';
                            input.classList.add('is-invalid');
                        } else {
                            errorDiv.style.display = 'none';
                            input.classList.remove('is-invalid');
                        }
                    });
                });
            }

            // Set up both validations
            validateUniqueness('.contact-id', '.error-msg');
            validateUniqueness('.address-id', '.error-msg');

        });
        document.addEventListener("DOMContentLoaded", function () {
            const staffRadios = document.querySelectorAll('input[name="isStaff"]');
