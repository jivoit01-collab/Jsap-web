            /* INFO MODAL */
            function v1_info(nodeId){ var n=getNodeData(nodeId);if(!n)return;var icons={owner:'award-fill',hod:'person-badge-fill',dept:'building-fill',subdept:'buildings-fill',subhod:'people-fill',exec:'person-fill'};var hdrCls={owner:'ip-owner-h',hod:'ip-hod',dept:'ip-dept-h',subdept:'ip-sd-h',subhod:'ip-shod-h',exec:'ip-exec-h'};var h='<div class="ip-header '+hdrCls[n.type]+'"><i class="bi bi-'+icons[n.type]+' me-2"></i>'+n.role+'</div><table class="ip-table">';var rows=[['Name','<strong style="font-size:15px">'+esc(n.name)+'</strong>']];if(n.code)rows.push(['Employee Code','<code>'+esc(n.code)+'</code>']);if(n.hod)rows.push(['HOD',esc(n.hod)]);if(n.dept)rows.push(['Department',esc(n.dept)]);if(n.subDept)rows.push(['Sub-Department',esc(n.subDept)]);if(n.subHod)rows.push(['Sub-HOD',esc(n.subHod)]);if(n.hodCount!==undefined)rows.push(['HODs','<strong>'+n.hodCount+'</strong>']);if(n.teamCount!==undefined)rows.push([n.type==='owner'?'Total Employees':'Team Size','<strong>'+n.teamCount+'</strong>']);if(n.deptCount!==undefined)rows.push(['Departments','<strong>'+n.deptCount+'</strong>']);if(n.subHodCount!==undefined)rows.push(['Sub-HODs','<strong>'+n.subHodCount+'</strong>']);if(n.subDeptCount!==undefined)rows.push(['Sub-Depts','<strong>'+n.subDeptCount+'</strong>']);if(n.execCount!==undefined)rows.push(['Executives','<strong>'+n.execCount+'</strong>']);if(n.sal&&SHOW_SAL)rows.push(['Salary','<span class="ip-sal">₹'+fmtN(n.sal)+'</span>']);rows.forEach(function(r){h+='<tr><th>'+r[0]+'</th><td>'+r[1]+'</td></tr>';});h+='</table>';document.getElementById('infoModalTitle').innerHTML='<i class="bi bi-'+icons[n.type]+' me-2"></i>'+esc(n.name);document.getElementById('infoModalBody').innerHTML=h;bsInfoModal.show(); }

            /* ══ V2 — TABLE DRILL-DOWN ══ */
            var v2_data=[],v2_filteredData=[],v2_state={};
            var v2_colOrder  =['hod','dept','subdept','subhod','exec','total','totalsalary'];
            var v2_colVisible={hod:1,dept:1,subdept:1,subhod:1,exec:1,total:1,totalsalary:0};
            var v2_colLabel  ={hod:'HOD',dept:'Department',subdept:'Sub-Dept',subhod:'Sub-HOD',exec:'Executive',total:'Team Size',totalsalary:'Total Salary'};
            var v2_colWidth  ={hod:180,dept:250,subdept:190,subhod:210,exec:300,total:120,totalsalary:170};
            var v2_filters   ={hod:[],dept:[],subdept:[],subhod:[],exec:[],salary:null};
            var v2_activeFdCol=null,v2_fdTemp={};

            function v2_init(){ v2_data=RAW_DATA;if(!SHOW_SAL)v2_colVisible.totalsalary=0;v2_applyFilters();v2_renderToolbar();v2_render(); }
            function v2_renderToolbar(){ var h='';v2_colOrder.forEach(function(c,i){if(c==='totalsalary'&&!SHOW_SAL)return;var lastIdx=SHOW_SAL?v2_colOrder.length-1:v2_colOrder.length-2;h+='<div class="col-tog"><button class="col-arr'+(i===0?' dis':'')+'" onclick="v2_moveCol(\''+c+'\',-1)">&larr;</button><label class="col-pill"><input type="checkbox" '+(v2_colVisible[c]?'checked':'')+' onchange="v2_togCol(\''+c+'\',this.checked)"><span>'+v2_colLabel[c]+'</span></label><button class="col-arr'+(i>=lastIdx?' dis':'')+'" onclick="v2_moveCol(\''+c+'\',1)">&rarr;</button></div>';});document.getElementById('v2ColToggles').innerHTML=h; }
            function v2_moveCol(c,d){ var i=v2_colOrder.indexOf(c),j=i+d;if(j<0||j>=v2_colOrder.length)return;v2_colOrder[i]=v2_colOrder[j];v2_colOrder[j]=c;v2_renderToolbar();v2_render(); }
            function v2_togCol(c,v){ v2_colVisible[c]=v?1:0;if(v2_getVisCols().length===0){v2_colVisible[c]=1;showAlert('warning','At least one column required.');}v2_render();v2_renderToolbar(); }
            function v2_getVisCols(){ return v2_colOrder.filter(function(c){return v2_colVisible[c]&&(c!=='totalsalary'||SHOW_SAL);}); }
            function v2_applyFilters(){ v2_filteredData=v2_data.filter(function(h){ if(v2_filters.hod.length&&v2_filters.hod.indexOf(h.name)===-1)return false;if(v2_filters.dept.length&&!h.depts.some(function(d){return v2_filters.dept.indexOf(d)>-1;}))return false;if(v2_filters.subdept.length&&!h.subs.some(function(s){return v2_filters.subdept.indexOf(s.sdName)>-1;}))return false;if(v2_filters.subhod.length){var hasSH=h.subs.some(function(s){return(s.subHods||[]).some(function(sh){var k=sh.code?(sh.name+' ('+sh.code+')'):sh.name;return v2_filters.subhod.indexOf(k)>-1;});});if(!hasSH)return false;}if(v2_filters.exec.length){var hasEx=h.subs.some(function(s){var fromSH=(s.subHods||[]).some(function(sh){return(sh.execs||[]).some(function(e){var k=e.code?(e.name+' ('+e.code+')'):e.name;return v2_filters.exec.indexOf(k)>-1;});});var fromDirect=(s.execs||[]).some(function(e){var k=e.code?(e.name+' ('+e.code+')'):e.name;return v2_filters.exec.indexOf(k)>-1;});return fromSH||fromDirect;});if(!hasEx)return false;}if(v2_filters.salary){var sv=v2_getSalForFilter(h,v2_filters.salary.target);if(!v2_matchSal(sv,v2_filters.salary))return false;}return true;}); }
            function v2_getSalForFilter(h,t){ if(t==='hod')return Number(h.sal)||0;if(t==='subhod'){var s=0;h.subs.forEach(function(x){(x.subHods||[]).forEach(function(sh){s+=Number(sh.sal)||0;});});return s;}if(t==='exec'){var s=0;h.subs.forEach(function(x){(x.subHods||[]).forEach(function(sh){(sh.execs||[]).forEach(function(e){s+=Number(e.sal)||0;});});(x.execs||[]).forEach(function(e){s+=Number(e.sal)||0;});});return s;}var s=Number(h.sal)||0;h.subs.forEach(function(x){(x.subHods||[]).forEach(function(sh){s+=Number(sh.sal)||0;(sh.execs||[]).forEach(function(e){s+=Number(e.sal)||0;});});(x.execs||[]).forEach(function(e){s+=Number(e.sal)||0;});});return s; }
            function v2_matchSal(val,f){ var v1=Number(f.value1)||0,v2b=Number(f.value2)||0;switch(f.condition){case'gte':return val>=v1;case'lte':return val<=v1;case'gt':return val>v1;case'lt':return val<v1;case'eq':return val===v1;case'between':return val>=v1&&val<=v2b;}return true; }
            function v2_hasFilters(){return v2_filters.hod.length||v2_filters.dept.length||v2_filters.subdept.length||v2_filters.subhod.length||v2_filters.exec.length||v2_filters.salary!==null;}
