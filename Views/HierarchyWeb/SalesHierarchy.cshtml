// ═══════════════════════════════════════════════════════════════
function showToastPersistent(msg, type = 'info') {
    const container = document.getElementById('toastContainer');
    const icons = { success: 'OK', error: 'ERR', info: 'INFO' };
    const div = document.createElement('div');
    div.className = `toast toast-${type}`;
    div.innerHTML = `<span class="toast-icon">${icons[type]||'INFO'}</span><span>${esc(msg)}</span>`;
    container.appendChild(div);
    if (type === 'error') {
        const banner = document.getElementById('pageErrorBanner');
        const text = document.getElementById('pageErrorText');
        if (banner && text) {
            text.textContent = String(msg ?? '');
            banner.style.display = 'block';
        }
        return;
    }
    setTimeout(() => div.remove(), 4000);
}

showToast = showToastPersistent;

window.addEventListener('error', function (event) {
    const message = `${event.message || 'Script error'}${event.filename ? `\n${event.filename}:${event.lineno || 0}` : ''}`;
    showToast(message, 'error');
});

window.addEventListener('unhandledrejection', function (event) {
    const reason = event.reason && event.reason.message ? event.reason.message : String(event.reason || 'Unhandled promise rejection');
    showToast(reason, 'error');
});

