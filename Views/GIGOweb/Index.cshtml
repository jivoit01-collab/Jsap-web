        function switchTab(tabName, tabElement) {
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));

            if (tabElement) {
                tabElement.classList.add('active');
            }

            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.remove('active');
            });

            const targetTab = document.getElementById(tabName + '-tab');
            if (targetTab) {
                targetTab.classList.add('active');
            }
        }

        function collectContentsTableData() {
            const table = document.getElementById('contentsTable');
            if (!table) {
                console.log("❌ Contents table not found");
                return [];
            }

            const tbody = table.getElementsByTagName('tbody')[0];
            if (!tbody) {
                console.log("❌ Contents table tbody not found");
                return [];
            }

            const rows = tbody.getElementsByTagName('tr');
            const contentsData = [];

            console.log(`📋 Processing ${rows.length} rows from contents table`);

            for (let i = 0; i < rows.length; i++) {
                const cells = rows[i].cells;
                if (cells.length >= 9) {
                    const itemNameInput = cells[1].querySelector('input');
                    const itemCodeInput = cells[2].querySelector('input');
                    const remarksInput = cells[3].querySelector('input');
                    const poQtyInput = cells[4].querySelector('input');
                    const openQtyInput = cells[5].querySelector('input');
                    const uomInput = cells[6].querySelector('input');
                    const quantityInput = cells[7].querySelector('input');
                    const userRemarksInput = cells[8].querySelector('input');

                    const itemData = {
                        rowNumber: i + 1,
                        itemName: itemNameInput ? itemNameInput.value.trim().toUpperCase() : '',
                        itemCode: itemCodeInput ? itemCodeInput.value.trim().toUpperCase() : '',
                        remarks: remarksInput ? remarksInput.value.trim().toUpperCase() : '',
                        poQuantity: poQtyInput ? parseFloat(poQtyInput.value) || 0 : 0,
                        openQuantity: openQtyInput ? parseFloat(openQtyInput.value) || 0 : 0,
                        uom: uomInput ? uomInput.value.trim().toUpperCase() : 'PCS',
                        quantityReceived: quantityInput ? parseFloat(quantityInput.value) || 0 : 0,
                        userRemarks: userRemarksInput ? userRemarksInput.value.trim().toUpperCase() : '',

                        poDocEntry: rows[i].getAttribute('data-po-docentry') || '',
                        poDocNum: rows[i].getAttribute('data-po-docnum') || '',
                        poLineNum: rows[i].getAttribute('data-po-linenum') || ''
                    };

                    console.log(`📋 Row ${i + 1}: ${itemData.itemCode} - ${itemData.itemName} (Qty: ${itemData.quantityReceived})`);
                    contentsData.push(itemData);
                }
            }

            console.log(`✅ Collected ${contentsData.length} items from contents table`);
            return contentsData;
        }

        function buildDocumentArrays() {
            const contentsData = collectContentsTableData();
            const cardType = document.getElementById("cardType")?.value || 'VENDOR';

            console.log(`📊 Building document arrays for ${cardType} with ${contentsData.length} items`);

            const customerDocs = [];
            const vendorDocs = [];
            const bstDocs = [];

            contentsData.forEach((item, index) => {
                const baseDoc = {
                    ItemCode: item.itemCode || "",
                    ItemName: item.itemName || "",
                    Remarks: item.userRemarks || "",
                    CreatedBy: parseInt(createdBy) || 67
                };

                if (cardType.toUpperCase() === 'CUSTOMER') {
                    const generatedDocId = item.poDocEntry ? `CU${item.poDocEntry}` : `CU${Date.now()}${index}`;

                    customerDocs.push({
                        ...baseDoc,
                        DocType: 'CUSTOMER',
                        DocId: generatedDocId,
                        Qty: item.poQuantity || 0,
                        ReceivedQty: item.quantityReceived || 0,
                        OpenQty: item.openQuantity || 0
                    });
                } else if (cardType.toUpperCase() === 'VENDOR') {
                    const generatedPONumber = item.poDocNum ? item.poDocNum : `PO${Date.now()}${index}`;

                    const vendorDoc = {
                        ...baseDoc,
                        DocType: 'VENDOR',
                        PONumber: generatedPONumber,
                        POQty: item.poQuantity || 0,
                        ReceivedQty: item.quantityReceived || 0,
                        OpenQty: item.openQuantity || 0
                    };

                    console.log(`📋 Created vendor doc: ${vendorDoc.ItemCode}, PO: ${vendorDoc.PONumber}, ReceivedQty: ${vendorDoc.ReceivedQty}`);
                    vendorDocs.push(vendorDoc);
                } else if (cardType.toUpperCase() === 'BST') {
                    const generatedDocId = item.poDocEntry ? `BST${item.poDocEntry}` : `BST${Date.now()}${index}`;

                    bstDocs.push({
                        ...baseDoc,
                        DocType: 'BST',
                        DocId: generatedDocId,
                        FromLocation: 'LOCA',
                        FromWarehouse: 'WH-BH',
                        ToWarehouse: 'WH-HP',
                        Qty: item.poQuantity || 0,
                        QtyReceived: item.quantityReceived || 0
                    });
                }
            });

            console.log(`✅ Document arrays built:`);
            console.log(`   - Customer Docs: ${customerDocs.length}`);
            console.log(`   - Vendor Docs: ${vendorDocs.length}`);
            console.log(`   - BST Docs: ${bstDocs.length}`);

            return { customerDocs, vendorDocs, bstDocs };
        }

