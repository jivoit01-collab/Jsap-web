        // Update selected rows function
        function updateSelectedRows() {
            const selectedRows = document.querySelectorAll('input[name="selectRow"]:checked');

            if (selectedRows.length === 0) {
                alert('❌ Please select at least one row to update.');
                return;
            }

            // Validate only selected rows
            let hasError = false;
            const updateData = [];

            selectedRows.forEach(checkbox => {
                const row = checkbox.closest('tr');
                const rowId = row.getAttribute('data-id');
                const acceptBtn = row.querySelector('.accept-btn');
                const rejectBtn = row.querySelector('.reject-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');
                const rejectReasonInput = row.querySelector('.reject-reason-input');

                // Validate that an action is selected
                if (!acceptBtn.classList.contains('active') && !rejectBtn.classList.contains('active')) {
                    hasError = true;
                    acceptBtn.style.borderColor = '#e74c3c';
                    rejectBtn.style.borderColor = '#e74c3c';
                    acceptBtn.classList.add('error');
                    rejectBtn.classList.add('error');
                } else if (acceptBtn.classList.contains('active')) {
                    // Accept selected - validate bundle status
                    if (!bundleStatusSelect || !bundleStatusSelect.value) {
                        hasError = true;
                        if (bundleStatusSelect) {
                            bundleStatusSelect.style.borderColor = '#e74c3c';
                            bundleStatusSelect.style.borderWidth = '2px';
                            bundleStatusSelect.classList.add('error');
                            bundleStatusSelect.focus();
                        }
                    } else {
                        updateData.push({
                            id: parseInt(rowId),
                            action: 'accept',
                            bundleStatus: bundleStatusSelect.value,
                            rejectReason: null
                        });
                    }
                } else if (rejectBtn.classList.contains('active')) {
                    // Reject selected - validate reject reason
                    if (!rejectReasonInput || !rejectReasonInput.value.trim()) {
                        hasError = true;
                        if (rejectReasonInput) {
                            rejectReasonInput.style.borderColor = '#e74c3c';
                            rejectReasonInput.style.borderWidth = '2px';
                            rejectReasonInput.classList.add('error');
                            rejectReasonInput.focus();
                        }
                    } else {
                        updateData.push({
                            id: parseInt(rowId),
                            action: 'reject',
                            bundleStatus: null,
                            rejectReason: rejectReasonInput.value.trim()
                        });
                    }
                }
            });

            if (hasError) {
                alert('❌ Please fix the following issues:\n• Selected rows must have either Accept or Reject chosen\n• Accepted rows must have Bundle Status selected\n• Rejected rows must have Reject Reason entered\n\n(Issues highlighted in red)');
                return;
            }

            if (updateData.length === 0) {
                alert('❌ No valid rows to update.');
                return;
            }

            // Show confirmation
            const acceptedCount = updateData.filter(item => item.action === 'accept').length;
            const rejectedCount = updateData.filter(item => item.action === 'reject').length;

            const confirmation = confirm(`✅ Are you sure you want to update ${updateData.length} selected rows?\n\n• Accepted: ${acceptedCount} rows\n• Rejected: ${rejectedCount} rows`);
            if (!confirmation) return;

            // Call API to update
            updateDocumentStatusAPI(updateData);
        }

        // API call to update document status
        function updateDocumentStatusAPI(updateData) {
            const receivedBy = parseInt(document.getElementById('UpdatedBy').value);

            // Prepare data for API - get docId from table row
            const apiData = updateData.map(item => {
                // Find the row to get docId
                const row = document.querySelector(`tr[data-id="${item.id}"]`);
                const docIdCell = row.querySelector('td:nth-child(4)'); // 4th column is Doc ID in pending mode
                const docId = docIdCell ? docIdCell.textContent.trim() : '';

                return {
                    id: item.id,
                    docId: docId,
                    status: item.action === 'accept' ? 'R' : 'NR', // R = Received/Accepted, NR = Not Received/Rejected
                    receivedBy: receivedBy,
                    rejectedReason: item.rejectReason || "",
                    BundleStatus: item.bundleStatus || ""
                };
            });

            console.log('Updating document status:', apiData);

            // Show loading state
            const updateBtn = document.getElementById('updateSelectedBtn');
            const originalBtnText = updateBtn.innerHTML;
            updateBtn.innerHTML = '⏳ Updating...';
            updateBtn.disabled = true;

            // Make API call
            fetch("/api/DocumentDispatch/UpdateDocumentStatus", {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(apiData)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(result => {
                console.log('API Response:', result);

                // Show success message with detailed breakdown
                const acceptedItems = updateData.filter(item => item.action === 'accept');
                const rejectedItems = updateData.filter(item => item.action === 'reject');

                let message = '✅ Document status updated successfully!\n\n';
                message += `📊 Summary:\n`;
                message += `• Accepted: ${acceptedItems.length} documents\n`;
                message += `• Rejected: ${rejectedItems.length} documents\n\n`;

                if (acceptedItems.length > 0) {
                    message += `✅ Accepted Documents:\n`;
                    acceptedItems.forEach(item => {
                        const row = document.querySelector(`tr[data-id="${item.id}"]`);
                        const docIdCell = row.querySelector('td:nth-child(4)');
                        const docId = docIdCell ? docIdCell.textContent.trim() : '';
                        message += `   - Doc ID ${docId}: ${item.bundleStatus}\n`;
                    });
                    message += '\n';
                }

                if (rejectedItems.length > 0) {
                    message += `❌ Rejected Documents:\n`;
                    rejectedItems.forEach(item => {
                        const row = document.querySelector(`tr[data-id="${item.id}"]`);
                        const docIdCell = row.querySelector('td:nth-child(4)');
                        const docId = docIdCell ? docIdCell.textContent.trim() : '';
                        message += `   - Doc ID ${docId}: ${item.rejectReason}\n`;
                    });
                }

                alert(message);

                // Reload data to refresh the table
                if (currentMode === 'pending') {
                    loadPendingData();
                } else {
                    loadAllData();
                }
            })
            .catch(error => {
                console.error('API Error:', error);
                alert(`❌ Failed to update document status: ${error.message}`);
            })
            .finally(() => {
                // Restore button state
                updateBtn.innerHTML = originalBtnText;
                updateBtn.disabled = false;
            });
        }

        // Helper functions
        function calculateDaysPending(createdDate) {
            const created = new Date(createdDate);
            const today = new Date();
            const timeDiff = today.getTime() - created.getTime();
            return Math.ceil(timeDiff / (1000 * 3600 * 24));
        }

        function getDaysPendingClass(days) {
            if (days <= 3) return 'days-1-3';
            if (days <= 7) return 'days-4-7';
            return 'days-8-plus';
        }

        function getStatusText(status) {
            const statusMap = {
                'S': 'Pending',
                'R': 'Received',
                'NR': 'Not Received',
                'ok': 'OK'
            };
            return statusMap[status] || status;
        }

        function getFileIcon(fileName) {
            if (!fileName) return '📁';
            const ext = fileName.split('.').pop().toLowerCase();
            const iconMap = {
                pdf: '📄',
                doc: '📝', docx: '📝',
                xls: '📊', xlsx: '📊', csv: '📊',
                jpg: '🖼️', jpeg: '🖼️', png: '🖼️', gif: '🖼️',
                zip: '🗜️', rar: '🗜️',
                txt: '📄', log: '📄'
            };
            return iconMap[ext] || '📁';
        }

        function formatDate(dateString) {
            if (!dateString || dateString === '0001-01-01T00:00:00') return '-';
            const date = new Date(dateString);
            return date.toISOString().split('T')[0];
        }

        function updatePendingCount(count) {
            document.getElementById('countValue').textContent = count;
        }

        function previewFile(filePath) {
            if (!filePath) {
                alert("No attachment available");
                return;
            }
            // Open file in new tab
            window.open(filePath, '_blank');
        }
    </script>
    <script>
         // Accept All Selected Rows
        function acceptAllSelected() {
            const selectedRows = document.querySelectorAll('input[name="selectRow"]:checked');

            if (selectedRows.length === 0) {
                alert('❌ Please select at least one row to accept.');
                return;
            }

            selectedRows.forEach(checkbox => {
                const index = checkbox.value;
                const row = checkbox.closest('tr');
                const acceptBtn = row.querySelector('.accept-btn');
                const rejectBtn = row.querySelector('.reject-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');
                const rejectReasonInput = row.querySelector('.reject-reason-input');

                // Set to accept state
                acceptBtn.classList.add('active');
                rejectBtn.classList.remove('active');

                // Enable bundle status, disable reject reason
                bundleStatusSelect.disabled = false;
                rejectReasonInput.disabled = true;
                rejectReasonInput.value = '';
                rejectReasonInput.style.borderColor = '#ddd';
                rejectReasonInput.style.borderWidth = '1px';

                // Mark bundle status as required
                if (!bundleStatusSelect.value) {
                    bundleStatusSelect.style.borderColor = '#e74c3c';
                    bundleStatusSelect.style.borderWidth = '2px';
                }
            });

            alert(`✅ ${selectedRows.length} rows set to Accept. Please select Bundle Status for each row.`);
        }

        // Reject All Selected Rows
        function rejectAllSelected() {
            const selectedRows = document.querySelectorAll('input[name="selectRow"]:checked');

            if (selectedRows.length === 0) {
                alert('❌ Please select at least one row to reject.');
                return;
            }

            selectedRows.forEach(checkbox => {
                const index = checkbox.value;
                const row = checkbox.closest('tr');
                const acceptBtn = row.querySelector('.accept-btn');
                const rejectBtn = row.querySelector('.reject-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');
                const rejectReasonInput = row.querySelector('.reject-reason-input');

                // Set to reject state
                rejectBtn.classList.add('active');
                acceptBtn.classList.remove('active');

                // Enable reject reason, disable bundle status
                rejectReasonInput.disabled = false;
                bundleStatusSelect.disabled = true;
                bundleStatusSelect.value = '';
                bundleStatusSelect.style.borderColor = '#ddd';
                bundleStatusSelect.style.borderWidth = '1px';

                // Mark reject reason as required
                if (!rejectReasonInput.value.trim()) {
                    rejectReasonInput.style.borderColor = '#e74c3c';
                    rejectReasonInput.style.borderWidth = '2px';
                }
            });

            alert(`❌ ${selectedRows.length} rows set to Reject. Please enter Reject Reason for each row.`);
        }
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
                e.preventDefault();
                if (currentMode === 'pending') {
                    document.getElementById('searchInput').focus();
                } else if (currentMode === 'allData') {
                    document.getElementById('allDataSearchInput').focus();
                }
            }
        });

    </script>
</body>
</html>