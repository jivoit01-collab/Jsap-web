        function checkAndProcessContactId(contactId, contactData) {
            const idInput = document.getElementById("contactIdInput");
            const errorDiv = document.getElementById("contact-id-error");
            const idCell = document.getElementById("contact-id-cell");
            if (!contactId) {
            alert("Contact ID is missing.");
            return;
        }
        fetch(`/api/BPmaster/CheckContactUid?contactUid=${encodeURIComponent(contactId)}`)
        .then(res => {
            if (!res.ok) throw new Error("Bad request");
            return res.json();
        })
        .then(data => {
            const msg = (data.data?.message || "").toLowerCase();

            if (msg.includes("exists")) {
                // ❌ ID already exists — show input and error
                idInput.value = contactId;
                idCell.style.display = "table-cell";
                idInput.removeAttribute("readonly");
                idInput.classList.add("error");
                errorDiv.textContent = "Contact ID already exists. Please modify it.";
                errorDiv.style.display = "block";

                // Attach input listener only once
                if (!idInput.dataset.listenerAttached) {
                    idInput.addEventListener("input", () => {
                        const newId = idInput.value.trim();
                        if (!newId) return;

                        fetch(`/api/BPmaster/CheckContactUid?contactUid=${encodeURIComponent(newId)}`)
                            .then(r => r.json())
                            .then(result => {
                                const newMsg = (result.data?.message || "").toLowerCase();

                                if (newMsg.includes("exists")) {
                                    idInput.classList.add("error");
                                    errorDiv.textContent = "Contact ID already exists.";
                                    errorDiv.style.display = "block";
                                } else if (newMsg.includes("not found")) {
                                    // ✅ Unique ID entered
                                    idInput.classList.remove("error");
                                    errorDiv.style.display = "none";
                                    idInput.setAttribute("readonly", true);
                                    idCell.style.display = "none";

                                    addContactRow(contactData, newId);
                                    resetContactForm();
                                    showContactSuccessMessage("Contact added successfully!");
                                }
                            });
                    });

                    idInput.dataset.listenerAttached = "true";
                }

            } else if (msg.includes("not found")) {
                // ✅ ID is unique from the beginning
                idInput.value = contactId;
                idInput.setAttribute("readonly", true);
                idCell.style.display = "none";
                errorDiv.style.display = "none";

                addContactRow(contactData, contactId);
                resetContactForm();
                showContactSuccessMessage("Contact added successfully!");
            } else {
                alert("Unexpected API response");
                console.warn(data);
            }
        })
        .catch(err => {
            console.error("Error:", err);
            alert("Something went wrong while checking Contact ID.");
        });
        }

        function generateContactId(firstName, lastName) {
            const fn = firstName.trim().toUpperCase().replace(/[^A-Z]/g, '');
            const ln = lastName.trim().toUpperCase().replace(/[^A-Z]/g, '');

            return fn + " " + ln;
        }        

