        async function searchStockCountData() {
            console.log('=== SEARCHING STOCK COUNT DATA ===');
            console.log('Current filters:', searchFilters);

            showLoadingOverlay('Searching stock count data...');

            const searchButton = document.getElementById('searchButton');
            searchButton.disabled = true;
            searchButton.innerHTML = '🔍 Searching...';

            try {
                if (!validateCompanyId()) {
                    throw new Error('Company ID validation failed');
                }

                // Build request data without lot number
                const requestData = {
                    lotNumber: '', // Always empty since lot number is handled by omni search
                    unit: searchFilters.unit ? searchFilters.unit.code || searchFilters.unit.name : '',
                    location: searchFilters.location ? searchFilters.location.name : '',
                    warehouse: isAllSelected('warehouse') ? 'ALL' :
                        searchFilters.warehouse.length > 0 ?
                        searchFilters.warehouse.filter(w => w.id !== 'SELECT_ALL').map(w => w.id).join(',') : '',
                    itemGroup: isAllSelected('itemGroup') ? 'ALL' :
                        searchFilters.itemGroup.length > 0 ?
                        searchFilters.itemGroup.filter(g => g.id !== 'SELECT_ALL').map(g => g.id).join(',') : '',
                    itemSubGroup: isAllSelected('subGroup') ? 'ALL' :
                        searchFilters.subGroup.length > 0 ?
                        searchFilters.subGroup.filter(s => s.id !== 'SELECT_ALL').map(s => s.id).join(',') : '',
                    status: searchFilters.status ? searchFilters.status.code || searchFilters.status.name : ''
                };

                console.log('FINAL Search request data:', requestData);

                // Call search API
                const response = await apiCallPost('/api/InventoryAudit/GetStockCountDataByFilter', requestData);

                if (response && response.success) {
                    stockCountData = response.data;
                    displayedData = response.data;

                    // Apply lot number search if active
                    if (lotNumberSearchValue) {
                        performLotNumberSearch(lotNumberSearchValue);
                    } else {
                        displayStockCountData(response.data);
                    }
                } else {
                    throw new Error(response?.message || 'Search failed');
                }

            } catch (error) {
                console.error('Search failed:', error);
                showGlobalError('Search failed: ' + error.message);
                displayStockCountData({ headers: [], itemGroups: [], itemSubGroups: [], warehouse: [] });
            } finally {
                hideLoadingOverlay();
                searchButton.disabled = false;
                searchButton.innerHTML = '🔍 Search Audit Data';
            }
        }

