@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JSAP Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
        }

        .container-wrapper {
            display: flex;
            width: 100%;
            height: 100vh;
        }

        .left-section {
            width: 50%;
            position: relative;
            overflow: hidden;
            background-color: #002147;
        }

        .slider {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

            .slider img {
                position: absolute;
                object-fit: cover;
                transition: opacity 1s ease-in-out;
            }

                .slider img:first-child {
                    opacity: 1;
                }

        .right-section {
            width: 50%;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: #fff;
        }

        .input-field {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 15px;
        }

        .password-wrapper {
            position: relative;
        }

            .password-wrapper .input-field {
                padding-right: 46px;
            }

        .password-toggle {
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            width: 28px;
            height: 28px;
            border: 0;
            background: transparent;
            color: #002147;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            padding: 0;
        }

            .password-toggle svg {
                width: 20px;
                height: 20px;
            }

            .password-toggle:focus {
                outline: 2px solid rgba(0, 33, 71, 0.25);
                outline-offset: 2px;
                border-radius: 4px;
            }

        .btn {
            width: 100%;
            padding: 12px;
            background: #002147;
            border: none;
            color: white;
            font-size: 16px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
        }

            .btn:hover {
                background: #001b36;
            }

            .btn:disabled {
                cursor: not-allowed;
                opacity: 0.85;
            }

        .error-message {
            color: red;
            font-size: 14px;
            margin-top: 10px;
        }

        .quote-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #002147;
            padding: 30px;
            border-radius: 10px;
            text-align: justify;
            max-width: 80%;
        }

        blockquote {
            color: #f9bd7c;
            font-size: 20px;
            margin: 0;
        }

        .flex-container {
            display: flex;
            align-items: center; /* Ensure everything is centered vertically */
            gap: 10px; /* Space between image and text */
            margin-top: 20px; /* Space between quote and citation */
        }

        .image-container {
            flex-shrink: 0;
            width: 60px; /* Set a fixed width */
            height: 60px; /* Set a fixed height */
        }

        .baba-img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
        }

        .text-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .name, .designation {
            margin: 0;
            color: #f9bd7c;
            line-height: 1.3; /* Improve line spacing */
        }

    </style>
</head>
<body>
    <div class="container-wrapper">
        <div class="left-section">
            <div class="slider">
                <div class="quote-container">
                    <blockquote>
                        <p><b>Adoption of renewable sources of energy not only helps in enhancing the sustainability of academies but also contributes a lot to the mother planet.</b></p>

                        <div class="flex-container">
                            <div class="image-container">
                                <img src="/images/baba-iqbal-singh-ji.png" alt="Baba Iqbal Singh Ji" class="baba-img">
                            </div>
                            <div class="text-container">
                                <h5 class="name" style="font-size:12px">Baba Iqbal Singh Ji</h5>
                                <h5 class="designation" style="font-size:12px">Former Director, Agricultural (HP)</h5>
                            </div>
                        </div>

                    </blockquote>
                </div>
            </div>
        </div>
        <div class="right-section">
            <div class="text-center mb-4">
                <img src="~/images/JSAP-LOGO.png" alt="JSAP Logo" width="80">
                <h2 style="color:#002147"><b>Welcome to Jivo Infotech</b></h2>
            </div>

            <form id="loginForm">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" id="username" name="Username" class="input-field" placeholder="Enter your username" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <div class="password-wrapper">
                        <input type="password" id="password" name="Password" class="input-field" placeholder="Enter your password" required />
                        <button type="button" class="password-toggle" id="togglePassword" aria-label="Show password" aria-pressed="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn" id="loginSubmitBtn">Sign In</button>
                <p id="error" style="color:red;"></p>
            </form>

            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <p class="error-message">@ViewBag.ErrorMessage</p>
            }
        </div>
    </div>
    <script>
        let loginInProgress = false;
        const passwordInput = document.getElementById("password");
        const togglePasswordBtn = document.getElementById("togglePassword");

        togglePasswordBtn.addEventListener("click", function () {
            const isPasswordHidden = passwordInput.type === "password";
            passwordInput.type = isPasswordHidden ? "text" : "password";
            togglePasswordBtn.setAttribute("aria-label", isPasswordHidden ? "Hide password" : "Show password");
            togglePasswordBtn.setAttribute("aria-pressed", isPasswordHidden ? "true" : "false");
        });

        document.getElementById("loginForm").addEventListener("submit", async function (e) {
            e.preventDefault();
            if (loginInProgress) return;
            loginInProgress = true;

            const submitBtn = e.target.querySelector("button[type='submit']");
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Signing in...';

            const loginUser = document.getElementById("username").value;
            const loginPassword = document.getElementById("password").value;
            const errorEl = document.getElementById("error");

            try {
                const loginRes = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ loginUser: loginUser, password: loginPassword })
                });

                if (!loginRes.ok) {
                    const errText = await loginRes.text();
                    let errData;
                    try { errData = JSON.parse(errText); } catch { errData = { message: "Login failed" }; }
                    throw new Error(errData.message || "Invalid login credentials");
                }

                const loginData = await loginRes.json();
                if (!loginData.success || !loginData.user) {
                    throw new Error(loginData.message || "Login failed");
                }

                const userId = loginData.user.userId;
                const userName = loginData.user.userName || loginData.user.firstName + " " + loginData.user.lastName;

                if (!userId || userId === 0) {
                    throw new Error("Invalid user data received");
                }

                const companyRes = await fetch(`/api/auth/getcompanies?userId=${userId}`, {
                    credentials: 'include'
                });
                if (!companyRes.ok) {
                    throw new Error("Failed to fetch companies");
                }
                const companyText = await companyRes.text();
                let companyData;
                try {
                    companyData = JSON.parse(companyText);
                } catch {
                    throw new Error("Server returned invalid response for companies");
                }

                if (!companyData.success || !companyData.data) {
                    throw new Error(companyData.message || "No companies found for your account");
                }

                localStorage.setItem("userId", userId);
                localStorage.setItem("userName", userName);
                localStorage.setItem("companies", JSON.stringify(companyData.data));

                const sessionRes = await fetch('/websession/set', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({
                        userId: userId,
                        userName: userName,
                        companies: companyData.data
                    })
                });

                if (!sessionRes.ok) {
                    const sessText = await sessionRes.text();
                    console.error("Session set failed:", sessText);
                    throw new Error("Failed to initialize session");
                }

                const sessionData = await sessionRes.json();
                console.log("Session set response:", sessionData);

                window.location.href = "/DashboardWeb/Index";

            } catch (err) {
                console.error("Login error:", err);
                if (errorEl) {
                    errorEl.innerText = err.message || "An unexpected error occurred";
                    errorEl.style.display = "block";
                } else {
                    alert(err.message || "An unexpected error occurred");
                }
                loginInProgress = false;
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            const errorEl = document.getElementById("error");
            if (errorEl) errorEl.style.display = "none";

            fetch('/api/Auth/refresh', {
                method: 'POST',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({})
            }).then(function(response) {
                if (response.ok) {
                    window.location.href = "/DashboardWeb/Index";
                }
            }).catch(function() { });
        });
    </script>
</body>
</html>
