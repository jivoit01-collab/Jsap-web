            function v1_expandPathTo(nodeId){
                var p=nodeId.split('-');
                if(p[0]==='hod') v1_exp['hod-'+p[1]]=true;
                else if(p[0]==='dept'){ v1_exp['hod-'+p[1]]=true; v1_exp[nodeId]=true; }
                else if(p[0]==='sd'){ var h=RAW_DATA[+p[1]];if(!h)return;var s=h.subs[+p[2]];if(!s)return;v1_exp[h.id]=true;var di=h.depts.indexOf(s.dept);if(di<0)di=0;v1_exp['dept-'+p[1]+'-'+di]=true; }
                else if(p[0]==='sh'){ var h=RAW_DATA[+p[1]];if(!h)return;var s=h.subs[+p[2]];if(!s)return;v1_exp[h.id]=true;var di=h.depts.indexOf(s.dept);if(di<0)di=0;v1_exp['dept-'+p[1]+'-'+di]=true;v1_exp['sd-'+p[1]+'-'+p[2]]=true; }
                else if(p[0]==='ex'||p[0]==='exd'){ var h=RAW_DATA[+p[1]];if(!h)return;var s=h.subs[+p[2]];if(!s)return;v1_exp[h.id]=true;var di=h.depts.indexOf(s.dept);if(di<0)di=0;v1_exp['dept-'+p[1]+'-'+di]=true;v1_exp['sd-'+p[1]+'-'+p[2]]=true;if(p[0]==='ex')v1_exp['sh-'+p[1]+'-'+p[2]+'-'+p[3]]=true; }
            }

            /* SVG CONNECTOR LINES */
