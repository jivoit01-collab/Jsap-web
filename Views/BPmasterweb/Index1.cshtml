        // Form cancellation
        function cancelForm() {
            if (confirm("Are you sure you want to cancel? All unsaved changes will be lost.")) {
                // Reset all form fields
                document.querySelectorAll('input, select').forEach(field => {
                    if (field.type === 'radio' || field.type === 'checkbox') {
                        field.checked = field.defaultChecked;
                    } else {
                        field.value = field.defaultValue || '';
                    }
                });

                // Clear error messages
                document.querySelectorAll('.error-message').forEach(error => {
                    error.style.display = 'none';
                });
                document.querySelectorAll('.form-group').forEach(group => {
                    group.classList.remove('error');
                });

                // Clear attachments
                attachments = [];
                uploadedFiles = [];
                if (typeof renderAttachments === 'function') {
                    renderAttachments();
                }
                if (typeof clearMessages === 'function') {
                    clearMessages();
                }

                // Re-lock the form
                lockFormElements();

                // Reload initial data
                loadGroups();
                loadChain();
                loadMainGroups();
                loadStates('billing');
                loadStates('shipping');
                loadPaymentTerms();
                loadMSMEtype();
                console.log("Form cancelled and reset");
                alert("Form has been reset!");
            }
        }

        // Initialize form validation listeners
        function initializeFormValidation() {
            const formFields = document.querySelectorAll('input, select');
            formFields.forEach(field => {
                // Blur validation
                field.addEventListener('blur', function() {
                    if (typeof validateField === 'function') {
                        validateField(this);
                    }
                });

                // Input validation for error clearing
                field.addEventListener('input', function() {
                    const formGroup = this.closest('.form-group');
                    if (formGroup && formGroup.classList.contains('error')) {
                        if (typeof validateField === 'function') {
                            validateField(this);
                        }
                    }
                });
            });
        }

        // Main initialization function
        function initializeForm() {
            console.log('Initializing Business Partner Form...');

            // Add CSS for form locking
            addFormLockingCSS();

            // Initially lock all fields except type and branch
            lockFormElements();

            // Setup form unlock listeners
            setupFormUnlockListeners();

            // Initialize existing functions
            if (typeof toggleFormSections === 'function') {
                toggleFormSections(false);
            }

            if (typeof setupEventListeners === 'function') {
                setupEventListeners();
            }

            if (typeof checkFormUnlock === 'function') {
                checkFormUnlock();
            }

            if (typeof updateCodeField === 'function') {
                updateCodeField();
            }

            // Load initial data
            if (typeof loadPaymentTerms === 'function') {
                loadPaymentTerms();
            }

            // Note: States will be loaded when country is selected (not initially)

            // Initialize validation
            initializeFormValidation();

            // Setup address synchronization
            if (typeof setupAddressSync === 'function') {
                setupAddressSync();
            }

            // Setup BP name validation
            if (typeof setupBPNameValidation === 'function') {
                setupBPNameValidation();
            }

            // Setup PAN validation
            if (typeof loadExistingPANs === 'function') {
                loadExistingPANs().then(() => {
                    if (typeof setupPANValidation === 'function') {
                        setupPANValidation();
                    }
                });
            }

            // Setup TAN validation
             if (typeof setupTANValidation === 'function') {
               
                setupTANValidation();
            }

            // Setup click outside handlers
            if (typeof setupClickOutsideHandler === 'function') {
                setupClickOutsideHandler();
            }

            // Load initial data and setup dropdowns
            if (typeof initializeAllDropdowns === 'function') {
                initializeAllDropdowns();
            } else {
                // Fallback - call individual functions
                if (typeof initializePaymentDropdowns === 'function') {
                    initializePaymentDropdowns();
                }

                if (typeof setupGSTValidation === 'function') {
                    setupGSTValidation();
                }

                if (typeof setupContactValidationListeners === 'function') {
                    setupContactValidationListeners();
                }

                if (typeof setupAddressSync === 'function') {
                    setupAddressSync();
                }
            }

            console.log('Business Partner Form initialized successfully');
        }

        // DOM Content Loaded Event
        document.addEventListener("DOMContentLoaded", initializeForm);

