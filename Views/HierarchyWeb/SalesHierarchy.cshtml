async function saveEdit() {
    if (!editRowId) return;
    const btn = document.getElementById('btnSaveEdit');
    btn.disabled = true; btn.textContent = 'Saving…';

    const payload = {
        salesHierarchyId: editRowId,
        empCode:     document.getElementById('edit_empCode').value.trim(),
        empName:     document.getElementById('edit_empName').value.trim(),
        state:       document.getElementById('edit_state').value,
        groupName:   document.getElementById('edit_groupName').value,
        designation: document.getElementById('edit_designation').value,
        isActive:    document.getElementById('edit_isActive').value === '1'
    };

    try {
        const res  = await fetchPost(API.updateRow, payload);
        if (res.success) {
            showToast('Row updated successfully', 'success');
            closeEditModal();
            // Update in-place
            const idx = allRows.findIndex(r => r.salesHierarchyId === editRowId);
            if (idx >= 0) Object.assign(allRows[idx], payload);
            applyFilters();
            loadStats();
        } else {
            showToast(res.message || 'Update failed', 'error');
        }
    } catch(e) { showToast('Error: ' + e.message, 'error'); }
    finally { btn.disabled = false; btn.textContent = 'Save Changes'; }
}

