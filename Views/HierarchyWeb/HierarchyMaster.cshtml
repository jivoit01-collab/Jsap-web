    function processXl(file){
        if(!file.name.match(/\.xlsx?$/i)){toast('Upload .xlsx file','err');return;}
        const reader=new FileReader();
        reader.onload=e=>{
            try{
                const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'});
                const pickedSheetName = pickHierarchySheetName(wb);
                if(!pickedSheetName){toast('Could not find a hierarchy data sheet in this workbook','err');return;}
                const ws=wb.Sheets[pickedSheetName];
                const json=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
                pendingXl=[];
                const headerRow=(json[0]||[]).map(normalizeHeader);
                const hodNameIdx=findColumnIndex(headerRow,['hodname','hod']);
                const hodCodeIdx=findColumnIndex(headerRow,['hodcode','hodemployeecode','hodempcode']);
                const deptIdx=findColumnIndex(headerRow,['department','dept']);
                const subDeptIdx=findColumnIndex(headerRow,['subdepartment','subdept']);
                const subHodNameIdx=findColumnIndex(headerRow,['subhodname','subhod']);
                const subHodCodeIdx=findColumnIndex(headerRow,['subhodcode','subhodemployeecode','subhodempcode']);
                const subHodDesignationIdx=findColumnIndex(headerRow,['subhoddesignation','subhoddesig','subdesignation']);
                const execNameIdx=findColumnIndex(headerRow,['executivename','execname','executive']);
                const execCodeIdx=findColumnIndex(headerRow,['executivecode','execcode','executiveemployeecode']);
                const execDesignationIdx=findColumnIndex(headerRow,['executivedesignation','execdesignation','execdesig']);
                for(let i=1;i<json.length;i++){
                    const r=json[i];
                    const hodName=cl(sheetCellAt(ws, i, hodNameIdx, 2));
                    const hodCode=cl(sheetCellAt(ws, i, hodCodeIdx, 13));
                    const department=cl(sheetCellAt(ws, i, deptIdx, 1));
                    const subDepartment=cl(sheetCellAt(ws, i, subDeptIdx, 3));
                    const subHodName=cl(sheetCellAt(ws, i, subHodNameIdx, 5));
                    const subHodCode=cl(sheetCellAt(ws, i, subHodCodeIdx, 12));
                    const subHodDesignation=cl(sheetCellAt(ws, i, subHodDesignationIdx, null));
                    const execName=cl(sheetCellAt(ws, i, execNameIdx, 7));
                    if(!hodName&&!subHodName&&!execName)continue;
                    pendingXl.push({
                        rowNumber:i+1,
                        hodName:hodName,
                        hodCode:hodCode,
                        department:department,
                        subDepartment:subDepartment,
                        subHodName:subHodName,
                        subHodCode:subHodCode,
                        subHodDesignation:subHodDesignation,
                        execName:execName,
                        execCode:cl(sheetCellAt(ws, i, execCodeIdx, 11)),
                        execDesignation:cl(sheetCellAt(ws, i, execDesignationIdx, 6))
                    });
                }
                const pv=document.getElementById('importPreview');
                document.getElementById('previewInfo').textContent=`✓ ${pendingXl.length} rows found in "${file.name}" (${pickedSheetName})`;
                document.getElementById('previewSample').innerHTML=pendingXl.slice(0,5).map(r=>`Row${r.rowNumber}: HOD=${r.hodCode||'?'}·${r.hodName} | ${r.department} | SubHOD=${r.subHodCode||'—'} | Exec=${r.execCode||'—'}·${r.execName}`).join('<br>');
                pv.style.display='block';
                document.getElementById('importResult').style.display='none';
            }catch(e){toast('Excel read error: '+e.message,'err');}
        };
        reader.readAsArrayBuffer(file);
    }
    function pickHierarchySheetName(wb){
        const requiredHints=['department','hod','executivename'];
        let bestName='';
        let bestScore=-1;
        (wb.SheetNames||[]).forEach(name=>{
            const ws=wb.Sheets[name];
            const json=XLSX.utils.sheet_to_json(ws,{header:1,defval:'',range:0});
            const headerRow=(json[0]||[]).map(normalizeHeader);
            const score=requiredHints.reduce((acc,h)=>acc+(headerRow.some(col=>col.includes(h))?1:0),0)
                + (headerRow.some(col=>col.includes('subhod'))?1:0)
                + (headerRow.some(col=>col.includes('executivecode')||col.includes('execcode'))?1:0);
            if(score>bestScore){
                bestScore=score;
                bestName=name;
            }
        });
        return bestScore>=3 ? bestName : '';
    }
    function normalizeHeader(v){return String(v||'').toLowerCase().replace(/[^a-z0-9]/g,'');}
    function findColumnIndex(headers, aliases){
        for(const alias of aliases){
            const idx=headers.indexOf(alias);
            if(idx!==-1)return idx;
        }
        return -1;
    }
    function rawSheetCellValue(ws,rowIdx,colIdx){
        if(colIdx===null||colIdx===undefined||colIdx<0)return '';
        const direct=ws[XLSX.utils.encode_cell({r:rowIdx,c:colIdx})];
        if(direct && direct.v!==undefined && direct.v!==null) return direct.v;
        const merges=ws['!merges']||[];
        for(const merge of merges){
            if(rowIdx>=merge.s.r && rowIdx<=merge.e.r && colIdx>=merge.s.c && colIdx<=merge.e.c){
                const root=ws[XLSX.utils.encode_cell({r:merge.s.r,c:merge.s.c})];
                return (root && root.v!==undefined && root.v!==null) ? root.v : '';
            }
        }
        return '';
    }
    function sheetCellAt(ws,rowIdx,idx,fallbackIdx){
        if(idx!==-1)return rawSheetCellValue(ws,rowIdx,idx);
        if(fallbackIdx===null||fallbackIdx===undefined)return '';
        return rawSheetCellValue(ws,rowIdx,fallbackIdx);
    }
    function cellAt(row, idx, fallbackIdx){
        if(idx!==-1)return row[idx];
        if(fallbackIdx===null||fallbackIdx===undefined)return '';
        return row[fallbackIdx];
    }
    function cl(v){if(!v&&v!==0)return'';const s=String(v).trim();if(!s||s==='0'||s.startsWith('=')||s==='#N/A'||s.startsWith('#'))return'';return s;}
    function clNumber(v){
        if(v===null||v===undefined||v==='')return null;
        const s=String(v).replace(/,/g,'').replace(/[^\d.-]/g,'').trim();
        if(!s)return null;
        const n=Number(s);
        return Number.isFinite(n)?n:null;
    }
    function clearImport(){
        pendingXl=[];
