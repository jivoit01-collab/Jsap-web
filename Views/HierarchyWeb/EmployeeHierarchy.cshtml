    let _ehAkKeyExists = false;

    function validateAdminKeyFormat(value) {
        return value
            && value.length >= 6
            && /[A-Z]/.test(value)
            && /[^A-Za-z0-9]/.test(value);
    }

    async function openEhAdminKeyModal() {
        ['ehAk_old','ehAk_new','ehAk_confirm'].forEach(id => {
            const el = document.getElementById(id); if (el) el.value = '';
        });
        const errEl = document.getElementById('ehAdminKeyErr');
        if (errEl) errEl.style.display = 'none';

        try {
            const res = await fetch(`${apiBase}/GetAdminKeyStatus`);
            const status = await res.json();
            if (!status.hasPermission) {
                alert('You do not have permission to manage the admin salary key.');
                return;
            }
            _ehAkKeyExists = !!status.keyExists;
        } catch(e) {
            alert('Could not load key status.');
            return;
        }

        const oldWrap = document.getElementById('ehAk_old_wrap');
        const title   = document.getElementById('ehAdminKeyTitle');
        const newLbl  = document.getElementById('ehAk_new_label');
        if (_ehAkKeyExists) {
            oldWrap.style.display = '';
            title.textContent  = 'Change Admin Key';
            newLbl.textContent = 'New Admin Key *';
        } else {
            oldWrap.style.display = 'none';
            title.textContent  = 'Create Admin Key';
            newLbl.textContent = 'Admin Key *';
        }

        document.getElementById('ehAdminKeyModal').classList.add('open');
        setTimeout(() => document.getElementById(_ehAkKeyExists ? 'ehAk_old' : 'ehAk_new').focus(), 100);
    }

    function closeEhAdminKeyModal() {
        document.getElementById('ehAdminKeyModal').classList.remove('open');
    }

    async function submitEhAdminKey() {
        const oldKey     = document.getElementById('ehAk_old').value;
        const newKey     = document.getElementById('ehAk_new').value;
        const confirmKey = document.getElementById('ehAk_confirm').value;
        const errEl      = document.getElementById('ehAdminKeyErr');
        errEl.style.display = 'none';

        if (_ehAkKeyExists && !oldKey) {
            errEl.textContent = 'Enter the current key'; errEl.style.display = 'block'; return;
        }
        if (!validateAdminKeyFormat(newKey)) {
            errEl.textContent = 'New key must be at least 6 characters and include one uppercase letter and one special character'; errEl.style.display = 'block'; return;
        }
        if (newKey !== confirmKey) {
            errEl.textContent = 'Keys do not match'; errEl.style.display = 'block'; return;
        }

        const btn = document.getElementById('ehAdminKeySubmitBtn');
        btn.disabled = true; btn.textContent = 'Saving…';

        try {
            const res = await fetch(`${apiBase}/SetAdminSalaryKey`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ oldKey: _ehAkKeyExists ? oldKey : null, adminKey: newKey })
            });
            const data = await res.json();
            if (data.success) {
                closeEhAdminKeyModal();
                alert(data.message || 'Admin key saved successfully.');
            } else {
                errEl.textContent = data.message || 'Failed to save key';
                errEl.style.display = 'block';
            }
        } catch(e) {
            errEl.textContent = 'Network error';
            errEl.style.display = 'block';
        } finally {
            btn.disabled = false; btn.textContent = 'Save Key';
        }
    }

    // ══════════════════════════════════════════════════════
    // SALARY PERMISSION MODAL
    // ══════════════════════════════════════════════════════
    let _salPermEmployees = [];
    let _salPermSelected = new Set();
    let _salPermSearchTerm = '';

    async function openSalaryPermModal() {
        document.getElementById('salPermModal').classList.add('open');
        document.getElementById('salPermList').innerHTML = '<div style="color:#64748b;padding:12px">Loading employees…</div>';
        document.getElementById('salPermErr').style.display = 'none';
        const searchInput = document.getElementById('salPermSearch');
        if (searchInput) searchInput.value = '';
        _salPermSearchTerm = '';

        try {
            const data = await apiJson(`${apiBase}/GetEmployeesForSalaryPermission`);
            _salPermEmployees = data.data ?? data.Data ?? [];
            _salPermSelected = new Set(_salPermEmployees.filter(employee => pick(employee, ['viewSalary', 'ViewSalary'], false)).map(employee => pick(employee, ['employeeId', 'EmployeeId'])));
            renderSalPermList();
        } catch (error) {
            document.getElementById('salPermList').innerHTML = '<div style="color:#991b1b;padding:12px">Failed to load employees.</div>';
        }
    }

    function getSalaryPermissionSearchBlob(employee) {
        return normalizeText([
            pick(employee, ['employeeName', 'EmployeeName'], ''),
            pick(employee, ['employeeCode', 'EmployeeCode'], ''),
            pick(employee, ['roleName', 'RoleName'], ''),
            pick(employee, ['designation', 'Designation'], ''),
            pick(employee, ['departmentName', 'DepartmentName', 'primaryDepartmentName', 'PrimaryDepartmentName'], ''),
            pick(employee, ['subDepartmentName', 'SubDepartmentName', 'primarySubDepartmentName', 'PrimarySubDepartmentName'], '')
        ].join(' '));
    }

    function filterSalaryPermissionList() {
        _salPermSearchTerm = normalizeText(document.getElementById('salPermSearch')?.value);
        renderSalPermList();
    }

    function renderSalPermList() {
        const list = document.getElementById('salPermList');
        const items = !_salPermSearchTerm
            ? _salPermEmployees
            : _salPermEmployees.filter(employee => getSalaryPermissionSearchBlob(employee).includes(_salPermSearchTerm));
        if (!items.length) {
            list.innerHTML = '<div style="color:#64748b;padding:12px">No employees found.</div>';
            return;
        }

        list.innerHTML = items.map(employee => {
            const employeeId = pick(employee, ['employeeId', 'EmployeeId']);
            const checked = _salPermSelected.has(employeeId) ? 'checked' : '';
            const deptText = [
                pick(employee, ['departmentName', 'DepartmentName', 'primaryDepartmentName', 'PrimaryDepartmentName'], ''),
                pick(employee, ['subDepartmentName', 'SubDepartmentName', 'primarySubDepartmentName', 'PrimarySubDepartmentName'], '')
            ].filter(Boolean).join(' / ');
            return `<label style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid #e2e8f0;cursor:pointer;font-size:13px">
                <input type="checkbox" ${checked} onchange="toggleSalPerm(${employeeId}, this.checked)" style="width:15px;height:15px;accent-color:#123f6d;cursor:pointer;flex-shrink:0" />
                <span style="flex:1">
                    <strong>${escapeHtml(pick(employee, ['employeeName', 'EmployeeName'], ''))}</strong>
                    <span style="font-size:11px;color:#64748b;font-family:monospace">${escapeHtml(pick(employee, ['employeeCode', 'EmployeeCode'], ''))}</span>
                    ${deptText ? `<div style="font-size:11px;color:#64748b;margin-top:2px">${escapeHtml(deptText)}</div>` : ''}
                </span>
                <span style="font-size:11px;color:#475569;background:#f1f5f9;border-radius:20px;padding:2px 8px">${escapeHtml(pick(employee, ['roleName', 'RoleName'], ''))}</span>
            </label>`;
        }).join('');
    }

    function toggleSalPerm(employeeId, checked) {
        if (checked) _salPermSelected.add(employeeId);
        else _salPermSelected.delete(employeeId);
    }

    function closeSalaryPermModal() {
        document.getElementById('salPermModal').classList.remove('open');
    }

    async function submitSalaryPerm() {
        const errEl = document.getElementById('salPermErr');
        errEl.style.display = 'none';
        const btn = document.getElementById('salPermSubmitBtn');
        btn.disabled = true; btn.textContent = 'Saving…';

        try {
            const res = await fetch(`${apiBase}/SetSalaryPermission`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ employeeIds: [..._salPermSelected] })
            });
            const data = await res.json();
            if (data.success) {
                closeSalaryPermModal();
                alert(data.message || 'Salary permissions updated.');
            } else {
                errEl.textContent = data.message || 'Failed to update permissions';
                errEl.style.display = 'block';
            }
        } catch(e) {
            errEl.textContent = 'Network error';
            errEl.style.display = 'block';
        } finally {
            btn.disabled = false; btn.textContent = 'Save Permissions';
        }
    }

    // ══════════════════════════════════════════════════════
    // UNLOCK SALARY — Tankha Payee API
    // ══════════════════════════════════════════════════════
    function openUnlockSalaryModal() {
        document.getElementById('ehTankhaUsername').value = '';
        document.getElementById('ehTankhaPassword').value = '';
        document.getElementById('ehTankhaAction').value = 'belowfourtyemployee';
        document.getElementById('ehTankhaErr').style.display = 'none';
        document.getElementById('ehTankhaModal').classList.add('open');
        setTimeout(() => document.getElementById('ehTankhaUsername').focus(), 100);
    }

    function closeUnlockSalaryModal() {
        document.getElementById('ehTankhaPassword').value = '';
        document.getElementById('ehTankhaModal').classList.remove('open');
    }

    async function submitTankhaFetch() {
        const username = document.getElementById('ehTankhaUsername').value.trim();
        const pwdField = document.getElementById('ehTankhaPassword');
        const pwd      = pwdField.value;
        const action   = document.getElementById('ehTankhaAction').value;
        const errEl    = document.getElementById('ehTankhaErr');
        errEl.style.display = 'none';

        if (!username) { errEl.textContent = 'Username is required'; errEl.style.display = 'block'; return; }
        if (!pwd)      { errEl.textContent = 'Password is required';  errEl.style.display = 'block'; return; }
        if (!action)   { errEl.textContent = 'Action is required';    errEl.style.display = 'block'; return; }

        const btn = document.getElementById('ehTankhaSubmitBtn');
        btn.disabled = true; btn.textContent = 'Loading…';

        try {
            const res = await fetch(`${apiBase}/UnlockSalarySession`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password: pwd, action })
            });
            pwdField.value = '';

            const data = await res.json();
            if (data.success) {
                closeUnlockSalaryModal();
                await loadAndShowSalary(data.expiresAt ?? data.ExpiresAt);
            } else {
                errEl.textContent = data.message || 'Failed. Check your credentials and try again.';
                errEl.style.display = 'block';
            }
        } catch(e) {
            pwdField.value = '';
            errEl.textContent = 'Network error'; errEl.style.display = 'block';
        } finally {
            btn.disabled = false; btn.textContent = 'Load Salaries';
        }
    }

    // ══════════════════════════════════════════════════════
    // SALARY COLUMN — inject / remove
    // ══════════════════════════════════════════════════════
    let _salaryTimerInterval = null;

    async function loadAndShowSalary(expiresAt) {
        try {
            const res  = await fetch(`${apiBase}/GetSalarySessionData`);
            const data = await res.json();
            if (!data.success) { alert(data.message || 'Could not load salary data.'); return; }
            const salaries = data.salaries ?? data.Salaries ?? {};
            injectSalaryColumn(salaries);
            startSalaryTimer(new Date(data.expiresAt ?? data.ExpiresAt ?? expiresAt));
        } catch(e) { alert('Could not load salary data.'); }
    }

    function injectSalaryColumn(salaryMap) {
        currentSalaryMap = salaryMap || {};
        renderEmployeeTable();
        document.querySelectorAll('.sal-col').forEach(el => el.style.display = '');
        document.getElementById('salaryTimerBadge').style.display = 'flex';
    }

    function removeSalaryColumn() {
        currentSalaryMap = {};
        renderEmployeeTable();
        document.querySelectorAll('.sal-col').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.sal-val').forEach(el => el.textContent = '—');
        document.getElementById('salaryTimerBadge').style.display = 'none';
        if (_salaryTimerInterval) { clearInterval(_salaryTimerInterval); _salaryTimerInterval = null; }
    }

    function startSalaryTimer(expiresAt) {
        if (_salaryTimerInterval) clearInterval(_salaryTimerInterval);
        const el = document.getElementById('salaryTimerText');

        function tick() {
            const remaining = Math.max(0, expiresAt - Date.now());
            const mins = String(Math.floor(remaining / 60000)).padStart(2, '0');
            const secs = String(Math.floor((remaining % 60000) / 1000)).padStart(2, '0');
            if (el) el.textContent = `${mins}:${secs}`;
            if (remaining <= 0) {
                clearInterval(_salaryTimerInterval);
                _salaryTimerInterval = null;
                removeSalaryColumn();
                fetch(`${apiBase}/ClearSalarySession`, { method: 'POST' });
                alert('Salary session has expired. All salary data has been cleared.');
            }
        }

        tick();
        _salaryTimerInterval = setInterval(tick, 1000);
    }

    async function manualLockSalary() {
        removeSalaryColumn();
        try { await fetch(`${apiBase}/ClearSalarySession`, { method: 'POST' }); } catch(e) {}
    }

    // ── On page load: restore active salary session if still valid ──
    document.addEventListener('DOMContentLoaded', async () => {
        try {
            const res  = await fetch(`${apiBase}/GetSalarySessionData`);
            const data = await res.json();
            if (data.success) {
                const salaries = data.salaries ?? data.Salaries ?? {};
                injectSalaryColumn(salaries);
                startSalaryTimer(new Date(data.expiresAt ?? data.ExpiresAt));
            }
        } catch(e) {}
    });
</script>

