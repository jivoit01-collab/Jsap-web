        function checkFormUnlock() {
            const type = document.querySelector('input[name="type"]:checked');
            const branch = document.getElementById("branch").value;
            const allFields = document.querySelectorAll("input, select, textarea");

            allFields.forEach(el => {
                if (["branch", "type"].includes(el.name || el.id)) return;
                el.disabled = !(type && branch);
            });
        }

        // BP Name validation and suggestions
        function setupBPNameValidation() {
            const bpNameField = document.getElementById("BPname");
            if (!bpNameField) return;

            bpNameField.addEventListener("input", async function() {
                const input = this;
                const query = input.value.trim().toLowerCase();
                const suggestionsBox = document.getElementById("bp-suggestions");
                const errorBox = document.getElementById("bpname-error");

                // Reset states
                errorBox.style.display = "none";
                errorBox.style.color = "";
                input.classList.remove("error");
                input.style.borderColor = "";

                if (query.length < 2) {
                    suggestionsBox.style.display = "none";
                    return;
                }

                const type = document.querySelector('input[name="type"]:checked')?.value;
                if (!type) {
                    suggestionsBox.style.display = "none";
                    return;
                }

                try {
                    const res = await fetch(`/api/BPmaster/BPGetCardInfo?company=${companyId}&BPType=${getBaseBpType()}`);
                    const data = await res.json();
                    omniBPList = Array.isArray(data) ? data : data.data;

                    const matches = omniBPList.filter(bp =>
                        bp.cardName?.toLowerCase().includes(query)
                    );

                    const exactMatch = matches.some(bp => bp.cardName?.toLowerCase() === query);

                    if (exactMatch) {
                        // Already exists
                        errorBox.style.display = "block";
                        errorBox.style.color = "#dc3545";
                        errorBox.textContent = "❌ Already exists, please write new.";
                        input.classList.add("error");
                        input.style.borderColor = "red";
                        suggestionsBox.style.display = "none";
                    } else {
                        // Valid new name
                        errorBox.style.display = "block";
                        errorBox.style.color = "green";
                        errorBox.textContent = "✓ Name is unique";
                        input.classList.remove("error");
                        input.style.borderColor = "green";

                        if (matches.length > 0) {
                            // Show suggestions
                            suggestionsBox.innerHTML = matches.map(bp => `
                                <div class="bp-suggestion-item" onclick="selectBPName('${bp.cardName.replace(/'/g, "\\'")}')">
                                    <strong>${bp.cardName}</strong>
                                    <small>${bp.address || ''}, ${bp.state || ''}</small>
                                    <small>GST: ${bp.gstRegnNo || '-'}</small>
                                </div>
                            `).join('');
                        } else {
                            suggestionsBox.innerHTML = `<div class="bp-suggestion-item">✅ Valid new name</div>`;
                        }
                        suggestionsBox.style.display = "block";
                    }
                } catch (err) {
                    console.error("Error loading BP data:", err);
                    suggestionsBox.style.display = "none";
                }
            });
        }

        function selectBPName(name) {
            const input = document.getElementById("BPname");
            const errorBox = document.getElementById("bpname-error");

            input.value = name;
            input.classList.add("error");
            input.style.borderColor = "red";
            errorBox.style.display = "block";
            errorBox.style.color = "#dc3545";
            errorBox.textContent = "❌ Already exists, please write new.";
            document.getElementById("bp-suggestions").style.display = "none";
        }

        // BP Filter Modal Functions
        function openBPFilter() {
            const type = document.querySelector('input[name="type"]:checked')?.value || '';
            if (!type) return alert("Please select type first");

            const url = `/api/BPmaster/BPGetCardInfo?company=${companyId}&BPType=${getBaseBpType()}`;

            fetch(url)
                .then(res => res.json())
                .then(data => {
                    const list = Array.isArray(data) ? data : data.data;
                    const tbody = document.querySelector('#bp-table tbody');
                    tbody.innerHTML = '';

                    list.forEach(item => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${item.cardCode}</td>
                            <td>${item.cardName}</td>
                            <td>${item.address}</td>
                            <td>${item.state}</td>
                            <td>${item.gstRegnNo || '-'}</td>
                        `;
                        tr.style.cursor = "pointer";
                        tr.onclick = () => {
                            document.getElementById("BPname").value = item.cardName;
                            closeBPFilter();
                        };
                        tbody.appendChild(tr);
                    });

                    document.getElementById("bp-modal").style.display = "block";
                })
                .catch(err => {
                    console.error("Error fetching BP info:", err);
                    alert("Failed to load BP list");
                });
        }

        function closeBPFilter() {
            document.getElementById("bp-modal").style.display = "none";
        }

        function filterBPTable() {
            const searchText = document.getElementById("bp-search").value.toLowerCase();
            const rows = document.querySelectorAll("#bp-table tbody tr");

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchText) ? "" : "none";
            });
        }

        // PAN validation setup
         function setupPANValidation() {
            const panInput = document.getElementById("pan");
            const panError = document.getElementById("pan-error");
            if (!panInput || !panError) return;

            panInput.addEventListener("input", () => {
                const panValue = panInput.value.toUpperCase().trim();
                const panRegex = /^[A-Z]{5}[0-9]{4}[A-Z]$/;

                // Reset styles
                panError.style.display = "none";
                panInput.style.borderColor = "";
                panInput.classList.remove("error");

                if (panValue.length === 10) {
                    if (!panRegex.test(panValue)) {
                        // Invalid format
                        panError.textContent = "❌ Invalid PAN format. Expected: ABCDE1234F";
                        panError.style.color = "#dc3545";
                        panError.style.display = "block";
                        panInput.style.borderColor = "red";
                        panInput.classList.add("error");
                    } else if (existingPANs.includes(panValue)) {
                        // Duplicate PAN
                        panError.textContent = "❌ Already exists, please enter a new PAN.";
                        panError.style.color = "#dc3545";
                        panError.style.display = "block";
                        panInput.style.borderColor = "red";
                        panInput.classList.add("error");
                    } else {
                        // Valid and unique
                        panError.textContent = "✓ PAN is valid and unique";
                        panError.style.color = "green";
                        panError.style.display = "block";
                        panInput.style.borderColor = "green";
                        panInput.classList.remove("error");
                    }
                } else if (panValue.length > 0 && panValue.length < 10) {
                    // Too short PAN input
                    panError.textContent = "❌ PAN must be exactly 10 characters";
                    panError.style.color = "#dc3545";
                    panError.style.display = "block";
                    panInput.style.borderColor = "red";
                    panInput.classList.add("error");
                }

                // Update the input with uppercase value
                panInput.value = panValue;
            });
        }

                function setupTANValidation() {
            const tanInput = document.getElementById("tan");
            const tanError = document.getElementById("tan-error");
            if (!tanInput || !tanError) return;

            tanInput.addEventListener("input", () => {
                const tanValue = tanInput.value.toUpperCase().trim();
                const tanRegex = /^[A-Z]{4}[0-9]{5}[A-Z]$/;

                // Reset styles
                tanError.style.display = "none";
                tanInput.style.borderColor = "";
                tanInput.classList.remove("error");

                if (tanValue.length === 10) {
                    if (!tanRegex.test(tanValue)) {
                        tanError.textContent = "❌ Invalid TAN format. Expected: ABCD12345E";
                        tanError.style.color = "#dc3545";
                        tanError.style.display = "block";
                        tanInput.style.borderColor = "red";
                        tanInput.classList.add("error");
                    } else {
                        tanError.textContent = "✓ Valid TAN format";
                        tanError.style.color = "green";
                        tanError.style.display = "block";
                        tanInput.style.borderColor = "green";
                        tanInput.classList.remove("error");
                    }
                } else if (tanValue.length > 0 && tanValue.length < 10) {
                    tanError.textContent = "❌ TAN must be exactly 10 characters";
                    tanError.style.color = "#dc3545";
                    tanError.style.display = "block";
                    tanInput.style.borderColor = "red";
                    tanInput.classList.add("error");
                }

                tanInput.value = tanValue; // force uppercase in input field
            });
        }

        // Load existing PANs
        async function loadExistingPANs() {
            try {
                const res = await fetch(`/api/BPmaster/GetUniquePANs?company=${companyId}`);
                const result = await res.json();
                if (result.success && Array.isArray(result.data)) {
                    existingPANs = result.data.map(p => p.paN_Number.toUpperCase());
                }
            } catch (err) {
                console.error("Error loading PAN list:", err);
            }
        }

        // Hide suggestions when clicking outside
        function setupClickOutsideHandler() {
            document.addEventListener("click", function(e) {
                const bpNameGroup = document.getElementById("bp-name-group");
                if (bpNameGroup && !bpNameGroup.contains(e.target)) {
                    const suggestions = document.getElementById("bp-suggestions");
                    if (suggestions) suggestions.style.display = "none";
                }
            });
        }

        // Set default values based on BP type
        function setDefaultValues() {
            // Price list default values based on full type (with staff)
            const fullType = getBpType(); // Use full type for internal logic
            const priceListSelect = document.getElementById("price-list");
            if (priceListSelect) {
                if (fullType === 'venda' || fullType === 'orgv') {
                    priceListSelect.value = '10';
                } else if (fullType === 'custa' || fullType === 'orgc') {
                    priceListSelect.value = '0';
                }
            }

            // Payment terms default values based on full type (with staff)
            const paymentTerms = getBpType(); // Use full type for internal logic
            const payTermSelect = document.getElementById("payment-terms");
            if (payTermSelect) {
                setTimeout(() => {
                    if (paymentTerms === 'venda' || paymentTerms === 'orgv') {
                        payTermSelect.value = 'NET-30';
                    } else if (paymentTerms === 'custa' || paymentTerms === 'orgc') {
                        payTermSelect.value = 'ADVANCE/CASH/0 DAYS';
                    }
                }, 300);
            }
        }
    </script>
    <script>
                // Script 3: Form Locking System & Main Initialization

        // CSS for form locking functionality
        const formLockingCSS = `
            .form-disabled input:not([name="type"]),
            .form-disabled select:not(#branch),
            .form-disabled textarea,
            .form-disabled button:not(.unlock-allowed) {
                pointer-events: none !important;
                opacity: 0.5 !important;
                background-color: #f8f9fa !important;
                cursor: not-allowed !important;
            }

            .tabs.disabled .tab {
                pointer-events: none !important;
                opacity: 0.5 !important;
                cursor: not-allowed !important;
                background-color: #e9ecef !important;
            }

            .form-disabled input[name="type"],
            .form-disabled #branch {
                pointer-events: auto !important;
                opacity: 1 !important;
                cursor: pointer !important;
            }

            .tab-content-disabled {
                pointer-events: none !important;
                opacity: 0.5 !important;
                position: relative;
            }

            .tab-content-disabled::before {
                content: "Please select Type first to enable this section";
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: rgba(255, 255, 255, 0.9);
                padding: 20px;
                border: 2px dashed #ccc;
                border-radius: 8px;
                font-weight: bold;
                color: #666;
                z-index: 1000;
                text-align: center;
            }

            .type-selection-warning {
                background: #fff3cd;
                border: 2px solid #ffeaa7;
                border-radius: 8px;
                padding: 20px;
                margin: 20px 0;
                text-align: center;
                font-weight: bold;
                color: #856404;
            }

            /* Hide fields based on type selection */
            .hidden {
                display: none !important;
            }

            /* Customer specific fields */
            .customer-only {
                display: none;
            }

            .show-customer .customer-only {
                display: block;
            }

            /* Vendor specific fields */
            .vendor-only {
                display: none;
            }

            .show-vendor .vendor-only {
                display: block;
            }

            /* Smooth transitions for field visibility */
            .form-group {
                transition: opacity 0.3s ease, height 0.3s ease;
            }

            .form-group.hidden {
                opacity: 0;
                height: 0;
                margin: 0;
                padding: 0;
                overflow: hidden;
            }
        `;

        // Add CSS to document head
        function addFormLockingCSS() {
            if (!document.getElementById('form-locking-styles')) {
                const style = document.createElement('style');
                style.id = 'form-locking-styles';
                style.textContent = formLockingCSS;
                document.head.appendChild(style);
            }
        }

        // Lock all form elements except type and branch
        function lockFormElements() {
            const container = document.querySelector('.container');
            if (container) {
                container.classList.add('form-disabled');
            }

            const tabsContainer = document.querySelector('.tabs');
            if (tabsContainer) {
                tabsContainer.classList.add('disabled');
            }

            // Disable specific tab contents
            const tabContents = ['contacts-tab', 'addresses-tab', 'payment-tab', 'attachments-tab'];
            tabContents.forEach(tabId => {
                const tab = document.getElementById(tabId);
                if (tab) {
                    tab.classList.add('tab-content-disabled');
                }
            });

            // Disable all inputs except type and branch
            const allInputs = document.querySelectorAll('input, select, textarea, button');
            allInputs.forEach(element => {
                if (element.name !== 'type' && element.id !== 'branch') {
                    element.disabled = true;
                }
            });

            showTypeSelectionWarning();
        }

        // Unlock all form elements
        function unlockFormElements() {
            const container = document.querySelector('.container');
            if (container) {
                container.classList.remove('form-disabled');
            }

            const tabsContainer = document.querySelector('.tabs');
            if (tabsContainer) {
                tabsContainer.classList.remove('disabled');
            }

            // Enable tab contents
            const tabContents = ['contacts-tab', 'addresses-tab', 'payment-tab', 'attachments-tab'];
            tabContents.forEach(tabId => {
                const tab = document.getElementById(tabId);
                if (tab) {
                    tab.classList.remove('tab-content-disabled');
                }
            });

            // Enable all form elements
            const allInputs = document.querySelectorAll('input, select, textarea, button');
            allInputs.forEach(element => {
                element.disabled = false;
            });

            removeTypeSelectionWarning();
        }

        // Show warning message to select type first
        function showTypeSelectionWarning() {
            const generalTab = document.getElementById('general-tab');
            if (generalTab && !document.getElementById('type-selection-warning')) {
                const warning = document.createElement('div');
                warning.id = 'type-selection-warning';
                warning.className = 'type-selection-warning';
                warning.innerHTML = `
                    <h3>⚠️ Please Select Business Partner Type First</h3>
                    <p>All form fields and tabs will be enabled after selecting the type (Customer/Vendor)</p>
                `;

                const salesSection = generalTab.querySelector('.form-section');
                if (salesSection) {
                    salesSection.parentNode.insertBefore(warning, salesSection);
                }
            }
        }

