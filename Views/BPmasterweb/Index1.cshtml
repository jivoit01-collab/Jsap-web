        // Attachment Functions
        function triggerAttachmentsInput() {
            document.getElementById('attachmentsInput').click();
        }

        function handleAttachmentsChange(event) {
            const newFiles = Array.from(event.target.files);
            const maxSize = 512 * 1024;
            const allowedTypes = ['.pdf', '.jpg', '.jpeg', '.png', '.doc', '.docx'];

            clearMessages();

            // Validate files
            for (let file of newFiles) {
                if (file.size > maxSize) {
                    showError(`File "${file.name}" is too large. Maximum size is 512KB.`);
                    return;
                }

                const fileExt = '.' + file.name.split('.').pop().toLowerCase();
                if (!allowedTypes.includes(fileExt)) {
                    showError(`File "${file.name}" has unsupported format. Allowed: PDF, JPG, PNG, DOC, DOCX.`);
                    return;
                }
            }

            attachments.push(...newFiles);
            renderAttachments();
            uploadFiles(newFiles);
            event.target.value = '';
        }

        function uploadFiles(files) {
            const formData = new FormData();
            files.forEach(file => formData.append('files', file));

            showProgress();

            fetch('/api/BPmaster/UploadAttachments', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                hideProgress();
                if (data.success) {
                    uploadedFiles.push(...data.filePaths);
                    showSuccess(`${files.length} file(s) uploaded successfully!`);
                } else {
                    throw new Error(data.message || 'Upload failed');
                }
            })
            .catch(error => {
                hideProgress();
                console.error('Upload error:', error);
            });
        }

        function removeAttachment(index) {
            const fileToRemove = attachments[index];
            const uploadedIndex = uploadedFiles.findIndex(path => path.includes(fileToRemove.name));

            if (uploadedIndex !== -1) {
                const filePath = uploadedFiles[uploadedIndex];
                fetch('/api/BPmaster/DeleteAttachment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filePath: filePath })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        uploadedFiles.splice(uploadedIndex, 1);
                    }
                })
                .catch(error => console.error('Delete error:', error));
            }

            attachments.splice(index, 1);
            renderAttachments();
            clearMessages();
        }

        function renderAttachments() {
            const container = document.getElementById('attachments-list');
            container.innerHTML = '';

            attachments.forEach((file, index) => {
                const item = document.createElement('div');
                item.className = 'file-item';
                item.innerHTML = `
                    <span>${file.name} (${(file.size / 1024).toFixed(2)} KB)</span>
                    <button class="remove-btn" onclick="removeAttachment(${index})">Remove</button>
                `;
                container.appendChild(item);
            });
        }

        function showProgress() {
            document.getElementById('upload-progress').style.display = 'block';
            let width = 0;
            const progressBar = document.getElementById('upload-progress-bar');
            const interval = setInterval(() => {
                width += 10;
                progressBar.style.width = width + '%';
                if (width >= 100) clearInterval(interval);
            }, 100);
        }

        function hideProgress() {
            setTimeout(() => {
                document.getElementById('upload-progress').style.display = 'none';
                document.getElementById('upload-progress-bar').style.width = '0%';
            }, 500);
        }

        function showError(message) {
            const errorElement = document.getElementById('upload-error');
            errorElement.textContent = message;
            errorElement.style.display = 'block';
        }

        function showSuccess(message) {
            const successElement = document.getElementById('upload-success');
            successElement.textContent = message;
            successElement.style.display = 'block';
            setTimeout(() => successElement.style.display = 'none', 3000);
        }

        function clearMessages() {
            document.getElementById('upload-error').style.display = 'none';
            document.getElementById('upload-success').style.display = 'none';
        }

        // Address synchronization setup
        function setupAddressSync() {
            const billingFields = [
                "billing-address1", "billing-address2", "billing-city",
                "billing-state", "billing-zip", "billing-country", "billing-gst"
            ];
            const shippingFields = [
                "shipping-address1", "shipping-address2", "shipping-city",
                "shipping-state", "shipping-zip", "shipping-country", "shipping-gst"
            ];

            billingFields.forEach((billingId, index) => {
                const billingField = document.getElementById(billingId);
                if (billingField) {
                    ['input', 'change'].forEach(eventType => {
                        billingField.addEventListener(eventType, function() {
                            if (document.getElementById("same-as-billing").checked) {
                                const shippingField = document.getElementById(shippingFields[index]);
                                if (shippingField) {
                                    shippingField.value = this.value;
                                }
                            }
                        });
                    });
                }
            });

            // Setup country change listeners for state loading
            const billingCountry = document.getElementById('billing-country');
            const shippingCountry = document.getElementById('shipping-country');

            if (billingCountry) {
                billingCountry.addEventListener('change', function() {
                    loadStates('billing');
                });
            }

            if (shippingCountry) {
                shippingCountry.addEventListener('change', function() {
                    loadStates('shipping');
                });
            }

            // Setup state change listeners for GST validation
            const billingState = document.getElementById('billing-state');
            const shippingState = document.getElementById('shipping-state');

            if (billingState) {
                billingState.addEventListener('change', function() {
                    handleStateChange('billing');
                });
            }

            if (shippingState) {
                shippingState.addEventListener('change', function() {
                    handleStateChange('shipping');
                });
            }

            // Setup address form validation listeners
            const requiredAddressFields = [
                'billing-address1', 'billing-city', 'billing-country',
                'billing-state', 'billing-zip'
            ];
            requiredAddressFields.forEach(id => {
                const field = document.getElementById(id);
                if (field) field.addEventListener('input', checkAddressForm);
            });

            // Setup account number validation listeners
            const accountNumber = document.getElementById('account-number');
            const confirmAccountNumber = document.getElementById('con-acc-number');

            if (accountNumber) {
                accountNumber.addEventListener('input', validateAccountNumbers);
            }

            if (confirmAccountNumber) {
                confirmAccountNumber.addEventListener('input', validateAccountNumbers);
            }
        }

