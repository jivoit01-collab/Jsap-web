                    // If no files, still create entry but allow empty attachment for rejected entries
                    attachmentData.push({
                        bundleId,
                        attachment: "",
                        docId: row.DocNum,
                        docType: row.docType,
                        branch: row.branch,
                        createdBy: updatedBy,
                        createdOn: new Date().toISOString(),
