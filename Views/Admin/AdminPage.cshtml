               @section scripts {
<script>

// TAB SWITCH
function switchTab(tab, el) {
    document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.admin-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('section-' + tab).classList.add('active');
    el.classList.add('active');
}

// FILTER TABLE
function filterTable(tableId, val) {
    document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
        row.style.display =
            row.innerText.toLowerCase().includes(val.toLowerCase()) ? '' : 'none';
    });
}

// GET FILTERS
function getFilters() {
    return {
        fromDate:    $('#fromDate').val(),
        toDate:      $('#toDate').val(),
        accountName: $('#accountName').val().trim() || null
    };
}

// BADGE HELPER
function badge(status) {
    if (!status || status === '-') return '-';
    const s = status.toLowerCase();
    if (s === 'approved') return `<span class="badge-approved">Approved</span>`;
    if (s === 'rejected') return `<span class="badge-rejected">Rejected</span>`;
    if (s === 'paid')     return `<span class="badge-paid">Paid</span>`;
    if (s === 'unpaid')   return `<span class="badge-unpaid">UnPaid</span>`;
    return `<span class="badge-pending">${status}</span>`;
}

function attachHtml(item) {
    if (item.attachment === 'File' && item.attachmentPath)
        return `<a href="#" onclick="openPdf('${item.attachmentPath}')" class="btn-view">View</a>`;
    return `<span style="color:#aaa;">No file</span>`;
}

function deleteBtn(item) {
    if (item.attachment === 'File')
        return `<button class="btn-delete" onclick="deleteAttachment(${item.vchNumber}, this)">Delete</button>`;
    return `<button class="btn-delete" disabled>Delete</button>`;
}

function deleteAttachment(vchNumber, btn) {
    const row = btn.closest('tr');
    btn.disabled = true;
    btn.textContent = 'Deleting';

    $.ajax({
        url: '/Admin/DeleteAttachment',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ vchNumber: vchNumber }),
        timeout: 30000,
        success: function(res) {
            if (res && res.success) {
                const cells = row.querySelectorAll('td');
                cells[cells.length - 2].innerHTML = '<span style="color:#aaa;">No file</span>';
                cells[cells.length - 1].innerHTML = '<button class="btn-delete" disabled>Delete</button>';
                return;
            }

            btn.disabled = false;
            btn.textContent = 'Delete';
            alert((res && res.message) || 'Delete failed');
        },
        error: function() {
            btn.disabled = false;
            btn.textContent = 'Delete';
            alert('Error deleting attachment');
        }
    });
}

function openPdf(path) {
    document.getElementById("pdfFrame").src = path;
    document.getElementById("pdfContainer").style.display = "block";
    window.scrollTo({ top: 0, behavior: "smooth" });
}

function closePdf() {
    document.getElementById("pdfContainer").style.display = "none";
    document.getElementById("pdfFrame").src = "";
}

function setBodyMessage(bodyId, colspan, message, isError) {
    const cls = isError ? 'text-center text-danger' : 'text-center text-muted';
    $('#' + bodyId).html(`<tr><td colspan="${colspan}" class="${cls} py-3">${message}</td></tr>`);
}

function loadSummary() {
    $.ajax({
        url: '/Admin/GetSummary',
        method: 'GET',
        timeout: 30000,
        success: function(d) {
            $('#totalBills').text(d.totalBills ?? 0);
            $('#pendingMaker').text(d.pendingMaker ?? 0);
            $('#approvedChecker').text(d.approvedChecker ?? 0);
            $('#totalPaid').text(d.totalPaid ?? 0);
        },
        error: function() {
            $('#totalBills, #pendingMaker, #approvedChecker, #totalPaid').text('0');
        }
    });
}

function loadAdminTable(config) {
    setBodyMessage(config.bodyId, config.colspan, 'Loading...', false);

    $.ajax({
        url: config.url,
        method: 'GET',
        data: getFilters(),
        timeout: 30000,
        success: function(data) {
            if (!data || !data.length) {
                setBodyMessage(config.bodyId, config.colspan, 'No records found', false);
                return;
            }

            let html = '';
            data.forEach(item => { html += config.row(item); });
            $('#' + config.bodyId).html(html || `<tr><td colspan="${config.colspan}" class="text-center text-muted py-3">No records found</td></tr>`);
        },
        error: function() {
            setBodyMessage(config.bodyId, config.colspan, 'Error loading data. Please try again.', true);
        }
    });
}

function loadMaker() {
    loadAdminTable({
        bodyId: 'makerBody',
        colspan: 8,
        url: '/Admin/GetMakerActivity',
        row: function(item) {
            return `<tr>
                <td>${item.accountName ?? ''}</td>
                <td>${item.vchNumber ?? ''}</td>
                <td>${item.voucherDate ?? '-'}</td>
                <td>${item.billAmount ?? '-'}</td>
                <td>${item.makerRemark ?? '-'}</td>
                <td>${badge(item.makerStatus)}</td>
                <td>${attachHtml(item)}</td>
                <td>${deleteBtn(item)}</td>
            </tr>`;
        }
    });
}

function loadChecker() {
    loadAdminTable({
        bodyId: 'checkerBody',
        colspan: 8,
        url: '/Admin/GetCheckerActivity',
        row: function(item) {
            return `<tr>
                <td>${item.accountName ?? ''}</td>
                <td>${item.vchNumber ?? ''}</td>
                <td>${item.voucherDate ?? '-'}</td>
                <td>${item.billAmount ?? '-'}</td>
                <td>${item.checkerRemark ?? '-'}</td>
                <td>${badge(item.checkerStatus)}</td>
                <td>${attachHtml(item)}</td>
                <td>${deleteBtn(item)}</td>
            </tr>`;
        }
    });
}

function loadInvoice() {
    loadAdminTable({
        bodyId: 'invoiceBody',
        colspan: 9,
        url: '/Admin/GetInvoiceActivity',
        row: function(item) {
            return `<tr>
                <td>${item.accountName ?? ''}</td>
                <td>${item.vchNumber ?? ''}</td>
                <td>${item.voucherDate ?? '-'}</td>
                <td>${item.billAmount ?? '-'}</td>
                <td>${item.dueDate ?? '-'}</td>
                <td>${badge(item.paymentStatus)}</td>
                <td>${item.paymentDate ?? '-'}</td>
                <td>${attachHtml(item)}</td>
                <td>${deleteBtn(item)}</td>
            </tr>`;
        }
    });
}

function loadPaymentChecker() {
    loadAdminTable({
        bodyId: 'paymentBody',
        colspan: 8,
        url: '/Admin/GetPaymentCheckerActivity',
        row: function(item) {
            return `<tr>
                <td>${item.accountName ?? ''}</td>
                <td>${item.vchNumber ?? ''}</td>
                <td>${item.voucherDate ?? '-'}</td>
                <td>${item.billAmount ?? '-'}</td>
                <td>${badge(item.paymentStatus)}</td>
                <td>${item.checkerRemark ?? '-'}</td>
                <td>${attachHtml(item)}</td>
                <td>${deleteBtn(item)}</td>
            </tr>`;
        }
    });
}

function validateFilters() {
    const fromDate = $('#fromDate').val();
    const toDate = $('#toDate').val();

    if (fromDate && toDate && fromDate > toDate) {
        setBodyMessage('makerBody', 8, 'From Date cannot be greater than To Date.', true);
        setBodyMessage('checkerBody', 8, 'From Date cannot be greater than To Date.', true);
        setBodyMessage('invoiceBody', 9, 'From Date cannot be greater than To Date.', true);
        setBodyMessage('paymentBody', 8, 'From Date cannot be greater than To Date.', true);
        return false;
    }

    return true;
}

function loadAllAdminData() {
    if (!validateFilters()) return;
    loadSummary();
    loadMaker();
    loadChecker();
    loadInvoice();
    loadPaymentChecker();
}

// SEARCH
$('#searchBtn').on('click', function() {
    loadAllAdminData();
});

// INIT
$(document).ready(function() {
    const today = new Date().toISOString().split('T')[0];
    const firstOfMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1)
        .toISOString().split('T')[0];

    $('#fromDate').val(firstOfMonth);
    $('#toDate').val(today);

    loadAllAdminData();
});

</script>

}
