            <div class="stat-chip"><span class="stat-val" id="statH4">—</span><span class="stat-label">H4 Levels</span></div>
            <div class="stat-chip"><span class="stat-val" id="statTotal">—</span><span class="stat-label">Total Employees</span></div>
            <div class="stat-chip active"><span class="stat-val" id="statActive">—</span><span class="stat-label">Active</span></div>
            <div class="stat-chip inactive"><span class="stat-val" id="statInactive">—</span><span class="stat-label">Inactive</span></div>
            <div class="stat-chip" style="margin-left:auto; border-left: 1px solid var(--border); border-right: none;">
                <span class="stat-val" id="statFiltered" style="color:var(--g3)">—</span><span class="stat-label">Showing</span>
            </div>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <input type="text" class="search-box" id="searchInput" placeholder="Search name, code, state…" oninput="debouncedApplyFilters()" />
        <select id="filterH1" onchange="applyFilters()"><option value="">All H1</option></select>
        <select id="filterH2" onchange="applyFilters()"><option value="">All H2</option></select>
        <select id="filterH3" onchange="applyFilters()"><option value="">All H3</option></select>
        <select id="filterH4" onchange="applyFilters()"><option value="">All H4</option></select>
        <select id="filterState" onchange="applyFilters()"><option value="">All States</option></select>
        <select id="filterGroup" onchange="applyFilters()"><option value="">All Groups</option></select>
        <select id="filterDesig" onchange="applyFilters()"><option value="">All Designations</option></select>
        <select id="filterStatus" onchange="applyFilters()">
            <option value="">All Status</option>
            <option value="1">Active</option>
            <option value="0">Inactive</option>
        </select>
        <button class="filter-clear" onclick="clearFilters()">✕ Clear</button>
        <span class="filter-badge" id="filterBadge" style="display:none">0</span>
    </div>

    <!-- MAIN CONTENT -->
    @if (initialRows.Any())
    {
        <div id="salesFallback" style="flex:1;overflow:auto;padding:16px 20px;">
            <div style="margin-bottom:10px;font-size:12px;color:var(--muted);">Server-rendered fallback view. If this is visible, the page script did not finish loading.</div>
            <div class="grid-wrap" style="border:1px solid var(--border);border-radius:10px;">
                <table class="sales-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th>H1</th>
                            <th>H2</th>
                            <th>H3</th>
                            <th>H4</th>
                            <th>Name</th>
                            <th>State</th>
                            <th>Group</th>
                            <th>Designation</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var fallbackIndex = 0;
                        }
                        @foreach (var row in initialRows.Take(100))
                        {
                            fallbackIndex++;
                            <tr>
                                <td>@fallbackIndex</td>
                                <td>@(!string.IsNullOrWhiteSpace(row.H1Name) ? row.H1Name : row.H1Code)</td>
                                <td>@(!string.IsNullOrWhiteSpace(row.H2Name) ? row.H2Name : row.H2Code)</td>
                                <td>@(!string.IsNullOrWhiteSpace(row.H3Name) ? row.H3Name : row.H3Code)</td>
                                <td>@(!string.IsNullOrWhiteSpace(row.H4Name) ? row.H4Name : row.H4Code)</td>
                                <td>
                                    <div class="name-code">
                                        <strong>@(string.IsNullOrWhiteSpace(row.EmpName) ? "—" : row.EmpName)</strong>
                                        <span class="mini-code">@(string.IsNullOrWhiteSpace(row.EmpCode) ? "No code" : row.EmpCode)</span>
                                    </div>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(row.State) ? "—" : row.State)</td>
                                <td>@(string.IsNullOrWhiteSpace(row.GroupName) ? "—" : row.GroupName)</td>
                                <td>@(string.IsNullOrWhiteSpace(row.Designation) ? "—" : row.Designation)</td>
                                <td><span class="badge @(row.IsActive ? "badge-active" : "badge-inactive")">@(row.IsActive ? "Active" : "Inactive")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <div class="page-main" id="salesPageMain" style="@(initialRows.Any() ? "display:none" : "")">
        <div class="grid-wrap" id="gridWrap">
            <table class="sales-table" id="salesTable">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th class="col-h1Name" data-col="h1Name" onclick="sortBy('h1Name')">H1 <span class="sort-icon">↕</span></th>
                        <th class="col-h2Name" data-col="h2Name" onclick="sortBy('h2Name')">H2 <span class="sort-icon">↕</span></th>
                        <th class="col-h3Name" data-col="h3Name" onclick="sortBy('h3Name')">H3 <span class="sort-icon">↕</span></th>
                        <th class="col-h4Name" data-col="h4Name" onclick="sortBy('h4Name')">H4 <span class="sort-icon">↕</span></th>
                        <th class="col-empName" data-col="empName" onclick="sortBy('empName')">Name <span class="sort-icon">↕</span></th>
                        <th class="col-state" data-col="state" onclick="sortBy('state')">State <span class="sort-icon">↕</span></th>
                        <th class="col-groupName" data-col="groupName" onclick="sortBy('groupName')">Group <span class="sort-icon">↕</span></th>
                        <th class="col-designation" data-col="designation" onclick="sortBy('designation')">Designation <span class="sort-icon">↕</span></th>
                        <th class="col-isActive" data-col="isActive">Status</th>
                        <th style="width:90px; text-align:center">Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr class="loading-row"><td colspan="11"><span class="spinner"></span>Loading sales data…</td></tr>
                </tbody>
            </table>
        </div>
        <div class="pag-bar" id="pagBar">
            <span class="info" id="pagInfo"></span>
            <div id="pagButtons"></div>
        </div>
    </div>
</div>

