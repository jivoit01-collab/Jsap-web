            /* ══════════════════════════════════════════════════════════
               CHANGE #2 — DRAG-TO-PAN
               We set overflow:hidden on #v1Outer and manually track
               scrollLeft / scrollTop via mouse and touch events.
               Clicks on .nc-expand-btn and .nc-info-btn are excluded
               so they still fire normally.
            ══════════════════════════════════════════════════════════ */
            var _pan = { active:false, startX:0, startY:0, scrollX:0, scrollY:0, moved:false };

            function v1_initDragPan(){
                var el = document.getElementById('v1Outer');
                if(!el) return;

                /* ── Mouse ── */
                el.addEventListener('mousedown', function(e){
                    if(e.button !== 0) return;
                    // let button clicks through
                    if(e.target.closest('.nc-expand-btn, .nc-info-btn, button, a')) return;
                    _pan.active  = true;
                    _pan.moved   = false;
                    _pan.startX  = e.clientX;
                    _pan.startY  = e.clientY;
                    _pan.scrollX = el.scrollLeft;
                    _pan.scrollY = el.scrollTop;
                    el.classList.add('is-dragging');
                    e.preventDefault();
                });

                window.addEventListener('mousemove', function(e){
                    if(!_pan.active) return;
                    var dx = e.clientX - _pan.startX;
                    var dy = e.clientY - _pan.startY;
                    if(Math.abs(dx)>3 || Math.abs(dy)>3) _pan.moved = true;
                    el.scrollLeft = _pan.scrollX - dx;
                    el.scrollTop  = _pan.scrollY - dy;
                    v1_drawLines();
                });

                window.addEventListener('mouseup', function(){
                    if(!_pan.active) return;
                    _pan.active = false;
                    el.classList.remove('is-dragging');
                });

                /* ── Touch ── */
                el.addEventListener('touchstart', function(e){
                    if(e.touches.length !== 1) return;
                    var t = e.touches[0];
                    _pan.active  = true;
                    _pan.moved   = false;
                    _pan.startX  = t.clientX;
                    _pan.startY  = t.clientY;
                    _pan.scrollX = el.scrollLeft;
                    _pan.scrollY = el.scrollTop;
                }, {passive:true});

                el.addEventListener('touchmove', function(e){
                    if(!_pan.active || e.touches.length!==1) return;
                    var t  = e.touches[0];
                    var dx = t.clientX - _pan.startX;
                    var dy = t.clientY - _pan.startY;
                    if(Math.abs(dx)>3 || Math.abs(dy)>3) _pan.moved = true;
                    el.scrollLeft = _pan.scrollX - dx;
                    el.scrollTop  = _pan.scrollY - dy;
                    v1_drawLines();
                    e.preventDefault();
                }, {passive:false});

                el.addEventListener('touchend', function(){ _pan.active = false; });
            }

