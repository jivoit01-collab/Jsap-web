        $(document).ready(function() {
            // Get userId and companyId from session
            const userId = @userId;
            const companyId = @(selectedCompanyId ?? 1);

            // Load dynamic menu
            loadDynamicMenu(userId, companyId);

            // Check if session is valid
            if (@(companies.Count == 0 ? "true" : "false")) {
                $("#sessionError").show();
                $("#dashboard-content").hide();
            }

            // Company dropdown change handler
            $('#companyDropdown').on('change', function () {
                const selectedCompanyId = $(this).val();
                const selectedCompanyName = $(this).find('option:selected').data('name');

                if (!selectedCompanyId) return;

                // Show loading state
                const originalHtml = $('#mainBody').html();
                $('#mainBody').html('<div style="text-align: center; padding: 50px;"><div class="spinner"></div><p>Changing company...</p></div>');

                $.ajax({
                    url: '/websession/updateSelectedCompany',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ companyId: parseInt(selectedCompanyId) }),
                    success: function (res) {
                        if (res.success) {
                            // Reload permissions for new company
                            $.ajax({
                                url: `/api/Permission/GetUserEffectivePermissions?UserId=${userId}&CompanyId=${selectedCompanyId}`,
                                method: 'GET',
                                success: function(permResponse) {
                                    if (permResponse.success && permResponse.data) {
                                        userPermissions = permResponse.data;

                                        // Check if user has permission for current page
                                        const hasPermission = checkPagePermission();

                                        if (hasPermission) {
                                            // User has permission, reload the page
                                            location.reload();
                                        } else {
                                            // User doesn't have permission, show denied message
                                            showPermissionDenied(selectedCompanyName);
                                        }
                                    } else {
                                        location.reload();
                                    }
                                },
                                error: function() {
                                    // If permission check fails, reload anyway
                                    location.reload();
                                }
                            });
                        } else {
                            alert('Failed to update company selection.');
                            $('#mainBody').html(originalHtml);
                        }
                    },
                    error: function () {
                        alert('Failed to update company selection.');
                        $('#mainBody').html(originalHtml);
                    }
                });
            });

            // Sidebar toggle functionality
            $('#sidebarToggle').on('click', function() {
                const sidebar = $('#sidebar');
                const mainBody = $('#mainBody');

                sidebar.toggleClass('collapsed');
                mainBody.toggleClass('collapsed');

                const isCollapsed = sidebar.hasClass('collapsed');
                localStorage.setItem('sidebarCollapsed', isCollapsed);
            });

            // Restore sidebar state on page load
            const wasCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (wasCollapsed) {
                $('#sidebar').addClass('collapsed');
                $('#mainBody').addClass('collapsed');
            }
        });

        function loadDynamicMenu(userId, companyId) {
            $.ajax({
                url: `/api/Permission/GetUserEffectivePermissions?UserId=${userId}&CompanyId=${companyId}`,
                method: 'GET',
                success: function(response) {
                    if (response.success && response.data) {
                        userPermissions = response.data;
                        generateMenuFromPermissions(response.data);
                    } else {
                        $('#menuLoading').html('<p style="color: #ff6b6b;">Failed to load menu permissions</p>');
                    }
                },
                error: function(error) {
                    console.error('Error loading permissions:', error);
                    $('#menuLoading').html('<p style="color: #ff6b6b;">Error loading menu. Please refresh the page.</p>');
                }
            });
        }

        function generateMenuFromPermissions(permissions) {
           // Group permissions by moduleName
           const groupedPermissions = {};

            permissions.forEach(perm => {
               if (!groupedPermissions[perm.moduleName]) {
                   groupedPermissions[perm.moduleName] = [];
                }
                groupedPermissions[perm.moduleName].push(perm);
            });


            // Generate HTML
            let menuHtml = '';

            for (const apiModuleName in groupedPermissions) {
                const modulePermissions = groupedPermissions[apiModuleName];

                // Get configuration for this module
                const config = menuConfig[apiModuleName];

                // Skip if no configuration found
                if (!config) {
                    console.warn(`No configuration found for module: ${apiModuleName}`);
                    continue;
                }

                // Use custom display name or fallback to API name
                const displayName = config.displayName || apiModuleName;
                const icon = config.icon || 'fas fa-folder';

                // Create menu item (parent)
                menuHtml += `
                    <div class="menu-item" onclick="toggleMenu(this)">
                        <i class="${icon}"></i>
                        <span class="menu-text">${displayName}</span>
                        <span class="arrow">▶</span>
                    </div>
                    <div class="submenu">
                `;

                // Create submenu items based on permissions
                modulePermissions.forEach(perm => {
                    //const permConfig = config.permissions[perm.permissionType];
            const permKey = Object.keys(config.permissions).find(key =>
            key.toLowerCase().trim() === perm.permissionType.toLowerCase().trim()
            );

                    const permConfig = config.permissions[permKey];

                    if (permConfig) {
                        // Use configured submenu
                        const permissionLinks = permConfig.links || [{ displayName: permConfig.displayName, url: permConfig.url }];
                        permissionLinks.forEach(link => {
                            menuHtml += `<a href="${link.url}">${link.displayName}</a>`;
                        });
                    } else {
                        // Fallback: create a menu item with formatted permission name
                        console.warn(`No configuration found for permission: ${perm.permissionType} in module ${apiModuleName}`);
                        const fallbackName = formatPermissionName(perm.permissionType);
                        menuHtml += `<a href="#">${fallbackName}</a>`;
                    }
                });

                menuHtml += `</div>`;
            }

            // Replace loading indicator with generated menu
            $('#dynamicMenu').html(menuHtml);
        }

        function formatPermissionName(permissionType) {
            // Convert "Inventory_admin" to "Admin"
            // This is a fallback function in case no configuration is found
            return permissionType
                .split('_')
                .slice(1)
                .map(word => word.charAt(0).toUpperCase() + word.slice(1))
                .join(' ');
        }

        function toggleMenu(element) {
            // Don't toggle menu if sidebar is collapsed
            if ($('#sidebar').hasClass('collapsed')) {
                return;
            }
            element.classList.toggle("active");
        }
    </script>
    <script>
        (function() {
            const userId = @userId;
            const currentPath = window.location.pathname.toLowerCase();
            if (!userId || userId <= 0) {
                if (!currentPath.includes("/login")) {
                    console.log("No authenticated session found, redirecting to login");
                    window.location.href = "/Login";
                }
                return;
            }
            window.APP = Object.assign(window.APP || {}, {
                userId: userId,
                userName: "@sidebarUserDisplay",
                userEmail: "@(userEmail ?? "")",
                companies: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(companies))
            });
        })();

        // auth.js handles $.ajaxSetup, fetch interceptor, error handlers, and window.APP
        // Only logout button handler remains here
        $('#logoutBtn').on('click', function () {
            if (confirm('Are you sure you want to logout?')) {
                fetch('/api/Auth/Logout', {
                    method: 'POST',
                    headers: { "Content-Type": "application/json" },
                    credentials: 'include'
                }).finally(function() {
                    if (window.APP && window.APP.clearAccessToken) {
                        window.APP.clearAccessToken();
                    }
                    localStorage.clear();
                    window.location.href = '/Login';
                });
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
