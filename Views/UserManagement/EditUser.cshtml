            // Password toggle functionality
            $('#togglePassword').on('click', function() {
                const passwordField = $('#password');
                const icon = $(this).find('i');
        
                if (passwordField.attr('type') === 'password') {
                    passwordField.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    passwordField.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });
        
            $('#userPermissionForm').on('submit', function (e) {
                e.preventDefault();
        
                const userId = $('#editingUserId').val();
                const firstName = $('#firstName').val().trim();
                const lastName = $('#lastName').val().trim();
                const userPhoneNumber = $('#phoneNumber').val().trim();
                const userEmail = $('#email').val().trim();
                const empId = $('#empId').val().trim();
                const deptIds = $('#deptIds').val(); // returns array of selected options
                const updatedBy = $('#adminId').val();
        
                // Optional validation
                if (userPhoneNumber.length !== 10 || !/^\d+$/.test(userPhoneNumber)) {
                    $('#phoneNumberFeedback').show();
                    return;
                } else {
                    $('#phoneNumberFeedback').hide();
                }
        
                const payload = {
                    userId: parseInt(userId),
                    firstName: firstName,
                    lastName: lastName,
                    userPhoneNumber: userPhoneNumber,
                    userEmail: userEmail,
                    empId: empId,
                    deptIds: deptIds ? deptIds.join(',') : '',
                    updatedBy: parseInt(updatedBy)
                };
        
                $.ajax({
                    url: '/api/auth/UpdateUserInfo',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function (response) {
                        $('#message').html(`<div class="alert alert-success">${response.message}</div>`);
                    },
                    error: function (xhr) {
                        const errMsg = xhr.responseJSON?.message || "An error occurred while saving.";
                        $('#message').html(`<div class="alert alert-danger">${errMsg}</div>`);
                    }
                });
            });
        });
