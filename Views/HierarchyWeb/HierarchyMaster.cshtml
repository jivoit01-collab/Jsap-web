    async function runImport(){
        if(!pendingXl.length){toast('No rows','err');return;}
        const btn=document.getElementById('importBtn');
        btn.disabled=true;btn.textContent='Importing…';
        toast(`Importing ${pendingXl.length} rows…`,'info');
        try{
            const res=await api(`${API}/ImportFromExcel`,'POST',pendingXl);
            if(!res.success){toast(res.message||'Import failed','err');return;}
            const d=res.data;
            document.getElementById('importStats').innerHTML=
                `<span class="ic"><b>${d.employeesCreated}</b>Created</span>
                 <span class="iu"><b>${d.employeesUpdated}</b>Updated</span>
                 <span class="ir"><b>${d.relationshipsCreated}</b>Relationships</span>
                 ${d.tempCodesGenerated>0?`<span class="iu"><b>${d.tempCodesGenerated}</b>TEMP codes</span>`:''}
                 ${d.errors>0?`<span class="ie"><b>${d.errors}</b>Errors</span>`:''}`;

            // Show TEMP codes list if any
            let extraHtml = '';
            if(d.tempCodes && d.tempCodes.length > 0){
                extraHtml += `<div style="margin-top:8px;font-size:10px;color:var(--warn)">
                    <b>TEMP codes generated (update with real codes later):</b><br>
                    ${d.tempCodes.map(t=>esc(t)).join('<br>')}
                </div>`;
            }
            if((d.errorDetails||[]).length > 0){
                extraHtml += `<div style="margin-top:6px" class="err-list">${(d.errorDetails||[]).map(e=>esc(e)).join('<br>')}</div>`;
            }
            document.getElementById('importErrors').innerHTML = extraHtml;
            document.getElementById('importResult').style.display='block';
            toast(`Done — ${d.employeesCreated} created, ${d.employeesUpdated} updated`,'ok');
            loadGrid();
        }catch(e){toast('Error: '+e.message,'err');}
        finally{btn.disabled=false;btn.textContent='✓ Run Import';}
    }

