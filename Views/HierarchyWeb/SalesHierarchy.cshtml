// CREATE EMPLOYEE
// ═══════════════════════════════════════════════════════════════
function openCreateEmpModal() {
    document.getElementById('newEmp_code').value = '';
    document.getElementById('newEmp_name').value = '';
    const msg = document.getElementById('createEmpMsg');
    msg.style.display = 'none'; msg.innerHTML = '';
    document.getElementById('btnSaveNewEmp').disabled = false;
    document.getElementById('btnSaveNewEmp').textContent = 'Create Employee';
    document.getElementById('createEmpOverlay').classList.add('open');
    setTimeout(() => document.getElementById('newEmp_code').focus(), 100);
}

function closeCreateEmpModal() {
    document.getElementById('createEmpOverlay').classList.remove('open');
}

async function saveNewEmployee() {
    const code = document.getElementById('newEmp_code').value.trim();
    const name = document.getElementById('newEmp_name').value.trim();
    const msg  = document.getElementById('createEmpMsg');

    if (!code) { showInlineMsg(msg, '❌ Employee code is required', 'error'); return; }
    if (!name) { showInlineMsg(msg, '❌ Employee name is required', 'error'); return; }

    const btn = document.getElementById('btnSaveNewEmp');
    btn.disabled = true; btn.textContent = 'Creating…';

    try {
        const res = await fetchPost(API.createEmployee, { empCode: code, empName: name });
        if (res.success) {
            showToast(`Employee "${name}" created`, 'success');
            // Add new employee to the master list so it appears in the datalist immediately.
            if (!allSalesEmployees.find(e => (e.employeeCode ?? e.EmployeeCode ?? '') === code)) {
                allSalesEmployees.push({ employeeCode: code, employeeName: name });
            }
            buildEmployeeDatalist();
            closeCreateEmpModal();
        } else {
            showInlineMsg(msg, '❌ ' + (res.message || 'Create failed'), 'error');
        }
    } catch(e) {
        showInlineMsg(msg, '❌ Error: ' + e.message, 'error');
    } finally {
        btn.disabled = false; btn.textContent = 'Create Employee';
    }
}

