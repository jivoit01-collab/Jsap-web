    <script>
        const GLOBAL_PAGE_SETTINGS_BASE = 13;
        const GLOBAL_PAGE_SETTINGS_PREFIX = 'jsap_page_settings::';
        const GLOBAL_PAGE_SETTINGS_DEFAULTS = {
            fontSize: GLOBAL_PAGE_SETTINGS_BASE,
            fontFamily: '',
            textColor: '',
            accentColor: '',
            bgColor: '',
            bold: false,
            underline: false,
            highlight: false
        };
        let globalPageSettingsObserver = null;

        function getGlobalPageSettingsKey() {
            return `${GLOBAL_PAGE_SETTINGS_PREFIX}${window.location.pathname.toLowerCase()}`;
        }

        function getStoredGlobalPageSettings() {
            try {
                const raw = localStorage.getItem(getGlobalPageSettingsKey());
                if (!raw) return { ...GLOBAL_PAGE_SETTINGS_DEFAULTS };
                return { ...GLOBAL_PAGE_SETTINGS_DEFAULTS, ...JSON.parse(raw) };
            } catch (e) {
                return { ...GLOBAL_PAGE_SETTINGS_DEFAULTS };
            }
        }

        function openGlobalPageSettings() {
            const settings = getStoredGlobalPageSettings();
            document.getElementById('globalFontSize').value = settings.fontSize || GLOBAL_PAGE_SETTINGS_BASE;
            document.getElementById('globalFontFamily').value = settings.fontFamily || '';
            document.getElementById('globalTextColor').value = settings.textColor || '#0f172a';
            document.getElementById('globalAccentColor').value = settings.accentColor || '#0b2c4d';
            document.getElementById('globalBgColor').value = settings.bgColor || '#f8f9fa';
            document.getElementById('globalBoldToggle').checked = !!settings.bold;
            document.getElementById('globalUnderlineToggle').checked = !!settings.underline;
            document.getElementById('globalHighlightToggle').checked = !!settings.highlight;
            previewGlobalPageSettings();
            document.getElementById('globalPageSettingsModal').classList.add('open');
        }

        function closeGlobalPageSettings() {
            document.getElementById('globalPageSettingsModal').classList.remove('open');
            applyGlobalPageSettingsToScope(document.getElementById('mainBody'), getStoredGlobalPageSettings());
        }

        function getGlobalPageSettingsFromInputs() {
            return {
                fontSize: parseInt(document.getElementById('globalFontSize').value, 10) || GLOBAL_PAGE_SETTINGS_BASE,
                fontFamily: document.getElementById('globalFontFamily').value || '',
                textColor: document.getElementById('globalTextColor').value || '',
                accentColor: document.getElementById('globalAccentColor').value || '',
                bgColor: document.getElementById('globalBgColor').value || '',
                bold: document.getElementById('globalBoldToggle').checked,
                underline: document.getElementById('globalUnderlineToggle').checked,
                highlight: document.getElementById('globalHighlightToggle').checked
            };
        }

        function previewGlobalPageSettings() {
            const settings = getGlobalPageSettingsFromInputs();
            document.getElementById('globalFontSizeValue').textContent = `${settings.fontSize}px`;
            document.getElementById('globalFontFamilyValue').textContent = getGlobalFontFamilyLabel(settings.fontFamily);
            document.getElementById('globalTextColorValue').textContent = settings.textColor ? settings.textColor.toUpperCase() : 'Default';
            document.getElementById('globalAccentColorValue').textContent = settings.accentColor ? settings.accentColor.toUpperCase() : 'Default';
            document.getElementById('globalBgColorValue').textContent = settings.bgColor ? settings.bgColor.toUpperCase() : 'Default';
            applyGlobalPageSettingsToScope(document.getElementById('mainBody'), settings);
        }

        function applyGlobalPageSettings() {
            const settings = getGlobalPageSettingsFromInputs();
            localStorage.setItem(getGlobalPageSettingsKey(), JSON.stringify(settings));
            applyGlobalPageSettingsToScope(document.getElementById('mainBody'), settings);
            closeGlobalPageSettings();
        }

        function resetGlobalPageSettings() {
            localStorage.removeItem(getGlobalPageSettingsKey());
            document.getElementById('globalFontSize').value = GLOBAL_PAGE_SETTINGS_BASE;
            document.getElementById('globalFontFamily').value = '';
            document.getElementById('globalTextColor').value = '#0f172a';
            document.getElementById('globalAccentColor').value = '#0b2c4d';
            document.getElementById('globalBgColor').value = '#f8f9fa';
            document.getElementById('globalBoldToggle').checked = false;
            document.getElementById('globalUnderlineToggle').checked = false;
            document.getElementById('globalHighlightToggle').checked = false;
            previewGlobalPageSettings();
        }

        function applyGlobalPageSettingsToScope(scope, settings) {
            if (!(scope instanceof HTMLElement)) return;

            scope.style.backgroundColor = settings.bgColor || '';
            scope.style.color = settings.textColor || '';
            scope.style.setProperty('--primary-color', settings.accentColor || '#0b2c4d');
            scope.style.setProperty('--primary-light', settings.accentColor ? mixGlobalColors(settings.accentColor, '#ffffff', 0.18) : '#1c3f5d');
            scope.style.setProperty('--primary-dark', settings.accentColor ? mixGlobalColors(settings.accentColor, '#051626', 0.35) : '#051626');

            applyGlobalFontScale(scope, settings);
            applyGlobalFormatting(scope, settings);
        }

        function applyGlobalFontScale(scope, settings) {
            const scale = (parseInt(settings.fontSize, 10) || GLOBAL_PAGE_SETTINGS_BASE) / GLOBAL_PAGE_SETTINGS_BASE;
            const nodes = [scope, ...scope.querySelectorAll('*')];

            nodes.forEach(el => {
                if (!(el instanceof HTMLElement) || !isScalableGlobalElement(el)) return;

                const baseSize = getGlobalBaseFontSize(el);
                if (!baseSize) return;

                el.style.fontSize = `${Math.round(baseSize * scale * 100) / 100}px`;
            });
        }

        function applyGlobalFormatting(scope, settings) {
            const nodes = [scope, ...scope.querySelectorAll('*')];

            nodes.forEach(el => {
                if (!(el instanceof HTMLElement) || !isScalableGlobalElement(el)) return;

                const hasText = hasDirectTextContent(el);
                el.style.fontFamily = settings.fontFamily || '';

                if (hasText) {
                    el.style.color = settings.textColor || '';
                    el.style.fontWeight = settings.bold ? '700' : '';
                    el.style.textDecoration = settings.underline ? 'underline' : '';
                    el.style.textDecorationThickness = settings.underline ? '1.5px' : '';
                    el.style.textUnderlineOffset = settings.underline ? '2px' : '';
                    el.style.backgroundColor = settings.highlight ? 'rgba(255, 235, 59, 0.35)' : '';
                    el.style.boxShadow = settings.highlight ? 'inset 0 -0.55em 0 rgba(255, 235, 59, 0.35)' : '';
                } else {
                    el.style.fontWeight = '';
                    el.style.textDecoration = '';
                    el.style.textDecorationThickness = '';
                    el.style.textUnderlineOffset = '';
                    if (!isContainerElement(el)) {
                        el.style.backgroundColor = '';
                        el.style.boxShadow = '';
                    }
                }
            });
        }

        function isScalableGlobalElement(el) {
            if (el.closest('svg')) return false;
            return !['SCRIPT', 'STYLE', 'LINK', 'META', 'TITLE', 'NOSCRIPT', 'BR'].includes(el.tagName);
        }

        function isContainerElement(el) {
            return ['DIV', 'SECTION', 'ARTICLE', 'MAIN', 'ASIDE', 'NAV'].includes(el.tagName);
        }

        function hasDirectTextContent(el) {
            return Array.from(el.childNodes || []).some(node => node.nodeType === Node.TEXT_NODE && String(node.textContent || '').trim().length > 0);
        }

        function getGlobalBaseFontSize(el) {
            const cached = parseFloat(el.dataset.globalBaseFontSize || '');
            if (Number.isFinite(cached) && cached > 0) return cached;

            const computed = parseFloat(window.getComputedStyle(el).fontSize || '');
            if (!Number.isFinite(computed) || computed <= 0) return null;

            el.dataset.globalBaseFontSize = `${computed}`;
            return computed;
        }

        function initGlobalPageSettingsObserver() {
            const scope = document.getElementById('mainBody');
            if (!scope || globalPageSettingsObserver || typeof MutationObserver === 'undefined') return;

            globalPageSettingsObserver = new MutationObserver(mutations => {
                const settings = getStoredGlobalPageSettings();
                mutations.forEach(mutation => {
                    mutation.addedNodes.forEach(node => {
                        if (node instanceof HTMLElement) {
                            applyGlobalPageSettingsToScope(node, settings);
                        }
                    });
                });
            });

            globalPageSettingsObserver.observe(scope, { childList: true, subtree: true });
        }

        function mixGlobalColors(primary, secondary, ratio) {
            const a = hexToRgbGlobal(primary);
            const b = hexToRgbGlobal(secondary);
            const mix = (x, y) => Math.round((x * (1 - ratio)) + (y * ratio));
            return `rgb(${mix(a.r, b.r)}, ${mix(a.g, b.g)}, ${mix(a.b, b.b)})`;
        }

        function hexToRgbGlobal(hex) {
            const clean = String(hex || '').replace('#', '');
            const normalized = clean.length === 3 ? clean.split('').map(x => x + x).join('') : clean.padEnd(6, '0').slice(0, 6);
            return {
                r: parseInt(normalized.slice(0, 2), 16) || 0,
                g: parseInt(normalized.slice(2, 4), 16) || 0,
                b: parseInt(normalized.slice(4, 6), 16) || 0
            };
        }

        function getGlobalFontFamilyLabel(fontFamily) {
            switch (fontFamily) {
                case "'Segoe UI', sans-serif": return 'Segoe UI';
                case "'Trebuchet MS', sans-serif": return 'Trebuchet';
                case 'Georgia, serif': return 'Georgia';
                case "'JetBrains Mono', monospace": return 'JetBrains Mono';
                default: return 'Default';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            initGlobalPageSettingsObserver();
            applyGlobalPageSettingsToScope(document.getElementById('mainBody'), getStoredGlobalPageSettings());
        });
    </script>

