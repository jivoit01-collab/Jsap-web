        <div id="ehTankhaErr" style="display:none;color:#991b1b;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 12px;font-size:13px;font-weight:700;margin-bottom:10px"></div>
        <div class="eh-modal-actions">
            <button type="button" class="eh-btn secondary" onclick="closeUnlockSalaryModal()">Cancel</button>
