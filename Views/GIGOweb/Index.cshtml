                        }, 100);

                        console.log("❌ VALIDATION FAILED: Vehicle number exists but no attachment");
                        return false;
                    } else {
                        // Clear any previous highlighting
                        this.clearFieldError('vehicleNoLogistics');
                        console.log("✅ VALIDATION PASSED: Vehicle number and attachment both exist");
                    }
                } else {
                    console.log("ℹ️ No vehicle number entered, vehicle attachment not required");
                }

                return true;
            },

            validateContentsTable() {
                const table = document.getElementById('contentsTable');
                if (!table) return { isValid: true, errors: [] };

                const tbody = table.getElementsByTagName('tbody')[0];
                const rows = tbody.getElementsByTagName('tr');
                const errors = [];

                if (rows.length === 0) {
                    errors.push('At least one item must be added to contents table');
                    return { isValid: false, errors };
                }

                for (let i = 0; i < rows.length; i++) {
                    const cells = rows[i].cells;
                    if (cells.length >= 8) {
                        const quantityInput = cells[7].querySelector('input');

                        if (quantityInput) {
                            const quantityReceived = parseFloat(quantityInput.value) || 0;

                            if (quantityReceived < 0) {
                                errors.push(`Item ${i + 1}: Received quantity cannot be negative`);
                            }

                            const poQtyInput = cells[4].querySelector('input');
                            const poQuantity = poQtyInput ? parseFloat(poQtyInput.value) || 0 : 0;

                            if (quantityReceived > poQuantity) {
                                errors.push(`Item ${i + 1}: Received quantity (${quantityReceived}) exceeds PO quantity (${poQuantity})`);
                            }
                        }
                    }
                }

                return { isValid: errors.length === 0, errors };
            },

            validateAll() {
                this.errors = [];
                let isValid = true;

                this.hideValidationSummary();

                // Validate all mandatory fields
                Object.keys(this.mandatoryFields).forEach(fieldId => {
                    if (!this.validateField(fieldId)) {
                        isValid = false;
                    }
                });

                // UPDATED: Validate vehicle attachment (separate from general attachments)
                if (!this.validateVehicleAttachment()) {
                    isValid = false;
                }

                // Validate contents table
                const contentsValidation = this.validateContentsTable();
                if (!contentsValidation.isValid) {
                    this.errors.push(...contentsValidation.errors);
                    isValid = false;
                }

                // Show validation summary if there are errors
                if (!isValid) {
                    this.showValidationSummary(this.errors);
                }

                return isValid;
            },

            showFieldError(fieldId, message) {
                const field = document.getElementById(fieldId);
                if (!field) return;

                field.classList.add('error');
                const errorElement = document.getElementById(`${fieldId}-error`);
                if (errorElement) {
                    errorElement.textContent = message;
                    errorElement.style.display = 'block';
                }
            },

            clearFieldError(fieldId) {
                const field = document.getElementById(fieldId);
                if (!field) return;

                field.classList.remove('error');
                const errorElement = document.getElementById(`${fieldId}-error`);
                if (errorElement) {
                    errorElement.style.display = 'none';
                }
            },

            showValidationSummary(errors) {
                const summary = document.getElementById('validationSummary');
                const list = document.getElementById('validationList');

                if (summary && list) {
                    list.innerHTML = errors.map(error => `<li>${error}</li>`).join('');
                    summary.classList.add('show');
                    summary.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            },

            hideValidationSummary() {
                const summary = document.getElementById('validationSummary');
                if (summary) {
                    summary.classList.remove('show');
                }
            }
        };

