            <td style="padding:6px 10px;border-bottom:1px solid var(--border);font-weight:500">${esc(r.empName||'—')}</td>
            <td style="padding:6px 10px;border-bottom:1px solid var(--border)">${r.h1Name ? `<span class="level-badge lvl-h1" style="font-size:10px">${esc(r.h1Name)}</span>` : '<span style="color:var(--muted)">—</span>'}</td>
