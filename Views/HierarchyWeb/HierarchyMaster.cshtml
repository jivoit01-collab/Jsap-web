<script>
    const PAGE_SETTINGS_KEY = 'hmPageSettings_v1';
    const DEFAULT_PAGE_SETTINGS = {
        fontSize: 13,
        fontFamily: "'Sora',sans-serif",
        fontWeight: '400',
        lineHeight: '1.5',
        rowDensity: 'comfortable',
        textColor: '#0f172a',
        accentColor: '#0b2c4d',
        backgroundColor: '#ffffff'
    };
    // Register modals for body append
    (function(){
        ['logModal','colModal','visModal','pageSettingsModal'].forEach(function(id){
            const m = document.getElementById(id);
            if(m) document.body.appendChild(m);
        });
    })();

    function getStoredPageSettings() {
        try {
            const raw = localStorage.getItem(PAGE_SETTINGS_KEY);
            if (!raw) return { ...DEFAULT_PAGE_SETTINGS };
            return { ...DEFAULT_PAGE_SETTINGS, ...JSON.parse(raw) };
        } catch (e) {
            return { ...DEFAULT_PAGE_SETTINGS };
        }
    }

    function applyPageSettingsToDocument(settings) {
        const root = document.documentElement;
        const fontSize  = parseInt(settings.fontSize, 10) || DEFAULT_PAGE_SETTINGS.fontSize;
        const textColor = settings.textColor       || DEFAULT_PAGE_SETTINGS.textColor;
        const accent    = settings.accentColor     || DEFAULT_PAGE_SETTINGS.accentColor;
        const bgColor   = settings.backgroundColor || DEFAULT_PAGE_SETTINGS.backgroundColor;
        const rowDensity= settings.rowDensity      || DEFAULT_PAGE_SETTINGS.rowDensity;
        const fontWeight= settings.fontWeight      || DEFAULT_PAGE_SETTINGS.fontWeight;
        const lineHeight= settings.lineHeight      || DEFAULT_PAGE_SETTINGS.lineHeight;
        const fontFamily= settings.fontFamily      || DEFAULT_PAGE_SETTINGS.fontFamily;
        const rowH      = { compact:'36px', comfortable:'44px', spacious:'54px' }[rowDensity] || '44px';
        const sm        = Math.max(10, fontSize - 2);
        const lg        = fontSize + 2;

        // ── Colors & layout via CSS variables ──
        root.style.setProperty('--row-h', rowH);
        root.style.setProperty('--text',  textColor);
        root.style.setProperty('--g1',    accent);
        root.style.setProperty('--g2',    accent);
        root.style.setProperty('--g3',    accent);
        root.style.setProperty('--bg',    bgColor);
        root.style.setProperty('--bg2',   mixColor(bgColor, '#f8fafc', 0.55));
        root.style.setProperty('--bg3',   mixColor(bgColor, '#e2e8f0', 0.45));
        root.style.setProperty('--muted', mixColor(textColor, '#94a3b8', 0.5));

        // ── Typography via a single injected style tag ──
        // CSS variables alone don't work because hundreds of CSS rules hardcode
        // font-family/font-size/font-weight directly. A style tag with !important
        // is the only reliable way to override them all at once.
        let ps = document.getElementById('ps-override');
        if (!ps) { ps = document.createElement('style'); ps.id = 'ps-override'; document.head.appendChild(ps); }

        ps.textContent = `
            /* Font-family: apply to all text elements */
            body, body div, body span, body p, body td, body th, body label,
            body input, body select, body textarea, body button, body a,
            body li, body h1, body h2, body h3, body h4, body h5, body h6 {
                font-family: ${fontFamily} !important;
            }
            /* Restore Bootstrap Icons (rendered via ::before pseudo-element) */
            .bi::before, [class^="bi-"]::before, [class*=" bi-"]::before {
                font-family: bootstrap-icons !important;
            }

            /* Font-size: regular content */
            body, table.hm td, .filterbar, .search-box, .filter-sel,
            .upload-panel, .grid-wrap div { font-size: ${fontSize}px !important; }

            /* Font-size: small elements */
            .btn, .row-count, .stat-pill, .stat-bar { font-size: ${sm}px !important; }

            /* Font-size: headings */
            .hm-modal-title, .topbar-title { font-size: ${lg}px !important; }

            /* Font-weight: main content */
            body, table.hm td, .filterbar, .search-box, .filter-sel,
            .stat-pill, .row-count, .upload-panel {
                font-weight: ${fontWeight} !important;
                line-height: ${lineHeight} !important;
            }

            /* Always-bold elements (preserve hierarchy) */
            .hm-modal-title, .topbar-title, b, strong, table.hm th,
            .stat-pill b, .fl { font-weight: 700 !important; }
        `;
    }

    function loadPageSettings() {
        const settings = getStoredPageSettings();
        applyPageSettingsToDocument(settings);
        return settings;
    }

    function openPageSettings() {
        const settings = getStoredPageSettings();
        document.getElementById('psFontSize').value = settings.fontSize;
        document.getElementById('psFontFamily').value = settings.fontFamily;
        document.getElementById('psFontWeight').value = settings.fontWeight || DEFAULT_PAGE_SETTINGS.fontWeight;
        document.getElementById('psLineHeight').value = settings.lineHeight || DEFAULT_PAGE_SETTINGS.lineHeight;
        document.getElementById('psRowDensity').value = settings.rowDensity || DEFAULT_PAGE_SETTINGS.rowDensity;
        document.getElementById('psTextColor').value = settings.textColor;
        document.getElementById('psAccentColor').value = settings.accentColor;
        document.getElementById('psBgColor').value = settings.backgroundColor;
        previewPageSettings();
        document.getElementById('pageSettingsModal').classList.add('open');
    }

    function closePageSettings() {
        document.getElementById('pageSettingsModal').classList.remove('open');
        applyPageSettingsToDocument(getStoredPageSettings());
    }

    function getPageSettingsFromInputs() {
        return {
            fontSize: parseInt(document.getElementById('psFontSize').value, 10) || DEFAULT_PAGE_SETTINGS.fontSize,
            fontFamily: document.getElementById('psFontFamily').value || DEFAULT_PAGE_SETTINGS.fontFamily,
            fontWeight: document.getElementById('psFontWeight').value || DEFAULT_PAGE_SETTINGS.fontWeight,
            lineHeight: document.getElementById('psLineHeight').value || DEFAULT_PAGE_SETTINGS.lineHeight,
            rowDensity: document.getElementById('psRowDensity').value || DEFAULT_PAGE_SETTINGS.rowDensity,
            textColor: document.getElementById('psTextColor').value || DEFAULT_PAGE_SETTINGS.textColor,
            accentColor: document.getElementById('psAccentColor').value || DEFAULT_PAGE_SETTINGS.accentColor,
            backgroundColor: document.getElementById('psBgColor').value || DEFAULT_PAGE_SETTINGS.backgroundColor
        };
    }

    function previewPageSettings() {
        const settings = getPageSettingsFromInputs();
        document.getElementById('psFontSizeVal').textContent = `${settings.fontSize}px`;
        document.getElementById('psFontFamilyVal').textContent = getFontFamilyLabel(settings.fontFamily);
        document.getElementById('psFontWeightVal').textContent = { '400':'Normal','500':'Medium','600':'Semi-Bold','700':'Bold' }[settings.fontWeight] || 'Normal';
        document.getElementById('psLineHeightVal').textContent = { '1.3':'Compact','1.5':'Normal','1.8':'Relaxed' }[settings.lineHeight] || 'Normal';
        document.getElementById('psRowDensityVal').textContent = { compact:'Compact', comfortable:'Comfortable', spacious:'Spacious' }[settings.rowDensity] || 'Comfortable';
        document.getElementById('psTextColorVal').textContent = settings.textColor.toUpperCase();
        document.getElementById('psAccentColorVal').textContent = settings.accentColor.toUpperCase();
        document.getElementById('psBgColorVal').textContent = settings.backgroundColor.toUpperCase();
        applyPageSettingsToDocument(settings);
    }

    function applyPageSettings() {
        const settings = getPageSettingsFromInputs();
        localStorage.setItem(PAGE_SETTINGS_KEY, JSON.stringify(settings));
        applyPageSettingsToDocument(settings);
        closePageSettings();
        toast('Page settings applied', 'ok');
    }

    function resetPageSettings() {
        localStorage.removeItem(PAGE_SETTINGS_KEY);
        document.getElementById('psFontSize').value = DEFAULT_PAGE_SETTINGS.fontSize;
        document.getElementById('psFontFamily').value = DEFAULT_PAGE_SETTINGS.fontFamily;
        document.getElementById('psFontWeight').value = DEFAULT_PAGE_SETTINGS.fontWeight;
        document.getElementById('psLineHeight').value = DEFAULT_PAGE_SETTINGS.lineHeight;
        document.getElementById('psRowDensity').value = DEFAULT_PAGE_SETTINGS.rowDensity;
        document.getElementById('psTextColor').value = DEFAULT_PAGE_SETTINGS.textColor;
        document.getElementById('psAccentColor').value = DEFAULT_PAGE_SETTINGS.accentColor;
        document.getElementById('psBgColor').value = DEFAULT_PAGE_SETTINGS.backgroundColor;
        previewPageSettings();
        toast('Page settings reset', 'ok');
    }

    function getFontFamilyLabel(fontFamily) {
        const map = {
            "'Sora',sans-serif": 'Sora',
            "'Inter',sans-serif": 'Inter',
            "'DM Sans',sans-serif": 'DM Sans',
            'Georgia,serif': 'Georgia',
            "'Trebuchet MS',sans-serif": 'Trebuchet',
            "'JetBrains Mono',monospace": 'JetBrains Mono',
            "'Courier New',monospace": 'Courier New'
        };
        return map[fontFamily] || 'Sora';
    }

function mixColor(primary, secondary, ratio) {
        const a = hexToRgb(primary);
        const b = hexToRgb(secondary);
        const mix = (x, y) => Math.round((x * (1 - ratio)) + (y * ratio));
        return `rgb(${mix(a.r, b.r)}, ${mix(a.g, b.g)}, ${mix(a.b, b.b)})`;
    }

    function hexToRgb(hex) {
        const value = (hex || '').replace('#', '');
        const normalized = value.length === 3
            ? value.split('').map(ch => ch + ch).join('')
            : value.padEnd(6, '0').slice(0, 6);

        return {
            r: parseInt(normalized.slice(0, 2), 16) || 0,
            g: parseInt(normalized.slice(2, 4), 16) || 0,
            b: parseInt(normalized.slice(4, 6), 16) || 0
        };
    }

    loadPageSettings();

    // ══════════════════════════════════════════════════════
    // CUSTOM COLUMN MANAGER
    // ══════════════════════════════════════════════════════
    let customFieldsMeta = [];
    let customValuesMap = {};  // { employeeId: { fieldId: value } }

    async function loadCustomFields() {
        try {
            const r = await api(`${API}/GetCustomFields`);
            if (r.success) customFieldsMeta = r.data || [];
        } catch(e) {}
    }

    async function loadCustomValues() {
        try {
            const r = await api(`${API}/GetEmployeeCustomValues`);
            if (r.success) {
                customValuesMap = {};
                (r.data || []).forEach(v => {
                    if (!customValuesMap[v.employeeId]) customValuesMap[v.employeeId] = {};
                    customValuesMap[v.employeeId][v.fieldId] = v.value;
                });
            }
        } catch(e) {}
    }

    // Override loadGrid to also load custom fields
    const _origLoadGrid = loadGrid;
    loadGrid = async function() {
        await Promise.all([loadCustomFields(), loadCustomValues()]);
        await _origLoadGrid();
    };

    function onCfTypeChange() {
        document.getElementById('cf_options_wrap').style.display =
            document.getElementById('cf_type').value === 'Dropdown' ? '' : 'none';
    }

    function showCfError(msg) {
        const el = document.getElementById('cfErr');
        el.textContent = msg || '';
        el.style.display = msg ? 'block' : 'none';
    }

    async function openColumnManager() {
        showCfError('');
        document.getElementById('cf_name').value = '';
        document.getElementById('cf_type').value = 'Text';
        document.getElementById('cf_options').value = '';
        document.getElementById('cf_options_wrap').style.display = 'none';
        await loadCustomFields();
        renderCfList();
        document.getElementById('colModal').classList.add('open');
    }

    function closeColumnManager() {
        document.getElementById('colModal').classList.remove('open');
    }

    function renderCfList() {
        const el = document.getElementById('cfList');
        if (!customFieldsMeta.length) {
            el.innerHTML = '<div class="dm-empty">No custom columns yet</div>';
            return;
        }
        el.innerHTML = customFieldsMeta.map(f =>
            `<div class="cf-row">
                <span class="cf-name">${esc(f.fieldName)}</span>
                <span class="cf-type">${esc(f.fieldType)}</span>
                ${f.isRequired ? '<span class="cf-type" style="color:var(--danger)">Required</span>' : ''}
                <button class="cf-del" onclick="removeCustomField(${f.fieldId},'${esc(f.fieldName)}')">✕ Remove</button>
            </div>`
        ).join('');
    }

    async function addCustomField() {
        showCfError('');
        const name = document.getElementById('cf_name').value.trim();
        const type = document.getElementById('cf_type').value;
        if (!name) { showCfError('Enter column name'); return; }

        let options = null;
        if (type === 'Dropdown') {
            const raw = document.getElementById('cf_options').value.trim();
            if (!raw) { showCfError('Enter dropdown options'); return; }
            options = JSON.stringify(raw.split(',').map(s => s.trim()).filter(Boolean));
        }

        try {
            const r = await api(`${API}/AddCustomField`, 'POST', { fieldName: name, fieldType: type, isRequired: false, options: options });
            if (r.success) {
                document.getElementById('cf_name').value = '';
                document.getElementById('cf_options').value = '';
                await loadCustomFields();
                renderCfList();
                showCfError('');
                toast(`Column "${name}" added`, 'ok');
                await loadGrid();
            } else {
                showCfError(r.message || 'Failed');
            }
        } catch(e) { showCfError('Error: ' + e.message); }
    }

    async function removeCustomField(fieldId, name) {
        if (!confirm(`Remove column "${name}"? Data will be hidden but not deleted.`)) return;
        try {
            const r = await api(`${API}/RemoveCustomField/${fieldId}`, 'DELETE');
            if (r.success) {
                await loadCustomFields();
                renderCfList();
                toast(`Column "${name}" removed`, 'ok');
                await loadGrid();
            } else { showCfError(r.message || 'Failed'); }
        } catch(e) { showCfError('Error'); }
    }

    async function saveCustomValue(empId, fieldId, value) {
        try {
            await api(`${API}/SetEmployeeCustomValue`, 'POST', { employeeId: empId, fieldId: fieldId, value: value });
            if (!customValuesMap[empId]) customValuesMap[empId] = {};
            customValuesMap[empId][fieldId] = value;
        } catch(e) {}
    }

    function getCustomValue(empId, fieldId) {
        return customValuesMap[empId]?.[fieldId] || '';
    }

    // ── Inject custom columns into renderGrid ──
    const _origRenderGrid = renderGrid;
    renderGrid = function(rows) {
        if (!customFieldsMeta.length) { _origRenderGrid(rows); return; }

        // Call original to build base grid
        _origRenderGrid(rows);

        // Now inject custom columns into the existing table
        const table = document.querySelector('table.hm');
        if (!table) return;

        const cf = customFieldsMeta;

        // Add headers to group row
        const grpRow = table.querySelector('thead tr.grp');
        if (grpRow) {
            const th = document.createElement('th');
            th.className = 'g-act';
            th.colSpan = cf.length;
            th.textContent = 'CUSTOM';
            th.style.cssText = 'background:rgba(147,51,234,.05);color:#9333ea';
            grpRow.insertBefore(th, grpRow.lastElementChild); // before Actions
        }

        // Add headers to cols row
        const colsRow = table.querySelector('thead tr.cols');
        if (colsRow) {
            cf.forEach(f => {
                const th = document.createElement('th');
                th.style.minWidth = '100px';
                th.textContent = f.fieldName;
                colsRow.insertBefore(th, colsRow.lastElementChild); // before Actions
            });
        }

        // Add colgroup cols
        const colgroup = table.querySelector('colgroup');
        if (colgroup && IS_ADMIN) {
            const actCol = colgroup.lastElementChild;
            cf.forEach(() => {
                const col = document.createElement('col');
                col.style.width = '110px';
                colgroup.insertBefore(col, actCol);
            });
        }

        // Add data cells to each row
        const bodyRows = table.querySelectorAll('tbody tr');
        bodyRows.forEach((tr, ri) => {
            const row = rows[ri];
            if (!row) return;
            // Find the leaf employee for this row
            const empId = row.execEmployeeId > 0 ? row.execEmployeeId : row.subHodEmployeeId > 0 ? row.subHodEmployeeId : row.hodEmployeeId;
            const actTd = IS_ADMIN ? tr.lastElementChild : null;

            cf.forEach(f => {
                const td = document.createElement('td');
                const val = getCustomValue(empId, f.fieldId);

                if (IS_ADMIN) {
                    if (f.fieldType === 'Dropdown') {
                        let opts = [];
                        try { opts = JSON.parse(f.options || '[]'); } catch(e) {}
                        td.innerHTML = `<select class="filter-sel" style="font-size:11px;padding:3px 6px;min-width:80px" onchange="saveCustomValue(${empId},${f.fieldId},this.value)"><option value="">—</option>${opts.map(o => `<option value="${esc(o)}" ${val === o ? 'selected' : ''}>${esc(o)}</option>`).join('')}</select>`;
                    } else if (f.fieldType === 'Boolean') {
                        td.innerHTML = `<select class="filter-sel" style="font-size:11px;padding:3px 6px" onchange="saveCustomValue(${empId},${f.fieldId},this.value)"><option value="">—</option><option value="Yes" ${val === 'Yes' ? 'selected' : ''}>Yes</option><option value="No" ${val === 'No' ? 'selected' : ''}>No</option></select>`;
                    } else if (f.fieldType === 'Date') {
                        td.innerHTML = `<input type="date" class="fi" style="font-size:11px;padding:3px 6px;width:120px" value="${esc(val)}" onchange="saveCustomValue(${empId},${f.fieldId},this.value)" />`;
                    } else {
                        td.innerHTML = `<input type="${f.fieldType === 'Number' ? 'number' : 'text'}" class="fi" style="font-size:11px;padding:3px 6px;width:100px" value="${esc(val)}" onblur="saveCustomValue(${empId},${f.fieldId},this.value)" />`;
                    }
                } else {
                    td.innerHTML = val ? `<span style="font-size:11px">${esc(val)}</span>` : '<span class="cell-empty">—</span>';
                }

                if (actTd) tr.insertBefore(td, actTd);
                else tr.appendChild(td);
            });
        });
    };

    // ══════════════════════════════════════════════════════
    // COLUMN VISIBILITY & ORDER
    // ══════════════════════════════════════════════════════
    const ALL_COL_DEFS = [
        { key:'hod',         label:'HOD',             group:'HOD',        groupCls:'g-hod',  sticky:true,  width:'140px', minWidth:'180px' },
        { key:'dept',        label:'Department',      group:'Department', groupCls:'g-dept',               width:'175px', minWidth:'130px' },
        { key:'subDept',     label:'Sub-Dept',        group:'Department', groupCls:'g-dept',               width:'130px', minWidth:'115px' },
        { key:'subHod',      label:'SubHOD',          group:'SubHOD',     groupCls:'g-sub',                width:'155px', minWidth:'170px' },
        { key:'subHodDesig', label:'SubHOD Desig.',   group:'SubHOD',     groupCls:'g-sub',                width:'105px', minWidth:'115px' },
        { key:'exec',        label:'Executive',       group:'Executive',  groupCls:'g-exec',               width:'155px', minWidth:'170px' },
        { key:'execDesig',   label:'Exec Desig.',     group:'Executive',  groupCls:'g-exec',               width:'105px', minWidth:'115px' },
        { key:'status',      label:'Status',          group:'Status',     groupCls:'g-act',                width:'85px',  minWidth:'78px'  },
        { key:'actions',     label:'Actions',         group:'Actions',    groupCls:'g-act',  adminOnly:true, noHide:true, width:'115px', minWidth:'68px' },
    ];
    const COL_LS_KEY = 'hmColVis_v1';
    let colVisState = null;

    function initColVis() {
        const defaults = { order: ALL_COL_DEFS.map(c=>c.key), hidden: [] };
        try {
            const s = localStorage.getItem(COL_LS_KEY);
            if (s) { const p = JSON.parse(s); if(p&&Array.isArray(p.order)) defaults.order=p.order; if(p&&Array.isArray(p.hidden)) defaults.hidden=p.hidden; }
        } catch(e) {}
        colVisState = { order: defaults.order.slice(), hidden: new Set(defaults.hidden) };
    }

    function saveColVis() {
        localStorage.setItem(COL_LS_KEY, JSON.stringify({ order: colVisState.order, hidden: [...colVisState.hidden] }));
    }

    function getEffectiveCols(salCols, adm) {
        if (!colVisState) initColVis();
        const available = new Set(ALL_COL_DEFS.filter(c=>!(c.salOnly&&!salCols)&&!(c.adminOnly&&!adm)).map(c=>c.key));
        const ordered = colVisState.order.filter(k=>available.has(k));
        ALL_COL_DEFS.forEach(c=>{ if(available.has(c.key)&&!ordered.includes(c.key)) ordered.push(c.key); });
        return ordered.map(k=>{ const d=ALL_COL_DEFS.find(c=>c.key===k); return d?{...d, hidden:colVisState.hidden.has(k)}:null; }).filter(Boolean);
    }

    function openVisModal() {
        if (!colVisState) initColVis();
        renderVisModalList();
        document.getElementById('visModal').classList.add('open');
    }
    function closeVisModal() { document.getElementById('visModal').classList.remove('open'); }

    function renderVisModalList() {
        const salCols = false;
        const adm = IS_ADMIN;
        const cols = getEffectiveCols(salCols, adm);
        document.getElementById('visColList').innerHTML = cols.map((c,i)=>`
            <div class="vis-row${c.hidden?' vis-row-hidden':''}">
                <label class="vis-col-label">
                    <input type="checkbox" ${c.hidden?'':'checked'} ${c.noHide?'disabled':''} onchange="toggleColVis('${c.key}',this.checked)" />
                    <span class="vis-col-name">${c.label}</span>
                </label>
                <span class="vis-group-badge">${c.group}</span>
                <div class="vis-arrows">
                    <button class="vis-arrow" onclick="moveCol('${c.key}',-1)" ${i===0?'disabled':''}>▲</button>
                    <button class="vis-arrow" onclick="moveCol('${c.key}',1)"  ${i===cols.length-1?'disabled':''}>▼</button>
                </div>
            </div>`).join('');
    }

    function toggleColVis(key, visible) {
        if (!colVisState) initColVis();
        if (visible) colVisState.hidden.delete(key); else colVisState.hidden.add(key);
        saveColVis();
        renderVisModalList();
    }

    function moveCol(key, dir) {
        if (!colVisState) initColVis();
        const cols = getEffectiveCols(false, IS_ADMIN);
        const keys = cols.map(c=>c.key);
        const idx = keys.indexOf(key);
        if (idx < 0) return;
        const newIdx = idx + dir;
        if (newIdx < 0 || newIdx >= keys.length) return;
        const bKey = keys[newIdx];
        const a = colVisState.order.indexOf(key);
        const b = colVisState.order.indexOf(bKey);
        if (a >= 0 && b >= 0) {
            [colVisState.order[a], colVisState.order[b]] = [colVisState.order[b], colVisState.order[a]];
        } else {
            colVisState.order = keys.slice();
            const na = colVisState.order.indexOf(key);
            if (na >= 0 && na + dir >= 0 && na + dir < colVisState.order.length)
                [colVisState.order[na], colVisState.order[na+dir]] = [colVisState.order[na+dir], colVisState.order[na]];
        }
        saveColVis();
        renderVisModalList();
    }

    function applyColVis() { closeVisModal(); loadGrid(); }

    function resetColVis() {
        colVisState = { order: ALL_COL_DEFS.map(c=>c.key), hidden: new Set() };
        saveColVis();
        renderVisModalList();
        toast('Column settings reset to default', 'ok');
    }
</script>

