            /* ══ SHARED TREE ══ */
            function sharedTreeRender(h,ts,togglePrefix){
                var hc=h.color;var html='<div class="tr-wrap"><div class="tr-root"><div class="tr-node tr-hod" style="background:'+hc.bg+';border-color:'+hc.border+';color:'+hc.text+'"><i class="bi bi-person-badge-fill tr-ico"></i><span class="tr-name">'+esc(h.name)+'</span><span class="tr-tag">HOD</span>';
                if(SHOW_SAL&&h.sal)html+='<span class="tr-sal">₹'+fmtN(h.sal)+'</span>';
                html+='</div>';
                if(h.depts.length){html+='<div class="tr-children">';h.depts.forEach(function(dept,di){var dKey='dept_'+dept,dExp=!!ts[dKey];var dc=DEPT_COLORS[di%DEPT_COLORS.length];var salesTree=getSalesTreeForDept(h,dept);var subs=h.subs.filter(function(s){return s.dept===dept||(s.dept===''&&dept===h.depts[0]);});var hasKids=salesTree?(salesTree.h2List||[]).length>0:subs.length>0;var deptCount=salesTree?(salesTree.h2List||[]).length:subs.length;html+='<div class="tr-item"><div class="tr-line-h"></div><div class="tr-node tr-dept'+(dExp?' tr-exp':'')+'" style="background:'+(dExp?dc.bg:'#fff')+';border-color:'+(dExp?dc.border:'#cbd5e1')+';color:'+(dExp?dc.text:'#1e293b')+'"'+(hasKids?' onclick="'+togglePrefix+'\''+escAttr(dKey)+'\',event)"':'')+'>'; if(hasKids)html+='<i class="bi '+(dExp?'bi-chevron-down':'bi-chevron-right')+' tr-arrow"></i>';html+='<i class="bi bi-building tr-ico"></i><span class="tr-name">'+esc(dept)+'</span><span class="tr-tag">Dept</span>';if(hasKids)html+='<span class="tr-count" style="background:'+(dExp?dc.badge:'#94a3b8')+'">'+deptCount+'</span>';html+='</div>';
                if(dExp&&salesTree){html+='<div class="tr-children">'+renderSalesTreeBranch(h,salesTree,ts,togglePrefix)+'</div>';}
                else if(dExp&&subs.length){html+='<div class="tr-children">';subs.forEach(function(s){var sdKey='sd_'+s.idx,sdExp=!!ts[sdKey];var hasSubHods=(s.subHods&&s.subHods.length>0),hasDirectEx=s.execs.length>0,hasMore=hasSubHods||hasDirectEx;var totalExecs=hasSubHods?s.subHods.reduce(function(a,sh){return a+(sh.execs||[]).length;},0):s.execs.length;html+='<div class="tr-item"><div class="tr-line-h"></div><div class="tr-node tr-subdept'+(sdExp?' tr-exp':'')+'" style="background:'+(sdExp?'#d1fae5':'#fff')+';border-color:'+(sdExp?'#059669':'#cbd5e1')+';color:'+(sdExp?'#064e3b':'#1e293b')+'"'+(hasMore?' onclick="'+togglePrefix+'\''+sdKey+'\',event)"':'')+'>'; if(hasMore)html+='<i class="bi '+(sdExp?'bi-chevron-down':'bi-chevron-right')+' tr-arrow"></i>';html+='<i class="bi bi-buildings tr-ico"></i><span class="tr-name">'+esc(s.sdName)+'</span><span class="tr-tag">Sub-Dept</span>';if(totalExecs)html+='<span class="tr-count" style="background:'+(sdExp?'#047857':'#94a3b8')+'">'+totalExecs+'</span>';html+='</div>';
                if(sdExp&&hasMore){html+='<div class="tr-children">';if(hasSubHods){s.subHods.forEach(function(sh,shi){var shKey='sh_'+s.idx+'_'+shi,shExp=!!ts[shKey];var shExecs=sh.execs||[];html+='<div class="tr-item"><div class="tr-line-h"></div><div class="tr-node tr-subhod'+(shExp?' tr-exp':'')+'" style="background:'+(shExp?'#fef3c7':'#fff')+';border-color:'+(shExp?'#d97706':'#cbd5e1')+';color:'+(shExp?'#78350f':'#1e293b')+'"'+(shExecs.length?' onclick="'+togglePrefix+'\''+shKey+'\',event)"':'')+'>'; if(shExecs.length)html+='<i class="bi '+(shExp?'bi-chevron-down':'bi-chevron-right')+' tr-arrow"></i>';html+='<i class="bi bi-people-fill tr-ico"></i><span class="tr-name">'+esc(sh.name)+'</span><span class="tr-tag">Sub-HOD</span>';if(sh.code)html+='<span class="tr-code">'+esc(sh.code)+'</span>';if(SHOW_SAL&&sh.sal)html+='<span class="tr-sal">₹'+fmtN(sh.sal)+'</span>';if(shExecs.length)html+='<span class="tr-count" style="background:'+(shExp?'#b45309':'#94a3b8')+'">'+shExecs.length+'</span>';html+='</div>';if(shExp&&shExecs.length){html+='<div class="tr-children">';shExecs.forEach(function(ex){html+='<div class="tr-item"><div class="tr-line-h"></div>'+trExecNode(ex)+'</div>';});html+='</div>';}html+='</div>';}); }else{s.execs.forEach(function(ex){html+='<div class="tr-item"><div class="tr-line-h"></div>'+trExecNode(ex)+'</div>';});}html+='</div>';}html+='</div>';});html+='</div>';}html+='</div>';});html+='</div>';}
                return html+'</div></div>';
            }
            function trExecNode(ex){ return '<div class="tr-node tr-exec"><i class="bi bi-person-fill tr-ico"></i><span class="tr-name">'+esc(ex.name)+'</span>'+(ex.code?'<span class="tr-code">'+esc(ex.code)+'</span>':'')+(SHOW_SAL&&ex.sal?'<span class="tr-sal">₹'+fmtN(ex.sal)+'</span>':'')+'</div>'; }

            /* ══ STAT POPUP ══ */
            function showStatPopup(type){
                if(!RAW_DATA.length)return;
                var cfgs={
                    hod:{title:'All HODs',grad:'#dc2626,#b91c1c',icon:'bi-person-badge-fill',heads:['#','Name','Code','Departments','Sub-HODs','Executives','Team'],rows:RAW_DATA.map(function(h){return[h.name,h.code||'—',h.depts.join(' · ')||'—',h.subhodCount,h.execCount,h.totalTeam];})},
                    dept:{title:'All Departments',grad:'#2563eb,#1d4ed8',icon:'bi-building-fill',heads:['#','Department','HOD','Sub-Depts'],rows:(function(){var r=[];RAW_DATA.forEach(function(h){h.depts.forEach(function(d){var cnt=h.subs.filter(function(s){return s.dept===d;}).length;r.push([d,h.name,cnt]);});});return r;})()},
                    subdept:{title:'All Sub-Departments',grad:'#d97706,#b45309',icon:'bi-buildings-fill',heads:['#','Sub-Dept','Department','HOD','Sub-HODs','Execs'],rows:(function(){var r=[];RAW_DATA.forEach(function(h){h.subs.forEach(function(s){var shNames=(s.subHods||[]).map(function(sh){return sh.name;}).join(', ')||'—';var exCnt=0;(s.subHods||[]).forEach(function(sh){exCnt+=sh.execs.length;});exCnt+=s.execs.length;r.push([s.sdName,s.dept||h.depts[0]||'—',h.name,shNames,exCnt]);});});return r;})()},
                    subhod:{title:'All Sub-HODs',grad:'#9333ea,#7c3aed',icon:'bi-people-fill',heads:['#','Name','Code','Sub-Dept','Department','HOD','Execs'],rows:(function(){var r=[],seen={};RAW_DATA.forEach(function(h){h.subs.forEach(function(s){(s.subHods||[]).forEach(function(sh){var k=sh.code||sh.name;if(!seen[k]){seen[k]=1;r.push([sh.name,sh.code||'—',s.sdName,s.dept||h.depts[0]||'—',h.name,(sh.execs||[]).length]);}});});});return r;})()},
                    exec:{title:'All Executives',grad:'#047857,#065f46',icon:'bi-person-fill',heads:['#','Name','Code','Sub-HOD','Sub-Dept','HOD'],rows:(function(){var r=[],seen={};RAW_DATA.forEach(function(h){h.subs.forEach(function(s){(s.subHods||[]).forEach(function(sh){(sh.execs||[]).forEach(function(e){var k=e.code||e.name;if(!seen[k]){seen[k]=1;r.push([e.name,e.code||'—',sh.name,s.sdName,h.name]);}});});(s.execs||[]).forEach(function(e){var k=e.code||e.name;if(!seen[k]){seen[k]=1;r.push([e.name,e.code||'—','—',s.sdName,h.name]);}});});});return r;})()}
                };
                var c=cfgs[type];if(!c)return;
                document.getElementById('statModalHdr').style.background='linear-gradient(135deg,'+c.grad+')';
                document.getElementById('statModalTitle').innerHTML='<i class="bi '+c.icon+' me-2" style="color:#fff"></i><span style="color:#fff">'+c.title+'</span> <span style="background:rgba(255,255,255,.2);padding:2px 10px;border-radius:20px;font-size:12px;color:#fff">'+c.rows.length+'</span>';
                var html='<div style="overflow-x:auto"><table class="stat-table"><thead><tr>';c.heads.forEach(function(h){html+='<th>'+h+'</th>';});html+='</tr></thead><tbody>';
                c.rows.forEach(function(row,i){html+='<tr><td style="color:#94a3b8;font-weight:700;width:36px">'+(i+1)+'</td>';row.forEach(function(cell,ci){if(ci===0)html+='<td><strong>'+esc(cell)+'</strong></td>';else if(typeof cell==='number')html+='<td><span class="stat-pill" style="background:#eff6ff;color:#1d4ed8">'+cell+'</span></td>';else html+='<td style="color:#475569">'+esc(String(cell))+'</td>';});html+='</tr>';});
                html+='</tbody></table></div>';document.getElementById('statModalBody').innerHTML=html;bsStatModal.show();
            }

            /* ══ NODE DATA ══ */
            function getNodeData(nodeId){
                if(nodeId==='owner'){var counts=getOrgEmployeeCounts();return{type:'owner',name:OWNER_NAME,role:'Owner',code:'',hodCount:counts.hodCount,teamCount:counts.totalEmployees};}
                var p=nodeId.split('-');
                if(p[0]==='hod'){var h=RAW_DATA[+p[1]];if(!h)return null;return{type:'hod',name:h.name,role:'HOD',code:h.code,sal:h.sal,deptCount:h.depts.length,subHodCount:h.subhodCount,execCount:h.execCount+getSalesEmployeeCount(h.salesTree),teamCount:h.totalTeam+getSalesEmployeeCount(h.salesTree)};}
                if(p[0]==='dept'){var h=RAW_DATA[+p[1]];if(!h)return null;var dName=h.depts[+p[2]];if(!dName)return null;var salesTree=getSalesTreeForDept(h,dName);if(salesTree)return{type:'dept',name:dName,role:'Department',code:'',hod:h.name,subDeptCount:(salesTree.h2List||[]).length,execCount:getSalesEmployeeCount(salesTree)};var subs=h.subs.filter(function(s){return s.dept===dName||(s.dept===''&&dName===h.depts[0]);});var exCnt=0;subs.forEach(function(s){(s.subHods||[]).forEach(function(sh){exCnt+=sh.execs.length;});exCnt+=s.execs.length;});return{type:'dept',name:dName,role:'Department',code:'',hod:h.name,subDeptCount:subs.length,execCount:exCnt};}
                if(p[0]==='sd'){var h=RAW_DATA[+p[1]];if(!h)return null;var s=h.subs[+p[2]];if(!s)return null;var exCnt=0;(s.subHods||[]).forEach(function(sh){exCnt+=sh.execs.length;});exCnt+=s.execs.length;return{type:'subdept',name:s.sdName,role:'Sub-Dept',code:'',dept:s.dept||h.depts[0]||'-',hod:h.name,subHod:(s.subHods&&s.subHods.length?s.subHods.map(function(x){return x.name;}).join(', '):'-'),execCount:exCnt};}
                if(p[0]==='sh'){var h=RAW_DATA[+p[1]];if(!h)return null;var s=h.subs[+p[2]];if(!s)return null;var shi=+p[3];var sh=(s.subHods&&s.subHods[shi])?s.subHods[shi]:null;if(!sh)return null;return{type:'subhod',name:sh.name,role:'Sub-HOD',code:sh.code,sal:sh.sal,subDept:s.sdName,dept:s.dept||h.depts[0]||'-',hod:h.name,execCount:(sh.execs||[]).length};}
                if(p[0]==='ex'){var h=RAW_DATA[+p[1]];if(!h)return null;var s=h.subs[+p[2]];if(!s)return null;var shi=+p[3],shi2=+p[4];var sh=(s.subHods&&s.subHods[shi])?s.subHods[shi]:null;var ex=sh?(sh.execs||[])[shi2]:null;if(!ex)return null;return{type:'exec',name:ex.name,role:'Executive',code:ex.code,sal:ex.sal,subHod:sh.name,subDept:s.sdName,dept:s.dept||h.depts[0]||'-',hod:h.name};}
                if(p[0]==='exd'){var h=RAW_DATA[+p[1]];if(!h)return null;var s=h.subs[+p[2]];if(!s)return null;var ex=(s.execs||[])[+p[3]];if(!ex)return null;return{type:'exec',name:ex.name,role:'Executive',code:ex.code,sal:ex.sal,subHod:'—',subDept:s.sdName,dept:s.dept||h.depts[0]||'-',hod:h.name};}
                if(p[0]==='sales2'){var h=RAW_DATA[+p[1]];var node=findSalesNode(h,p);if(!node||!node.h2)return null;return{type:'subdept',name:node.h2.h2Name||'H2',role:'H2 Level',dept:SALES_DEPT_NAME,hod:h.name,subDept:'H2',execCount:(getSalesStateBuckets(node.h2)||[]).length};}
                if(p[0]==='sales3'){var h=RAW_DATA[+p[1]];var node=findSalesNode(h,p);if(!node||!node.stateBucket)return null;return{type:'subdept',name:node.stateBucket.state||'State',role:'State',dept:SALES_DEPT_NAME,hod:h.name,subDept:node.h2.h2Name||'H2',execCount:(node.stateBucket.combos||[]).length};}
                if(p[0]==='sales4'){var h=RAW_DATA[+p[1]];var node=findSalesNode(h,p);if(!node||!node.combo)return null;return{type:'subhod',name:node.combo.label||'Designation + Group',role:'Designation + Group',dept:SALES_DEPT_NAME,hod:h.name,subDept:node.stateBucket.state||'State',execCount:(node.combo.employees||[]).length};}
                if(p[0]==='salese'){var h=RAW_DATA[+p[1]];var node=findSalesNode(h,p);if(!node||!node.employee)return null;return{type:'exec',name:node.employee.empName||'-',role:'Employee',code:node.employee.empCode||'',dept:SALES_DEPT_NAME,hod:h.name,subDept:node.combo.label||'Designation + Group',subHod:node.stateBucket.state||'State'};}
                return null;
            }

            /* ══ EXPORT ══ */
            function ehExport(){
                if(!RAW_DATA.length){showAlert('warning','Data not loaded yet.');return;}
                var hdr=['Owner','HOD','HOD Code'];if(SHOW_SAL)hdr.push('HOD Salary');hdr.push('Department','Sub-Dept','Sub-HOD','Sub-HOD Code','Sub-HOD Designation');if(SHOW_SAL)hdr.push('Sub-HOD Salary');hdr.push('Executive','Executive Code','Designation');if(SHOW_SAL)hdr.push('Exec Salary');
                var rows=[hdr.map(csvE).join(',')];
                RAW_DATA.forEach(function(h){ h.depts.forEach(function(d){ var subs=h.subs.filter(function(s){return s.dept===d||(s.dept===''&&d===h.depts[0]);});if(!subs.length){var r=[OWNER_NAME,h.name,h.code||''];if(SHOW_SAL)r.push(h.sal||'');r.push(d,'','','','');if(SHOW_SAL)r.push('');r.push('','','');if(SHOW_SAL)r.push('');rows.push(r.map(csvE).join(','));}else{subs.forEach(function(s){var shRows=[];(s.subHods||[]).forEach(function(sh){(sh.execs||[]).forEach(function(ex){shRows.push({shName:sh.name,shCode:sh.code||'',shDesig:sh.desig||'',shSal:sh.sal,ex:ex});});if(!(sh.execs||[]).length)shRows.push({shName:sh.name,shCode:sh.code||'',shDesig:sh.desig||'',shSal:sh.sal,ex:null});});(s.execs||[]).forEach(function(ex){shRows.push({shName:'',shCode:'',shDesig:'',shSal:null,ex:ex});});if(!shRows.length)shRows.push({shName:'',shCode:'',shDesig:'',shSal:null,ex:null});shRows.forEach(function(sr){var r=[OWNER_NAME,h.name,h.code||''];if(SHOW_SAL)r.push(h.sal||'');r.push(d,s.sdName,sr.shName||'',sr.shCode||'',sr.shDesig||'');if(SHOW_SAL)r.push(sr.shSal||'');r.push(sr.ex?sr.ex.name:'',sr.ex?sr.ex.code||'':'',sr.ex?sr.ex.desig||'':'');if(SHOW_SAL)r.push(sr.ex&&sr.ex.sal?sr.ex.sal:'');rows.push(r.map(csvE).join(','));});});}});});
                var blob=new Blob(['\uFEFF'+rows.join('\n')],{type:'text/csv;charset=utf-8;'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='Hierarchy_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
            }

            /* ══ UTILS ══ */
            function initials(n){if(!n)return'?';var p=n.trim().split(' ').filter(Boolean);return p.length>=2?(p[0][0]+p[1][0]).toUpperCase():n.substring(0,2).toUpperCase();}
            function fmtN(n){return n?Number(n).toLocaleString('en-IN'):'0';}
            function esc(t){if(t==null)return'';var d=document.createElement('div');d.textContent=String(t);return d.innerHTML;}
            function escAttr(s){return(s||'').replace(/'/g,"\\'").replace(/"/g,'&quot;');}
            function csvE(s){if(!s)return'';s=String(s);return(s.indexOf(',')>-1||s.indexOf('"')>-1)?'"'+s.replace(/"/g,'""')+'"':s;}
            function showAlert(type,msg){var el=document.getElementById('ehAlert');if(!el)return;el.innerHTML='<div class="alert alert-'+type+' alert-dismissible fade show mx-3 mt-2">'+msg+'<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';setTimeout(function(){var a=el.querySelector('.alert');if(a)$(a).alert('close');},4000);}
    </script>
    <script src="~/js/hierarchy-sales-popup.js?v=20260420b"></script>
}

<div class="eh-root" id="ehRoot">

    <header class="eh-header">
        <div class="eh-brand">
            <div class="eh-logo"><i class="bi bi-diagram-3-fill"></i></div>
            <div><div class="eh-hd-title">Organization Hierarchy</div><div class="eh-hd-sub">Interactive · Multi-View</div></div>
        </div>
        <div class="eh-sw" id="ehSW">
            <i class="bi bi-search eh-si"></i>
            <input type="text" id="ehSearch" class="eh-search" placeholder="Search employees, depts… (Ctrl+K)" oninput="ehSearchHandle(this.value)" autocomplete="off">
            <div class="search-drop" id="searchDrop" style="display:none"></div>
        </div>
        <div class="eh-right">
            @if (!string.IsNullOrEmpty(empName))
            {
                <div class="role-chip">
                    @if (isAdmin)
                    {
                        <span class="rc-dot" style="background:#f87171"></span>

                        <span>Admin</span>
                    }
                    else if (currentRoleTypeId == 1)
                    {
                        <span class="rc-dot" style="background:#60a5fa"></span>

                        <span>HOD</span>
                    }
                    else if (currentRoleTypeId == 2)
                    {
                        <span class="rc-dot" style="background:#fbbf24"></span>

                        <span>Sub-HOD</span>
                    }
                    else
                    {
                        <span class="rc-dot" style="background:#34d399"></span>

                        <span>Executive</span>
                    }
                    <span class="rc-sep"></span><span class="rc-name">@empName</span>
                </div>
            }
            @if ((bool)(ViewBag.CanViewSales ?? false))
            {
                <button class="eh-btn eh-btn-sal" id="btnSalesToggle" onclick="toggleSalesHierarchy()"><i class="bi bi-diagram-3"></i> Show Sales Team</button>
                <button class="eh-btn eh-btn-dup" id="btnSalesDuplicates" onclick="showSalesDuplicates()" style="display:none"><i class="bi bi-intersect"></i> <span id="btnSalesDuplicatesLabel">Duplicates (0)</span></button>
            }
            <button class="eh-btn eh-btn-export" onclick="ehExport()"><i class="bi bi-file-earmark-excel"></i> Export</button>
        </div>
    </header>

    <div id="ehAlert"></div>

    <div class="eh-stats" id="ehStats" style="display:none">
        <div class="esc" onclick="showStatPopup('hod')"><div class="esc-ico" style="background:#dbeafe;color:#2563eb"><i class="bi bi-person-badge-fill"></i></div><div><div class="esc-val" id="escHod">0</div><div class="esc-lbl">HODs</div></div></div>
        <div class="esc" onclick="showStatPopup('dept')"><div class="esc-ico" style="background:#bbf7d0;color:#16a34a"><i class="bi bi-building-fill"></i></div><div><div class="esc-val" id="escDept">0</div><div class="esc-lbl">Departments</div></div></div>
        <div class="esc" onclick="showStatPopup('subdept')"><div class="esc-ico" style="background:#fde68a;color:#d97706"><i class="bi bi-buildings-fill"></i></div><div><div class="esc-val" id="escSD">0</div><div class="esc-lbl">Sub-Depts</div></div></div>
        <div class="esc" onclick="showStatPopup('subhod')"><div class="esc-ico" style="background:#ede9fe;color:#9333ea"><i class="bi bi-people-fill"></i></div><div><div class="esc-val" id="escSH">0</div><div class="esc-lbl">Sub-HODs</div></div></div>
        <div class="esc" onclick="showStatPopup('exec')"><div class="esc-ico" style="background:#cffafe;color:#0891b2"><i class="bi bi-person-fill"></i></div><div><div class="esc-val" id="escEx">0</div><div class="esc-lbl">Executives</div></div></div>
        <div class="esc"><div class="esc-ico" style="background:#dcfce7;color:#15803d"><i class="bi bi-people-fill"></i></div><div><div class="esc-val" id="escTeam">0</div><div class="esc-lbl">Employees</div></div></div>
    </div>

