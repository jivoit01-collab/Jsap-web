    if (file) parseExcelFile(file);
}

function handleFileSelect(e) {
    const file = e.target.files[0];
    if (file) parseExcelFile(file);
}

function parseExcelFile(file) {
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const wb   = XLSX.read(e.target.result, { type: 'array', cellDates: true });
            const ws   = wb.Sheets[wb.SheetNames[0]];
            const data = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
            if (!data || data.length < 2) { showToast('Excel file appears empty', 'error'); return; }

            const headers = (data[0] || []).map(h => String(h ?? '').trim());
            const colMap  = mapColumns(headers);

            pendingRows = [];
            for (let i = 1; i < data.length; i++) {
                const row = data[i];
                const allEmpty = row.every(v => v === '' || v === null || v === undefined);
                if (allEmpty) continue;

                const g = (colIdx) => {
                    if (colIdx < 0) return '';
                    const v = String(row[colIdx] ?? '').trim();
                    return (v === '-' || v === '—' || v === '–' || v === '--') ? '' : v;
                };

                const parsedRow = {
                    rowNumber:   i,
                    h1Code:      g(colMap.h1code),
                    h1Name:      g(colMap.h1name),
                    h2Code:      g(colMap.h2code),
                    h2Name:      g(colMap.h2name),
                    h3Code:      g(colMap.h3code),
                    h3Name:      g(colMap.h3name),
                    h4Code:      g(colMap.h4code),
                    h4Name:      g(colMap.h4name),
                    empCode:     g(colMap.empcode),
                    empName:     g(colMap.empname),
                    state:       g(colMap.state),
                    groupName:   g(colMap.group),
                    designation: g(colMap.designation)
                };

                normalizeHierarchyPair(parsedRow, 'h1Code', 'h1Name');
                normalizeHierarchyPair(parsedRow, 'h2Code', 'h2Name');
                normalizeHierarchyPair(parsedRow, 'h3Code', 'h3Name');
                normalizeHierarchyPair(parsedRow, 'h4Code', 'h4Name');

                pendingRows.push(parsedRow);
            }

            document.getElementById('uploadRowCount').textContent = pendingRows.length;
            document.getElementById('btnUpload').style.display = '';
            document.getElementById('importResults').style.display = '';

            // Show which Excel column was matched for each field (helps debug missing empCode)
            const detectedEmpCodeHeader = colMap.empcode >= 0 ? headers[colMap.empcode] : null;
            const detectedEmpNameHeader = colMap.empname >= 0 ? headers[colMap.empname] : null;

            const empCodeStatus = detectedEmpCodeHeader
                ? `<span style="color:var(--success)">✅ Detected as column <strong>"${esc(detectedEmpCodeHeader)}"</strong></span>`
                : `<span style="color:var(--danger)">❌ NOT DETECTED — rename your column to <strong>"Emp Code"</strong></span>`;

            const codesDetected = pendingRows.filter(r => r.empCode).length;

            // Show all Excel headers so user can see exactly what was read
            const allHeadersHtml = headers.map((h, idx) => {
                const norm = normalizeExcelHeader(h);
                const usedFor = Object.entries(colMap).find(([, v]) => v === idx)?.[0] || '';
                const highlight = usedFor === 'empcode' ? 'background:#dcfce7;color:#16a34a;font-weight:700' :
                                  usedFor ? 'background:#eff6ff;color:#1d4ed8' : 'color:var(--muted)';
