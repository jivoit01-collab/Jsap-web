                }
                var shSet={},exSet={};
                srcHod.subs.forEach(function(s){
                    (s.subHods||[]).forEach(function(sh){
                        var k=getPersonKey('subhod',sh.name,sh.code);if(k)shSet[k]=1;
                        (sh.execs||[]).forEach(function(e){var ek=getPersonKey('exec',e.name,e.code);if(ek)exSet[ek]=1;});
                    });
                    (s.execs||[]).forEach(function(e){var ek=getPersonKey('exec',e.name,e.code);if(ek)exSet[ek]=1;});
                });
