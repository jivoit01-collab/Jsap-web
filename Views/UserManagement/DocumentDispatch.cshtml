            selectedRows.forEach(checkbox => {
                const index = checkbox.dataset.index;
                delete filesMap[`reject_${index}`];
            });

        } catch (error) {
            console.error("Update error:", error);
            hideLoader();
            alert("❌ Failed to update rejected entries: " + error.message);
        }
    }

