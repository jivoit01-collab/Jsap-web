                else if(p[0]==='hod'){ var h=RAW_DATA[+p[1]];if(!h)return desc;h.depts.forEach(function(d,di){desc.push('dept-'+h.idx+'-'+di);});h.subs.forEach(function(s){desc.push('sd-'+h.idx+'-'+s.idx);(s.subHods||[]).forEach(function(sh,shi){desc.push('sh-'+h.idx+'-'+s.idx+'-'+shi);});}); }
                else if(p[0]==='dept'){ var h=RAW_DATA[+p[1]];if(!h)return desc;var dName=h.depts[+p[2]];h.subs.filter(function(s){return s.dept===dName||(s.dept===''&&dName===h.depts[0]);}).forEach(function(s){desc.push('sd-'+h.idx+'-'+s.idx);(s.subHods||[]).forEach(function(sh,shi){desc.push('sh-'+h.idx+'-'+s.idx+'-'+shi);});}); }
                else if(p[0]==='sd'){ var h=RAW_DATA[+p[1]];if(!h)return desc;var s=h.subs[+p[2]];if(!s)return desc;(s.subHods||[]).forEach(function(sh,shi){desc.push('sh-'+h.idx+'-'+s.idx+'-'+shi);}); }
