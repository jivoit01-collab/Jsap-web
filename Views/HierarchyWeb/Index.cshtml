            <span class="ll-item"><span class="ll-dot" style="background:#d97706"></span>Sub-Dept</span><span class="ll-sep">→</span>
            <span class="ll-item"><span class="ll-dot" style="background:#9333ea"></span>Sub-HOD</span><span class="ll-sep">→</span>
            <span class="ll-item"><span class="ll-dot" style="background:#0891b2"></span>Executive</span>
            <div style="margin-left:auto;display:flex;gap:6px">
