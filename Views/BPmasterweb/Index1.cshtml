        // Setup type selection listeners for form unlocking
        function setupFormUnlockListeners() {
            const typeRadios = document.querySelectorAll('input[name="type"]');
            typeRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.checked) {
                        unlockFormElements();

                        // Call existing type handling functions
                        if (typeof handleTypeSelection === 'function') {
                            handleTypeSelection();
                        }

                        if (typeof handleTypeOrStaffChange === 'function') {
                            handleTypeOrStaffChange();
                        }

                        if (typeof checkFormUnlock === 'function') {
                            checkFormUnlock();
                        }

                        console.log('Form unlocked after type selection');
                    }
                });
            });
        }

        // Enhanced tab switching with type validation
        function switchTab(tabName) {
            const typeSelected = document.querySelector('input[name="type"]:checked');

            if (!typeSelected) {
                alert('कृपया पहले Business Partner Type (Customer/Vendor) select करें!');
                return;
            }

            // Remove active class from all tabs
            document.querySelectorAll(".tab").forEach((tab) => {
                tab.classList.remove("active");
            });

            // Add active class to clicked tab
            event.target.classList.add("active");

            // Hide all tab contents
            const tabIds = ["general-tab", "contacts-tab", "addresses-tab", "payment-tab", "attachments-tab"];
            tabIds.forEach(id => {
                const tab = document.getElementById(id);
                if (tab) tab.style.display = "none";
            });

            // Show selected tab content
            const activeTabId = `${tabName}-tab`;
            const activeTab = document.getElementById(activeTabId);
            if (activeTab) {
                activeTab.style.display = "block";
            }

            console.log("Switched to tab:", tabName);
        }

        // Validate current tab
        function validateCurrentTab() {
            let isValid = true;
            const activeTab = document.querySelector('.tab.active');
            const currentTab = activeTab ? activeTab.textContent.trim().toLowerCase() : 'general';

            let fieldsToValidate = [];

            if (currentTab.includes('general') || currentTab === 'business partner master data') {
                fieldsToValidate = [
                    document.getElementById('group'),
                    document.getElementById('BPname'),
                    document.getElementById('main-group'),
                    document.getElementById('chain'),
                    document.getElementById('SPname')
                ].filter(field => field !== null);

                // Validate radio buttons
                if (!document.querySelector('input[name="type"]:checked')) {
                    showFieldError('type', 'Please select a type');
                    isValid = false;
                }
                if (!document.querySelector('input[name="isStaff"]:checked')) {
                    showFieldError('isStaff', 'Please select if this is a staff member');
                    isValid = false;
                }
            } else if (currentTab.includes('contact')) {
                fieldsToValidate = Array.from(document.querySelectorAll('#contactForm input[required]'));
            } else if (currentTab.includes('address')) {
                fieldsToValidate = [
                    document.getElementById('billing-address1'),
                    document.getElementById('billing-country'),
                    document.getElementById('billing-state'),
                    document.getElementById('billing-city'),
                    document.getElementById('billing-zip')
                ].filter(field => field !== null);

                if (!document.getElementById('same-as-billing')?.checked) {
                    const shippingFields = [
                        document.getElementById('shipping-address1'),
                        document.getElementById('shipping-country'),
                        document.getElementById('shipping-state'),
                        document.getElementById('shipping-city'),
                        document.getElementById('shipping-zip')
                    ].filter(field => field !== null);
                    fieldsToValidate.push(...shippingFields);
                }
            } else if (currentTab.includes('payment')) {
                fieldsToValidate = [
                    document.getElementById('payment-terms'),
                    document.getElementById('BankName')
                ].filter(field => field !== null);
            }

            // Validate each field
            fieldsToValidate.forEach(field => {
                if (field && typeof validateField === 'function' && !validateField(field)) {
                    isValid = false;
                }
            });

            // Additional validations
            if (typeof validateAccountNumbers === 'function' && !validateAccountNumbers()) {
                isValid = false;
            }

            return isValid;
        }

        function showFieldError(fieldName, message) {
            const errorElement = document.getElementById(fieldName + '-error');
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.style.display = 'block';
                const formGroup = errorElement.closest('.form-group');
                if (formGroup) {
                    formGroup.classList.add('error');
                }
            }
        }
