        function setupAutocomplete(inputId, searchType) {
            const input = document.getElementById(inputId);
            if (!input) return;

            const wrapper = input.closest('.omnisearch-input');
            if (!wrapper) return;

            let dropdown = wrapper.querySelector('.autocomplete-dropdown');
            if (!dropdown) {
                dropdown = document.createElement('div');
                dropdown.className = 'autocomplete-dropdown';
                wrapper.appendChild(dropdown);
            }

            let currentHighlight = -1;
            let debounceTimer = null;

            const newInput = input.cloneNode(true);
            input.parentNode.replaceChild(newInput, input);

            newInput.addEventListener('input', function() {
                const query = this.value.trim().toLowerCase();

                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    if (query.length >= 2) {
                        showSuggestions(query, dropdown, searchType, newInput);
                    } else {
                        hideSuggestions(dropdown);
                    }
                }, 300);
            });

            newInput.addEventListener('keydown', function(e) {
                const items = dropdown.querySelectorAll('.autocomplete-item');

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    currentHighlight = Math.min(currentHighlight + 1, items.length - 1);
                    updateHighlight(items, currentHighlight);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    currentHighlight = Math.max(currentHighlight - 1, -1);
                    updateHighlight(items, currentHighlight);
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    if (currentHighlight >= 0 && items[currentHighlight]) {
                        const bpData = JSON.parse(items[currentHighlight].dataset.bp);
                        selectBusinessPartner(bpData, searchType);
                        hideSuggestions(dropdown);
                    }
                } else if (e.key === 'Escape') {
                    hideSuggestions(dropdown);
                }
            });

            document.addEventListener('click', function(e) {
                if (!wrapper.contains(e.target)) {
                    hideSuggestions(dropdown);
                }
            });

            dropdown.addEventListener('mouseenter', function() {
                currentHighlight = -1;
                updateHighlight(dropdown.querySelectorAll('.autocomplete-item'), -1);
            });
        }

        function showSuggestions(query, dropdown, searchType, input) {
            const matches = bpList.filter(bp => {
                if (searchType === 'code') {
                    return bp.cardCode.toLowerCase().includes(query) ||
                           bp.cardName.toLowerCase().includes(query);
                } else {
                    return bp.cardName.toLowerCase().includes(query) ||
                           bp.cardCode.toLowerCase().includes(query);
                }
            }).slice(0, 15);

            if (matches.length === 0) {
                hideSuggestions(dropdown);
                return;
            }

            dropdown.innerHTML = '';

            matches.forEach(bp => {
                const item = document.createElement('div');
                item.className = 'autocomplete-item';
                item.dataset.bp = JSON.stringify(bp);

                item.innerHTML = `
                    <div>
                        <div class="autocomplete-main">${bp.cardName}</div>
                        <div class="autocomplete-sub">Type: ${bp.cardType || 'N/A'}</div>
                    </div>
                    <div class="autocomplete-code">${bp.cardCode}</div>
                `;

                item.addEventListener('click', function() {
                    selectBusinessPartner(bp, searchType);
                    hideSuggestions(dropdown);
                });

                item.addEventListener('mouseenter', function() {
                    const items = dropdown.querySelectorAll('.autocomplete-item');
                    updateHighlight(items, Array.from(items).indexOf(this));
                });

                dropdown.appendChild(item);
            });

            dropdown.style.display = 'block';
        }

        function hideSuggestions(dropdown) {
            dropdown.style.display = 'none';
        }

        function updateHighlight(items, index) {
            items.forEach((item, i) => {
                if (i === index) {
                    item.classList.add('highlighted');
                } else {
                    item.classList.remove('highlighted');
                }
            });
        }

