            /* ══════════════════════════════════════════════════════════
               SEARCH  (CHANGE #3)
               When a result is clicked:
                1. Reset v1_exp = {}  → collapse everything
                2. expandPathTo(nodeId) → open only the needed parents
                3. Render → the tree shows only the found node's chain
                4. Scroll into view and flash the node
            ══════════════════════════════════════════════════════════ */
            var S_CMAP={hod:'#1d4ed8',dept:'#15803d',subdept:'#b45309',subhod:'#7c3aed',exec:'#0e7490'};
            var S_IMAP={hod:'person-badge-fill',dept:'building-fill',subdept:'buildings-fill',subhod:'people-fill',exec:'person-fill'};

            function ehSearchHandle(val){
                var q=(val||'').trim().toLowerCase();
                if(!q){$('#searchDrop').hide();return;}
                var res=[];
                RAW_DATA.forEach(function(hod){
                    if(hod.name.toLowerCase().indexOf(q)>-1) res.push({type:'hod',id:hod.id,name:hod.name,detail:'HOD · '+hod.depts.join(', ')});
                    hod.depts.forEach(function(d,di){if(d.toLowerCase().indexOf(q)>-1)res.push({type:'dept',id:'dept-'+hod.idx+'-'+di,name:d,detail:'HOD: '+hod.name});});
                    hod.subs.forEach(function(s,si){
                        if(s.sdName!=='-'&&s.sdName.toLowerCase().indexOf(q)>-1)res.push({type:'subdept',id:'sd-'+hod.idx+'-'+si,name:s.sdName,detail:hod.name+' › '+(s.dept||hod.depts[0]||'')});
                        (s.subHods||[]).forEach(function(sh,shi){
                            if(sh.name.toLowerCase().indexOf(q)>-1)res.push({type:'subhod',id:'sh-'+hod.idx+'-'+si+'-'+shi,name:sh.name,detail:s.sdName+' · '+hod.name});
                            (sh.execs||[]).forEach(function(ex,ei){if(ex.name.toLowerCase().indexOf(q)>-1)res.push({type:'exec',id:'ex-'+hod.idx+'-'+si+'-'+shi+'-'+ei,name:ex.name,detail:sh.name+' · '+s.sdName});});
                        });
                        (s.execs||[]).forEach(function(ex,ei){if(ex.name.toLowerCase().indexOf(q)>-1)res.push({type:'exec',id:'exd-'+hod.idx+'-'+si+'-'+ei,name:ex.name,detail:s.sdName+' (direct)'});});
                    });
                });
                if(!res.length){$('#searchDrop').html('<div class="sd-empty"><i class="bi bi-search me-2"></i>No results</div>').show();return;}
                var h='';
                res.slice(0,8).forEach(function(r){
