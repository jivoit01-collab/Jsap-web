@model JSAPNEW.Models.DashboardSummaryDto
@{
    var canViewSalary = false;
    var currentRoleTypeId = (int)(ViewBag.CurrentRoleTypeId ?? 0);
    var isAdmin = (bool)(ViewBag.IsAdmin ?? false);
    var empName = ViewBag.FirstName ?? "";
}

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    html, body {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .eh-root, .eh-root * {
        font-family: 'Sora', system-ui, sans-serif;
        box-sizing: border-box;
    }

    .eh-root {
        background: #eef2f7;
        min-height: 100vh;
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
    }

    /* ══ HEADER ══ */
    .eh-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 24px;
        height: 66px;
        background: #ffffff;
        border-bottom: 1.5px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
        flex-wrap: wrap;
    }

    .eh-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    .eh-logo {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg, #1e3a5f, #2563eb);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
        box-shadow: 0 2px 8px rgba(37,99,235,.2);
    }

    .eh-hd-title {
        font-size: 1.05rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -.2px;
    }

    .eh-hd-sub {
        font-size: 11px;
        color: #94a3b8;
        font-weight: 500;
    }

    .eh-sw {
        flex: 1;
        max-width: 440px;
        min-width: 200px;
        position: relative;
        display: flex;
        align-items: center;
    }

    .eh-si {
        position: absolute;
        left: 12px;
        color: #94a3b8;
        font-size: 13px;
        pointer-events: none;
    }

    .eh-search {
        width: 100%;
        padding: 10px 14px 10px 36px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        color: #0f172a;
        font-size: 13px;
        font-weight: 500;
        outline: none;
        transition: all .2s;
        font-family: 'Sora', sans-serif;
    }

        .eh-search:focus {
            border-color: #2563eb;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

        .eh-search::placeholder {
            color: #94a3b8;
        }

    .search-drop {
        position: absolute;
        top: calc(100% + 7px);
        left: 0;
        right: 0;
        z-index: 200;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 12px 32px rgba(0,0,0,.12);
        overflow: hidden;
    }

    .sd-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f8fafc;
        transition: background .15s;
    }

        .sd-item:hover {
            background: #f8fafc;
        }

    .sd-ico {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        flex-shrink: 0;
    }

    .sd-name {
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
    }

    .sd-detail {
        font-size: 11px;
        color: #64748b;
        margin-top: 2px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .sd-type {
        padding: 2px 7px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 700;
    }

    .sd-empty {
        padding: 16px;
        text-align: center;
        color: #94a3b8;
        font-size: 13px;
    }

    .eh-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
        margin-left: auto;
    }

    .role-chip {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 7px 14px;
        border-radius: 20px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        font-size: 12px;
        font-weight: 600;
        color: #0f172a;
    }

    .rc-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .rc-sep {
        width: 1px;
        height: 13px;
        background: #e2e8f0;
    }

    .rc-name {
        color: #64748b;
        font-weight: 500;
    }

    .eh-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 15px;
        border-radius: 9px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid;
        transition: all .2s;
        font-family: 'Sora', sans-serif;
    }

    .eh-btn-sal {
        background: #f8fafc;
        border-color: #e2e8f0;
        color: #64748b;
    }

    .eh-btn-sal-on {
        background: #ecfdf5;
        border-color: #10b981;
        color: #059669;
    }

    .eh-btn-export {
        background: #ecfdf5;
        border-color: #10b981;
        color: #059669;
    }

        .eh-btn-export:hover {
            background: #d1fae5;
        }

    .eh-btn-dup {
        background: #fff7ed;
        border-color: #fdba74;
        color: #c2410c;
    }

        .eh-btn-dup:hover {
            background: #ffedd5;
        }

    .eh-btn-print {
        background: #eff6ff;
        border-color: #2563eb;
        color: #2563eb;
    }

        .eh-btn-print:hover {
            background: #dbeafe;
        }

    .eh-sm-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #64748b;
        font-family: 'Sora', sans-serif;
        transition: all .15s;
    }

        .eh-sm-btn:hover {
            background: #fff;
            border-color: #94a3b8;
            color: #0f172a;
        }

    /* ══ STAT CARDS ══ */
    .eh-stats {
        display: flex;
        gap: 10px;
        padding: 16px 24px 0;
        flex-wrap: wrap;
    }

    .esc {
        flex: 1;
        min-width: 108px;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        padding: 13px 15px;
        display: flex;
        align-items: center;
        gap: 11px;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
        cursor: pointer;
        transition: all .2s;
    }

        .esc:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(0,0,0,.1);
        }

    .esc-ico {
        width: 42px;
        height: 42px;
        border-radius: 11px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .esc-val {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .esc-lbl {
        font-size: 9px;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        margin-top: 3px;
    }

    .sales-insights {
        display: none;
        margin: 16px 24px 0;
        padding: 16px 18px;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(15,23,42,.05);
    }

    .si-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        flex-wrap: wrap;
    }

    .si-title {
        font-size: 14px;
        font-weight: 800;
        color: #0f172a;
    }

    .si-sub {
        font-size: 12px;
        color: #64748b;
        margin-top: 2px;
    }

    .si-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
        gap: 12px;
    }

    .si-card {
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        background: linear-gradient(180deg,#fff,#f8fafc);
        padding: 14px 16px;
        cursor: pointer;
        transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    }

        .si-card:hover {
            transform: translateY(-2px);
            border-color: #93c5fd;
            box-shadow: 0 10px 24px rgba(37,99,235,.12);
        }

    .si-kicker {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .7px;
        color: #64748b;
        margin-bottom: 8px;
    }

    .si-name {
        font-size: 15px;
        font-weight: 800;
        color: #0f172a;
    }

    .si-meta {
        margin-top: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .si-count {
        font-size: 24px;
        font-weight: 900;
        color: #1d4ed8;
        line-height: 1;
    }

    .si-note {
        font-size: 11px;
        color: #64748b;
        text-align: right;
    }

    /* ══ TABS ══ */
    .eh-tabs {
        display: flex;
        gap: 8px;
        padding: 16px 24px 0;
        flex-wrap: wrap;
    }

    .eh-tab {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 9px 16px;
        border-radius: 10px;
        cursor: pointer;
        border: 1.5px solid #e2e8f0;
        background: #fff;
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        transition: all .2s;
        font-family: 'Sora', sans-serif;
    }

        .eh-tab:hover {
            border-color: #2563eb;
            color: #2563eb;
            background: #eff6ff;
            transform: translateY(-1px);
        }

        .eh-tab.on {
            border-color: #2563eb;
            background: #eff6ff;
            color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    /* ══ LOADING ══ */
    .eh-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 0;
        gap: 20px;
    }

    .eh-spinner {
        position: relative;
        width: 56px;
        height: 56px;
    }

        .eh-spinner div {
            position: absolute;
            border-radius: 50%;
            border: 3px solid transparent;
            animation: ehspin 1.2s cubic-bezier(.5,0,.5,1) infinite;
        }

            .eh-spinner div:nth-child(1) {
                width: 56px;
                height: 56px;
                border-top-color: #1e3a5f;
                animation-delay: -.45s;
            }

            .eh-spinner div:nth-child(2) {
                width: 40px;
                height: 40px;
                top: 8px;
                left: 8px;
                border-top-color: #2563eb;
                animation-delay: -.3s;
            }

            .eh-spinner div:nth-child(3) {
                width: 26px;
                height: 26px;
                top: 15px;
                left: 15px;
                border-top-color: #60a5fa;
                animation-delay: -.15s;
            }

            .eh-spinner div:nth-child(4) {
                width: 12px;
                height: 12px;
                top: 22px;
                left: 22px;
                border-top-color: #93c5fd;
            }

    @@keyframes ehspin {
        0% {
            transform: rotate(0)
        }

        100% {
            transform: rotate(360deg)
        }
    }

    .eh-ld-txt {
        color: #64748b;
        font-size: 14px;
        font-weight: 600;
    }

    .ld-err {
        color: #dc2626;
        font-size: 14px;
        font-weight: 600;
    }

    /* ══ VIEW WRAPPER ══ */
    .eh-view {
        margin: 14px 24px 0;
        width: auto;
        max-width: 100%;
        min-width: 0;
        animation: ehFI .22s ease;
    }

    #tabV2 {
        margin-left: 0;
        margin-right: 0;
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

        #tabV2 > div,
        #tabV2 .main-card,
        #tabV2 .table-wrap {
            width: 100%;
            max-width: 100%;
            min-width: 0;
        }

    @@keyframes ehFI {
        from {
            opacity: 0;
            transform: translateY(5px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }
    }

    /* ══ V1 — ORG TREE ══ */
    .v1-legend {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 6px 12px;
        padding: 10px 16px;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
        margin-bottom: 12px;
    }

    .ll-title {
        font-size: 11px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .8px;
    }

    .ll-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 700;
        color: #334155;
    }

    .ll-dot {
        width: 13px;
        height: 13px;
        border-radius: 4px;
        flex-shrink: 0;
        box-shadow: 0 1px 3px rgba(0,0,0,.15);
    }

    .ll-sep {
        color: #cbd5e1;
        font-size: 14px;
        font-weight: 800;
    }

    /* ═══════════════════════════════════════
                       CHANGE #2: v1-outer uses overflow:hidden
                       Drag-to-pan is handled entirely via JS.
                       A grab cursor signals it's pannable.
                    ═══════════════════════════════════════ */
    .v1-outer {
        position: relative;
        overflow: hidden;
        min-height: calc(100vh - 290px);
        padding-bottom: 100px;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
        cursor: grab;
        user-select: none;
        -webkit-user-select: none;
    }

        .v1-outer.is-dragging {
            cursor: grabbing;
        }

    /* Drag hint pill — bottom-right corner */
    .v1-drag-hint {
        position: absolute;
        bottom: 12px;
        right: 16px;
        z-index: 20;
        background: rgba(15,23,42,.52);
        backdrop-filter: blur(4px);
        color: #fff;
        font-size: 11px;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 5px;
        pointer-events: none;
        opacity: 1;
        transition: opacity .4s;
    }

    .v1-svg {
        position: absolute;
        top: 0;
        left: 0;
        pointer-events: none;
        z-index: 0;
        overflow: visible;
    }

    /* ══ ORPHAN PANEL ══ */
    .orphan-panel {
        position: fixed;
        right: 0;
        top: 130px;
        width: 300px;
        max-height: calc(100vh - 160px);
        overflow-y: auto;
        background: #fff1f2;
        border-left: 3px solid #dc2626;
        border-radius: 12px 0 0 12px;
        box-shadow: -4px 0 20px rgba(220,38,38,.12);
        z-index: 90;
        padding: 14px;
        display: none;
    }

        .orphan-panel.show {
            display: block;
        }

    .orphan-title {
        font-size: 13px;
        font-weight: 800;
        color: #dc2626;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .orphan-title .orphan-count {
            background: #dc2626;
            color: #fff;
            font-size: 11px;
            padding: 1px 8px;
            border-radius: 20px;
            font-weight: 700;
        }

    .orphan-card {
        background: #fff;
        border: 1.5px solid rgba(220,38,38,.25);
        border-left: 3px solid #dc2626;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 8px;
        transition: all .15s;
    }

        .orphan-card:hover {
            border-color: #dc2626;
            box-shadow: 0 2px 8px rgba(220,38,38,.1);
        }

    .orphan-name {
        font-size: 13px;
        font-weight: 700;
        color: #7f1d1d;
    }

    .orphan-code {
        font-family: 'JetBrains Mono',monospace;
        font-size: 10px;
        color: #dc2626;
        background: rgba(220,38,38,.08);
        padding: 1px 6px;
        border-radius: 3px;
    }

    .orphan-role {
        font-size: 10px;
        font-weight: 700;
        color: #fff;
        padding: 2px 8px;
        border-radius: 20px;
        display: inline-block;
        margin-top: 4px;
    }

        .orphan-role.subhod {
            background: #9333ea;
        }

        .orphan-role.exec {
            background: #0891b2;
        }

    .orphan-meta {
        font-size: 11px;
        color: #64748b;
        margin-top: 4px;
    }

    .orphan-toggle {
        position: fixed;
        right: 12px;
        top: 135px;
        z-index: 91;
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Sora',sans-serif;
        box-shadow: 0 2px 8px rgba(220,38,38,.3);
        display: none;
    }

        .orphan-toggle:hover {
            background: #b91c1c;
        }

    .v1-canvas {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 40px 60px 60px;
        min-width: fit-content;
    }

    .branch {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .children-row {
        display: flex;
        flex-direction: row;
        justify-content: center;
        padding-top: 52px;
    }

        .children-row > .branch {
            padding: 0 10px;
        }

    /* NODE CARDS */
    .node-card {
        position: relative;
        border-radius: 14px;
        cursor: pointer;
        transition: all .22s;
        user-select: none;
        overflow: hidden;
        border-left: 4px solid var(--nc, #2563eb);
        border-top: 1.5px solid;
        border-right: 1.5px solid;
        border-bottom: 1.5px solid;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

        .node-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 28px rgba(0,0,0,.14) !important;
        }
    /* CHANGE #1: .nc-comparing and .nc-chk CSS removed entirely */
    .nc-owner {
        width: 220px;
        background: #fef9c3 !important;
        border-color: #f59e0b !important;
        border-left-color: #d97706 !important;
        box-shadow: 0 3px 14px rgba(245,158,11,.2) !important;
    }

    .nc-hod {
        width: 185px;
        background: #dbeafe !important;
        border-color: #3b82f6 !important;
        border-left-color: #2563eb !important;
    }

    .nc-dept {
        width: 165px;
        background: #bbf7d0 !important;
        border-color: #22c55e !important;
        border-left-color: #16a34a !important;
    }

    .nc-subdept {
        width: 155px;
        background: #fde68a !important;
        border-color: #f59e0b !important;
        border-left-color: #d97706 !important;
    }

    .nc-subhod {
        width: 155px;
        background: #ede9fe !important;
        border-color: #a855f7 !important;
        border-left-color: #9333ea !important;
    }

    .nc-exec {
        width: 142px;
        background: #cffafe !important;
        border-color: #22d3ee !important;
        border-left-color: #0891b2 !important;
    }

    .nc-info-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1.5px solid rgba(0,0,0,.15);
        background: rgba(255,255,255,.7);
        color: #334155;
        font-size: 11px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .2s;
        z-index: 3;
    }

        .nc-info-btn:hover {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

    .nc-card-inner {
        padding: 13px 12px 10px 14px;
    }

    .nc-name {
        font-size: 14px !important;
        font-weight: 900 !important;
        color: #0f172a !important;
        line-height: 1.2 !important;
        margin-bottom: 6px !important;
        word-break: break-word;
    }

    .nc-owner .nc-name {
        font-size: 16px !important;
        color: #78350f !important;
    }

    .nc-hod .nc-name {
        font-size: 15px !important;
        color: #1e3a8a !important;
    }

    .nc-dept .nc-name {
        font-size: 13px !important;
        color: #14532d !important;
    }

    .nc-subdept .nc-name {
        font-size: 13px !important;
        color: #78350f !important;
    }

    .nc-subhod .nc-name {
        font-size: 13px !important;
        color: #4c1d95 !important;
    }

    .nc-exec .nc-name {
        font-size: 12px !important;
        color: #164e63 !important;
    }

    .nc-stats {
        display: flex;
        align-items: center;
