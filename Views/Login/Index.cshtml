@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JSAP Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root {
            --brand: #002147;
            --brand-2: #06406f;
            --accent: #f9bd7c;
            --text: #0f172a;
            --muted: #64748b;
            --border: #d7dee8;
            --danger: #b42318;
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            background: #eef3f8;
            color: var(--text);
        }

        .container-wrapper {
            width: 100%;
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(360px, 1fr) minmax(420px, 1fr);
            background: #fff;
        }

        .left-section {
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
            background:
                linear-gradient(135deg, rgba(0, 33, 71, 0.96), rgba(0, 33, 71, 0.9)),
                url("/images/JSAP-LOGO.png") center 18% / 180px auto no-repeat;
        }

        .left-section::after {
            content: "";
            position: absolute;
            inset: auto -18% -24% auto;
            width: 340px;
            height: 340px;
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 50%;
        }

        .slider {
            width: min(430px, 100%);
            position: relative;
            z-index: 1;
        }

        .quote-container {
            padding: 8px 0;
        }

        blockquote {
            margin: 0;
            color: var(--accent);
            font-size: clamp(19px, 2vw, 27px);
            line-height: 1.48;
            font-weight: 800;
            letter-spacing: 0;
        }

        blockquote p {
            margin: 0;
        }

        .flex-container {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-top: 26px;
        }

        .image-container {
            width: 54px;
            height: 54px;
            flex: 0 0 auto;
        }

        .baba-img {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(255,255,255,0.8);
        }

        .text-container {
            min-width: 0;
        }

        .name,
        .designation {
            margin: 0;
            color: #fff1df;
            line-height: 1.35;
            font-size: 12px;
        }

        .name {
            font-weight: 800;
        }

        .right-section {
            min-height: 100vh;
            padding: clamp(32px, 6vw, 72px);
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
        }

        .login-panel {
            width: min(100%, 420px);
        }

        .brand-block {
            text-align: center;
            margin-bottom: 30px;
        }

        .brand-block img {
            width: 92px;
            height: auto;
            margin-bottom: 12px;
        }

        .brand-block h2 {
            margin: 0;
            color: var(--brand);
            font-size: clamp(25px, 3vw, 34px);
            font-weight: 850;
            letter-spacing: 0;
        }

        .brand-block p {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .form-label {
            color: #172033;
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .input-field {
            width: 100%;
            min-height: 48px;
            padding: 12px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 15px;
            color: var(--text);
            background: #fff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .input-field:focus {
            border-color: var(--brand-2);
            box-shadow: 0 0 0 4px rgba(0, 33, 71, 0.1);
            outline: none;
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper .input-field {
            padding-right: 48px;
        }

        .password-toggle {
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            width: 32px;
            height: 32px;
            border: 0;
            background: transparent;
            color: var(--brand);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            padding: 0;
            border-radius: 6px;
        }

        .password-toggle:hover,
        .password-toggle:focus {
            background: #edf5ff;
            outline: none;
        }

        .password-toggle svg {
            width: 20px;
            height: 20px;
        }

        .login-btn {
            width: 100%;
            min-height: 48px;
            margin-top: 12px;
            border: 0;
            border-radius: 8px;
            background: var(--brand);
            color: white;
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 14px 26px rgba(0, 33, 71, 0.18);
            transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
        }

        .login-btn:hover {
            background: #001a38;
            transform: translateY(-1px);
            box-shadow: 0 18px 32px rgba(0, 33, 71, 0.24);
        }

        .login-btn:disabled {
            cursor: wait;
            opacity: 0.82;
            transform: none;
        }

        .error-message,
        #error {
            display: none;
            margin: 14px 0 0;
            padding: 10px 12px;
            border: 1px solid #fecaca;
            border-radius: 8px;
            background: #fef2f2;
            color: var(--danger);
            font-size: 13px;
            font-weight: 650;
        }

        @@media (max-width: 900px) {
            .container-wrapper {
                grid-template-columns: 1fr;
            }

            .left-section {
                min-height: 260px;
                padding: 34px 24px;
            }

            .right-section {
                min-height: auto;
                padding: 34px 22px 42px;
                align-items: flex-start;
            }

            .login-panel {
                margin: 0 auto;
            }
        }

        @@media (max-width: 520px) {
            .left-section {
                min-height: 220px;
                padding: 26px 20px;
                align-items: flex-end;
            }

            blockquote {
                font-size: 17px;
            }

            .flex-container {
                margin-top: 18px;
            }

            .brand-block {
                margin-bottom: 24px;
            }

            .brand-block img {
                width: 76px;
            }
        }
    </style>
</head>
<body>
    <div class="container-wrapper">
        <div class="left-section">
            <div class="slider">
                <div class="quote-container">
                    <blockquote>
                        <p><b>Adoption of renewable sources of energy not only helps in enhancing the sustainability of academies but also contributes a lot to the mother planet.</b></p>

                        <div class="flex-container">
                            <div class="image-container">
                                <img src="/images/baba-iqbal-singh-ji.png" alt="Baba Iqbal Singh Ji" class="baba-img">
                            </div>
                            <div class="text-container">
                                <h5 class="name" style="font-size:12px">Baba Iqbal Singh Ji</h5>
                                <h5 class="designation" style="font-size:12px">Former Director, Agricultural (HP)</h5>
                            </div>
                        </div>

                    </blockquote>
                </div>
            </div>
        </div>
        <div class="right-section">
            <div class="login-panel">
            <div class="brand-block">
                <img src="~/images/JSAP-LOGO.png" alt="JSAP Logo" width="80">
                <h2>Welcome to Jivo Infotech</h2>
                <p>Sign in to continue to JSAP</p>
            </div>

            <form id="loginForm">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" id="username" name="Username" class="input-field" placeholder="Enter your username" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <div class="password-wrapper">
                        <input type="password" id="password" name="Password" class="input-field" placeholder="Enter your password" required />
                        <button type="button" class="password-toggle" id="togglePassword" aria-label="Show password" aria-pressed="false">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="login-btn" id="loginSubmitBtn">Sign In</button>
                <p id="error" role="alert"></p>
            </form>

            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <p class="error-message">@ViewBag.ErrorMessage</p>
            }
            </div>
        </div>
    </div>
    <script>
        let loginInProgress = false;
        const passwordInput = document.getElementById("password");
        const togglePasswordBtn = document.getElementById("togglePassword");
        const errorEl = document.getElementById("error");
        const usernameInput = document.getElementById("username");

        function showError(message) {
            if (!errorEl) return;
            errorEl.innerText = message || "Unable to sign in. Please try again.";
            errorEl.style.display = "block";
        }

        function clearError() {
            if (!errorEl) return;
            errorEl.innerText = "";
            errorEl.style.display = "none";
        }

        function getRedirectUrl() {
            const params = new URLSearchParams(window.location.search);
            const returnUrl = params.get("ReturnUrl");
            if (returnUrl && returnUrl.startsWith("/") && !returnUrl.toLowerCase().startsWith("/login")) {
                return returnUrl;
            }
            return "/DashboardWeb/Index";
        }

        usernameInput.addEventListener("input", clearError);
        passwordInput.addEventListener("input", clearError);

        togglePasswordBtn.addEventListener("click", function () {
            const isPasswordHidden = passwordInput.type === "password";
            passwordInput.type = isPasswordHidden ? "text" : "password";
            togglePasswordBtn.setAttribute("aria-label", isPasswordHidden ? "Hide password" : "Show password");
            togglePasswordBtn.setAttribute("aria-pressed", isPasswordHidden ? "true" : "false");
        });

        document.getElementById("loginForm").addEventListener("submit", async function (e) {
            e.preventDefault();
            if (loginInProgress) return;
            loginInProgress = true;

            const submitBtn = e.target.querySelector("button[type='submit']");
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Signing in...';

            const loginUser = usernameInput.value.trim();
            const loginPassword = passwordInput.value;
            clearError();

            if (!loginUser || !loginPassword) {
                showError("Please enter both username and password.");
                loginInProgress = false;
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }

            try {
                const loginRes = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ loginUser: loginUser, password: loginPassword })
                });

                if (!loginRes.ok) {
                    if (loginRes.status === 429) {
                        throw new Error("Too many attempts. Please wait one minute and try again.");
                    }
                    const errText = await loginRes.text();
                    let errData;
                    try { errData = JSON.parse(errText); } catch { errData = { message: "Login failed" }; }
                    throw new Error(errData.message || "Invalid login credentials");
                }

                const loginData = await loginRes.json();
                if (!loginData.success || !loginData.user) {
                    throw new Error(loginData.message || "Login failed");
                }

                const userId = loginData.user.userId;
                const userName = loginData.user.userName || loginData.user.firstName + " " + loginData.user.lastName;

                if (!userId || userId === 0) {
                    throw new Error("Invalid user data received");
                }

                const authHeaders = {
                    'Content-Type': 'application/json'
                };

                const companyRes = await fetch(`/api/auth/getcompanies?userId=${userId}`, {
                    headers: authHeaders,
                    credentials: 'include'
                });
                if (!companyRes.ok) {
                    throw new Error("Failed to fetch companies");
                }
                const companyText = await companyRes.text();
                let companyData;
                try {
                    companyData = JSON.parse(companyText);
                } catch {
                    throw new Error("Server returned invalid response for companies");
                }

                if (!companyData.success || !companyData.data) {
                    throw new Error(companyData.message || "No companies found for your account");
                }

                const sessionRes = await fetch('/websession/set', {
                    method: 'POST',
                    headers: authHeaders,
                    credentials: 'include',
                    body: JSON.stringify({
                        userId: userId,
                        userName: userName,
                        companies: companyData.data
                    })
                });

                if (!sessionRes.ok) {
                    const sessText = await sessionRes.text();
                    console.error("Session set failed:", sessText);
                    throw new Error("Failed to initialize session");
                }

                const sessionData = await sessionRes.json();
                console.log("Session set response:", sessionData);

                window.location.replace(getRedirectUrl());

            } catch (err) {
                console.error("Login error:", err);
                showError(err.message || "An unexpected error occurred");
                loginInProgress = false;
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            clearError();
            usernameInput.focus();
        });
    </script>
</body>
</html>
