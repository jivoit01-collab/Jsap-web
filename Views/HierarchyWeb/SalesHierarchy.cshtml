    fH1.innerHTML = '<option value="">All H1</option>' + h1s.map(v => `<option value="${esc(v.value)}"${v.value===curH1?' selected':''}>${esc(v.label)}</option>`).join('');
    fH2.innerHTML = '<option value="">All H2</option>' + h2s.map(v => `<option value="${esc(v.value)}"${v.value===curH2?' selected':''}>${esc(v.label)}</option>`).join('');
