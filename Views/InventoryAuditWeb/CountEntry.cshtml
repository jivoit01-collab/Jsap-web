        function getHeaderStatus(header) {
          // Try the common field names you might have
          const candidates = [
            'status',          // e.g. "Closed", "Pending"
            'sessionStatus',   // often used by APIs
            'SessionStatus',   // PascalCase variant
            'state',
            'State',
            'currentStatus'
          ];
          for (const k of candidates) {
            if (header && header[k] != null && header[k] !== '') {
              return String(header[k]);
            }
          }
          return '';
        }

        function applyReadOnlyMode(readOnly, meta = {}) {
            const search = document.getElementById('itemSearchInput');
            const qty    = document.getElementById('physicalQuantityInput');
            const addBtn = document.getElementById('addItemButton');

            if (search)  search.disabled = readOnly;
            if (qty)     qty.disabled    = readOnly;
            if (addBtn) {
                addBtn.disabled = true;
                addBtn.style.display = readOnly ? 'none' : 'inline-flex';
            }

            // ✅ IMPORTANT: Hide action buttons when read-only
            const actions = document.getElementById('itemsActions');
            if (actions) {
                if (readOnly) {
                    actions.style.display = 'none';  // Always hide when read-only
                } else {
                    actions.style.display = tableItems.length > 0 ? 'flex' : 'none';
                }
            }

            const bar = document.querySelector('.item-input-bar');
            if (bar) bar.style.opacity = readOnly ? '0.6' : '1';

            updateItemsTable();

            const reason = meta.reason || (readOnly ? 'This session is read-only.' : '');
            const existing = document.getElementById('readonlyBanner');
            if (readOnly) {
                if (!existing) {
                    const cardBody = document.querySelector('.card-body');
                    if (cardBody) {
                        const div = document.createElement('div');
                        div.id = 'readonlyBanner';
                        div.className = 'alert alert-info';
                        div.style.marginBottom = '12px';
                        div.textContent = reason;
                        cardBody.insertBefore(div, cardBody.firstChild);
                    }
                } else {
                    existing.textContent = reason;
                }
            } else if (existing) {
                existing.remove();
            }
        }
