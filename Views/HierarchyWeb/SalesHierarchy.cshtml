<script>
// ═══════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════
const API = {
    getData:       '/HierarchyWeb/GetSalesData',
    getStats:      '/HierarchyWeb/GetSalesStats',
    importExcel:   '/HierarchyWeb/ImportSalesExcel',
    updateRow:     '/HierarchyWeb/UpdateSalesRow',
    updateMissingCodes: '/HierarchyWeb/UpdateMissingSalesCodes',
    shiftEmp:      '/HierarchyWeb/ShiftSalesEmployee',
    getLookups:    '/HierarchyWeb/GetSalesLookups',
    getAudit:      '/HierarchyWeb/GetSalesAuditLogs',
    createEmployee:'/HierarchyWeb/CreateSalesEmployee',
    getEmployees:  '/HierarchyWeb/GetSalesEmployeeList'
};

const INITIAL_SALES_DATA = @Html.Raw(initialSalesDataJson);
const INITIAL_SALES_STATS = @Html.Raw(initialSalesStatsJson);
const INITIAL_SALES_STATES = @Html.Raw(initialSalesStatesJson);
const INITIAL_SALES_GROUPS = @Html.Raw(initialSalesGroupsJson);
const INITIAL_SALES_DESIGNATIONS = @Html.Raw(initialSalesDesignationsJson);
const INITIAL_SALES_EMPLOYEES = @Html.Raw(initialSalesEmployeesJson);

function mapSalesRow(row) {
    if (!row) return row;
    return {
        salesHierarchyId: row.salesHierarchyId ?? row.SalesHierarchyId ?? 0,
        companyId: row.companyId ?? row.CompanyId ?? 0,
        h1Code: row.h1Code ?? row.H1Code ?? '',
        h1Name: row.h1Name ?? row.H1Name ?? '',
        h2Code: row.h2Code ?? row.H2Code ?? '',
        h2Name: row.h2Name ?? row.H2Name ?? '',
        h3Code: row.h3Code ?? row.H3Code ?? '',
        h3Name: row.h3Name ?? row.H3Name ?? '',
        h4Code: row.h4Code ?? row.H4Code ?? '',
        h4Name: row.h4Name ?? row.H4Name ?? '',
        employeeId: row.employeeId ?? row.EmployeeId ?? null,
        empCode: row.empCode ?? row.EmpCode ?? '',
        empName: row.empName ?? row.EmpName ?? '',
        state: row.state ?? row.State ?? '',
        groupName: row.groupName ?? row.GroupName ?? '',
        designation: row.designation ?? row.Designation ?? '',
        department: row.department ?? row.Department ?? '',
        mobile: row.mobile ?? row.Mobile ?? '',
        email: row.email ?? row.Email ?? '',
        dateOfJoining: row.dateOfJoining ?? row.DateOfJoining ?? null,
        isActive: row.isActive ?? row.IsActive ?? false,
        createdOn: row.createdOn ?? row.CreatedOn ?? null,
        modifiedOn: row.modifiedOn ?? row.ModifiedOn ?? null
    };
}

function mapSalesStats(stats) {
    if (!stats) return stats;
    return {
        h1Count: stats.h1Count ?? stats.H1Count ?? 0,
        h2Count: stats.h2Count ?? stats.H2Count ?? 0,
        h3Count: stats.h3Count ?? stats.H3Count ?? 0,
        h4Count: stats.h4Count ?? stats.H4Count ?? 0,
        totalEmployees: stats.totalEmployees ?? stats.TotalEmployees ?? 0,
        activeCount: stats.activeCount ?? stats.ActiveCount ?? 0,
        inactiveCount: stats.inactiveCount ?? stats.InactiveCount ?? 0
    };
}

let allRows    = [];
let allSalesEmployees = []; // all employees from [Hie].[Employees] (independent of hierarchy rows)
let filtered   = [];
let lookups    = { states: [], groups: [], designations: [] };
let currentPage = 1;
const PAGE_SIZE = 50;
let sortKey    = 'h1Name';
let sortDir    = 1; // 1=asc, -1=desc
let editRowId  = null;
let shiftRowId = null;
let pendingRows = [];  // parsed Excel rows pending upload
let hierarchyOptions = { h1: [], h2: [], h3: [], h4: [], employees: [] };

const COLUMNS = [
    { key: 'h1Name',      label: 'H1',          visible: true,  defaultVisible: true  },
    { key: 'h2Name',      label: 'H2',          visible: true,  defaultVisible: true  },
    { key: 'h3Name',      label: 'H3',          visible: true,  defaultVisible: true  },
    { key: 'h4Name',      label: 'H4',          visible: true,  defaultVisible: true  },
    { key: 'empName',     label: 'Name',        visible: true,  defaultVisible: true  },
    { key: 'state',       label: 'State',       visible: true,  defaultVisible: true  },
    { key: 'groupName',   label: 'Group',       visible: true,  defaultVisible: true  },
    { key: 'designation', label: 'Designation', visible: true,  defaultVisible: true  },
    { key: 'isActive',    label: 'Status',      visible: true,  defaultVisible: true  }
];

// Load saved column visibility
const COL_STORE_KEY = 'salesHierarchy_cols_v1';
(function loadColState() {
    try {
        const saved = JSON.parse(localStorage.getItem(COL_STORE_KEY) || '{}');
        COLUMNS.forEach(c => {
            if (saved[c.key] !== undefined) c.visible = saved[c.key];
        });
    } catch(e) {}
})();

function saveColState() {
    const s = {};
    COLUMNS.forEach(c => s[c.key] = c.visible);
    localStorage.setItem(COL_STORE_KEY, JSON.stringify(s));
}

// ═══════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    // Move all overlays to <body> so layout's overflow-x:hidden doesn't trap fixed positioning
    document.querySelectorAll('.overlay').forEach(el => document.body.appendChild(el));
    renderColManager();
    applyColumnVisibility();
    hydrateInitialViewData();
    loadLookups().then(() => loadData(true));
    loadStats(true);
});

// ═══════════════════════════════════════════════════════════════
// DATA LOADING
// ═══════════════════════════════════════════════════════════════
async function loadData(skipIfSeeded = false) {
    if (skipIfSeeded && Array.isArray(INITIAL_SALES_DATA) && INITIAL_SALES_DATA.length) {
        allRows = INITIAL_SALES_DATA.map(mapSalesRow);
        buildModalOptions();
        applyFilters();
        populateFilterDropdowns();
        return;
    }
    showTableLoading();
    try {
        const res = await fetch(API.getData);
        const json = normalizeApiResponse(await res.json());
        if (!json.success) { showToast(json.message || 'Failed to load data', 'error'); return; }
        allRows = (json.data || []).map(mapSalesRow);
        buildModalOptions();
        applyFilters();
        populateFilterDropdowns();
    } catch(e) {
        showToast('Error loading data: ' + e.message, 'error');
        document.getElementById('tableBody').innerHTML = '<tr><td colspan="11" style="text-align:center;padding:30px;color:var(--danger)">Failed to load data. Please refresh.</td></tr>';
    }
}

async function loadStats(skipIfSeeded = false) {
    if (skipIfSeeded && INITIAL_SALES_STATS) {
        const d = mapSalesStats(INITIAL_SALES_STATS);
        document.getElementById('statH1').textContent      = d.h1Count ?? 0;
        document.getElementById('statH2').textContent      = d.h2Count ?? 0;
        document.getElementById('statH3').textContent      = d.h3Count ?? 0;
        document.getElementById('statH4').textContent      = d.h4Count ?? 0;
        document.getElementById('statTotal').textContent   = d.totalEmployees ?? 0;
        document.getElementById('statActive').textContent  = d.activeCount ?? 0;
        document.getElementById('statInactive').textContent= d.inactiveCount ?? 0;
        return;
    }
    try {
        const res = await fetch(API.getStats);
        const json = normalizeApiResponse(await res.json());
        if (json.success) {
            const d = mapSalesStats(json.data);
            document.getElementById('statH1').textContent      = d.h1Count ?? 0;
            document.getElementById('statH2').textContent      = d.h2Count ?? 0;
            document.getElementById('statH3').textContent      = d.h3Count ?? 0;
            document.getElementById('statH4').textContent      = d.h4Count ?? 0;
            document.getElementById('statTotal').textContent   = d.totalEmployees ?? 0;
            document.getElementById('statActive').textContent  = d.activeCount ?? 0;
            document.getElementById('statInactive').textContent= d.inactiveCount ?? 0;
        }
    } catch(e) {}
}

async function loadLookups() {
    if (INITIAL_SALES_STATES.length || INITIAL_SALES_GROUPS.length || INITIAL_SALES_DESIGNATIONS.length) {
        lookups.states = INITIAL_SALES_STATES;
        lookups.groups = INITIAL_SALES_GROUPS;
        lookups.designations = INITIAL_SALES_DESIGNATIONS;
        populateLookupSelects();
    }
    try {
        const res = await fetch(API.getLookups);
        const json = normalizeApiResponse(await res.json());
        if (json.success) {
            lookups.states       = json.states       || [];
            lookups.groups       = json.groups       || [];
            lookups.designations = json.designations || [];
            populateLookupSelects();
        }
    } catch(e) {}
}

function hydrateInitialViewData() {
    if (Array.isArray(INITIAL_SALES_EMPLOYEES)) {
        allSalesEmployees = INITIAL_SALES_EMPLOYEES;
    }
    if (Array.isArray(INITIAL_SALES_DATA) && INITIAL_SALES_DATA.length) {
        allRows = INITIAL_SALES_DATA.map(mapSalesRow);
        buildModalOptions(); // calls buildEmployeeDatalist() internally
        applyFilters();
        populateFilterDropdowns();
    } else {
        // No hierarchy rows yet — still populate the employee datalist from allSalesEmployees
        buildEmployeeDatalist();
    }

    if (INITIAL_SALES_STATS) {
        const d = mapSalesStats(INITIAL_SALES_STATS);
        document.getElementById('statH1').textContent      = d.h1Count ?? 0;
        document.getElementById('statH2').textContent      = d.h2Count ?? 0;
        document.getElementById('statH3').textContent      = d.h3Count ?? 0;
        document.getElementById('statH4').textContent      = d.h4Count ?? 0;
        document.getElementById('statTotal').textContent   = d.totalEmployees ?? 0;
        document.getElementById('statActive').textContent  = d.activeCount ?? 0;
        document.getElementById('statInactive').textContent= d.inactiveCount ?? 0;
    }
}

function populateLookupSelects() {
    const selState = document.getElementById('edit_state');
    const selGroup = document.getElementById('edit_groupName');
    const selDesig = document.getElementById('edit_designation');
    const fsState  = document.getElementById('filterState');
    const fsGroup  = document.getElementById('filterGroup');
    const fsDesig  = document.getElementById('filterDesig');
    const nrState  = document.getElementById('newRel_state');
    const nrGroup  = document.getElementById('newRel_groupName');
    const nrDesig  = document.getElementById('newRel_designation');
    const baState  = document.getElementById('bulk_state');
    const baGroup  = document.getElementById('bulk_groupName');
    const baDesig  = document.getElementById('bulk_designation');
    const states = getUniqueTextValues(lookups.states, 'stateName');
    const groups = getUniqueTextValues(lookups.groups, 'groupName');
    const designations = getUniqueTextValues(lookups.designations, 'designationName');

    selState.innerHTML = '<option value="">— Select State —</option>';
    fsState.innerHTML = '<option value="">All States</option>';
    nrState.innerHTML = '<option value="">— Select State —</option>';
    baState.innerHTML = '<option value="">— Keep existing —</option>';

    selGroup.innerHTML = '<option value="">— Select Group —</option>';
    fsGroup.innerHTML = '<option value="">All Groups</option>';
    nrGroup.innerHTML = '<option value="">— Select Group —</option>';
    baGroup.innerHTML = '<option value="">— Keep existing —</option>';

    selDesig.innerHTML = '<option value="">— Select Designation —</option>';
    fsDesig.innerHTML = '<option value="">All Designations</option>';
    nrDesig.innerHTML = '<option value="">— Select Designation —</option>';
    baDesig.innerHTML = '<option value="">— Keep existing —</option>';

    states.forEach(value => {
        const opt = `<option value="${esc(value)}">${esc(value)}</option>`;
        selState.insertAdjacentHTML('beforeend', opt);
        fsState.insertAdjacentHTML('beforeend', opt);
        nrState.insertAdjacentHTML('beforeend', opt);
        baState.insertAdjacentHTML('beforeend', opt);
    });
    groups.forEach(value => {
        const opt = `<option value="${esc(value)}">${esc(value)}</option>`;
        selGroup.insertAdjacentHTML('beforeend', opt);
        fsGroup.insertAdjacentHTML('beforeend', opt);
        nrGroup.insertAdjacentHTML('beforeend', opt);
        baGroup.insertAdjacentHTML('beforeend', opt);
    });
    designations.forEach(value => {
        const opt = `<option value="${esc(value)}">${esc(value)}</option>`;
        selDesig.insertAdjacentHTML('beforeend', opt);
        fsDesig.insertAdjacentHTML('beforeend', opt);
        nrDesig.insertAdjacentHTML('beforeend', opt);
        baDesig.insertAdjacentHTML('beforeend', opt);
    });

    registerSearchableSelect('newRel_state', 'Select State', states.map(value => ({ value, label: value })));
    registerSearchableSelect('newRel_groupName', 'Select Group', groups.map(value => ({ value, label: value })));
}

function getUniqueDataColumnValues(field) {
    const seen = new Set();
    return allRows
        .map(r => String(r[field] || '').trim())
        .filter(v => {
            const key = v.toLowerCase();
            if (!key || seen.has(key)) return false;
            seen.add(key);
            return true;
        })
        .sort((a, b) => a.localeCompare(b));
}

function fillPlainSelectFromValues(id, values, placeholder) {
    const el = document.getElementById(id);
    if (!el) return;
    const current = el.value;
    el.innerHTML = `<option value="">${esc(placeholder)}</option>` +
        values.map(v => `<option value="${esc(v)}">${esc(v)}</option>`).join('');
    if (current && values.includes(current)) el.value = current;
}

function buildModalOptions() {
    hierarchyOptions = {
        h1: getUniqueHierarchyOptions('h1Code', 'h1Name'),
        h2: getUniqueHierarchyOptions('h2Code', 'h2Name'),
        h3: getUniqueHierarchyOptions('h3Code', 'h3Name'),
        h4: getUniqueHierarchyOptions('h4Code', 'h4Name'),
        employees: getUniqueHierarchyOptions('empCode', 'empName', true)
    };

    fillSelectOptions('shift_h1code', hierarchyOptions.h1, 'Select H1');
    fillSelectOptions('shift_h2code', hierarchyOptions.h2, 'Select H2');
    fillSelectOptions('shift_h3code', hierarchyOptions.h3, 'Select H3');
    fillSelectOptions('shift_h4code', hierarchyOptions.h4, 'Select H4');
    // New relation panel
    fillSelectOptions('newRel_h1code', hierarchyOptions.h1, 'Select H1');
    fillSelectOptions('newRel_h2code', hierarchyOptions.h2, 'Select H2');
    fillSelectOptions('newRel_h3code', hierarchyOptions.h3, 'Select H3');
    fillSelectOptions('newRel_h4code', hierarchyOptions.h4, 'Select H4');
    buildEmployeeDatalist(); // merges allSalesEmployees with hierarchy-row employees
    // Bulk assign panel
    fillSelectOptions('bulk_h1code', hierarchyOptions.h1, 'Any H1');
    fillSelectOptions('bulk_h2code', hierarchyOptions.h2, 'Any H2');
    fillSelectOptions('bulk_h3code', hierarchyOptions.h3, 'Any H3');
    fillSelectOptions('bulk_h4code', hierarchyOptions.h4, 'Any H4');

    // Populate State / Group / Designation dropdowns from actual data rows
    // so they always reflect what is in the table, regardless of master-table sync.
    const dataStates = getUniqueDataColumnValues('state');
    const dataGroups = getUniqueDataColumnValues('groupName');
    const dataDesigs = getUniqueDataColumnValues('designation');

    fillPlainSelectFromValues('filterState',      dataStates, 'All States');
    fillPlainSelectFromValues('edit_state',        dataStates, '— Select State —');
    fillPlainSelectFromValues('newRel_state',      dataStates, '— Select State —');
    fillPlainSelectFromValues('bulk_state',        dataStates, '— Keep existing —');

    fillPlainSelectFromValues('filterGroup',       dataGroups, 'All Groups');
    fillPlainSelectFromValues('edit_groupName',    dataGroups, '— Select Group —');
    fillPlainSelectFromValues('newRel_groupName',  dataGroups, '— Select Group —');
    fillPlainSelectFromValues('bulk_groupName',    dataGroups, '— Keep existing —');

    fillPlainSelectFromValues('filterDesig',       dataDesigs, 'All Designations');
    fillPlainSelectFromValues('edit_designation',  dataDesigs, '— Select Designation —');
    fillPlainSelectFromValues('newRel_designation',dataDesigs, '— Select Designation —');
    fillPlainSelectFromValues('bulk_designation',  dataDesigs, '— Keep existing —');
}

function getUniqueHierarchyOptions(codeField, nameField, includeCodeInLabel = false) {
    const seen = new Set();
    return allRows
        .map(r => {
            const rawCode = String(r[codeField] || '').trim();
            const name = String(r[nameField] || '').trim();
            const code = includeCodeInLabel ? rawCode : normalizeHierarchyCode(rawCode, name);
            return {
                value: code,
                name: name,
                code: code
            };
        })
        .filter(x => {
            const dedupeKey = normalizeKey(x.value || x.name);
            if (!(x.value || x.name) || seen.has(dedupeKey)) return false;
            seen.add(dedupeKey);
            return true;
        })
        .map(x => ({
            value: x.value || x.name,
            label: includeCodeInLabel ? formatLevelFilterLabel(x.name, x.code) : formatLevelFilterLabel(x.name, x.code),
            name: x.name,
            code: x.code
        }))
        .sort((a, b) => a.label.localeCompare(b.label));
}

function fillSelectOptions(id, options, placeholder) {
    const select = document.getElementById(id);
    if (!select) return;
    const current = select.value;
    select.innerHTML = `<option value="">— ${esc(placeholder)} —</option>` +
        options.map(o => `<option value="${esc(o.value)}" data-name="${esc(o.name || '')}" data-code="${esc(o.code || o.value || '')}">${esc(o.label)}</option>`).join('');
    if (current) select.value = current;
}

function registerSearchableSelect(id, placeholder, options) {
    const searchInput = document.getElementById(`${id}_search`);
    if (!searchInput) return;
    searchableSelectOptions[id] = {
        placeholder,
        options: Array.isArray(options) ? options.map(o => ({ ...o })) : []
    };
    filterSearchableSelect(id);
}

function filterSearchableSelect(id) {
    const select = document.getElementById(id);
    const searchInput = document.getElementById(`${id}_search`);
    const meta = searchableSelectOptions[id];
    if (!select || !searchInput || !meta) return;

    const current = select.value;
    const term = searchInput.value.trim().toLowerCase();
    const filteredOptions = !term
        ? meta.options
        : meta.options.filter(o => {
            const hay = `${o.label || ''} ${o.value || ''} ${o.name || ''} ${o.code || ''}`.toLowerCase();
            return hay.includes(term);
        });

    select.innerHTML = `<option value="">â€” ${esc(meta.placeholder)} â€”</option>` +
        filteredOptions.map(o => `<option value="${esc(o.value)}">${esc(o.label)}</option>`).join('');

    if (current && filteredOptions.some(o => o.value === current)) {
        select.value = current;
    } else {
        select.value = '';
    }
}

function resetSearchableSelect(id) {
    const searchInput = document.getElementById(`${id}_search`);
    if (searchInput) searchInput.value = '';
    filterSearchableSelect(id);
}

function fillEmployeeDatalist(id, options) {
    const input = document.getElementById(id);
    const list = document.getElementById(`${id}_list`);
    if (!input || !list) return;
    const current = input.value;
    list.innerHTML = options.map(o => `<option value="${esc(o.value)}" label="${esc(o.label)}"></option>`).join('');
    if (current) input.value = current;
}

function populateFilterDropdowns() {
    const getLevelOptions = (nameField, codeField) => {
        const seen = new Set();
        return allRows
            .map(r => ({
                value: r[nameField] || r[codeField] || '',
                label: formatLevelFilterLabel(r[nameField], r[codeField])
            }))
            .filter(x => x.value && !seen.has(x.value) && seen.add(x.value))
            .sort((a, b) => a.label.localeCompare(b.label));
    };

    const h1s = getLevelOptions('h1Name', 'h1Code');
    const h2s = getLevelOptions('h2Name', 'h2Code');
    const h3s = getLevelOptions('h3Name', 'h3Code');
    const h4s = getLevelOptions('h4Name', 'h4Code');

    const fH1 = document.getElementById('filterH1');
    const fH2 = document.getElementById('filterH2');
    const fH3 = document.getElementById('filterH3');
    const fH4 = document.getElementById('filterH4');

