        s.innerHTML='<option value="">— Select HOD —</option>'+(hods||[])
            .filter(e=>!excludedId || getDropdownEmployeeId(e)!==excludedId)
            .map(e=>`<option value="${getDropdownEmployeeId(e)}">${esc(e.employeeName||e.EmployeeName)} (${esc(e.employeeCode||e.EmployeeCode||'')})</option>`).join('');
    }
    function getSubHodsForDepartment(hodId, deptId, subDeptId){
        const hodKey = Number(hodId) || 0;
        const deptKey = Number(deptId) || 0;
        const subDeptKey = Number(subDeptId) || 0;
        const items=new Map();
        allRows
            .filter(r=>{
                const rowHodId = Number(r.hodEmployeeId) || 0;
                const rowSubHodId = Number(r.subHodEmployeeId) || 0;
                const rowDeptId = Number(r.departmentId) || 0;
                const rowSubDeptId = Number(r.subDepartmentId) || 0;
                if(rowHodId !== hodKey || rowSubHodId <= 0) return false;
                if(deptKey && rowDeptId !== deptKey) return false;
                if(subDeptKey && rowSubDeptId !== subDeptKey) return false;
                return true;
            })
            .forEach(r=>{
                const rowSubHodId = Number(r.subHodEmployeeId) || 0;
                if(!items.has(rowSubHodId)){
                    items.set(rowSubHodId,{ employeeId:rowSubHodId, employeeName:r.subHodName, employeeCode:r.subHodCode });
                }
            });
        return [...items.values()];
    }
    async function populateAddSubHods(hodId, deptId){
        const subDeptId=parseInt(document.getElementById('f_sdept').value)||0;
        const sel=document.getElementById('f_sub');
        sel.innerHTML='<option value="">— Direct to HOD —</option>';
        if(addLvl!==3 || !hodId || !deptId)return;
        let subHods=getSubHodsForDepartment(hodId, deptId, subDeptId);
        if(!subHods.length){
            try{
                const r=await api(`${API}/GetSubHODsForEdit?hodId=${hodId}`);
                if(r.success){
                    subHods=(r.data||[]).map(e=>({
                        employeeId:e.employeeId||e.EmployeeId,
                        employeeName:e.employeeName||e.EmployeeName,
                        employeeCode:e.employeeCode||e.EmployeeCode
                    }));
                }
            }catch(e){}
        }
        subHods.forEach(e=>{
            sel.innerHTML+=`<option value="${e.employeeId}">${esc(e.employeeName)} (${e.employeeCode})</option>`;
        });
    }
