        function showElement(element) {
            if (element) {
                element.classList.remove('hidden');
                element.classList.remove('disabled-section');
                element.style.display = 'block';
             element.style.visibility = 'visible';
            }
        }

        function hideElement(element) {
        if (element) {
             element.classList.add('hidden');
             element.classList.add('disabled-section');
             element.style.display = 'none';
             element.style.visibility = 'hidden';
            }
        }
        // Handle type selection and show/hide conditional fields
        function handleTypeSelection() {
         const type = document.querySelector('input[name="type"]:checked')?.value;
        if (!type) return toggleFormSections(false);

        toggleFormSections(true);
        document.getElementById('staff-section').classList.remove('disabled-section');
        document.getElementById('code-group').classList.remove('disabled-section');

        const isCustomer = type === 'custa';
        const isVendor = type === 'venda';

        // Customer specific fields (Chain)
        const chainGroup = document.getElementById('chain-group');
        if (chainGroup) {
            if (isCustomer) {
                showElement(chainGroup);
            } else {
                hideElement(chainGroup);
            }
        }
            // Vendor specific fields (MSME fields)
            const vendorFields = ['msme-type-group', 'msme-no-group', 'msme-btype-group'];
            vendorFields.forEach(id => {
                const element = document.getElementById(id);
                if (isVendor) {
                    showElement(element);
                } else {
                    hideElement(element);
                }
            });

            // Common fields for both (always visible) - PAN, TAN, FSSAI etc are already in HTML

            // Set required fields based on type
            const chainField = document.getElementById('chain');
            if (chainField) {
                chainField.required = isCustomer;
            }

            // MSME fields required only for vendors
            ['MSME', 'MSMEno', 'MSMEbtype'].forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.required = isVendor;
                }
            });

            // PAN and TAN are common fields, not required by default but can be filled
            ['pan', 'tan'].forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.required = false; // Make them optional for both
                }
            });

            updateCodeField();
            handleTypeOrStaffChange();

            console.log(`Type selected: ${type}. Showing ${isCustomer ? 'Customer' : 'Vendor'} specific fields.`);
        }
        //     document.addEventListener("DOMContentLoaded", function () {
        //     handleTypeSelection(); 
        //     Ensure proper toggle on load

        //     Bind to radio change
        //     document.querySelectorAll('input[name="type"]').forEach(radio => {
        //         radio.addEventListener("change", function(){handleTypeSelection();});
        //     });
        // });
                document.addEventListener("DOMContentLoaded", function () {
            handleTypeSelection();
            // Ensure proper toggle on load

            // Bind to radio change
            document.querySelectorAll('input[name="type"]').forEach(radio => {
                radio.addEventListener("change", function(){
                    handleTypeSelection();
                });
            });
        });
