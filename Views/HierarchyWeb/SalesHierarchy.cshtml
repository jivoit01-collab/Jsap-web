                </div>` : '<div style="margin-top:8px;color:var(--muted);font-size:12px">Click <strong>Import</strong> to proceed.</div>'}`;
        } catch(err) {
            showToast('Error parsing Excel: ' + err.message, 'error');
        }
    };
    reader.readAsArrayBuffer(file);
}

function mapColumns(headers) {
    const normalizedHeaders = headers.map(normalizeExcelHeader);
    const findAlias = (...aliases) => {
        for (const alias of aliases) {
            const idx = normalizedHeaders.findIndex(h => h === alias);
            if (idx >= 0) return idx;
        }
        return -1;
    };

    return {
        h1code:      findAlias('ech1', 'h1code', 'h1employeecode'),
        h2code:      findAlias('ech2', 'h2code', 'h2employeecode'),
        h3code:      findAlias('ech3', 'h3code', 'h3employeecode'),
        h4code:      findAlias('ech4', 'h4code', 'h4employeecode'),
        h1name:      findAlias('h1', 'h1name', 'hod', 'head', 'headofdepartment', 'departmenthead'),
        h2name:      findAlias('h2', 'h2name', 'subhod', 'sub hod', 'subhead', 'sub head', 'subheadofdepartment'),
        h3name:      findAlias('h3', 'h3name'),
        h4name:      findAlias('h4', 'h4name'),
        empcode:     findAlias('empcode', 'empco', 'employeecode', 'employeeid', 'empid', 'ec', 'ecode', 'staffcode', 'staffid', 'sapcode', 'sapid', 'workercode', 'workerid'),
        empname:     findAlias('name', 'empname', 'employeename'),
        state:       findAlias('state'),
        group:       findAlias('group', 'groupname', 'da'),
        designation: findAlias('designation', 'desig')
    };
}

async function processUpload() {
    if (!pendingRows.length) return;
    const btn = document.getElementById('btnUpload');
    btn.disabled = true;
    btn.querySelector('#uploadBtnText').textContent = 'Importing…';

    document.getElementById('uploadProgress').style.display = '';
    document.getElementById('progressFill').style.width = '30%';

    try {
        const res = await fetchPost(API.importExcel, pendingRows);
        document.getElementById('progressFill').style.width = '100%';

        if (res.success) {
            const d = res.data;
            document.getElementById('importResults').innerHTML = `
                <div style="background:var(--bg2);border-radius:8px;padding:14px;margin-top:4px">
                    <div style="font-weight:700;color:var(--success);margin-bottom:8px;font-size:13px">✅ Import Successful</div>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;font-size:12px">
                        <div><span style="color:var(--muted)">Total Rows:</span> <strong>${d.totalRows}</strong></div>
                        <div><span style="color:var(--muted)">Upserted:</span> <strong style="color:var(--success)">${d.rowsUpserted}</strong></div>
                        <div><span style="color:var(--muted)">Errors:</span> <strong style="color:${d.errors>0?'var(--danger)':'var(--muted)'}">${d.errors}</strong></div>
                        <div><span style="color:var(--muted)">Emp Created:</span> <strong>${d.employeesCreated}</strong></div>
                        <div><span style="color:var(--muted)">Emp Updated:</span> <strong>${d.employeesUpdated}</strong></div>
                        <div><span style="color:var(--muted)">Temp Codes:</span> <strong>${d.tempCodesGenerated || 0}</strong></div>
                    </div>
                    ${d.tempCodes && d.tempCodes.length ? `
                        <div style="margin-top:10px;color:var(--text);font-size:11px">
                            <strong>Temp Codes:</strong><br>${d.tempCodes.slice(0,5).map(e=>`&bull; ${e}`).join('<br>')}
                            ${d.tempCodes.length>5?`<br>...and ${d.tempCodes.length-5} more`:''}
                        </div>` : ''}
                    ${d.errorDetails && d.errorDetails.length ? `
                        <div style="margin-top:10px;color:var(--danger);font-size:11px">
                            <strong>Errors:</strong><br>${d.errorDetails.slice(0,5).map(e=>`• ${e}`).join('<br>')}
                            ${d.errorDetails.length>5?`<br>…and ${d.errorDetails.length-5} more`:''}
                        </div>` : ''}
                </div>`;
            btn.style.display = 'none';
            refreshData();
        } else {
            document.getElementById('importResults').innerHTML =
                `<div style="color:var(--danger);font-size:13px">❌ ${res.message || 'Import failed'}</div>`;
        }
    } catch(e) {
        document.getElementById('importResults').innerHTML =
            `<div style="color:var(--danger);font-size:13px">❌ Error: ${e.message}</div>`;
    } finally {
        btn.disabled = false;
        btn.querySelector('#uploadBtnText').textContent = `Import ${pendingRows.length} Rows`;
    }
}

