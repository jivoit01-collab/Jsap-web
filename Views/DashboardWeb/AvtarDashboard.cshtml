@{
    ViewData["Title"] = "Budget Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Budget Dashboard | Jivo Infotech</title>
    <link rel="stylesheet" href="~/css/AvtarDashboard.css" />
</head>
<body>
    <!-- Loader Overlay -->
    <div id="loaderOverlay">
        <div class="loader-container">
            <div class="loader">
                <div class="loader-ring"></div>
                <div class="loader-ring"></div>
                <div class="loader-ring"></div>
            </div>
            <p class="loader-text">Loading your data...</p>
        </div>
    </div>

    <!-- Main Container -->
    <div class="dashboard-container">
        <!-- Header -->
        <header class="dashboard-header">
            <div class="header-content">
                <div class="header-title-group">
                    <span class="header-eyebrow">Financial Analytics</span>
                    <h1 class="header-title">Budget Dashboard</h1>
                </div>
            </div>
        </header>

        <!-- Filters Card -->
        <section class="glass-card filter-card">
            <div class="card-header">
                <div class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                    </svg>
                </div>
                <h2 class="card-title">Filter Controls</h2>
            </div>

            <div class="filter-grid">
                <!-- Branch Filter -->
                <div class="filter-group" id="branch-filter">
                    <label class="filter-label">
                        <span class="label-text">Branch</span>
                        <span class="label-badge">Primary</span>
                    </label>
                    <div class="select-wrapper">
                        <select class="custom-select" id="company-selector" onchange="branchChange()">
                            <option value="" disabled selected>Select Branch</option>
                            <option value="">All Branches</option>
                            <option value="OIL">OIL</option>
                            <option value="BEVERAGE">BEVERAGE</option>
                        </select>
                        <div class="select-arrow">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Ledgers Filter -->
                <div class="filter-group disabled" id="ledger-filter">
                    <label class="filter-label">
                        <span class="label-text">Ledgers</span>
                        <span class="label-count" id="ledger-count">0 selected</span>
                    </label>
                    <div class="multi-select-container">
                        <select class="custom-select multi-select" id="ledger-selector" multiple>
                            <option value="" disabled>Select Ledgers</option>
                        </select>
                    </div>
                    <div class="selected-chips" id="selected-ledgers"></div>
                </div>

                <!-- Budgets Filter -->
                <div class="filter-group disabled" id="budget-filter">
                    <label class="filter-label">
                        <span class="label-text">Budgets</span>
                        <span class="label-count" id="budget-count">0 selected</span>
                    </label>
                    <div class="multi-select-container">
                        <select class="custom-select multi-select" id="budget-selector" multiple>
                            <option value="" disabled>Select Budget</option>
                        </select>
                    </div>
                    <div class="selected-chips" id="selected-budgets"></div>
                </div>

                <!-- Months Filter -->
                <div class="filter-group disabled" id="month-filter">
                    <label class="filter-label">
                        <span class="label-text">Months</span>
                        <span class="label-count" id="month-count">0 selected</span>
                    </label>
                    <div class="multi-select-container">
                        <select class="custom-select multi-select" id="month-selector" multiple>
                            <option value="" disabled>Select Month</option>
                        </select>
                    </div>
                    <div class="selected-chips" id="selected-months"></div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="filter-actions">
                <button class="btn btn-secondary" onclick="resetFilters()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                        <path d="M3 3v5h5"></path>
                    </svg>
                    Reset
                </button>
                <button class="btn btn-primary" onclick="filterByCompany()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Apply Filters
                </button>
            </div>
        </section>

        <!-- Main Data Table -->
        <section class="glass-card data-card">
            <div class="card-header">
                <div class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"></path>
                    </svg>
                </div>
                <h2 class="card-title">Budget Overview</h2>
                <span class="card-subtitle">Detailed financial breakdown</span>
            </div>

            <div class="table-wrapper">
                <div class="table-container" id="table-container-1">
                    <table id="master-table"></table>
                </div>
                <div class="table-empty-state" id="empty-state-1">
                    <div class="empty-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                    <h3>No Data to Display</h3>
                    <p>Select a branch and apply filters to view your budget data</p>
                </div>
            </div>
        </section>

        <!-- Month-wise Analysis Section -->
        <section class="glass-card data-card">
            <div class="card-header">
                <div class="card-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                </div>
                <h2 class="card-title">Month-wise Analysis</h2>
                <span class="card-subtitle">Temporal budget breakdown</span>
            </div>

            <!-- Secondary Filters -->
            <div class="secondary-filters">
                <div class="year-select-group">
                    <label class="filter-label small">
                        <span class="label-text">Year</span>
                    </label>
                    <div class="select-wrapper small">
                        <select class="custom-select year-selector" onchange="setYear()"></select>
                        <div class="select-arrow">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="checkbox-group">
                    <label class="filter-label small">
                        <span class="label-text">Select Months</span>
                    </label>
                    <div class="checkbox-grid month2-selector"></div>
                </div>

                <div class="checkbox-group">
                    <label class="filter-label small">
                        <span class="label-text">Select Budgets</span>
                    </label>
                    <div class="checkbox-grid budget2-selector"></div>
                </div>
            </div>

            <div class="table-wrapper">
                <div class="table-container" id="table-container-2">
                    <table id="master-table2"></table>
                </div>
            </div>
        </section>
    </div>

    <script src="~/js/AvtarDashboard.js"></script>
</body>
</html>