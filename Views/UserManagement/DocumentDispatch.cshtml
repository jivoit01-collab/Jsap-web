                if (files.length > 0) {
                    let fileIndex = 1;
                    for (let file of files) {
                        try {
                            const fileForm = new FormData();
                            const customFileName = `${bundleId}_${row.DocNum}_${fileIndex}_${file.name}`;
                            fileForm.append("file", file, customFileName);

                            const uploadResp = await fetch("/api/DocumentDispatch/UploadSingleFile", {
                                method: "POST",
                                body: fileForm
                            });

                            const uploadResult = await uploadResp.json();

                            attachmentData.push({
                                bundleId,
                                attachment: uploadResult?.filePath || "",
                                docId: row.DocNum,
                                docType: selectedDocType,
                                branch: row.branch,
                                createdBy: updatedBy,
                                createdOn: new Date().toISOString(),
                                status: "S"
                            });

                            fileIndex++;
                        } catch (uploadErr) {
                            console.warn("File upload error:", uploadErr);
                            attachmentData.push({
                                bundleId,
                                attachment: null,
                                docId: row.DocNum,
                                docType: selectedDocType,
                                branch: row.branch,
                                createdBy: updatedBy,
                                createdOn: new Date().toISOString(),
                                status: "S"
                            });
                        }
                    }
                } else {
                    attachmentData.push({
                        bundleId,
                        attachment: "",
                        docId: row.DocNum,
                        docType: selectedDocType,
                        branch: row.branch,
                        createdBy: updatedBy,
                        createdOn: new Date().toISOString(),
                        status: "S"
                    });
                }
            }

            const invalidRows = attachmentData.filter(item => !item.attachment || item.attachment.trim() === "");
            if (invalidRows.length > 0) {
