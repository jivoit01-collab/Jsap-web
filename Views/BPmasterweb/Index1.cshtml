        function removeShippingValidation() {
            const shippingFields = [
                'shipping-address1', 'shipping-country', 'shipping-state',
                'shipping-city', 'shipping-zip'
            ];
            shippingFields.forEach(id => {
                const field = document.getElementById(id);
                if (field) field.removeAttribute('required');
            });
        }

        function addShippingValidation() {
            const shippingFields = [
                'shipping-address1', 'shipping-country', 'shipping-state',
                'shipping-city', 'shipping-zip'
            ];
            shippingFields.forEach(id => {
                const field = document.getElementById(id);
                if (field) field.setAttribute('required', 'required');
            });
        }
        async function checkAddressIdUnique(addressId) {
            const response = await fetch(`/api/BPMaster/CheckAddressUid?addressUid=${encodeURIComponent(addressId)}`);
            if (!response.ok) {
                throw new Error("Server error while checking address ID");
            }
            const data = await response.json();
            return data.exists === false; // true if ID is unique
        }

        function checkAndProcessAddressId(addressId, addressData, type) {
            const input = document.getElementById(`${type}-address-id-input`);
            const errorDiv = document.getElementById(`${type}-address-id-error`);
            const hiddenField = document.getElementById(`${type}-address-id`);
            // const existingIds = ["DL-SAHILCHAHHAR", "PB-CONTABC", "ADDR003"]; 🔹 Add test IDs here
            // if (!addressId) {
            //     alert(`${type.charAt(0).toUpperCase() + type.slice(1)} Address ID is missing.`);
            //     return;
            // }
            if (!addressId || addressId === '-' || String(addressId).includes("undefined")) {
                alert("Address ID could not be generated. Check state and name fields.");
                return;
            }
            console.log("Checking address ID:", addressId);

            fetch(`/api/BPmaster/CheckAddressUid?addressUid=${encodeURIComponent(addressId)}`)
            .then(res => {
                    if (!res.ok) throw new Error("Bad request");
                    return res.json();
                })
       
                .then(data => {
                    const msg = (data.data?.message || "").toLowerCase();
                    if (msg.includes("exists")) {
                        input.value = addressId;
                        input.style.display = "block";
                        input.removeAttribute("readonly");
                        input.classList.add("error");
                        errorDiv.textContent = `${type.charAt(0).toUpperCase() + type.slice(1)} Address ID already exists. Please modify it.`;
                        errorDiv.style.display = "block";

                        if (!input.dataset.listenerAttached) {
                            input.addEventListener("input", () => {
                                const newId = input.value.trim();
                                if (!newId) return;
                                fetch(`/api/BPmaster/CheckAddressUid?addressUid=${encodeURIComponent(newId)}`)
                                    .then(r => r.json())
                                    .then(result => {
                                        const newMsg = (result.data?.message || "").toLowerCase();

                                        if (newMsg.includes("exists")) {
                                            input.classList.add("error");
                                            errorDiv.textContent = "Address ID already exists.";
                                            errorDiv.style.display = "block";
                                        } else if (newMsg.includes("not found")) {
                                            input.classList.remove("error");
                                            errorDiv.style.display = "none";
                                            input.setAttribute("readonly", true);
                                            input.style.display = "none";

                                            hiddenField.value = newId;
                                            // proceedToAddAddressRow(addressData, newId, type);
                                            if (type === 'both' || type === 'shipping') {
                                                // Billing already processed or same ID, proceed
                                                addAddressRow(
                                                addressData.billAddress,
                                                addressData.billAddressId,
                                                addressData.shipAddress,
                                                addressData.shipAddressId
                                                );
                                                resetAddressForm();
                                            }

                                        }
                                    });
                            });

                            input.dataset.listenerAttached = "true";
                        }
                    } else if (msg.includes("not found")) {
                        input.value = addressId;
                        input.setAttribute("readonly", true);
                        input.style.display = "none";
                        errorDiv.style.display = "none";

                        hiddenField.value = addressId;
                        if (type === 'both' || type === 'shipping') {
                            // Billing already processed or same ID, proceed
                            addAddressRow(
                                addressData.billAddress,
                                addressData.billAddressId,
                                addressData.shipAddress,
                                addressData.shipAddressId
                            );
                            resetAddressForm();
                        }

                        // proceedToAddAddressRow(addressData, addressId, type);
                    } else {
                        alert("Unexpected API response for address check.");
                        console.warn(data);
                    }
                })
                .catch(err => {
                    console.error("Error checking address ID:", err);
                    alert("Something went wrong while checking address ID.");
                    console.log("Checking address ID:", addressId);

                });
        }
