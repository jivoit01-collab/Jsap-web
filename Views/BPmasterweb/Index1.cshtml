@{
    ViewData["Title"] = "BP Creation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        
    #staffExtraFields {
            display: block;
        }

     #staffExtraField{
            display: block;
        }
         .editable-id { 
             border: 1px solid #ccc; 
             padding: 4px; 
             font-size: 14px; 
         } */

             .editable-id.error { 
                 border-color: red; 
                 background-color: #ffe5e5; 
             } 


        .hidden{display:none;}
        .bp-modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        .bp-modal {
            background: white;
            max-width: 800px;
            width: 90%;
            margin: auto;
            position: relative;
            top: 50%;
            transform: translateY(-50%);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .bp-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .bp-modal .close-btn {
            background: transparent;
            border: none;
            font-size: 24px;
            cursor: pointer;
        }

        .bp-table-wrapper {
            max-height: 300px;
            overflow-y: auto;
            border: 1px solid #ccc;
        }

        #bp-table {
            width: 100%;
            border-collapse: collapse;
        }

            #bp-table th, #bp-table td {
                padding: 8px 12px;
                border-bottom: 1px solid #ccc;
                text-align: left;
            }

            #bp-table tbody tr:hover {
                background-color: #f5f5f5;
            }

        .bp-search {
            width: 100%;
            padding: 6px 10px;
            margin-bottom: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }


        /* Table */
        .bp-table-wrapper {
            flex: 1;
            overflow-y: auto;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
        }

        #bp-table {
            width: 100%;
            border-collapse: collapse;
        }

            #bp-table th, #bp-table td {
                padding: 12px;
                text-align: left;
                border-bottom: 1px solid #f1f5f9;
                font-size: 14px;
            }

            #bp-table th {
                background-color: #f8fafc;
                text-transform: uppercase;
                font-weight: 600;
                color: #4a5568;
                position: sticky;
                top: 0;
                z-index: 1;
            }

            #bp-table tbody tr:hover {
                background-color: #edf2f7;
                cursor: pointer;
            }

        .error-message {
            color: #dc3545;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }

        .form-group.error input,
        .form-group.error select {
            border-color: #dc3545;
        }

        .required {
            color: #dc3545;
        }

        .loading {
            opacity: 0.6;
            pointer-events: none;
        }

        .bp-suggestions {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            max-height: 250px;
            overflow-y: auto;
            background: white;
            border: 1px solid #ccc;
            border-top: none;
            z-index: 999;
            box-shadow: 0 2px 5px rgba(0,0,0,0.15);
        }

        .bp-suggestion-item {
            padding: 10px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
        }

            .bp-suggestion-item:hover {
                background-color: #f2f2f2;
            }

            .bp-suggestion-item strong {
                display: block;
                font-weight: 600;
                font-size: 15px;
            }

            .bp-suggestion-item small {
                color: #666;
                display: block;
            }

        .success-message {
            color: green;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }


        #addAddressBtn {
            display: inline-flex;
            align-items: center;
            padding: 10px 20px;
            background-color: #f0f4f8;
            color: #007bff;
            border: 2px solid #007bff;
            border-radius: 50px;
            font-size: 14px;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.3s ease;
        }

            #addAddressBtn svg {
                width: 20px;
                height: 20px;
                margin-right: 8px;
            }

            #addAddressBtn:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

            #addAddressBtn:hover:not(:disabled) {
                background-color: #e0e7ff;
                transform: scale(1.05);
            }

        #addContactBtn {
            display: inline-flex;
            align-items: center;
            padding: 10px 20px;
            background-color: #f0f4f8; /* Light color background */
            color: #007bff;
            border: 2px solid #007bff;
            border-radius: 50px;
            font-size: 14px;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.3s ease;
        }

            #addContactBtn svg {
                width: 24px;
                height: 24px;
                margin-right: 8px;
            }

            /* Hover effect to highlight the button */
            #addContactBtn:hover {
                background-color: #e0e7ff; /* Light blue background on hover */
                transform: scale(1.05);
            }

            /* Focus effect for accessibility */
            #addContactBtn:focus {
                outline: none;
                box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.5);
            }

            /* Adding a simple transition effect */
            #addContactBtn:active {
                transform: scale(0.98);
            }
            #addressTable{
            width:100%;
            }
        .contact-table {
            width: 100%;
            border-collapse: collapse;
        }

            .contact-table th, .contact-table td {
                padding: 12px;
                border: 1px solid #ddd;
            }

            .contact-table th {
                background-color: #f4f4f4;
                font-weight: bold;
                text-align: left;
            }

            .contact-table td {
                text-align: left;
            }

            .contact-table input[type="text"],
            .contact-table input[type="email"],
            .contact-table input[type="tel"] {
                width: 100%;
                padding: 8px;
                margin: 4px 0;
                border-radius: 4px;
                border: 1px solid #ccc;
            }

        .edit-btn {
            background-color: #dc3545;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 4px;
        }

            .edit-btn:hover {
                background-color: #c82333;
            }

        .delete-btn {
            background-color: #dc3545;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
            border-radius: 4px;
        }

        .delete-btn:hover {
            background-color: #c82333;
        }

        .error-message {
            color: #dc3545;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }

        .form-group.error input,
        .form-group.error select {
            border-color: #dc3545;
        }

        .required {
            color: #dc3545;
        }

        .loading {
            opacity: 0.6;
            pointer-events: none;
        }

    </style>
</head>
<body>

    <div class="container">
        <div class="form-section">
            <h2 class="section-title">Business Partner Master Data</h2>
            <div class="form-grid">
                <div class="form-group disabled-section">
                    <label for="branch">Branch <span class="required">*</span></label>
                    <select id="branch" required>
                        <option value="1">Jivo Oil</option>
                        <option value="2">Jivo Bevrages</option>
                        <option value="3">Jivo Mart</option>
                    </select>
                    <div class="error-message" id="group-error">Please select a group</div>
                </div>

                <div class="form-group">
                    <label>Type <span class="required">*</span></label>
                    <div class="radio-group">
                        <label>
                            <input type="radio" name="type" value="custa" required  />
                            Customer
                        </label>
                        <label><input type="radio" name="type" value="venda" required /> Vendor</label>
                    </div>
                </div>

                <div class="form-group disabled-section" id="staff-section">
                    <label>Is this a staff member? <span class="required">*</span></label>
                    <div class="radio-group">
                        <label>
                            <input type="radio" name="isStaff" value="Y" required />
                            Yes
                        </label>
                        <label><input type="radio" name="isStaff" checked value="N" required /> No</label>
                    </div>
                </div>

                <div class="form-group disabled-section" id="code-group">
                    <label for="bp-code">Code <span class="required">*</span></label>
                    <input type="text" id="bp-code" name="bp-code" class="code-field" readonly placeholder="Select type and staff status" />
                </div>

                <div class="form-group" id="staffCodeSection" style="display:none;">
                    <label for="staffCode">Staff Code <span class="required">*</span></label>
                    <div style="display: flex; gap: 5px;">
                        <span class="form-control" style="width: 70px; text-align: center;">JWPL</span>
                        <input id="staffCodeSuffix" class="form-control" maxlength="4" style="flex: 1; height:45px"/>
                    </div>
                </div>

                <div class="form-group" id="bp-name-group" style="position: relative;">
                    <label for="BPname">Name <span class="required">*</span></label>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <input type="text" id="BPname" name="BPname" autocomplete="off" />
                        <button type="button" onclick="openBPFilter()" style="background: none; border: none; cursor: pointer;">
                            🔍
                        </button>
                    </div>
                    <div id="bpname-error" class="error-message" style="display: none;">Already exists, please write new.</div>

                    <!-- Suggestion dropdown -->
                    <div id="bp-suggestions" class="bp-suggestions" style="display: none;"></div>
                </div>
                <!-- BP Name Filter Modal -->
                <div id="bp-modal" class="bp-modal-overlay">
                    <div class="bp-modal">
                        <div class="bp-modal-header">
                            <h2>Select Business Partner</h2>
                            <button class="close-btn" onclick="closeBPFilter()">&times;</button>
                        </div>

                        <input type="text" id="bp-search" placeholder="Search by name or address..." onkeyup="filterBPTable()" class="bp-search" />

                        <div class="bp-table-wrapper">
                            <table id="bp-table">
                                <thead>
                                    <tr>
                                        <th>Card Code</th>
                                        <th>Card Name</th>
                                        <th>Address</th>
                                        <th>State</th>
                                        <th>GST No</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows will be populated dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="form-group disabled-section">
                    <label for="group">Group <span class="required">*</span></label>
                    <select id="group" required>
                        <option value="">Select Group</option>
                    </select>
                    <div class="error-message" id="group-error">Please select a group</div>
                </div>

                <div class="form-group disabled-section">
                    <label for="main-group">Main Group <span class="required">*</span></label>
                    <select id="main-group" required>
                        <option value="">Select Main Group</option>
                    </select>
                    <div class="error-message" id="main-group-error">Please select a main group</div>
                </div>

                <div class="form-group disabled-section" id="chain-group">
                    <label for="chain">Chain <span class="required">*</span></label>
                    <select id="chain" required>
                        <option value="">Select Chain</option>
                    </select>
                    <div class="error-message" id="chain-error">Please select a chain</div>
                </div>

                <div class="form-group disabled-section" id="msme-type-group">
                    <label for="MSME">MSME Type</label>
                    <select id="MSME">
                        <option value="">Select MSME</option>                        
                    </select>
                    <div class="error-message" id="MSME-error">Please select MSME type</div>
                </div>

                <div class="form-group disabled-section hidden" id="msme-no-group">
                    <label for="MSMEno">MSME No.</label>
                    <input type="text" id="MSMEno" placeholder="Enter MSME Number" maxlength="25" />
                    <div class="error-message" id="MSMEno-error">Invalid MSME number</div>
                </div>

                <div class="form-group disabled-section hidden" id="msme-btype-group">
                    <label for="MSMEbtype">MSME Business Type</label>
                    <input type="text" id="MSMEbtype" placeholder="Enter MSME Business Type" maxlength="50" />
                    <div class="error-message" id="MSMEbtype-error">Invalid MSME business type</div>
                </div>
                <div id="staffExtraFields">
                <div class="form-group disabled-section">
                    <label for="fssai">FSSAI No.</label>
                    <input type="text" id="fssai" placeholder="Enter FSSAI number" pattern="[0-9]{14}" maxlength="14" />
                    <div class="error-message" id="fssai-error">FSSAI number must be exactly 14 digits</div>
                </div>
                </div>
                <div id="staffExtraField">
                <div class="form-group disabled-section" id="tan-group">
                    <label for="tan">TAN<span class="required">*</span></label>
                    <input type="text" id="tan" placeholder="Enter TAN" pattern="[A-Z]{4}[0-9]{5}[A-Z]{1}" maxlength="10" style="text-transform: uppercase;" required/>
                    <div class="error-message" id="tan-error">TAN format: ABCD12345E</div>
                </div>
                </div>
                <div class="form-group disabled-section" id="pan-group">
                    <label for="pan">PAN</label>
                    <input type="text" id="pan" placeholder="Enter PAN" pattern="[A-Z]{5}[0-9]{4}[A-Z]{1}" maxlength="10" style="text-transform: uppercase;" />
                    <div class="error-message" id="pan-error">PAN format: ABCDE1234F</div>
                </div>
                

            </div>
        </div>

        <div class="tabs">
            <div class="tab active" onclick="switchTab('general')">General</div>
            <div class="tab" onclick="switchTab('contacts')"> Contact Persons </div>
            <div class="tab" onclick="switchTab('addresses')">Addresses</div>
            <div class="tab" onclick="switchTab('payment')">Payment Terms</div>
            <div class="tab" onclick="switchTab('attachments')">Attachments</div>
        </div>

        <div class="general-table" id="general-tab">
            <div class="form-section">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="SPname">Sales Employee Selection <span class="required">*</span></label>
                        <select id="SPname" required>
                            <option value="">Select Name</option>
                            @if (ViewBag.SPname != null)
                            {
                                @foreach (var name in ViewBag.SPname)
                                {
                                    if (name.SlpName == "-No Sales Employee-")
                                    {
                                        <option value="@name.SlpCode" selected>@name.SlpName</option>
                                    }
                                    else
                                    {
                                        <option value="@name.SlpCode">@name.SlpName</option>
                                    }
                                }
                            }
                        </select>
                        <div class="error-message" id="SPname-error">Please select a sales employee</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="" id="contacts-tab" style="display: none">
            <form id="contactForm" class="contact-form" onsubmit="event.preventDefault();">
                <div class="form-section">
                    <!-- Add Contact Button -->
                    <div style="display: flex; justify-content: flex-end; margin-bottom: 10px;">
                        <button id="addContactBtn" class="btn btn-primary" disabled onclick="addNewContactForm()">
                            <svg class="icon" viewBox="0 0 24 24">
                                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                            </svg>
                            Add New Contact
                        </button>
                    </div>

                    <div class="form-group">
                        <table class="table" style="width:100%">
                            <thead>
                                <tr>
                                    <th>FIRST NAME <span class="required">*</span></th>
                                    <th>LAST NAME <span class="required">*</span></th>
                                    <th>MOBILE NO. <span class="required">*</span></th>
                                    <th>EMAIL <span class="required">*</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <input type="text" style="text-transform:uppercase" name="contactFirstName" placeholder="Enter First Name" required />
                                        <div class="error-message" style="display: none; color: red; font-size: 12px; margin-top: 5px;"></div>
                                    </td>
                                    <td>
                                        <input type="text" style="text-transform:uppercase" name="contactLastName" placeholder="Enter Last Name" required />
                                        <div class="error-message" style="display: none; color: red; font-size: 12px; margin-top: 5px;"></div>
                                    </td>
                                    <td>
                                        <input type="tel" maxlength="10" name="phone" placeholder="Enter Mobile No." required />
                                        <div class="error-message" style="display: none; color: red; font-size: 12px; margin-top: 5px;"></div>
                                    </td>
                                    <td>
                                        <input type="email" style="text-transform:uppercase" name="email" placeholder="Enter Email" required />
                                        <div class="error-message" style="display: none; color: red; font-size: 12px; margin-top: 5px;"></div>
                                    </td>
                                    <td id="contact-id-cell" style="display: none;">
                                        <input type="text" id="contactIdInput" readonly class="form-control" />
                                        <div id="contact-id-error" class="error-message" style="display:none;"> Contact ID already exists. Please enter a unique one.</div>
                                    </td>


                                </tr>
                            </tbody>
                        </table>
                    </div><div id="contact-edit-actions" style="display: none; margin-top: 10px; text-align: right;">
                        <button class="btn btn-success" onclick="saveEditedContact()">Save Changes</button>
                        <button class="btn btn-secondary" onclick="cancelEditContact()">Cancel</button>
                    </div>


                    <!-- Display Table for Added Contacts -->
                    <table class="contact-table-display contact-table" style="width:100%; margin-top:20px; display:none;">
                        <thead>
                            <tr>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Mobile Number</th>
                                <th>Email</th>
                                <th>Contact ID</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Contact rows will be dynamically added here -->
                        </tbody>
                    </table>
                </div>
            </form>
        </div>

        <div class="payment-content" id="payment-tab" style="display: none">
            <div class="form-section">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="payment-terms">Payment Terms <span class="required">*</span></label>
                        <select id="payment-terms" required>
                            <option value="">Select Payment Terms</option>
                        </select>
                        <div class="error-message" id="payment-terms-error">Please select payment terms</div>
                    </div>

                    <div class="form-group">
                        <label for="price-list">Price List</label>
                        <select id="price-list" required>
                            <option value="">Select Price List</option>
                        </select>
                        <div class="error-message" id="price-list-error">Please select price list</div>
                    </div>

                    <div class="form-group">
                        <label for="credit-limit">Credit Limit</label>
                        <input type="number" id="credit-limit" placeholder="Enter credit limit" readonly/>
                        <div class="error-message" id="credit-limit-error">Please enter a valid credit limit</div>
                    </div>
                </div>

                <h3 style="margin: 30px 0 20px 0; color: #2d3748; font-size: 16px">
                    Bank Information
                </h3>

                <div class="form-grid">
                    <div class="form-group">
                        <label for="BankName">Bank Name <span class="required">*</span></label>
                        <select id="BankName" required>
                            <option value="">Select Bank Name</option>
                        </select>
                        <div class="error-message" id="bank-name-error">Please select bank name</div>
                    </div>

                    <div class="form-group">
                        <label for="account-name">Account Name</label>
                        <input type="text" id="account-name" placeholder="Enter account name" maxlength="100" />
                        <div class="error-message" id="account-name-error">Please enter account name</div>
                    </div>

                    <div class="form-group">
                        <label for="account-number">Account Number</label>
                        <input type="text" id="account-number" placeholder="Enter account number" pattern="[0-9]{9,18}" maxlength="18" />
                        <div class="error-message" id="account-number-error">Account number must be 9-18 digits</div>
                    </div>

                    <div class="form-group">
                        <label for="con-acc-number">Confirm Account Number</label>
                        <input type="text" id="con-acc-number" placeholder="Confirm Account Number" pattern="[0-9]{9,18}" maxlength="18" />
                        <div class="error-message" id="con-acc-number-error">Account number must be 9-18 digits.</div>
                    </div>

                    <div class="form-group">
                        <label for="ifsc-code">IFSC Code/Swift Code</label>
                        <input type="text" id="ifsc-code" placeholder="Enter code" pattern="^[A-Z]{4}0[A-Z0-9]{6}$" maxlength="11" style="text-transform: uppercase;" />
                        <div class="error-message" id="ifsc-code-error">IFSC code format: ABCD0123456</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="addresses-content" id="addresses-tab" style="display: none">
            <div class="form-section">
                <!-- Add Address Button -->
                <div style="display: flex; justify-content: flex-end;">
                    <button id="addAddressBtn" disabled onclick="addAddressEntry()">
                        <svg class="icon" viewBox="0 0 24 24">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" />
                        </svg>
                        Add Address
                    </button>
                </div>

                <h3 style="margin-bottom: 20px; color: #2d3748; font-size: 16px">
                    Billing Address
                </h3>

                <div class="form-grid">
                    

                    <div class="form-group">
                        <label for="billing-address1">Address Line 1 <span class="required">*</span></label>
                        <input type="text" id="billing-address1" placeholder="Enter address line 1" required maxlength="200" />
                        <div class="error-message" id="billing-address1-error">Address line 1 is required</div>
                    </div>

                    <div class="form-group">
                        <label for="billing-address2">Address Line 2</label>
                        <input type="text" id="billing-address2" placeholder="Enter address line 2" maxlength="200" />
                        <div class="error-message" id="billing-address2-error">Invalid address line 2</div>
                    </div>
                    <div class="form-group">
                        <label for="billing-country">Country <span class="required">*</span></label>
                        <select id="billing-country" required>
                            <option value="">Select Country</option>
                            <!-- Remove default India selection, populate from ViewBag.Country -->
                            @{
                                
                                if (ViewBag.Country != null)
                                {
                                    foreach (var data in ViewBag.Country)
                                    {
                                        // <option value="@data.Code">@data.Name</option>
             
                                          var isSelected = data.Code.ToString().Trim().ToUpper() == "IN" ? "selected" : "";
                                        @:<option value="@data.Code" @isSelected>@data.Name</option>
                                    }
                                }
                            }


                        </select>
                        <div class="error-message" id="billing-country-error">Please select a country</div>
                    </div>

                    <div class="form-group">
                        <label for="billing-state">State/Province <span class="required">*</span></label>
                        <select id="billing-state" required disabled>
                            <option value="">Select State</option>
                        </select>
                        <div class="error-message" id="billing-state-error">Please select a state</div>
                    </div>
                    <div class="form-group">
                        <label for="billing-city">City <span class="required">*</span></label>
                        <input type="text" id="billing-city" placeholder="Enter city" required maxlength="50" />
                        <div class="error-message" id="billing-city-error">City is required</div>
                    </div>

                    <div class="form-group">
                        <label for="billing-zip">ZIP/Postal Code <span class="required">*</span></label>
                        <input type="text" id="billing-zip" placeholder="Enter ZIP/postal code" required pattern="[0-9]{6}" maxlength="6" />
                        <div class="error-message" id="billing-zip-error">ZIP code must be 6 digits</div>
