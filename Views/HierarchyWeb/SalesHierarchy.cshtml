function renderBulkTable() {
    const q = document.getElementById('bulkSearchEmp').value.toLowerCase().trim();
    const rows = allRows.filter(r => {
        if (!q) return true;
        return (r.empCode||'').toLowerCase().includes(q)
            || (r.empName||'').toLowerCase().includes(q)
            || (r.h1Name||'').toLowerCase().includes(q)
            || (r.state||'').toLowerCase().includes(q);
    });

    document.getElementById('bulkTableInfo').textContent = `${rows.length} of ${allRows.length} employees`;

    const tbody = document.getElementById('bulkEmpTableBody');
    if (!rows.length) {
        tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--muted)">No employees found</td></tr>`;
        return;
    }
    tbody.innerHTML = rows.map(r => {
        const checked = bulkSelected.has(r.salesHierarchyId) ? 'checked' : '';
        return `<tr style="${checked ? 'background:#eff6ff' : ''}">
