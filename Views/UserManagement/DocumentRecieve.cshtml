        // FIXED: Toggle Accept/Reject action with better visual feedback
        function toggleAction(index, action) {
            const row = document.querySelector(`input[name="selectRow"][value="${index}"]`).closest('tr');
            const acceptBtn = row.querySelector('.accept-btn');
            const rejectBtn = row.querySelector('.reject-btn');
            const bundleStatusSelect = row.querySelector('.table-bundle-status');
            const rejectReasonInput = row.querySelector('.reject-reason-input');

            // Clear previous selections
            acceptBtn.classList.remove('active');
            rejectBtn.classList.remove('active');

            if (action === 'accept') {
                acceptBtn.classList.add('active');
                // Enable bundle status, disable reject reason
                bundleStatusSelect.disabled = false;
                rejectReasonInput.disabled = true;
                rejectReasonInput.value = '';
                rejectReasonInput.style.borderColor = '#ddd';
                rejectReasonInput.style.borderWidth = '1px';

                // Mark bundle status as required
                if (!bundleStatusSelect.value) {
                    bundleStatusSelect.style.borderColor = '#e74c3c';
                    bundleStatusSelect.style.borderWidth = '2px';
                }
            } else if (action === 'reject') {
                rejectBtn.classList.add('active');
                // Enable reject reason, disable bundle status
                rejectReasonInput.disabled = false;
                bundleStatusSelect.disabled = true;
                bundleStatusSelect.value = '';
                bundleStatusSelect.style.borderColor = '#ddd';
                bundleStatusSelect.style.borderWidth = '1px';

                // Mark reject reason as required
                if (!rejectReasonInput.value.trim()) {
                    rejectReasonInput.style.borderColor = '#e74c3c';
                    rejectReasonInput.style.borderWidth = '2px';
                }

                // Focus on reject reason input for user convenience
                rejectReasonInput.focus();
            }

            validateSelectedRows();
        }

        // Update row states based on selection
        function updateRowStates() {
            const allRows = document.querySelectorAll('#receiverTable tbody tr');

            allRows.forEach(row => {
                const checkbox = row.querySelector('input[name="selectRow"]');
                const acceptBtn = row.querySelector('.accept-btn');
                const rejectBtn = row.querySelector('.reject-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');
                const rejectReasonInput = row.querySelector('.reject-reason-input');

                if (checkbox.checked) {
                    // Row is selected - enable action buttons
                    acceptBtn.disabled = false;
                    rejectBtn.disabled = false;

                    // If no action selected yet, disable both bundle status and reject reason
                    if (!acceptBtn.classList.contains('active') && !rejectBtn.classList.contains('active')) {
                        bundleStatusSelect.disabled = true;
                        rejectReasonInput.disabled = true;
                        bundleStatusSelect.value = '';
                        rejectReasonInput.value = '';
                        bundleStatusSelect.style.borderColor = '#ddd';
                        bundleStatusSelect.style.borderWidth = '1px';
                        rejectReasonInput.style.borderColor = '#ddd';
                        rejectReasonInput.style.borderWidth = '1px';
                    }
                } else {
                    // Row is not selected - disable everything
                    acceptBtn.disabled = true;
                    rejectBtn.disabled = true;
                    acceptBtn.classList.remove('active');
                    rejectBtn.classList.remove('active');

                    bundleStatusSelect.disabled = true;
                    bundleStatusSelect.value = '';
                    bundleStatusSelect.style.borderColor = '#ddd';
                    bundleStatusSelect.style.borderWidth = '1px';

                    // Also disable reject reason for unselected rows
                    rejectReasonInput.disabled = true;
                    rejectReasonInput.value = '';
                    rejectReasonInput.style.borderColor = '#ddd';
                    rejectReasonInput.style.borderWidth = '1px';
                }
            });
        }

        // Validate selected rows
        function validateSelectedRows() {
            const allRows = document.querySelectorAll('#receiverTable tbody tr');

            allRows.forEach(row => {
                const checkbox = row.querySelector('input[name="selectRow"]');
                const acceptBtn = row.querySelector('.accept-btn');
                const rejectBtn = row.querySelector('.reject-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');
                const rejectReasonInput = row.querySelector('.reject-reason-input');

                if (checkbox.checked) {
                    // Selected row - validate action choice and corresponding field
                    if (acceptBtn.classList.contains('active')) {
                        // Accept selected - validate bundle status
                        if (!bundleStatusSelect.value) {
                            bundleStatusSelect.style.borderColor = '#e74c3c';
                            bundleStatusSelect.style.borderWidth = '2px';
                        } else {
                            bundleStatusSelect.style.borderColor = '#28a745';
                            bundleStatusSelect.style.borderWidth = '2px';
                        }
                    } else if (rejectBtn.classList.contains('active')) {
                        // Reject selected - validate reject reason
                        if (!rejectReasonInput.value.trim()) {
                            rejectReasonInput.style.borderColor = '#e74c3c';
                            rejectReasonInput.style.borderWidth = '2px';
                        } else {
                            rejectReasonInput.style.borderColor = '#28a745';
                            rejectReasonInput.style.borderWidth = '2px';
                        }
                    }
                }
            });
        }

        // Global Bundle Status (only affects accepted rows)
        document.getElementById('globalBundleStatus').addEventListener('change', function() {
            const selectedStatus = this.value;
            if (!selectedStatus) return;

            const checkedRows = document.querySelectorAll('input[name="selectRow"]:checked');
            checkedRows.forEach(checkbox => {
                const row = checkbox.closest('tr');
                const acceptBtn = row.querySelector('.accept-btn');
                const bundleStatusSelect = row.querySelector('.table-bundle-status');

                // Only apply to rows with Accept selected
