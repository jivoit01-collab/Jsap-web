// ═══════════════════════════════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════════════════════════════
function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function normalizeExcelHeader(value) {
    return String(value ?? '')
        .trim()
        .toLowerCase()
        .replace(/[\r\n\t]+/g, ' ')
        .replace(/[^a-z0-9]+/g, '');
}

function looksLikeEmployeeCode(value) {
    return /^[a-z]{2,}\d{2,}$/i.test(String(value || '').trim());
}

function normalizeHierarchyPair(row, codeKey, nameKey) {
    const codeVal = String(row[codeKey] || '').trim();
    const nameVal = String(row[nameKey] || '').trim();

    if (!codeVal && looksLikeEmployeeCode(nameVal)) {
        row[codeKey] = nameVal;
        row[nameKey] = '';
    }
}

function formatLevelFilterLabel(name, code) {
    if (name && normalizeKey(name) === normalizeKey(code)) return name;
    if (name && code) return `${name} - ${code}`;
    return name || code || '';
}

function normalizeHierarchyCode(code, name) {
    const rawCode = String(code || '').trim();
    const rawName = String(name || '').trim();
    if (!rawName) return rawCode;
    if (!rawCode || normalizeKey(rawCode) === normalizeKey(rawName) || /\s/.test(rawCode)) {
        return rawName
            .replace(/[^a-zA-Z0-9\s]/g, '')
            .trim()
            .replace(/\s+/g, '_')
            .toUpperCase();
    }
    return rawCode;
}

function normalizeKey(value) {
    return String(value ?? '').trim().toLowerCase().replace(/\s+/g, ' ');
}

function getUniqueTextValues(items, textKey) {
    const seen = new Set();
    return (items || [])
        .map(item => String(item?.[textKey] || '').trim())
        .filter(value => {
            const key = normalizeKey(value);
            if (!key || seen.has(key)) return false;
            seen.add(key);
            return true;
        })
        .sort((a, b) => a.localeCompare(b));
}

function getEmployeeNameByCode(code) {
    const match = hierarchyOptions.employees.find(e => e.value === code);
    return match ? (match.name || '') : '';
}

function normalizeApiResponse(json) {
    const obj = json || {};
    return {
        ...obj,
        success: obj.success ?? obj.Success ?? false,
        data: obj.data ?? obj.Data ?? null,
        message: obj.message ?? obj.Message ?? '',
        states: obj.states ?? obj.States ?? [],
        groups: obj.groups ?? obj.Groups ?? [],
        designations: obj.designations ?? obj.Designations ?? []
    };
}

function setSelectVal(id, val) {
    const sel = document.getElementById(id);
    for (let i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === val) { sel.selectedIndex = i; return; }
    }
    sel.selectedIndex = 0;
}

async function fetchPost(url, body) {
    const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    });
    return normalizeApiResponse(await res.json());
}

function debounce(fn, ms) {
    let t;
    return function(...args) { clearTimeout(t); t = setTimeout(() => fn.apply(this, args), ms); };
}

function showToast(msg, type = 'info') {
    const container = document.getElementById('toastContainer');
    const icons = { success: '✅', error: '❌', info: 'ℹ️' };
    const div = document.createElement('div');
    div.className = `toast toast-${type}`;
    div.innerHTML = `<span class="toast-icon">${icons[type]||'ℹ️'}</span><span>${esc(msg)}</span>`;
    container.appendChild(div);
    setTimeout(() => div.remove(), 4000);
}

