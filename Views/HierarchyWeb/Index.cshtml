            function v1_expandAll(){ RAW_DATA.forEach(function(hod){ v1_exp[hod.id]=true; hod.depts.forEach(function(d,di){v1_exp['dept-'+hod.idx+'-'+di]=true;}); hod.subs.forEach(function(s,si){v1_exp['sd-'+hod.idx+'-'+s.idx]=true;(s.subHods||[]).forEach(function(sh,shi){v1_exp['sh-'+hod.idx+'-'+s.idx+'-'+shi]=true;});}); }); v1_rerender(); }
