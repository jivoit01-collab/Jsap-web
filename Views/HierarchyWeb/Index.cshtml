            function v2_clickHod(idx,e){ e.stopPropagation();if(!v2_state[idx])v2_state[idx]={expanded:false,selDept:null,selSD:{}};if(v2_state[idx].expanded||v2_state[idx].selDept)v2_state[idx]={expanded:false,selDept:null,selSD:{}};else{v2_state[idx].expanded=true;v2_autoExpand(idx);}v2_render(); }
