        function showPurchaseOrderPopup(cardCode, showProgress = true) {
            if (!cardCode) {
                showAlert("Please enter a valid CardCode", 'warning');
                lockFormFields(false);
                return;
            }

            if (!ValidationManager.validateField('cardCode')) {
                showAlert("Please enter a valid CardCode before loading POs", 'error');
                lockFormFields(false);
                return;
            }

            const selectedCompany = getSelectedCompany();
            if (!selectedCompany) {
                showAlert("Please select a company first", 'error');
                lockFormFields(false);
                return;
            }

            isLoadingPOs = true;

            // Show different loading states based on showProgress parameter
            if (showProgress) {
                // Show full page progress for "Copy From" button
                showFullPageProgress('Loading Purchase Orders...');
            } else {
                // Show only form loading state for dropdown selection
                lockFormFields(true);
            }

            fetch(`/api/AdvanceRequest/GetPurchaseOrders?CardCode=${encodeURIComponent(cardCode)}&company=${encodeURIComponent(selectedCompany)}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(res => {
                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }
                return res.json();
            })
            .then(data => {
                isLoadingPOs = false;

                // Hide appropriate loading state
                if (showProgress) {
                    hideFullPageProgress();
                } else {
                    lockFormFields(false);
                }

                fullPOData = data;
                populatePOPopupTable(data);
                document.getElementById("poPopupModal").style.display = "flex";
            })
            .catch(err => {
                isLoadingPOs = false;

                // Hide appropriate loading state
                if (showProgress) {
                    hideFullPageProgress();
                } else {
                    lockFormFields(false);
                }

                showAlert(`❌ Error loading Purchase Orders: ${err.message}`, 'error');
            });
        }

