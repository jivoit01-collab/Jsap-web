            function getSalesStateBuckets(h2){
                var stateMap = Object.create(null), stateOrder = [];
                (h2 && h2.h3List || []).forEach(function(h3){
                    (h3.h4List || []).forEach(function(h4){
                        (h4.groups || []).forEach(function(group){
                            (group.employees || []).forEach(function(emp){
                                var stateName = (emp.state || 'Unknown State').trim() || 'Unknown State';
                                if(!stateMap[stateName]){
                                    stateMap[stateName] = { state: stateName, combos: [], comboMap: Object.create(null), employeeCount: 0 };
                                    stateOrder.push(stateName);
                                }
                                var designation = (emp.designation || 'No Designation').trim() || 'No Designation';
                                var groupName = (group.groupName || 'No Group').trim() || 'No Group';
                                var comboKey = designation + '||' + groupName;
                                if(!stateMap[stateName].comboMap[comboKey]){
                                    stateMap[stateName].comboMap[comboKey] = {
                                        designation: designation,
                                        groupName: groupName,
                                        label: designation + ' + ' + groupName,
                                        employees: []
                                    };
                                    stateMap[stateName].combos.push(stateMap[stateName].comboMap[comboKey]);
                                }
                                stateMap[stateName].comboMap[comboKey].employees.push(emp);
                                stateMap[stateName].employeeCount++;
                            });
                        });
                    });
                });
                return stateOrder.map(function(stateName){ return stateMap[stateName]; });
            }

            function findSalesNode(hod, parts){
                var salesTree = hod && hod.salesTree;
                if(!salesTree) return null;
                var h2 = null, stateBucket = null, combo = null, employee = null;
                if(parts.length > 2){
                    h2 = (salesTree.h2List || [])[+parts[2]];
                    if(!h2) return null;
                }
                if(parts.length > 3){
                    stateBucket = (getSalesStateBuckets(h2) || [])[+parts[3]];
                    if(!stateBucket) return null;
                }
                if(parts.length > 4){
                    combo = (stateBucket.combos || [])[+parts[4]];
                    if(!combo) return null;
                }
                if(parts.length > 5){
                    employee = (combo.employees || [])[+parts[5]];
                    if(!employee) return null;
                }
                return { salesTree: salesTree, h2: h2, stateBucket: stateBucket, combo: combo, employee: employee };
            }

