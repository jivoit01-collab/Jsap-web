        function validateField(field) {
            var fieldId = field.id || field.name;
            var formGroup = field.closest('.form-group');
            var errorElement = document.getElementById(fieldId + '-error');
            var isValid = true;
            var errorMessage = '';

            // Reset previous state
            if (formGroup) formGroup.classList.remove('error');
            if (errorElement) errorElement.style.display = 'none';

            const value = field.value.trim().toUpperCase();

            // Required field check
            if (field.hasAttribute('required') && !value) {
                isValid = false;
                errorMessage = 'This field is required';
            }
            // Email validation
            else if (field.type === 'email' && value && !isValidEmail(value)) {
                isValid = false;
                errorMessage = 'Please enter a valid email address';
            }
            // Specific field validations
            else if (fieldId === 'MSMEnum' && value && !/^UDYAM-[A-Z]{2}-[0-9]{7,15}$/i.test(value)) {
                isValid = false;
                errorMessage = 'Invalid MSME No. Format. Expected: UDYAM-XX-1234567';
            }
            else if (fieldId === 'tan' && value && !/^[A-Z]{4}[0-9]{5}[A-Z]$/.test(value)) {
                isValid = false;
                errorMessage = 'Invalid TAN number. Format: ABCD12345E';
            }
            else if (fieldId === 'pan' && value && !/^[A-Z]{5}[0-9]{4}[A-Z]$/.test(value)) {
                isValid = false;
                errorMessage = 'Invalid PAN number. Format: ABCDE1234F';
            }
            // Generic pattern validation
            else if (field.pattern && value && !new RegExp(`^${field.pattern}$`, 'i').test(value)) {
                isValid = false;
                errorMessage = 'Invalid format';
            }

            // Show error if validation failed
            if (!isValid) {
                if (formGroup) formGroup.classList.add('error');
                if (errorElement) {
                    errorElement.textContent = errorMessage;
                    errorElement.style.display = 'block';
                }
            }

            field.value = value; // enforce uppercase in input box
            return isValid;
        }


        function isValidEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function validateAccountNumbers() {
            const accountNumber = document.getElementById('account-number');
            const confirmAccountNumber = document.getElementById('con-acc-number');
            const accountError = document.getElementById('account-number-error');
            const confirmError = document.getElementById('con-acc-number-error');
            let isValid = true;

            // Validate account number format
            if (!/^\d{9,18}$/.test(accountNumber.value)) {
                accountError.style.display = 'block';
                isValid = false;
            } else {
                accountError.style.display = 'none';
            }

            // Validate confirmation and match
            if (confirmAccountNumber.value !== accountNumber.value) {
                confirmError.textContent = 'Account numbers must match';
                confirmError.style.display = 'block';
                isValid = false;
            } else if (!/^\d{9,18}$/.test(confirmAccountNumber.value)) {
                confirmError.textContent = 'Account number must be 9-18 digits';
                confirmError.style.display = 'block';
                isValid = false;
            } else {
                confirmError.style.display = 'none';
            }

            return isValid;
        }

