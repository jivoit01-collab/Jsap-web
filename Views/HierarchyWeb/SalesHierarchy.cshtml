    visible.forEach(r => {
        if (checked) bulkSelected.add(r.salesHierarchyId);
        else bulkSelected.delete(r.salesHierarchyId);
    });
    updateBulkHeader();
    renderBulkTable();
}

function updateBulkHeader() {
    document.getElementById('bulkSelCount').textContent = bulkSelected.size;
    const btn = document.getElementById('btnSaveBulk');
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Assign ${bulkSelected.size} Employee${bulkSelected.size !== 1 ? 's' : ''}`;
    btn.disabled = bulkSelected.size === 0;
}

function getBulkHierarchyName(selectId, codeField, nameField) {
    const select = document.getElementById(selectId);
    const val = select.value;
    if (!val) return '';
    const opt = select.options[select.selectedIndex];
    if (opt?.dataset?.name) return opt.dataset.name;
    const match = allRows.find(r => (r[codeField]||'') === val);
    return match ? (match[nameField]||val) : val;
}

async function saveBulkAssign() {
    if (!bulkSelected.size) return;

    const h1Code = document.getElementById('bulk_h1code').value;
    const h2Code = document.getElementById('bulk_h2code').value;
    const h3Code = document.getElementById('bulk_h3code').value;
    const h4Code = document.getElementById('bulk_h4code').value;
    const state  = document.getElementById('bulk_state').value;
    const group  = document.getElementById('bulk_groupName').value;
    const desig  = document.getElementById('bulk_designation').value;

    const h1Name = getBulkHierarchyName('bulk_h1code', 'h1Code', 'h1Name');
    const h2Name = getBulkHierarchyName('bulk_h2code', 'h2Code', 'h2Name');
    const h3Name = getBulkHierarchyName('bulk_h3code', 'h3Code', 'h3Name');
    const h4Name = getBulkHierarchyName('bulk_h4code', 'h4Code', 'h4Name');

    const payload = [...bulkSelected].map((id, i) => {
        const row = allRows.find(r => r.salesHierarchyId === id);
        if (!row) return null;
        return {
            rowNumber:   i + 1,
            empCode:     row.empCode,
            empName:     row.empName,
            h1Code:      h1Code || row.h1Code,
            h1Name:      h1Name || row.h1Name,
            h2Code:      h2Code || row.h2Code,
            h2Name:      h2Name || row.h2Name,
            h3Code:      h3Code || row.h3Code,
            h3Name:      h3Name || row.h3Name,
            h4Code:      h4Code || row.h4Code,
            h4Name:      h4Name || row.h4Name,
            state:       state  || row.state,
            groupName:   group  || row.groupName,
            designation: desig  || row.designation
        };
    }).filter(Boolean);

    const btn = document.getElementById('btnSaveBulk');
    btn.disabled = true; btn.textContent = 'Assigning…';

    try {
        const res = await fetchPost(API.importExcel, payload);
        if (res.success) {
            const d = res.data || {};
            showToast(`Bulk assign done — ${d.rowsUpserted ?? payload.length} rows updated`, 'success');
            closeBulkAssignModal();
            refreshData();
        } else {
            showToast(res.message || 'Bulk assign failed', 'error');
        }
    } catch(e) {
        showToast('Error: ' + e.message, 'error');
    } finally {
        btn.disabled = bulkSelected.size === 0;
        updateBulkHeader();
    }
}

