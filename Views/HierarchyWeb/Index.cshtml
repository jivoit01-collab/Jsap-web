ollapse"></i></button></div>';}html+='</div>';if(isExp){html+='<div class="hs-body" style="border-color:'+c.border+'">'+sharedTreeRender(h,v3_treeStates[h.idx]||{},'v3_toggleNode('+h.idx+',')+'</div>';}return html+'</div>'; }
