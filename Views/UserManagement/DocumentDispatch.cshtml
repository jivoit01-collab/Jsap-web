    // File preview functions (keeping your original code)
    async function handleZipPreview(zipUrl) {
        if (typeof JSZip === 'undefined') {
        console.error('JSZip library not loaded');
        alert('ZIP preview functionality is not available. The required library failed to load. Please download the file manually.');

        // Provide fallback download option
        const link = document.createElement('a');
        link.href = zipUrl;
        link.download = 'attachment.zip';
        link.click();
        return;
    }
        try {
            const response = await fetch(zipUrl);
            const blob = await response.blob();
            const zip = await JSZip.loadAsync(blob);
            const fileNames = Object.keys(zip.files);

            if (fileNames.length === 0) {
                alert("ZIP file is empty.");
                return;
            }

            const container = document.getElementById("filePreviewContent");
            container.innerHTML = "";

            for (let fileName of fileNames) {
                const file = zip.files[fileName];
                if (file.dir) continue;

                const extension = fileName.split('.').pop().toLowerCase();
                const section = document.createElement("div");
                section.style.marginBottom = "30px";
                section.innerHTML = `<h4>${fileName}</h4>`;

                let contentBlob, url;

                if (extension === "pdf") {
                    const arrayBuffer = await file.async("uint8array");
                    contentBlob = new Blob([arrayBuffer], { type: "application/pdf" });
                    url = URL.createObjectURL(contentBlob);
                    section.innerHTML += `
                        <iframe src="${url}" width="100%" height="600px" style="border:1px solid #ccc;"></iframe>
                    `;
                } else if (["jpg", "jpeg", "png", "gif", "bmp", "webp"].includes(extension)) {
                    const arrayBuffer = await file.async("uint8array");
                    contentBlob = new Blob([arrayBuffer]);
                    url = URL.createObjectURL(contentBlob);
                    section.innerHTML += `<img src="${url}" style="max-width:100%; height:auto;" />`;
                } else if (["txt", "csv", "log", "json", "xml"].includes(extension)) {
                    const text = await file.async("text");
                    section.innerHTML += `
                        <pre style="white-space:pre-wrap; word-wrap:break-word; background:#f4f4f4; padding:10px;">
    ${text}</pre>`;
                } else {
                    const arrayBuffer = await file.async("uint8array");
                    contentBlob = new Blob([arrayBuffer]);
                    url = URL.createObjectURL(contentBlob);
                    section.innerHTML += `
                        <i>Cannot preview this file type: <strong>.${extension}</strong></i><br/>
                        <a href="${url}" download>Click here to download</a>
                    `;
                }

                container.appendChild(section);
            }

            // Show modal after all previews are added
            document.getElementById("filePreviewModal").style.display = "block";
            document.getElementById("filePreviewBackdrop").style.display = "block";

        } catch (err) {
            console.error("Preview error:", err);
            alert("Failed to preview attachment.");
        }
    }


    function closeFilePreview() {
        document.getElementById("filePreviewModal").style.display = "none";
        document.getElementById("filePreviewBackdrop").style.display = "none";

        // ✅ Add cleanup to prevent memory leaks
        const content = document.getElementById("filePreviewContent");
        const iframes = content.querySelectorAll('iframe');
        const images = content.querySelectorAll('img');

        // Revoke object URLs to free memory
        images.forEach(img => {
            if (img.src.startsWith('blob:')) {
                URL.revokeObjectURL(img.src);
            }
        });

        content.innerHTML = "";
    }

    function formatDate(dateString) {
        if (!dateString) return '-';
        const date = new Date(dateString);
        return date.toISOString().split('T')[0]; // Returns 'YYYY-MM-DD'
    }
        // Add this helper function
    function escapeHtml(unsafe) {
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Then use it in your render functions:
    // Instead of: <td>${item.cardName}</td>
    // Use: <td>${escapeHtml(item.cardName || '')}</td>
</script>

