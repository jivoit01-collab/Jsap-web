    function getSelectedBulkExecIds() {
        return [...bulkSelectedExecIds].filter(Boolean);
    }

    function updateBulkExecSummary() {
        const total = bulkExecsMeta.length;
        const selected = getSelectedBulkExecIds().length;
        const label = total ? `${selected} selected of ${total}` : '0 selected';
        document.getElementById('bulkExecSummary').textContent = label;
    }

    function getCurrentBulkExecRows() {
        const q = (document.getElementById('b_exec_search').value || '').toLowerCase();
        return bulkExecsMeta.filter(e => !q || `${e.employeeName||''} ${e.employeeCode||''}`.toLowerCase().includes(q));
    }

    function bulkSelectVisible(selectVisible) {
        getCurrentBulkExecRows().forEach(e => {
            if (selectVisible) bulkSelectedExecIds.add(e.employeeId);
            else bulkSelectedExecIds.delete(e.employeeId);
        });
        renderBulkExecList();
    }

    function onBulkExecToggle(employeeId, checked) {
        if (checked) bulkSelectedExecIds.add(employeeId);
        else bulkSelectedExecIds.delete(employeeId);
        updateBulkExecSummary();
    }

    function collectBulkExecRowsFromGrid(hodId, deptId, subDeptId) {
        const map = new Map();
        (allRows || []).forEach(r => {
            if (!(r.execEmployeeId > 0)) return;
            if (hodId && r.hodEmployeeId !== hodId) return;
            if (deptId && r.departmentId !== deptId) return;
            if (subDeptId && r.subDepartmentId !== subDeptId) return;
            if (!map.has(r.execEmployeeId)) {
                map.set(r.execEmployeeId, {
                    employeeId: r.execEmployeeId,
                    employeeName: r.execName,
                    employeeCode: r.execCode || '',
                    currentSubHodName: r.subHodName || '',
                    currentSubDepartmentName: r.subDepartmentName || '',
                    currentDepartmentName: r.departmentName || '',
                    currentHodName: r.hodName || ''
                });
            }
        });
        return [...map.values()];
    }

    async function refreshBulkExecutives() {
        const hodId = parseInt(document.getElementById('b_hod').value) || 0;
        const deptId = parseInt(document.getElementById('b_dept').value) || 0;
        const subDeptId = parseInt(document.getElementById('b_sdept').value) || 0;
        bulkSelectedExecIds = new Set();
        bulkExecsMeta = [];
        if (!deptId) {
            document.getElementById('bulkExecList').innerHTML = '<div class="dm-empty">Select department above</div>';
            updateBulkExecSummary();
            return;
        }

        if (bulkMode === 'reassign') {
            // CHANGE SUBHOD mode: show only executives under the selected CURRENT sub-HOD
            const currentSubHodId = parseInt(document.getElementById('b_current_subhod').value) || 0;
            const map = new Map();
            (allRows || []).forEach(r => {
                if (!(r.execEmployeeId > 0)) return;
                if (r.hodEmployeeId !== hodId) return;
                if (deptId && r.departmentId !== deptId) return;
                if (subDeptId && r.subDepartmentId !== subDeptId) return;
                // Filter by current sub-HOD: 0 means "Direct to HOD" (no sub-HOD)
                const rowSubHod = r.subHodEmployeeId || 0;
                if (rowSubHod !== currentSubHodId) return;
                if (!map.has(r.execEmployeeId)) {
                    map.set(r.execEmployeeId, {
                        employeeId: r.execEmployeeId,
                        employeeName: r.execName,
                        employeeCode: r.execCode || '',
                        currentSubHodName: r.subHodName || 'Direct to HOD',
                        currentSubDepartmentName: r.subDepartmentName || '',
                        currentDepartmentName: r.departmentName || '',
                        currentHodName: r.hodName || ''
                    });
                }
            });
            bulkExecsMeta = [...map.values()].sort((a,b)=>(a.employeeName||'').localeCompare(b.employeeName||''));
            // Pre-select all since we're moving the whole group
            bulkExecsMeta.forEach(e => bulkSelectedExecIds.add(e.employeeId));
        } else {
            // ASSIGN TEAM mode: show all available executives for creating new teams
            const fromGrid = collectBulkExecRowsFromGrid(hodId, deptId, subDeptId);
            const merged = new Map(fromGrid.map(e => [e.employeeId, e]));

            // Load ALL active executives so new teams can pick from any available executive
            try {
                const r = await api(`${API}/SearchEmployees?roleTypeId=3&isActive=true&pageSize=500`);
                if (r.success) {
                    (r.data || []).forEach(e => {
                        if (!merged.has(e.employeeId)) {
                            merged.set(e.employeeId, {
                                employeeId: e.employeeId,
                                employeeName: e.employeeName,
                                employeeCode: e.employeeCode || '',
                                currentSubHodName: '',
                                currentSubDepartmentName: '',
                                currentDepartmentName: e.primaryDepartmentName || '',
                                currentHodName: ''
                            });
                        }
                    });
                }
            } catch (e) {}

            bulkExecsMeta = [...merged.values()].sort((a,b)=>(a.employeeName||'').localeCompare(b.employeeName||''));
        }

        renderBulkExecList();
    }

    function renderBulkExecList() {
        const el = document.getElementById('bulkExecList');
        if(!bulkExecsMeta.length){
            el.innerHTML = bulkMode === 'reassign'
                ? '<div class="dm-empty">No executives found in this HOD / department / sub-department</div>'
                : '<div class="dm-empty">No executives found</div>';
            updateBulkExecSummary();
            return;
        }
        const rows = getCurrentBulkExecRows();
        el.innerHTML = rows.length
            ? rows.map(e=>{
                const managerLabel = e.currentSubHodName ? `Current SubHOD: ${e.currentSubHodName}` : 'Current manager: Direct to HOD';
                const scopeParts = [e.currentDepartmentName, e.currentSubDepartmentName, e.currentHodName].filter(Boolean);
                return `<label class="bulk-exec-row"><input type="checkbox" class="bulk-exec-check" value="${e.employeeId}" ${bulkSelectedExecIds.has(e.employeeId)?'checked':''} onchange="onBulkExecToggle(${e.employeeId}, this.checked)" /><span class="bulk-exec-meta"><span>${esc(e.employeeName)}</span><small>${esc(e.employeeCode||'')}</small><div class="bulk-exec-hint">${esc(managerLabel)}${scopeParts.length?` - ${esc(scopeParts.join(' / '))}`:''}</div></span></label>`;
            }).join('')
            : '<div class="dm-empty">No executives match search</div>';
        updateBulkExecSummary();
    }

    async function onBulkHodChange() {
        document.getElementById('b_dept').value = '';
        document.getElementById('b_sdept').innerHTML = '<option value="">— None —</option>';
        document.getElementById('b_subhod').innerHTML = '<option value="">— Direct to HOD —</option>';
        document.getElementById('bulkExecList').innerHTML = '<div class="dm-empty">Select department above</div>';
        bulkExecsMeta = [];
        bulkSelectedExecIds = new Set();
        const hodId = parseInt(document.getElementById('b_hod').value) || 0;
        if(!hodId){
            renderDeptOptions('b_dept', deptsMeta);
            updateBulkExecSummary();
            return;
        }
        if (bulkMode === 'reassign') {
            // Change SubHOD mode: only show departments already assigned to this HOD
            try {
                const r = await api(`${API}/GetDepartmentsForHOD/${hodId}`);
                renderDeptOptions('b_dept', r.success ? (r.data || []) : []);
            } catch(e) {
                renderDeptOptions('b_dept', []);
            }
        } else {
            // Assign Team mode: show ALL departments
            renderDeptOptions('b_dept', deptsMeta);
        }
        updateBulkExecSummary();
    }

    async function onBulkDeptChange() {
        const deptId = parseInt(document.getElementById('b_dept').value) || 0;
        await loadSubDepts(deptId, 'b_sdept');
        await renderBulkSubHodOptions();
        await refreshBulkExecutives();
    }

    async function onBulkSubDeptChange() {
        await renderBulkSubHodOptions();
        await refreshBulkExecutives();
    }

    async function submitBulkAssign() {
        showBulkError('');
        const hodId = parseInt(document.getElementById('b_hod').value) || 0;
        const deptId = parseInt(document.getElementById('b_dept').value) || 0;
        const subDeptId = parseInt(document.getElementById('b_sdept').value) || null;
        const subHodId = parseInt(document.getElementById('b_subhod').value) || null;
        const execIds = getSelectedBulkExecIds();
        if(!hodId){ showBulkError('Select a HOD'); return; }
        if(!deptId){ showBulkError('Select a department'); return; }
        if(bulkMode === 'reassign' && !subDeptId){ showBulkError('Select a sub-department'); return; }
        if(bulkMode === 'reassign' && !execIds.length){ showBulkError('Select at least one executive'); return; }
        const btn = document.getElementById('bulkAssignBtn');
        btn.disabled = true; btn.textContent = 'Assigning…';
        try{
            const r = await api(`${API}/BulkAssignTeam`, 'POST', {
                hodEmployeeId: hodId,
                departmentId: deptId,
                subDepartmentId: subDeptId,
                subHodEmployeeId: subHodId,
                executiveEmployeeIds: execIds
            });
            if(r.success){
                const okMsg = bulkMode === 'reassign'
                    ? (r.message || `${execIds.length} executive(s) moved successfully`)
                    : (r.message || 'Team assigned successfully');
                showBulkError(okMsg, 'ok');
                await loadGrid();
                await refreshBulkExecutives();
            }else{
                showBulkError(r.message || 'Bulk assign failed');
            }
        }catch(e){
            showBulkError('Error: ' + e.message);
        }finally{
            btn.disabled = false; btn.textContent = bulkMode === 'assign' ? 'Assign Team' : 'Change SubHOD';
        }
    }




