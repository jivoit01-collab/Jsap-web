                'vehicleNoLogistics': { name: 'Vehicle No', section: 'Logistics', pattern: /^[A-Z]{2}[-\s]?[0-9]{1,2}[-\s]?[A-Z]{1,2}[-\s]?[0-9]{4}$/i },
