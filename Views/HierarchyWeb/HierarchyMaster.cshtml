<script>
    const IS_ADMIN    = @(isAdmin ? "true" : "false");
    const API         = '/api/Hierarchy';
    let allRows=[], deptsMeta=[], hodsMeta=[], bulkExecsMeta=[], bulkSelectedExecIds=new Set(), bulkMode='assign', addLvl=1, pendingXl=[], editCurrentDateOfJoining=null;

    document.addEventListener('DOMContentLoaded', async()=>{
        // Move all overlays to <body> so layout's overflow-x:hidden doesn't trap fixed positioning
        document.querySelectorAll('.hm-modal-overlay').forEach(el => document.body.appendChild(el));
        await Promise.all([loadGrid(), loadDeptsMeta(), loadHodsMeta()]);
    });

    async function loadGrid(){
        setLoad(true);
        try{
            const r = await api(`${API}/GetMasterFlatAdmin`);
            if(!r.success){toast(r.message||'Load failed','err');return;}
            allRows=r.data||[];
            updateStats(); populateDeptFilter(); applyFilters();
        }catch(e){toast('Network error','err');}
        finally{setLoad(false);}
    }
    function setLoad(v){
        document.getElementById('gridLoading').style.display=v?'flex':'none';
        document.getElementById('gridCont').style.display=v?'none':'block';
    }
    function updateStats(){
        const ROLE_PRIORITY = { hod: 3, subhod: 2, exec: 1 };
        const employees = new Map();

        function registerEmployee(id, role, isActive){
            if(!id || id <= 0) return;
            const existing = employees.get(id);
            const next = { role, isActive: !!isActive };
            if(!existing || ROLE_PRIORITY[role] > ROLE_PRIORITY[existing.role]){
                employees.set(id, next);
                return;
            }
            if(existing.role === role){
                existing.isActive = existing.isActive || !!isActive;
            }
        }

        allRows.forEach(r=>{
            registerEmployee(r.hodEmployeeId, 'hod', r.hodIsActive);
            registerEmployee(r.subHodEmployeeId, 'subhod', r.subHodIsActive);
            registerEmployee(r.execEmployeeId, 'exec', r.execIsActive);
        });

        let active = 0, activeH = 0, activeS = 0, activeE = 0;
        employees.forEach(emp => {
            if(!emp.isActive) return;
            active++;
            if(emp.role === 'hod') activeH++;
            else if(emp.role === 'subhod') activeS++;
            else if(emp.role === 'exec') activeE++;
        });

        const inactive = employees.size - active;
        document.getElementById('sTotal').textContent = active;
        document.getElementById('sActive').textContent = active;
        document.getElementById('sInactive').textContent = inactive;
        document.getElementById('sHod').textContent = activeH;
        document.getElementById('sSub').textContent = activeS;
        document.getElementById('sExec').textContent = activeE;
    }

    function renderGrid(rows){
        if(!colVisState) initColVis();
        const adm=IS_ADMIN, salCols=false;
        const allCols = getEffectiveCols(salCols, adm);
        const visCols = allCols.filter(c=>!c.hidden);

        // Build colgroup
        const colgroupHtml = '<colgroup>' + visCols.map(c=>`<col style="width:${c.width}">`).join('') + '</colgroup>';

        // Build group header row (merge consecutive same-group)
        let grpHtml=''; let gi=0;
        while(gi<visCols.length){
            const g=visCols[gi].group, cls=visCols[gi].groupCls;
            let span=1;
            while(gi+span<visCols.length && visCols[gi+span].group===g) span++;
            grpHtml+=`<th class="${cls}" colspan="${span}">${g==='Actions'?'':g}</th>`;
            gi+=span;
        }

        // Build column header row
        const colsHtml = visCols.map(c=>{
            const sticky=c.sticky?' class="sk1"':'';
            return `<th${sticky} style="min-width:${c.minWidth}">${c.label}</th>`;
        }).join('');

        let h=`<table class="hm">${colgroupHtml}<thead><tr class="grp">${grpHtml}</tr><tr class="cols">${colsHtml}</tr></thead><tbody id="gb">`;

        let prevH=null;
        rows.forEach((row,ri)=>{
            const nH=row.hodEmployeeId!==prevH; prevH=row.hodEmployeeId;
            const hasS=(row.subHodEmployeeId>0)||!!(row.subHodName||row.subHodCode||row.subHodDesignation);
            const hasE=(row.execEmployeeId>0)||!!(row.execName||row.execCode||row.execDesignation);
            const leafOk=hasE?row.execIsActive:hasS?row.subHodIsActive:row.hodIsActive;
            const hodEditBtn  = adm?`<button class="btn-icon btn-edit-hod"  onclick="openEdit(${row.hodEmployeeId})"    title="Edit HOD">H</button>` :'';
            const subEditBtn  = adm&&hasS?`<button class="btn-icon btn-edit-sub"  onclick="openEdit(${row.subHodEmployeeId})" title="Edit SubHOD">S</button>`:'';
            const execEditBtn = adm&&hasE?`<button class="btn-icon btn-edit-exec" onclick="openEdit(${row.execEmployeeId})"   title="Edit Exec">E</button>`:'';
            const cellMap={
                hod:`<td class="sk1">${eCell(row.hodName,row.hodCode)}</td>`,
                dept:`<td class="td-wrap">${row.departmentName?`<span class="dept-badge">${esc(row.departmentName)}</span>`:'<span class="cell-empty">—</span>'}</td>`,
                subDept:`<td class="td-wrap">${row.subDepartmentName?`<span class="subdept-text">${esc(row.subDepartmentName)}</span>`:'<span class="cell-empty">—</span>'}</td>`,
                subHod:`<td>${hasS?eCell(row.subHodName,row.subHodCode):'<span class="cell-empty">—</span>'}</td>`,
                subHodDesig:`<td>${row.subHodDesignation&&hasS?`<span class="desig-text">${esc(row.subHodDesignation)}</span>`:'<span class="cell-empty">—</span>'}</td>`,
                exec:`<td>${hasE?eCell(row.execName,row.execCode):'<span class="cell-empty">—</span>'}</td>`,
                execDesig:`<td>${row.execDesignation&&hasE?`<span class="desig-text">${esc(row.execDesignation)}</span>`:'<span class="cell-empty">—</span>'}</td>`,
                status:`<td>${leafOk?'<span class="status-dot active">Active</span>':'<span class="status-dot inactive">Inactive</span>'}</td>`,
                actions:adm?`<td><div class="act-cell">${hodEditBtn}${subEditBtn}${execEditBtn}</div></td>`:'',
            };
            h+=`<tr data-hod="${row.hodEmployeeId}" class="${nH?'hod-border':''}">${visCols.map(c=>cellMap[c.key]||'<td></td>').join('')}</tr>`;
        });
        h+=`</tbody></table>`;
        document.getElementById('gridCont').innerHTML=h;
        document.getElementById('rowCount').textContent=`${rows.length} rows`;
    }

    function eCell(n,c){
        const hasName=!!(n&&String(n).trim());
        const hasCode=!!(c&&String(c).trim());
        if(!hasName && !hasCode)return`<span class="cell-empty">—</span>`;
        const isTemp = hasCode && String(c).toUpperCase().startsWith('TEMP');
        const codeClass = isTemp ? 'emp-code temp-code' : 'emp-code';
        if(!hasName && hasCode){
            return`<div class="emp-cell"><span class="${codeClass}">${esc(c)}</span></div>`;
        }
        return`<div class="emp-cell"><span class="emp-name">${esc(n)}</span>${hasCode?`<span class="${codeClass}">${esc(c)}</span>`:''}</div>`;
    }
    function startEdit(td){
        if(td.classList.contains('editing'))return;
        document.querySelectorAll('td.editing').forEach(e=>cancelEdit(e));
        const ri=parseInt(td.dataset.ri), field=td.dataset.field, empId=parseInt(td.dataset.empid);
        const row=allRows[ri]; const val=row[field]||'';
        td.classList.add('editing');
        td.innerHTML=`<input type="text" value="${esc(val)}" />`;
        const inp=td.querySelector('input'); inp.focus(); inp.select();
        inp.addEventListener('blur',()=>commitEdit(td,empId,field,ri,inp));
        inp.addEventListener('keydown',e=>{
            if(e.key==='Enter'){e.preventDefault();inp.blur();}
            if(e.key==='Escape'){e.preventDefault();cancelEdit(td,ri,field);}
        });
    }
    function cancelEdit(td,ri,field){
        td.classList.remove('editing');
        if(ri!==undefined){
            const row=allRows[ri]; const val=row[field]||'';
            if(field.includes('Name')) td.innerHTML=eCell(val,row[field.replace('Name','Code')]);
            else td.innerHTML=val?`<span class="desig-text">${esc(val)}</span>`:`<span class="cell-empty">—</span>`;
        }
    }
    async function commitEdit(td,empId,field,ri,inp){
        const nv=inp.value.trim(), row=allRows[ri];
        td.classList.remove('editing');
        const pfx=field.startsWith('hod')?'hod':field.startsWith('subHod')?'subHod':'exec';
        const payload={
            employeeId:empId, employeeName:row[`${pfx}Name`]||'',
            designation:row[`${pfx}Designation`]||null,
            dateOfJoining:row[`${pfx}DateOfJoining`]||null, isActive:row[`${pfx}IsActive`]??true
        };
        if(field.includes('Name')) payload.employeeName=nv;
        else if(field.includes('Desig')) payload.designation=nv||null;
        row[field]=nv;
        if(field.includes('Name')) td.innerHTML=eCell(nv,row[field.replace('Name','Code')]);
        else td.innerHTML=nv?`<span class="desig-text">${esc(nv)}</span>`:`<span class="cell-empty">—</span>`;
        td.classList.add('saving');
        try{
            const res=await api(`${API}/UpdateEmployeeBasic`,'POST',payload);
            td.classList.remove('saving');
            if(res.success){td.classList.add('save-ok');setTimeout(()=>td.classList.remove('save-ok'),600);}
            else{td.classList.add('save-err');setTimeout(()=>td.classList.remove('save-err'),600);toast('Save failed: '+res.message,'err');}
        }catch(e){td.classList.remove('saving');td.classList.add('save-err');setTimeout(()=>td.classList.remove('save-err'),600);toast('Network error','err');}
    }

    function applyFilters(){
