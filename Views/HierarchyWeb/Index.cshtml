            function v2_cellHod(h,st){ var isAct=st.expanded||st.selDept||Object.keys(st.selSD||{}).length>0;var c=h.color;var style='background:'+c.bg+';border-color:'+(isAct?c.border:'#e2e8f0')+';'+(isAct?'box-shadow:0 2px 8px '+c.border+'30;':'');var r='<td><div class="cell" style="'+style+'"><div class="cell-row"><span class="cell-name" style="color:'+c.text+'" onclick="v2_clickHod('+h.idx+',event)">'+esc(h.name)+'</span><span class="cell-info-btn" onclick="v2_showHodInfo('+h.idx+',event)"><i class="bi bi-info-circle"></i></span><span class="cell-badge" style="background:'+c.badge+'" onclick="v2_clickHod('+h.idx+',event)">'+h.depts.length+'</span></div>';if(SHOW_SAL&&h.sal)r+='<div class="cell-sal">₹'+fmtN(h.sal)+'</div>';return r+'</div></td>'; }
