        function selectPurchaseOrders() {
            const selectedCheckboxes = document.querySelectorAll(".po-row-checkbox:checked");

            if (selectedCheckboxes.length === 0) {
                showAlert('Please select at least one Purchase Order', 'warning');
                return;
            }

            const selectedLineItems = [];
            let selectedCardName = '';
            let selectedPONumbers = [];

            selectedCheckboxes.forEach(checkbox => {
                const docEntry = checkbox.getAttribute('data-docentry');
                const docNum = checkbox.getAttribute('data-docnum');

                const selectedPO = fullPOData.find(po => po.docEntry.toString() === docEntry);

                if (selectedPO) {
                    if (!selectedCardName) {
                        selectedCardName = selectedPO.cardName;
                    }

                    if (selectedPO.docNum) {
                        selectedPONumbers.push(selectedPO.docNum);
                    }

                    if (selectedPO.documentLines && selectedPO.documentLines.length > 0) {
                        selectedPO.documentLines.forEach(line => {
                            const lineItem = {
                                docEntry: selectedPO.docEntry,
                                docNum: selectedPO.docNum,
                                cardName: selectedPO.cardName,
                                lineNum: line.lineNum,
                                itemCode: line.itemCode || '',
                                itemDescription: line.itemDescription || '',
                                quantity: line.quantity || 0,
                                remainingOpenQuantity: line.remainingOpenQuantity || 0,
                                measureUnit: line.measureUnit || 'PCS',
                                remarks: line.u_Remarks || '',
                                rate: line.rate || 0,
                                lineTotal: line.lineTotal || 0
                            };
                            selectedLineItems.push(lineItem);
                        });
                    }
                }
            });

            if (selectedLineItems.length === 0) {
                showAlert('No line items found in selected Purchase Orders', 'warning');
                return;
            }

            if (selectedCardName) {
                const cardNameField = document.getElementById('cardName');
                if (cardNameField) {
                    cardNameField.value = selectedCardName.toUpperCase();
                    ValidationManager.clearFieldError('cardName');
                }
            }

            if (selectedPONumbers.length > 0) {
                const poNumberField = document.getElementById('poNumber');
                const poNumberGroup = document.getElementById('poNumberGroup');

                if (poNumberField && poNumberGroup) {
                    poNumberGroup.style.display = 'block';
                    poNumberField.value = selectedPONumbers.join(', ').toUpperCase();
                }
            }

            populateContentsTableFromLineItems(selectedLineItems);
            closeModal('poPopupModal');
            switchTab('contents', document.querySelector('.tab'));
        }

