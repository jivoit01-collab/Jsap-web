                return h+'</div>';
            }
            function v1_buildDept(hod,dName,di){ var salesTree=getSalesTreeForDept(hod,dName);if(salesTree)return v1_buildSalesDept(hod,salesTree,di);var nid='dept-'+hod.idx+'-'+di,isExp=!!v1_exp[nid];var subs=hod.subs.filter(function(s){return s.dept===dName||(s.dept===''&&di===0);});var h='<div class="branch" data-node-id="'+nid+'" data-parent-id="'+hod.id+'">';h+=v1_card({id:nid,type:'dept',name:dName,c:hod.color.badge,stats:[{ic:'bi-buildings',v:subs.length,lb:'Sub-Depts'}],sal:null,hasKids:subs.length>0});if(isExp&&subs.length){h+='<div class="children-row">';subs.forEach(function(s){h+=v1_buildSD(hod,s,nid);});h+='</div>';}return h+'</div>'; }
            function v1_buildSD(hod,s,parId){ var nid='sd-'+hod.idx+'-'+s.idx,isExp=!!v1_exp[nid];var hasSubHods=(s.subHods&&s.subHods.length>0),hasDirectEx=s.execs.length>0,hasKids=hasSubHods||hasDirectEx;var totalEx=(hasSubHods?s.subHods.reduce(function(a,sh){return a+sh.execs.length;},0):0)+s.execs.length;var h='<div class="branch" data-node-id="'+nid+'" data-parent-id="'+parId+'">';h+=v1_card({id:nid,type:'subdept',name:s.sdName,c:hod.color.badge,stats:[{ic:'bi-person-badge',v:s.subHods?s.subHods.length:0,lb:'Sub-HOD'},{ic:'bi-person',v:totalEx,lb:'Execs'}],sal:null,hasKids:hasKids});if(isExp&&hasKids){h+='<div class="children-row">';if(hasSubHods){s.subHods.forEach(function(sh,shi){h+=v1_buildSH(hod,s,sh,shi,nid);});}if(hasDirectEx){s.execs.forEach(function(ex,ei){h+=v1_buildEx(hod,s,ex,ei,nid,null);});}if(!hasSubHods&&!hasDirectEx){}h+='</div>';}return h+'</div>'; }
            function v1_buildSH(hod,s,sh,shi,parId){ var nid='sh-'+hod.idx+'-'+s.idx+'-'+shi,isExp=!!v1_exp[nid];var shExecs=sh.execs||[];var h='<div class="branch" data-node-id="'+nid+'" data-parent-id="'+parId+'">';h+=v1_card({id:nid,type:'subhod',name:sh.name,c:hod.color.badge,stats:[{ic:'bi-people',v:shExecs.length,lb:'Execs'}],sal:SHOW_SAL?sh.sal:null,hasKids:shExecs.length>0});if(isExp&&shExecs.length){h+='<div class="children-row">';shExecs.forEach(function(ex,ei){h+=v1_buildEx(hod,s,ex,ei,nid,shi);});h+='</div>';}return h+'</div>'; }
