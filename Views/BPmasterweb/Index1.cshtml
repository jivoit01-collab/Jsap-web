            }

            if (shippingGST) {
                shippingGST.addEventListener('input', function() {
                    validateGSTNumber('shipping');
                });

                shippingGST.addEventListener('blur', function() {
                    validateGSTNumber('shipping');
                });
            }
        }

        function validateGSTNumber(addressType) {
            const gstField = document.getElementById(addressType + '-gst');
            const stateSelect = document.getElementById(addressType + '-state');
            const gstError = document.getElementById(addressType + '-gst-error');

            if (!gstField || !stateSelect || !gstError) return;

            const gstNumber = gstField.value.trim().toUpperCase();
            const stateCode = stateSelect.value;

            // Reset previous state
            clearGSTValidation(addressType);

            // If GST field is empty, no validation needed
            if (!gstNumber) {
                return;
            }

            // Basic GST format validation (15 characters)
            if (gstNumber.length !== 15) {
                showGSTError(addressType, 'GST number must be exactly 15 characters');
                return;
            }

            // Basic GST pattern validation
            const gstPattern = /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}[Z]{1}[0-9A-Z]{1}$/;
            if (!gstPattern.test(gstNumber)) {
                showGSTError(addressType, 'Invalid GST number format');
                return;
            }

            // If state is not selected, ask user to select state first
            if (!stateCode) {
                showGSTError(addressType, 'Please select state first to validate GST number');
                return;
            }

            // Validate GST with state code
            validateGSTWithState(addressType, gstNumber, stateCode);
        }

        function validateGSTWithState(addressType, gstNumber, stateCode) {
            const gstError = document.getElementById(addressType + '-gst-error');
            const gstField = document.getElementById(addressType + '-gst');

            // Show loading state
            if (gstError) {
                gstError.textContent = 'Validating GST...';
                gstError.style.color = '#007bff';
                gstError.style.display = 'block';
            }

            fetch(`/api/BPmaster/GetGSTMismatchByState?company=${companyId}&stateCode=${stateCode}`)
                .then(response => {
                    if (!response.ok) throw new Error('Failed to fetch GST validation data');
                    return response.json();
                })
                .then(data => {
                    if (data.success && data.data && data.data.length > 0) {
                        const stateGSTCode = data.data[0].gstCode;
                        const inputGSTCode = gstNumber.substring(0, 2);

                        if (inputGSTCode === stateGSTCode) {
                            // GST is valid
                            showGSTSuccess(addressType, '✓ GST number is valid for selected state');
                        } else {
                            // GST code mismatch
                            showGSTError(addressType, `GST code mismatch. Expected: ${stateGSTCode}, Got: ${inputGSTCode}`);
                        }
                    } else {
                        showGSTError(addressType, 'Unable to validate GST for selected state');
                    }
                })
                .catch(error => {
                    console.error('GST validation error:', error);
                    showGSTError(addressType, 'Error validating GST number. Please try again.');
                });
        }

