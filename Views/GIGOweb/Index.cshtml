        // All business partner and PO functions remain the same...
        function loadBusinessPartners() {
            if (isLoadingBP) return;

            const cardType = document.getElementById('cardType').value;
            const selectedCompany = getSelectedCompany();

            if (!cardType) {
                console.log('No card type selected');
                return;
            }

            if (!selectedCompany) {
                console.log('No company selected');
                showAlert('Please select a company first', 'error');
                return;
            }

            isLoadingBP = true;

            // Show loading overlay with your existing CSS classes
            showBPLoadingOverlay(`Loading business partners for ${cardType} in selected company...`);
            showBPLoadingState(true); // Keep the existing input loading state too

            fetch(`/api/AdvanceRequest/GetBusinessPartners?company=${encodeURIComponent(selectedCompany)}&type=${encodeURIComponent(cardType)}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(res => {
                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                }
                return res.json();
            })
            .then(data => {
                bpList = data || [];
                setupOmnisearch();
                isLoadingBP = false;
                showBPLoadingState(false);
                hideBPLoadingOverlay(); // Hide the overlay
                console.log(`Loaded ${bpList.length} Business Partners for ${cardType}`);

                // Show success message
                if (bpList.length > 0) {
                    showAlert(`Successfully loaded ${bpList.length} business partners`, 'success');
                } else {
                    showAlert('No business partners found for selected criteria', 'warning');
                }
            })
            .catch(err => {
                isLoadingBP = false;
                showBPLoadingState(false);
                hideBPLoadingOverlay(); // Hide the overlay on error
                console.error('Error loading Business Partners:', err);
                showAlert(`Failed to load Business Partners: ${err.message}`, 'error');
                bpList = [];
            });
        }

