                        <input type="file" name="reject_attachments_${index}" id="reject_attachments_${index}" multiple onchange="previewRejectFiles(${index})" hidden />
                    </label>
                    <div id="reject_preview_${index}" class="attachment-icons" style="margin-top: 6px;"></div>
                </td>
            </tr>
        `;
    }).join('');

    tbody.innerHTML = rows;
}

