@{
    ViewData["Title"] = "InvoicePaymentPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .details-row {
    background-color: #f8f9fa;
}

.details-row td {
    padding: 10px !important;
}
a {
    cursor: pointer;
}
    #suggestionBox {
        position: absolute;
        top: 70px;
        width: 100%;
        background: white;
        /*border: 1px solid #ccc;*/
        z-index: 1000;
    }

    .suggest-item {
        padding: 8px;
        cursor: pointer;
    }

        .suggest-item:hover {
            background: #f1f1f1;
        }
       .soft-badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    display: inline-block;
}

.badge-approved {
    background: rgba(25, 135, 84, 0.1);
    color: #198754;
    border: 1px solid rgba(25, 135, 84, 0.2);
}

.badge-rejected {
    background: rgba(220, 53, 69, 0.1);
    color: #dc3545;
    border: 1px solid rgba(220, 53, 69, 0.2);
}

.badge-pending {
    background: rgba(255, 193, 7, 0.15);
    color: #b8860b;
    border: 1px solid rgba(255, 193, 7, 0.3);
}
</style>
<div id="pdfContainer" class="bill-ui" style="display:none; background:#fff; padding:10px; border-radius:8px;">
    <button onclick="closePdf()" class="btn btn-secondary btn-sm mb-2">
        Back
    </button>
    <iframe id="pdfFrame" style="width:100%; height:80vh; border:none;"></iframe>
</div>
<div class="bill-ui">
<div class="container-fluid mt-4">

    <h3 class="page-title">Bill Verification - Invoice Payment</h3>
    


<div class="container-fluid mt-3">

    <!-- FILTER -->
    <div class="card p-3 mb-3">
        <div class="row">
            <div class="col-md-3">
                <label for="fromDate">From Date</label>
                <input type="date" id="fromDate" class="form-control" />
            </div>

            <div class="col-md-3">
                <label for="toDate">To Date</label>
                <input type="date" id="toDate" class="form-control" />
            </div>

            <div class="col-md-4">
                <label for="accountName">Account Name</label>
                <input type="text" id="accountName" class="form-control" placeholder="Search Account" autocomplete="off" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button id="searchBtn" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    <div class="card p-3">
        <h5 class="mb-3">Invoice Monitoring</h5>

        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                
                <!-- HEADER -->
                <thead>
                    <tr>
                        <th>Account</th>
                        <th>Voucher</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Supplier Ref</th>
                         <th>Ref Date</th>
                        <th>Due Date</th>
                        <th>Attachment</th>
                        <th>Maker Remark</th>
                        <th>Checker Remark</th>
                        <th>Checker Status</th>
                        <th>Payment Status</th>

                    </tr>
                </thead>

                <!-- BODY -->
                <tbody id="PaymentTable">
                    <tr class="empty-row">
                        <td colspan="12" class="text-center">Select filters and click Search to view approved unpaid bills.</td>
                    </tr>
                </tbody>

            </table>
        </div>
    </div>

</div>
</div>
</div>

<!-- jQuery already loaded in _Layout.cshtml -->


<script>
//------------------------------------
// LOAD DATA
//------------------------------------
function loadData() {
    let fromDate = $("#fromDate").val();
    let toDate = $("#toDate").val();
    let accountName = $("#accountName").val().trim() || null;

    if (fromDate && toDate && fromDate > toDate) {
        $("#PaymentTable").html(`<tr class="empty-row"><td colspan="12" class="text-center text-danger">From Date cannot be greater than To Date.</td></tr>`);
        return;
    }

    $("#PaymentTable").html(`<tr class="empty-row"><td colspan="12" class="text-center">Loading bills...</td></tr>`);

    $.ajax({
        url: "/InvoicePayment/GetBillDetails",
        method: "GET",
        data: {
            fromDate: fromDate || null,
            toDate: toDate || null,
            accountName: accountName
        },
        timeout: 120000,
        success: function (data) {
        renderTable(data || []);
        },
        error: function () {
        $("#PaymentTable").html(`<tr class="empty-row"><td colspan="12" class="text-center text-danger">Error loading bills. Please try again.</td></tr>`);
        }
    });
}

//------------------------------------
// RENDER TABLE
//------------------------------------
function renderTable(data) {

    if (!data || data.length === 0) {
        $("#PaymentTable").html(`<tr class="empty-row"><td colspan="12" class="text-center">No bills found for the selected filters.</td></tr>`);
        return;
    }

    let html = "";

    let approvedData = data.filter(item => 
    normalizeStatus(item.checkerStatus, "") === "approved" && 
    isUnpaidStatus(item.paymentStatus)
);
   if (approvedData.length === 0) {
    $("#PaymentTable").html(`<tr class="empty-row"><td colspan="12" class="text-center">No approved unpaid bills found.</td></tr>`);
    return;
}

    approvedData.forEach(item => {

        let checkerBadge = `<span class="badge bg-success">Approved</span>`;

        let paymentBadge = normalizeStatus(item.paymentStatus, "UnPaid") === "paid"
            ? `<span class="badge bg-success">Paid</span>`
            : `<span class="badge bg-warning text-dark">UnPaid</span>`;

     let attachHtml =
    item.attachmentPath
        ? `<a href="#" onclick="openPdf('${item.attachmentPath}')" class="btn btn-sm btn-outline-primary">View</a>`
        : `<span class="text-muted">No File</span>`;

        html += `
        <tr>
            <td>${item.accountName ?? ""}</td>
            <td>${item.vchNumber ?? ""}</td>
            <td>${formatDate(item.voucherDate)}</td>
            <td>${item.billAmount ?? ""}</td>
            <td>${item.supplierRef || '-'}</td>
             <td>${formatDate(item.supplierRefDate)}</td>
            <td>${formatDate(item.dueDate)}</td>
            
            <td>${attachHtml}</td>
            <td>${item.makerRemark ?? "-"}</td>
            <td>${item.checkerRemark ?? "-"}</td>
            <td>${checkerBadge}</td>
            <td>${paymentBadge}</td>
        </tr>`;
    });

    $("#PaymentTable").html(html);
}

function normalizeStatus(value, fallback) {
    return (value || fallback || "").toString().trim().toLowerCase().replace(/\s+/g, "");
}

function isUnpaidStatus(value) {
    const status = normalizeStatus(value, "UnPaid");
    return status === "unpaid" || status === "pending" || status === "";
}

//------------------------------------
// DATE FORMAT
//------------------------------------
    function formatDate(dateString) {
    if (!dateString || dateString === "-") return "-";
    let d = new Date(dateString);
    if (isNaN(d)) return "-";
    return d.toISOString().split('T')[0];
    }
/// open pdf
function openPdf(path) {
    document.getElementById("pdfFrame").src = path;
    document.getElementById("pdfContainer").style.display = "block";
    window.scrollTo({ top: 0, behavior: "smooth" });
}

function closePdf() {
    document.getElementById("pdfContainer").style.display = "none";
    document.getElementById("pdfFrame").src = "";
}

//------------------------------------
// SEARCH BUTTON & INIT
//------------------------------------
$("#searchBtn").click(loadData);

$(document).ready(function () {
    loadData();
});


</script>


