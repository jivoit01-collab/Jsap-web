        // IMPROVED: Better handling of empty data response
        async function getItemStockDetails(itemCode = null, selectedWarehouse = null) {
            if (!validateCompanyId()) return null;
            const companyId = getCompanyId();

            let warehousesToQuery = '';
            if (selectedWarehouse) {
                warehousesToQuery = selectedWarehouse;
            } else {
                warehousesToQuery = selectedItems.warehouse.map(w => w.code).join(',');
            }

            const selectedItemGroups = selectedItems.itemgroup.map(g => g.code).join(',');
            const selectedSubGroups = selectedItems.subgroup.map(s => s.code).join(',');
            const selectedLocation = selectedItems.location ? String(selectedItems.location.code) : '';
            const selectedUnit = selectedItems.unit ? String(selectedItems.unit.code) : '';

            const requestData = {
                p_warehouses: String(warehousesToQuery),
                p_units: String(selectedUnit),
                p_itemGroups: String(selectedItemGroups),
                p_subGroups: String(selectedSubGroups),
                p_Locations: String(selectedLocation),
                p_ItemCodes: String(itemCode || ''),
                company: parseInt(companyId)
            };

            try {
                console.log(`🔍 Getting stock details for item ${itemCode || 'ALL'}:`, requestData);
                const response = await apiCallPost('/api/InventoryAudit/GetItemStockDetails', requestData);
                console.log('📦 Stock details API response:', response);

                // Check if response has data
                if (response && response.success && response.data && response.data.length > 0) {
                    const sortedData = response.data.sort((a, b) =>
                        parseFloat(b.onHand || 0) - parseFloat(a.onHand || 0)
                    );
                    console.log(`✅ Found ${sortedData.length} warehouse entries with stock`);
                    return {
                        isEmpty: false,
                        warehouseEntries: sortedData,
                        totalOnHand: sortedData.reduce((sum, entry) => sum + parseFloat(entry.onHand || 0), 0)
                    };
                }

                // IMPORTANT: Check for success with empty data array
                if (itemCode && response && response.success && Array.isArray(response.data) && response.data.length === 0) {
                    console.log('⚠️ API returned {success: true, data: []} - Trying fallback API...');
                    return await getItemDetailsFallback(itemCode);
                }

                console.warn(`⚠️ No stock data found for the given parameters`);
                return { isEmpty: true, warehouseEntries: [], totalOnHand: 0 };
            } catch (error) {
                console.error(`❌ Failed to get stock details:`, error);

                if (itemCode) {
                    console.log('🔄 First API failed, trying fallback API...');
                    return await getItemDetailsFallback(itemCode);
                }

                return { isEmpty: true, warehouseEntries: [], totalOnHand: 0 };
            }
        }

        async function getItemDetailsFallback(itemCode) {
            if (!validateCompanyId()) return { isEmpty: true, warehouseEntries: [], totalOnHand: 0 };
            const companyId = getCompanyId();
            const UserId = getUserId();

            const selectedLocation = selectedItems.location ? String(selectedItems.location.code) : '';
            const selectedUnit = selectedItems.unit ? String(selectedItems.unit.code) : '';

            const fallbackRequestData = {
                p_warehouses: "",
                p_units: String(selectedUnit),
                p_itemGroups: "",
                p_subGroups: "",
                p_Locations: "",
                p_ItemCodes: String(itemCode),
                company: parseInt(companyId)
            };

            try {
                console.log(`🔄 Fallback API call for item ${itemCode}:`, fallbackRequestData);
                const response = await apiCallPost('/api/InventoryAudit/GetItemStockDetails', fallbackRequestData);
                console.log('📋 Fallback API response:', response);

                // ✅ CHECK FOR EMPTY DATA ARRAY
                if (response && response.success && Array.isArray(response.data) && response.data.length === 0) {
                    console.warn(`⚠️ Item ${itemCode} not found in any warehouse`);
                    return {
                        isEmpty: true,
                        warehouseEntries: [],
                        totalOnHand: 0,
                        notFound: true  // ✅ Add flag for not found
                    };
                }

                if (response && response.success && response.data && response.data.length > 0) {
                    const firstItem = response.data[0];

                    const itemDetails = {
                        itemCode: firstItem.itemCode || itemCode,
                        itemName: firstItem.itemName || 'N/A',
                        u_Sub_Group: firstItem.u_Sub_Group || '',
                        itmsGrpCod: firstItem.itmsGrpCod || '',
                        itmsGrpNam: firstItem.itmsGrpNam || '',
                        onHand: parseFloat(firstItem.onHand || 0),
                        stockValue: parseFloat(firstItem.stockValue || 0),
                        UserId : UserId,
                        isLitre : firstItem.u_IsLitre,
                        salPackUn : firstItem.salPackUn  // ✅ Keep consistent naming
                    };

                    const availableWarehouses = response.data.map(item => ({
                        code: item.warehouse,
                        name: item.warehouse,
                        onHand: parseFloat(item.onHand || 0),
                        stockValue: parseFloat(item.stockValue || 0)
                    }));

                    console.log('✅ Extracted item details from fallback API:', itemDetails);
                    console.log('✅ Available warehouses from API:', availableWarehouses);

                    return {
                        isEmpty: false,
                        warehouseEntries: [],
                        totalOnHand: 0,
                        itemDetails: itemDetails,
                        availableWarehouses: availableWarehouses,
                        requiresWarehouseSelection: true
                    };
                }

                console.warn(`⚠️ Fallback API also returned no data for item ${itemCode}`);
                return { isEmpty: true, warehouseEntries: [], totalOnHand: 0, notFound: true };
            } catch (error) {
                console.error(`❌ Fallback API failed for item ${itemCode}:`, error);
                return { isEmpty: true, warehouseEntries: [], totalOnHand: 0 };
            }
        }

        async function processAddItem() {
            if (isReadOnlySession) { showTemporaryMessage('Session is closed. Adding items is disabled.', 'info'); return; }
            console.log('\n=== 🚀 PROCESS ADD ITEM STARTED ===');

            const searchInput = document.getElementById('itemSearchInput');
            const quantityInput = document.getElementById('physicalQuantityInput');

            const itemCode = searchInput.getAttribute('data-selected-item-code');
            const searchQuery = searchInput.value.trim();
            const physicalQuantity = parseFloat(quantityInput.value) || 0;

            console.log('📝 Step 1 - Input Values:');
            console.log('  - Selected Item Code:', itemCode);
            console.log('  - Search Display:', searchQuery);
            console.log('  - Physical Quantity:', physicalQuantity);

            if (!itemCode || !searchQuery) {
                console.error('❌ VALIDATION FAILED: No item selected');
                alert('Please search for an item first');
                searchInput.focus();
                return;
            }

            if (physicalQuantity <= 0) {
                console.error('❌ VALIDATION FAILED: Invalid quantity');
                alert('Please enter a valid physical quantity');
                quantityInput.focus();
                return;
            }

            console.log('✅ Step 2 - Basic validation passed');

            const selectedItem = omniSearchItems.find(item =>
                item.itemCode.toLowerCase() === itemCode.toLowerCase()
            );

            if (!selectedItem) {
                console.error('❌ VALIDATION FAILED: Item not found in omniSearchItems');
                alert('Please select a valid item from the search dropdown');
                searchInput.focus();
                return;
            }

            console.log('✅ Step 3 - Item found in omniSearchItems:', selectedItem);

            const addButton = document.getElementById('addItemButton');
            addButton.textContent = 'Adding...';
            addButton.disabled = true;

            try {
                console.log('📞 Step 4 - Calling getItemStockDetails...');

                if (tableItems.length === 0) {
                    await loadGlobalStockData();
                }

                console.log('🔍 Step 5 - Getting stock details for item:', itemCode);
                const stockDetails = await getItemStockDetails(itemCode);
                console.log('📦 Step 6 - Stock details received:', stockDetails);

                // ✅ CHECK IF ITEM NOT FOUND
                if (stockDetails.isEmpty && stockDetails.notFound) {
                    alert(`Item ${itemCode} is not available in the system.`);

                    // ✅ CLEAR INPUTS AND RESET
                    searchInput.value = '';
                    searchInput.removeAttribute('data-selected-item-code');
                    quantityInput.value = '';
                    hideSearchDropdown();

                    addButton.textContent = '+ Add Item';
                    addButton.disabled = false;

                    searchInput.focus();
                    return;
                }

                // Stock found with warehouse entries
                if (!stockDetails.isEmpty && stockDetails.warehouseEntries && stockDetails.warehouseEntries.length > 0) {
                    console.log('✅ Step 7 - Stock found with warehouse entries, adding directly');
                    await addItemWithStockDetails(selectedItem, physicalQuantity, stockDetails);

                    searchInput.value = '';
                    searchInput.removeAttribute('data-selected-item-code');
                    quantityInput.value = '';
                    hideSearchDropdown();

                    console.log('✅ Step 8 - Item added successfully with stock details');
                }
                // Item found but needs warehouse selection
                else if (!stockDetails.isEmpty && stockDetails.requiresWarehouseSelection && stockDetails.itemDetails) {
                    console.log('🔔 Step 7 - Item found but requires warehouse selection, showing modal');
                    showCountParametersModalWithItemDetails(
                        selectedItem,
                        physicalQuantity,
                        stockDetails.itemDetails,
                        stockDetails.availableWarehouses
                    );
                    console.log('✅ Step 8 - Warehouse selection modal displayed');
                    return; // Don't clear inputs yet - user needs to complete modal
                }
                // No stock found anywhere
                else {
                    console.log('⚠️ Step 7 - No stock found, creating entries from count parameters');
                    await createItemEntriesFromCountParameters(selectedItem, physicalQuantity, stockDetails);

                    searchInput.value = '';
                    searchInput.removeAttribute('data-selected-item-code');
                    quantityInput.value = '';
                    hideSearchDropdown();

                    console.log('✅ Step 8 - Item added with count parameter warehouses');
                }

            } catch (error) {
                console.error('❌ ERROR in processAddItem:', error);
                alert('Error adding item: ' + error.message);
            } finally {
                addButton.textContent = '+ Add Item';
                addButton.disabled = false;
                console.log('🏁 Step 9 - Process Close, button restored');
            }
        }

