    <script>
            /* ═══════════════════════════════════════════════════════════════
               EMPLOYEE HIERARCHY — 3 CHANGES APPLIED:
                 CHANGE #1: Checkbox / compare feature REMOVED from V1 tree
                 CHANGE #2: Drag-to-pan on #v1Outer (no scrollbar needed)
                 CHANGE #3: Search nav collapses ALL nodes, expands only path
            ═══════════════════════════════════════════════════════════════ */

            var SHOW_SAL_PERM = @(canViewSalary ? "true" : "false");
            var OWNER_NAME    = "@(ViewBag.OwnerName ?? "Director")";
            var RAW_DATA      = [];
            var SUMMARY_COUNTS = {
                hodCount: @(Model?.TotalHODs ?? 0),
                subHodCount: @(Model?.TotalSubHODs ?? 0),
                execCount: @(Model?.TotalExecutives ?? 0),
                totalEmployees: @(Model?.TotalEmployees ?? 0)
            };
            var SHOW_SAL      = false;
            var ACTIVE_TAB    = 'v1';
            var BASE_RAW_DATA = [];   // original hierarchy (no sales)
            var SALES_RAW_DATA= [];   // sales HOD nodes
            var SHOW_SALES    = false;
            var SAL_AFTER_OPEN= false;
            var SALES_DESIG_SUMMARY = [];
            var SALES_DUPLICATES = [];
            var SALES_DEPT_NAME = 'Frontend Sales';
            
            var HOD_COLORS = [
                {bg:'#dbeafe',border:'#2563eb',text:'#1e3a8a',badge:'#1d4ed8',light:'#eff6ff'},
                {bg:'#fde68a',border:'#d97706',text:'#78350f',badge:'#b45309',light:'#fffbeb'},
