            document.getElementById('searchInput').value = '';
            filterTable();
            document.getElementById('searchInput').focus();
        }

        function clearAllDataSearch() {
            document.getElementById('allDataSearchInput').value = '';
            currentStatusFilter = '';
            resetStatusButtons();
            filterAllDataTable();
            document.getElementById('allDataSearchInput').focus();
