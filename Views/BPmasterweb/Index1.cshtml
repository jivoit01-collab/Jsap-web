        }

        function saveEditedAddress(fullName) {
            if (!editingAddressRow) return;

            const billing = getBillingAddress();
            const billAddress = formatAddressWithGST(billing);
                const billAddressId = generateAddressId(billing.state, fullName);

                const sameAsBilling = document.getElementById("same-as-billing").checked;
            let shipAddress = "Same as Billing";
            let shipAddressId = billAddressId;

            if (!sameAsBilling) {
                const shipping = getShippingAddress();
                shipAddress = formatAddressWithGST(shipping);
                    shipAddressId = generateAddressId(shipping.state, fullName);
                }

            editingAddressRow.cells[0].textContent = billAddress;
            editingAddressRow.cells[1].textContent = billAddressId;
            editingAddressRow.cells[2].textContent = shipAddress;
            editingAddressRow.cells[3].textContent = shipAddressId;

            resetAddressForm();
            document.getElementById("address-edit-actions").style.display = "none";
            editingAddressRow = null;
        }
        function cancelEditAddress() {
            resetAddressForm();
            document.getElementById("address-edit-actions").style.display = "none";
            editingAddressRow = null;
        }

                function parseAddressString(addressString) {
            const parts = addressString.split(',').map(p => p.trim());

            return {
                line1: parts[0] || '',
                line2: parts[1] || '',
                city: parts[2] || '',
                state: parts[3] || '',
                country: parts[4] || '',
                zip: parts[5] || '',
                gst: parts[6] || ''
            };
        }
            function getBillingAddress() {
            return {
                line1: document.getElementById('billing-address1').value.trim(),
                line2: document.getElementById('billing-address2').value.trim(),
                city: document.getElementById('billing-city').value.trim(),
                state: document.getElementById('billing-state').value.trim(),
                country: document.getElementById('billing-country').value.trim(),
                zip: document.getElementById('billing-zip').value.trim(),
                gst: document.getElementById('billing-gst').value.trim()
            };
        }

        function getShippingAddress() {
            return {
                line1: document.getElementById('shipping-address1').value.trim(),
                line2: document.getElementById('shipping-address2').value.trim(),
                city: document.getElementById('shipping-city').value.trim(),
                state: document.getElementById('shipping-state').value.trim(),
                country: document.getElementById('shipping-country').value.trim(),
                zip: document.getElementById('shipping-zip').value.trim(),
                gst: document.getElementById('shipping-gst').value.trim()
            };
        }

