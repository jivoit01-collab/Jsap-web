@{
    ViewData["Title"] = "Checker Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .soft-btn {
    background: rgba(13, 110, 253, 0.08); /* soft blue */
    color: #0d6efd;
    border: 1px solid rgba(13, 110, 253, 0.2);
    backdrop-filter: blur(6px);
    transition: all 0.2s ease;
    font-weight: 500;
}

.soft-btn:hover {
    background: rgba(13, 110, 253, 0.15);
    border-color: rgba(13, 110, 253, 0.4);
    color: #084298;
}
    #suggestionBox {
        position: absolute;
        top: 70px;
        width: 100%;
        background: white;
        z-index: 1000;
    }

    .suggest-item {
        padding: 8px;
        cursor: pointer;
    }

        .suggest-item:hover {
            background: #f1f1f1;
        }

    td, th {
        text-align: center;
        vertical-align: middle !important;
    }
</style>
<div id="pdfContainer" class="bill-ui" style="display:none; background:#fff; padding:10px; border-radius:8px;">

    <button onclick="closePdf()" 
            class="btn btn-secondary btn-sm mb-2">
        Back
    </button>

    <iframe id="pdfFrame" 
            style="width:100%; height:80vh; border:none; border-radius:8px;">
    </iframe>

</div>
<div class="bill-ui">
<div class="container-fluid mt-4">

    <h3 class="page-title">Bill Verification - Checker</h3>

    <!-- FILTER -->
    <div class="card p-3 shadow-sm">
        <div class="row">

            <div class="col-md-3">
                <label for="fromDate">From Date</label>
                <input type="date" id="fromDate" class="form-control">
            </div>

            <div class="col-md-3">
                <label for="toDate">To Date</label>
                <input type="date" id="toDate" class="form-control">
            </div>

            <div class="col-md-3 position-relative">
                <label for="accountName">Account Name</label>
                <input type="text" id="accountName" class="form-control" placeholder="Search Account" autocomplete="off">
                <div id="suggestionBox" class="suggestion-box"></div>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100" id="searchBtn">Search</button>
            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card mt-4 shadow-sm">

        <div class="card-header bg-primary text-white">
            <span>Bills Pending Checker Action</span>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-striped">

                    <thead class="table-light">
                        <tr>
                            <th>Account</th>
                            <th>Voucher</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Supplier Ref</th>
                            <th>Due Date</th>
                            <th>Attachment</th>
                            <th>Maker Remark</th>
                            <th>Status</th>
                            <th>Checker Remark</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="checkerTable">
                        <tr class="empty-row">
                            <td colspan="11" class="text-center">Select filters and click Search to view bills.</td>
                        </tr>
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
</div>

<!-- jQuery already loaded in _Layout.cshtml -->
<script>

//------------------------------------
// LOAD DATA
//------------------------------------
function loadData() {

    let fromDate    = $("#fromDate").val();
    let toDate      = $("#toDate").val();
    let accountName = $("#accountName").val().trim() || null;

    if (fromDate && toDate && fromDate > toDate) {
        $("#checkerTable").html(`<tr class="empty-row"><td colspan="11" class="text-center text-danger">From Date cannot be greater than To Date.</td></tr>`);
        return;
    }

    $("#checkerTable").html(`<tr class="empty-row"><td colspan="11" class="text-center">Loading bills...</td></tr>`);

    $.ajax({
        url: "/Checker/GetBillDetails",
        method: "GET",
        data: {
        fromDate:    fromDate || null,
        toDate:      toDate || null,
        accountName: accountName
        },
        timeout: 30000,
        success: function (data) {
        console.log("DATA:", data);
        renderTable(data || []);
        },
        error: function (err) {
        console.log("ERROR:", err);
        $("#checkerTable").html(`<tr class="empty-row"><td colspan="11" class="text-center text-danger">Error loading bills. Please try again.</td></tr>`);
        }
    });
}


//------------------------------------
// RENDER TABLE
//------------------------------------
function renderTable(data) {

    if (!data || data.length === 0) {
        $("#checkerTable").html(`<tr class="empty-row"><td colspan="11" class="text-center">No bills found for the selected filters.</td></tr>`);
        return;
    }

    let html    = "";
    let seenVch = new Set();

    data.forEach(item => {

        if (seenVch.has(item.vchNumber)) return;
        seenVch.add(item.vchNumber);

        let statusBadge =
            item.checkerStatus === "Approved"
                ? `<span class="badge bg-success">Approved</span>`
                : item.checkerStatus === "Rejected"
                ? `<span class="badge bg-danger">Rejected</span>`
                : `<span class="badge bg-warning text-dark">Pending</span>`;

        let actionBtn =
            item.checkerStatus === "Approved"
                ? `<span class="badge bg-success">Approved</span>`
                : item.checkerStatus === "Rejected"
                ? `<span class="badge bg-danger">Rejected</span>`
                : `<div class="d-flex gap-2 justify-content-center">
                       <button class="btn btn-success btn-sm approveBtn" data-vch="${item.vchNumber}">Approve</button>
                       <button class="btn btn-danger btn-sm rejectBtn"  data-vch="${item.vchNumber}">Reject</button>
                   </div>`;

       //let attachHtml =
           // item.attachmentPath
              //  ? `<a href="${item.attachmentPath}" target="_blank" class="btn btn-sm btn-outline-primary">View</a>`
               // : `<span class="text-muted">No File</span>`;
               let attachHtml =
    item.attachmentPath
        ? `<a href="#" onclick="openPdf('${item.attachmentPath}')" class="btn btn-sm btn-outline-primary">View</a>`
        : `<span class="text-muted">No File</span>`;
 
        html += `<tr id="row-${item.vchNumber}">
<td><a href="javascript:void(0)" onclick="loadDetails(${item.vchNumber}, ${item.serialNumber})">${item.accountName ?? ""}</a></td>

            <td>${item.vchNumber ?? ""}</td>
            <td>${formatDate(item.voucherDate)}</td>
            <td>${item.billAmount ?? ""}</td>
            <td>${item.supplierRef || "-"}</td>
            <td>${formatDate(item.dueDate)}</td>
            <td>${attachHtml}</td>
            <td>${item.makerRemark ?? "-"}</td>
            <td>${statusBadge}</td>
            <td><input type="text" class="form-control form-control-sm checkerRemark" placeholder="Enter remark" value="${item.checkerRemark ?? ""}"></td>
            <td>${actionBtn}</td>
        </tr>`;
    });

    $("#checkerTable").html(html);
}


//------------------------------------
// APPROVE
//------------------------------------
$(document).on("click", ".approveBtn", function () {

    let vch    = $(this).data("vch");
    let remark = $(this).closest("tr").find(".checkerRemark").val();

    $.post("/Checker/UpdateCheckerStatus", {
        vchNumber: vch,
        status:    "Approved",
        remark:    remark
    }).done(function () {
        alert("Approved");
        loadData();
    }).fail(function () {
        alert("Error");
    });
});


//------------------------------------
// REJECT
//------------------------------------
$(document).on("click", ".rejectBtn", function () {

    let vch    = $(this).data("vch");
    let remark = $(this).closest("tr").find(".checkerRemark").val();

    $.post("/Checker/UpdateCheckerStatus", {
        vchNumber: vch,
        status:    "Rejected",
        remark:    remark
    }).done(function () {
        alert("Rejected");
        loadData();
    }).fail(function () {
        alert("Error");
    });
});


//------------------------------------
// OMNI SEARCH
//------------------------------------
$("#accountName").on("keyup", function () {

    let searchText = $(this).val().trim();

    if (searchText.length < 2) {
        $("#suggestionBox").empty();
        return;
    }

    $.get("/Checker/GetAccountSuggestions",
        { term: searchText },
        function (data) {
            let html = "";
            if (!data || data.length === 0) {
                html = `<div class="suggest-item">No result</div>`;
            } else {
                data.forEach(x => {
                    html += `<div class="suggest-item">${x}</div>`;
                });
            }
            $("#suggestionBox").html(html);
        });
});
// open pdf//
function openPdf(path) {
    document.getElementById("pdfFrame").src = path;
    document.getElementById("pdfContainer").style.display = "block";
}

function closePdf() {
    document.getElementById("pdfContainer").style.display = "none";
    document.getElementById("pdfFrame").src = "";
}

//------------------------------------
// SELECT SUGGESTION
//------------------------------------
$(document).on("click", ".suggest-item", function () {
    let text = $(this).text();
    if (text === "No result") return;
    $("#accountName").val(text);
    $("#suggestionBox").empty();
});


//------------------------------------
// SEARCH BUTTON + INIT
//------------------------------------
$(document).ready(function () {
    console.log("Checker JS Loaded");
    $("#searchBtn").click(loadData);
    //loadData();
});


//------------------------------------
// DATE FORMAT
//------------------------------------
function formatDate(dateString) {
    if (!dateString) return "";
    let d = new Date(dateString);
    if (isNaN(d)) return dateString;
    return d.toISOString().split('T')[0];
}


//------------------------------------
// LOAD DETAILS (Account click)
//------------------------------------
function loadDetails(vchNumber, serialNumber) { 
    if (!vchNumber) return;

    let existing = document.getElementById("details-" + vchNumber);
    if (existing) { existing.remove(); return; }

    document.querySelectorAll("[id^='details-']").forEach(el => el.remove());

    let row = document.getElementById("row-" + vchNumber);
    if (!row) return;

    row.insertAdjacentHTML("afterend",
        `<tr id="details-${vchNumber}">
             <td colspan="11" class="text-center text-muted">Loading items...</td>
         </tr>`
    );

    const controller = new AbortController();
    const timeout    = setTimeout(() => controller.abort(), 15000);

    fetch("/Checker/GetInvoiceItems?serialNumber=" + serialNumber, { signal: controller.signal })
        .then(res => {
            if (!res.ok) throw new Error("Server error: " + res.status);
            return res.json();
        })
        .then(data => {
            clearTimeout(timeout);
let rows = data.map(item => `
<tr>
    <td>${item.productName ?? ""}</td>
    <td>${item.quantity ?? ""}</td>
    <td>${item.warehouseName ?? "-"}</td>
    <td>${item.tax ?? ""}</td>
    <td>${item.taxName ?? "-"}</td>
    <td>${item.itemValue ?? ""}</td>
</tr>
`).join("");

            let html =
                `<tr id="details-${vchNumber}" style="background-color:#f8f9fa;">
                     <td colspan="11">
                         <table class="table table-bordered table-sm mb-0">
                             <thead class="table-light">
                                 <tr>
                                      <th>Product</th>
            <th>Qty</th>
            <th>Warehouse</th>
            <th>Tax %</th>
            <th>Tax Name</th>
            <th>Item Value</th>
                                 </tr>
                             </thead>
                             <tbody>
                                 ${rows.length ? rows : "<tr><td colspan='6' class='text-center'>No items</td></tr>"}
                             </tbody>
                         </table>
                     </td>
                 </tr>`;

            let detailRow = document.getElementById("details-" + vchNumber);
            if (detailRow) detailRow.outerHTML = html;
        })
        .catch(err => {
            clearTimeout(timeout);
            let msg = err.name === "AbortError" ? "Request timed out" : "Error loading items";
            let detailRow = document.getElementById("details-" + vchNumber);
            if (detailRow) detailRow.innerHTML = `<td colspan="11" class="text-danger text-center">${msg}</td>`;
        });
}

</script>
