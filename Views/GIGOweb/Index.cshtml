        // Calculate net weight
        function calculateNetWeight() {
            const grossWeight = parseFloat(document.getElementById('grossWeight')?.value) || 0;
            const tareWeight = parseFloat(document.getElementById('tareWeight')?.value) || 0;
            const netWeight = grossWeight - tareWeight;

            const netWeightElement = document.getElementById('netWeight');
            if (netWeightElement) netWeightElement.value = netWeight.toFixed(2);

            if (netWeight < 0) {
                showAlert('⚠️ Warning: Net weight is negative. Please check your weights.', 'warning');
            }
        }

