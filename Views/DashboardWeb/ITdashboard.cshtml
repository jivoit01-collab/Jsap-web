@{
    ViewData["Title"] = "IT Standards Dashboard";
}

<!-- Include Chart.js for bar charts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    :root {
        --primary: #0b2c4d;
        --primary-light: #1a4a7a;
        --primary-dark: #061a2e;
        --primary-gradient: linear-gradient(135deg, #0b2c4d 0%, #1a4a7a 100%);
        --accent: #3b82f6;
        --accent-light: #60a5fa;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --text-light: #ffffff;
        --text-muted: #94a3b8;
        --bg-light: #f1f5f9;
        --card-bg: rgba(255, 255, 255, 0.95);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: var(--bg-light);
        min-height: 100vh;
    }

    .dashboard-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0;
    }

    /* ============================================
               HEADER SECTION
               ============================================ */
    .dashboard-header {
        background: var(--primary-gradient);
        padding: 30px 40px;
        color: var(--text-light);
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(11, 44, 77, 0.3);
    }

    .dashboard-title {
        font-size: 28px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0;
    }

        .dashboard-title span {
            font-size: 32px;
        }

    .dashboard-subtitle {
        color: var(--text-muted);
        margin-top: 8px;
        font-size: 14px;
    }

    .content-wrapper {
        padding: 0 30px 30px;
    }

    /* ============================================
               SUMMARY CARDS
               ============================================ */
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-card {
        background: var(--card-bg);
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(11, 44, 77, 0.08);
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.3s ease;
        cursor: pointer;
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.5s ease forwards;
        border-left: 4px solid var(--primary);
        position: relative;
        overflow: hidden;
    }

        .summary-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--primary-gradient);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .summary-card:hover::before {
            opacity: 0.05;
        }

        .summary-card:nth-child(1) {
            animation-delay: 0.1s;
            border-left-color: var(--danger);
        }

        .summary-card:nth-child(2) {
            animation-delay: 0.15s;
            border-left-color: var(--warning);
        }

        .summary-card:nth-child(3) {
            animation-delay: 0.2s;
            border-left-color: var(--success);
        }

        .summary-card:nth-child(4) {
            animation-delay: 0.25s;
            border-left-color: #8b5cf6;
        }

        .summary-card:nth-child(5) {
            animation-delay: 0.3s;
            border-left-color: var(--accent);
        }

        .summary-card:nth-child(6) {
            animation-delay: 0.35s;
            border-left-color: #06b6d4;
        }

        .summary-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(11, 44, 77, 0.15);
        }

        .summary-card .icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            position: relative;
            z-index: 1;
        }

        .summary-card:nth-child(1) .icon {
            background: rgba(239, 68, 68, 0.1);
        }

        .summary-card:nth-child(2) .icon {
            background: rgba(245, 158, 11, 0.1);
        }

        .summary-card:nth-child(3) .icon {
            background: rgba(16, 185, 129, 0.1);
        }

        .summary-card:nth-child(4) .icon {
            background: rgba(139, 92, 246, 0.1);
        }

        .summary-card:nth-child(5) .icon {
            background: rgba(59, 130, 246, 0.1);
        }

        .summary-card:nth-child(6) .icon {
            background: rgba(6, 182, 212, 0.1);
        }

        .summary-card .info {
            position: relative;
            z-index: 1;
        }

            .summary-card .info h2 {
                font-size: 13px;
                color: #64748b;
                margin-bottom: 4px;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .summary-card .info p {
                font-size: 28px;
                font-weight: 700;
                color: var(--primary);
                margin: 0;
            }

    /* ============================================
               CHART SECTION
               ============================================ */
    .chart-container {
        background: var(--card-bg);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(11, 44, 77, 0.08);
        margin-bottom: 30px;
        opacity: 0;
        animation: fadeIn 0.6s ease 0.4s forwards;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--bg-light);
    }

        .section-header .icon-box {
            width: 40px;
            height: 40px;
            background: var(--primary-gradient);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
        }

        .section-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: var(--primary);
            margin: 0;
        }

    .chart-wrapper {
        height: 350px;
        position: relative;
    }

    /* ============================================
               TABLES SECTION
               ============================================ */
    .table-container {
        background: var(--card-bg);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(11, 44, 77, 0.08);
        margin-bottom: 30px;
        opacity: 0;
        animation: fadeIn 0.6s ease 0.5s forwards;
    }

    .table-wrapper {
        overflow-x: auto;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        min-width: 800px;
    }

    th {
        background: var(--primary);
        color: white;
        padding: 14px 16px;
        text-align: left;
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

        th:first-child {
            border-top-left-radius: 9px;
        }

        th:last-child {
            border-top-right-radius: 9px;
        }

    td {
        padding: 14px 16px;
        border-bottom: 1px solid #e2e8f0;
        font-size: 14px;
        color: #334155;
    }

    tbody tr {
        background: white;
        transition: all 0.2s ease;
    }

        tbody tr:hover {
            background: rgba(11, 44, 77, 0.03);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

    /* Priority badges */
    .priority-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 11px;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .priority-p1 {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .priority-p2 {
        background: #fffbeb;
        color: #d97706;
        border: 1px solid #fde68a;
    }

    .priority-p3 {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    /* Gap level badges */
    .gap-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 500;
        font-size: 11px;
        display: inline-block;
    }

    .gap-high {
        background: #fef2f2;
        color: #dc2626;
    }

    .gap-medium {
        background: #fffbeb;
        color: #d97706;
    }

    .gap-low {
        background: #f0fdf4;
        color: #16a34a;
    }

    /* Full details section */
    .full-details-container {
        background: var(--card-bg);
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(11, 44, 77, 0.08);
        margin-top: 30px;
        opacity: 0;
        animation: fadeIn 0.6s ease 0.6s forwards;
    }

        .full-details-container > p {
            color: #64748b;
            margin-bottom: 20px;
            font-size: 14px;
        }

    /* Filter buttons */
    .filter-buttons {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 10px 20px;
        border: 2px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .filter-btn:hover {
            transform: translateY(-2px);
        }

        .filter-btn.all {
            background: var(--primary);
            color: white;
        }

            .filter-btn.all:hover {
                background: var(--primary-light);
            }

        .filter-btn.p1 {
            background: white;
            color: var(--danger);
            border-color: var(--danger);
        }

            .filter-btn.p1:hover, .filter-btn.p1.active {
                background: var(--danger);
                color: white;
            }

        .filter-btn.p2 {
            background: white;
            color: var(--warning);
            border-color: var(--warning);
        }

            .filter-btn.p2:hover, .filter-btn.p2.active {
                background: var(--warning);
                color: white;
            }

        .filter-btn.p3 {
            background: white;
            color: var(--success);
            border-color: var(--success);
        }

            .filter-btn.p3:hover, .filter-btn.p3.active {
                background: var(--success);
                color: white;
            }

        .filter-btn.all.active {
            box-shadow: 0 4px 15px rgba(11, 44, 77, 0.3);
        }

    /* Loading spinner */
    .loading {
        text-align: center;
        padding: 40px;
        color: #64748b;
    }

        .loading::after {
            content: '';
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #e2e8f0;
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 10px;
            vertical-align: middle;
        }

    /* Animations */
    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        to {
            opacity: 1;
        }
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Row animation for table */
    tbody tr {
        opacity: 0;
        animation: fadeInRow 0.4s ease forwards;
    }

    @@keyframes fadeInRow {
        to {
            opacity: 1;
        }
    }

    /* Scrollbar styling */
    .table-wrapper::-webkit-scrollbar {
        height: 8px;
    }

    .table-wrapper::-webkit-scrollbar-track {
        background: #f1f5f9;
        border-radius: 4px;
    }

    .table-wrapper::-webkit-scrollbar-thumb {
        background: var(--primary);
        border-radius: 4px;
    }

        .table-wrapper::-webkit-scrollbar-thumb:hover {
            background: var(--primary-light);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .summary-cards {
            grid-template-columns: repeat(2, 1fr);
        }

        .dashboard-header {
            padding: 20px;
        }

        .content-wrapper {
            padding: 0 15px 20px;
        }

        .dashboard-title {
            font-size: 22px;
        }
    }

    @@media (max-width: 480px) {
        .summary-cards {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">
            <span>💻</span> IT Standards Dashboard
        </h1>
        <p class="dashboard-subtitle">Monitor and track IT compliance standards across all departments</p>
    </div>

    <div class="content-wrapper">
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card">
                <div class="icon">⚠️</div>
                <div class="info">
                    <h2>P1 Items</h2>
                    <p id="p1Count">0</p>
                </div>
            </div>
            <div class="summary-card">
                <div class="icon">⏳</div>
                <div class="info">
                    <h2>P2 Items</h2>
                    <p id="p2Count">0</p>
                </div>
            </div>
            <div class="summary-card">
                <div class="icon">✅</div>
                <div class="info">
                    <h2>P3 Items</h2>
                    <p id="p3Count">0</p>
                </div>
            </div>
            <div class="summary-card">
                <div class="icon">🔴</div>
                <div class="info">
                    <h2>High Gaps</h2>
                    <p id="highGap">0</p>
                </div>
            </div>
            <div class="summary-card">
                <div class="icon">🟡</div>
                <div class="info">
                    <h2>Medium Gaps</h2>
                    <p id="mediumGap">0</p>
                </div>
            </div>
            <div class="summary-card">
                <div class="icon">🟢</div>
                <div class="info">
                    <h2>Low Gaps</h2>
                    <p id="lowGap">0</p>
                </div>
            </div>
        </div>

        <!-- Chart Section -->
        <div class="chart-container">
            <div class="section-header">
                <div class="icon-box">📊</div>
                <h2>IT Standards Overview</h2>
            </div>
            <div class="chart-wrapper">
                <canvas id="standardsChart"></canvas>
            </div>
        </div>

        <!-- IT Standards Summary Table -->
        <div class="table-container">
            <div class="section-header">
                <div class="icon-box">🖥️</div>
                <h2>IT Standards Summary</h2>
            </div>
            <div class="table-wrapper">
                <table id="itStandardsTable">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Sub-Category</th>
                            <th>Priority</th>
                            <th>Gap Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="4" class="loading">Loading data</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Full Details Section -->
        <div class="full-details-container">
            <div class="section-header">
                <div class="icon-box">📋</div>
                <h2>All IT Standards – Full Details</h2>
            </div>
            <p>Click on any filter button to filter data or scroll to view complete information.</p>

            <!-- Filter Buttons -->
            <div class="filter-buttons">
                <button class="filter-btn all active" id="filterAll">All Standards</button>
                <button class="filter-btn p1" id="filterP1">P1 - Critical</button>
                <button class="filter-btn p2" id="filterP2">P2 - Important</button>
                <button class="filter-btn p3" id="filterP3">P3 - Normal</button>
            </div>

            <div class="table-wrapper">
                <table id="fullDetailsTable">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Sub Category</th>
                            <th>Industry Standard</th>
                            <th>Current State</th>
                            <th>Gap Level</th>
                            <th>Risk Level</th>
                            <th>Required Improvement</th>
                            <th>Priority</th>
                            <th>Owner</th>
                            <th>Budget Needed</th>
                            <th>Timeline</th>
                            <th>Tools Recommended</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="13" class="loading">Loading data</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    let standardsChart = null;
    let allData = [];

    // Theme colors matching #0b2c4d
    const themeColors = {
        primary: '#0b2c4d',
        primaryLight: '#1a4a7a',
        danger: '#ef4444',
        warning: '#f59e0b',
        success: '#10b981',
        purple: '#8b5cf6',
        blue: '#3b82f6',
        cyan: '#06b6d4'
    };

    $(document).ready(function () {
        // Initialize chart
        initChart();

        // Fetch summary
        fetchSummary();

        // Fetch all IT standards
        loadStandards();

        // Filter button handlers
        $('.filter-btn').click(function () {
            $('.filter-btn').removeClass('active');
            $(this).addClass('active');
        });

        $('#filterAll').click(() => filterTable(''));
        $('#filterP1').click(() => filterTable('P1'));
        $('#filterP2').click(() => filterTable('P2'));
        $('#filterP3').click(() => filterTable('P3'));
    });

    // Initialize Chart.js bar chart with theme colors
    function initChart() {
        const ctx = document.getElementById('standardsChart').getContext('2d');
        standardsChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['P1 - Critical', 'P2 - Important', 'P3 - Normal', 'High Gap', 'Medium Gap', 'Low Gap'],
                datasets: [{
                    label: 'Count',
                    data: [0, 0, 0, 0, 0, 0],
                    backgroundColor: [
                        themeColors.danger,
                        themeColors.warning,
                        themeColors.success,
                        'rgba(239, 68, 68, 0.5)',
                        'rgba(245, 158, 11, 0.5)',
                        'rgba(16, 185, 129, 0.5)'
                    ],
                    borderColor: [
                        themeColors.danger,
                        themeColors.warning,
                        themeColors.success,
                        themeColors.danger,
                        themeColors.warning,
                        themeColors.success
                    ],
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: themeColors.primary,
                        titleColor: '#fff',
                        bodyColor: '#fff',
                        padding: 12,
                        cornerRadius: 8,
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            color: '#64748b',
                            font: { size: 12 }
                        },
                        grid: {
                            color: 'rgba(11, 44, 77, 0.08)',
                            drawBorder: false
                        }
                    },
                    x: {
                        ticks: {
                            color: '#64748b',
                            font: { size: 11 }
                        },
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    }

    // Fetch summary data
    function fetchSummary() {
        $.getJSON('/api/Dashboard/GetSummary', function (response) {
            if (response && response.success && response.data) {
                const summary = response.data;

                // Update cards with animation
                animateNumber('#p1Count', summary.p1 || 0);
                animateNumber('#p2Count', summary.p2 || 0);
                animateNumber('#p3Count', summary.p3 || 0);
                animateNumber('#highGap', summary.high || 0);
                animateNumber('#mediumGap', summary.medium || 0);
                animateNumber('#lowGap', summary.low || 0);

                // Update chart
                updateChart(summary);
            }
        }).fail(function() {
            console.error('Failed to fetch summary');
        });
    }

    // Animate number counting
    function animateNumber(selector, target) {
        let current = 0;
        const duration = 1000;
        const steps = 30;
        const increment = target / steps;
        const stepTime = duration / steps;

        const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
                current = target;
                clearInterval(timer);
            }
            $(selector).text(Math.round(current));
        }, stepTime);
    }

    // Update chart with summary data
    function updateChart(summary) {
        if (standardsChart) {
            standardsChart.data.datasets[0].data = [
                summary.p1 || 0,
                summary.p2 || 0,
                summary.p3 || 0,
                summary.high || 0,
                summary.medium || 0,
                summary.low || 0
            ];
            standardsChart.update('active');
        }
    }

    // Load all standards data
    function loadStandards(priorityFilter = '') {
        let apiUrl = '/api/Dashboard/GetMaster';
        if (priorityFilter) {
            apiUrl += `?priority=${priorityFilter}`;
        }

        $.getJSON(apiUrl, function (response) {
            if (response && response.success && response.data && response.data.length > 0) {
                allData = response.data;
                renderSummaryTable(allData);
                renderFullDetailsTable(allData);
            } else {
                showNoData();
            }
        }).fail(function() {
            showNoData();
        });
    }

    // Render summary table (4 columns)
    function renderSummaryTable(data) {
        const tbody = $('#itStandardsTable tbody');
        tbody.empty();

        data.forEach(function(item, idx) {
            const priorityClass = getPriorityClass(item.priority);
            const gapClass = getGapClass(item.gap_Level);

            const row = `<tr style="animation-delay: ${idx * 0.05}s">
                <td>${escapeHtml(item.category)}</td>
                <td>${escapeHtml(item.subCategory)}</td>
                <td><span class="priority-badge ${priorityClass}">${escapeHtml(item.priority)}</span></td>
                <td><span class="gap-badge ${gapClass}">${escapeHtml(item.gap_Level)}</span></td>
            </tr>`;
            tbody.append(row);
        });
    }

    // Render full details table (13 columns)
    function renderFullDetailsTable(data) {
        const tbody = $('#fullDetailsTable tbody');
        tbody.empty();

        data.forEach(function(item, idx) {
            const priorityClass = getPriorityClass(item.priority);
            const gapClass = getGapClass(item.gap_Level);

            const row = `<tr style="animation-delay: ${idx * 0.05}s">
                <td>${escapeHtml(item.category)}</td>
                <td>${escapeHtml(item.subCategory)}</td>
                <td>${escapeHtml(item.industry_Standard)}</td>
                <td>${escapeHtml(item.current_State)}</td>
                <td><span class="gap-badge ${gapClass}">${escapeHtml(item.gap_Level)}</span></td>
                <td>${escapeHtml(item.risk_Level)}</td>
                <td>${escapeHtml(item.required_Improvement)}</td>
                <td><span class="priority-badge ${priorityClass}">${escapeHtml(item.priority)}</span></td>
                <td>${escapeHtml(item.owner)}</td>
                <td>${escapeHtml(item.budget_Needed)}</td>
                <td>${escapeHtml(item.timeline)}</td>
                <td>${escapeHtml(item.tools_Recommended)}</td>
                <td>${escapeHtml(item.notes)}</td>
            </tr>`;
            tbody.append(row);
        });
    }

    // Filter table by priority (client-side)
    function filterTable(priority) {
        if (!priority) {
            renderFullDetailsTable(allData);
            return;
        }

        const filtered = allData.filter(item => item.priority === priority);
        renderFullDetailsTable(filtered);
    }

    // Helper functions
    function getPriorityClass(priority) {
        switch (priority) {
            case 'P1': return 'priority-p1';
            case 'P2': return 'priority-p2';
            case 'P3': return 'priority-p3';
            default: return '';
        }
    }

    function getGapClass(gap) {
        switch (gap) {
            case 'High': return 'gap-high';
            case 'Medium': return 'gap-medium';
            case 'Low': return 'gap-low';
            default: return '';
        }
    }

    function escapeHtml(text) {
        if (!text) return '';
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return String(text).replace(/[&<>"']/g, m => map[m]);
    }

    function showNoData() {
        $('#itStandardsTable tbody').html('<tr><td colspan="4" style="text-align:center; padding: 40px; color: #64748b;">No IT standards found</td></tr>');
        $('#fullDetailsTable tbody').html('<tr><td colspan="13" style="text-align:center; padding: 40px; color: #64748b;">No IT standards found</td></tr>');
    }
</script>
