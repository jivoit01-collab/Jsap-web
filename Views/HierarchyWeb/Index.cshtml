            function getPersonKey(role, name, code){
                var cleanCode = (code || '').toString().trim().toUpperCase();
                if(cleanCode) return role + '|' + cleanCode;

                var cleanName = (name || '').toString().trim().toLowerCase();
                return cleanName ? role + '|' + cleanName : '';
            }

            function countUniquePeople(items, role){
                var seen = {}, count = 0;
                (items || []).forEach(function(item){
                    var key = getPersonKey(role, item && item.name, item && item.code);
                    if(key && !seen[key]){
                        seen[key] = 1;
                        count++;
                    }
                });
                return count;
            }

            function getOrgEmployeeCounts(){
                var hodSet={},shSet={},exSet={};
                RAW_DATA.forEach(function(h){
                    var hodKey=getPersonKey('hod',h.name,h.code);
                    if(hodKey) hodSet[hodKey]=1;
                    h.subs.forEach(function(s){
                        (s.subHods||[]).forEach(function(sh){
                            var shKey=getPersonKey('subhod',sh.name,sh.code);
                            if(shKey) shSet[shKey]=1;
                            (sh.execs||[]).forEach(function(e){
                                var exKey=getPersonKey('exec',e.name,e.code);
                                if(exKey) exSet[exKey]=1;
                            });
                        });
                        (s.execs||[]).forEach(function(e){
                            var exKey=getPersonKey('exec',e.name,e.code);
                            if(exKey) exSet[exKey]=1;
                        });
                    });
                    // Sales tree employees are NOT included in HO hierarchy counts
                });

                return {
                    hodCount: Object.keys(hodSet).length,
                    subHodCount: Object.keys(shSet).length,
                    execCount: Object.keys(exSet).length,
                    totalEmployees: Object.keys(hodSet).length + Object.keys(shSet).length + Object.keys(exSet).length
                };
            }

            function normalizeData(raw){
                return raw.map(function(h, i){
                    var deptSet = Object.create(null);
                    if(h.departments && Array.isArray(h.departments)){
                        h.departments.forEach(function(d){
                            var deptName = d && d.departmentName ? d.departmentName.trim() : '';
                            if(deptName) deptSet[deptName] = 1;
                        });
                    }
                    var rawSubs = (h.subHODs||[]).map(function(s){
                        return { sdName:s.subDepartmentName||'-', shName:s.employeeName||'-', shCode:s.employeeCode||'', shSal:s.salary||0, shDesig:s.designation||'', dept:s.departmentName||'',
                            execs:(s.executives||[]).filter(function(e){return e&&e.employeeName;}).map(function(e){ return {name:e.employeeName,code:e.employeeCode||'',sal:e.salary||0,desig:e.designation||''}; }) };
                    });
                    var sdMap={}, sdOrder=[];
                    rawSubs.forEach(function(s){
                        var key=(s.dept||'')+'||'+s.sdName;
                        if(!sdMap[key]){ sdMap[key]={idx:sdOrder.length,sdName:s.sdName,dept:s.dept,subHods:[],execs:[]}; sdOrder.push(key); }
                        var entry=sdMap[key];
                        if(s.shName&&s.shName!=='-'){
                            var dup=entry.subHods.some(function(x){return(x.code&&x.code===s.shCode)||x.name===s.shName;});
                            if(!dup) entry.subHods.push({name:s.shName,code:s.shCode,sal:s.shSal,desig:s.shDesig,execs:s.execs});
                        } else {
                            s.execs.forEach(function(e){ if(!entry.execs.some(function(x){return(x.code&&x.code===e.code)||x.name===e.name;})) entry.execs.push(e); });
                        }
                    });
                    var subs=sdOrder.map(function(key){return sdMap[key];});
                    subs.forEach(function(s){
                        var deptName = (s.dept||'').trim();
                        if(deptName && deptName !== '-') deptSet[deptName] = 1;
                    });
                    var deptNames = Object.keys(deptSet);
                    if(!deptNames.length && (h.departmentCount||0)>0) deptNames.push('Department');
                    var uniqueSubHods=[],uniqueExecs=[];
                    subs.forEach(function(s){
                        (s.subHods||[]).forEach(function(sh){
                            uniqueSubHods.push({name:sh.name,code:sh.code});
                            (sh.execs||[]).forEach(function(e){ uniqueExecs.push({name:e.name,code:e.code}); });
                        });
                        (s.execs||[]).forEach(function(e){ uniqueExecs.push({name:e.name,code:e.code}); });
                    });
                    var subhodCount=countUniquePeople(uniqueSubHods,'subhod'), execCount=countUniquePeople(uniqueExecs,'exec');
                    return { id:'hod-'+i, idx:i, name:h.employeeName||'-', code:h.employeeCode||'', sal:h.salary||0, depts:deptNames, deptCount:h.departmentCount||deptNames.length||0, subs:subs, color:HOD_COLORS[i%HOD_COLORS.length], subhodCount:subhodCount, execCount:execCount, totalTeam:subhodCount+execCount };
                });
            }

