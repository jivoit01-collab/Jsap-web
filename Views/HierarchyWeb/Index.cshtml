                var oR=outer.getBoundingClientRect(),sL=outer.scrollLeft,sT=outer.scrollTop;
                document.querySelectorAll('.children-row').forEach(function(row){ var children=row.querySelectorAll(':scope > .branch > .node-card');if(children.length<2)return;var first=children[0].getBoundingClientRect(),last=children[children.length-1].getBoundingClientRect();var y=first.top-oR.top+sT-22;var x1=first.left-oR.left+sL+first.width/2,x2=last.left-oR.left+sL+last.width/2;var line=document.createElementNS('http://www.w3.org/2000/svg','line');line.setAttribute('x1',x1);line.setAttribute('y1',y);line.setAttribute('x2',x2);line.setAttribute('y2',y);line.setAttribute('stroke','rgba(100,116,139,.22)');line.setAttribute('stroke-width','1.5');svg.appendChild(line); });
                document.querySelectorAll('.branch[data-parent-id]').forEach(function(branch){ var parId=branch.getAttribute('data-parent-id');if(!parId)return;var parBranch=document.querySelector('.branch[data-node-id="'+parId+'"]');if(!parBranch)return;var pCard=parBranch.querySelector(':scope > .node-card'),cCard=branch.querySelector(':scope > .node-card');if(!pCard||!cCard)return;var pr=pCard.getBoundingClientRect(),cr=cCard.getBoundingClientRect();var x1=pr.left-oR.left+sL+pr.width/2,y1=pr.top-oR.top+sT+pr.height;var x2=cr.left-oR.left+sL+cr.width/2,y2=cr.top-oR.top+sT;if(y2<y1+4)return;var midY=(y1+y2)/2;var isOwner=parId==='owner';var nc=getComputedStyle(cCard).getPropertyValue('--nc').trim()||'rgba(100,116,139,.4)';var stroke=isOwner?'rgba(217,119,6,.5)':nc+'90';var path=document.createElementNS('http://www.w3.org/2000/svg','path');path.setAttribute('d','M'+x1+','+y1+' C'+x1+','+midY+' '+x2+','+midY+' '+x2+','+y2);path.setAttribute('fill','none');path.setAttribute('stroke',stroke);path.setAttribute('stroke-width','2');svg.appendChild(path);var dot=document.createElementNS('http://www.w3.org/2000/svg','circle');dot.setAttribute('cx',x2);dot.setAttribute('cy',y2);dot.setAttribute('r','3.5');dot.setAttribute('fill',isOwner?'#d97706':stroke);svg.appendChild(dot); });
