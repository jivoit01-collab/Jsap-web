function showInlineMsg(el, html, type) {
    const colors = { error: '#fef2f2', success: '#f0fdf4', info: '#eff6ff' };
    const borders = { error: '#fecaca', success: '#bbf7d0', info: '#bfdbfe' };
    const texts = { error: '#991b1b', success: '#166534', info: '#1e3a8a' };
    el.style.display = '';
    el.innerHTML = `<div style="background:${colors[type]};border:1px solid ${borders[type]};color:${texts[type]};border-radius:6px;padding:8px 12px;font-size:12px">${html}</div>`;
}

// Close panels when clicking outside
document.addEventListener('click', e => {
    if (auditPanelOpen && !document.getElementById('auditPanel').contains(e.target) && !e.target.closest('[onclick*="toggleAuditPanel"]')) {
        auditPanelOpen = false;
        document.getElementById('auditPanel').classList.remove('open');
    }
    if (colManagerOpen && !document.getElementById('colManager').contains(e.target) && !e.target.closest('[onclick*="toggleColManager"]')) {
        colManagerOpen = false;
        document.getElementById('colManager').classList.remove('open');
    }
});

// Close overlays on backdrop click
document.querySelectorAll('.overlay').forEach(ov => {
    ov.addEventListener('click', e => {
        if (e.target === ov) ov.classList.remove('open');
    });
});
