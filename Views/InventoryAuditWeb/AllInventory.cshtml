        // Selection handlers
        function selectSingleSelectItem(type, item, element) {
            const dropdown = element.parentElement;
            dropdown.querySelectorAll('.select-option').forEach(el => {
                el.classList.remove('selected');
            });

            element.classList.add('selected');
            searchFilters[type] = item;
            updateSingleSelectedDisplay(type);
            dropdown.classList.remove('show');

            const container = dropdown.closest('.select-container');
            container.classList.remove('active');

            handleCascadingSelection(type, item);
            updateFilterSummary();

            console.log(`Selected ${type}:`, item);
        }

        function toggleMultiSelectItem(type, item, element) {
            const selectedArray = searchFilters[type];
            const existingIndex = selectedArray.findIndex(selected => selected.id === item.id);

            if (existingIndex > -1) {
                selectedArray.splice(existingIndex, 1);
                element.classList.remove('selected');

                // If unselecting an individual item, also unselect "Select All"
                const selectAllIndex = selectedArray.findIndex(selected => selected.id === 'SELECT_ALL');
                if (selectAllIndex > -1) {
                    selectedArray.splice(selectAllIndex, 1);
                    const selectAllOption = element.parentElement.querySelector('[data-value="SELECT_ALL"]');
                    if (selectAllOption) {
                        selectAllOption.classList.remove('selected');
                    }
                }
            } else {
                selectedArray.push(item);
                element.classList.add('selected');
            }

            updateMultiSelectedDisplay(type);
            updateFilterSummary();

            console.log(`Toggled ${type}:`, selectedArray);
        }

        function toggleSelectAll(type, element) {
            const dropdown = element.parentElement;
            const selectedArray = searchFilters[type];
            const isCurrentlySelected = element.classList.contains('selected');

            if (isCurrentlySelected) {
                // Unselect all
                selectedArray.length = 0;
                dropdown.querySelectorAll('.select-option').forEach(option => {
                    option.classList.remove('selected');
                });
            } else {
                // Select all
                selectedArray.length = 0;

                // Add select all marker
                selectedArray.push({ id: 'SELECT_ALL', name: 'Select All', code: 'SELECT_ALL' });

                // Add all individual items
                const dataSource = type === 'warehouse' ? apiData.warehouses :
                                 type === 'itemGroup' ? apiData.itemGroups :
                                 apiData.subGroups;

                dataSource.forEach(item => {
                    const normalizedItem = normalizeSelectAllItem(item, type);
                    selectedArray.push(normalizedItem);
                });

                dropdown.querySelectorAll('.select-option').forEach(option => {
                    option.classList.add('selected');
                });
            }

            updateMultiSelectedDisplay(type);
            updateFilterSummary();
        }

        function normalizeSelectAllItem(item, type) {
            switch(type) {
                case 'warehouse':
                    return {
                        id: item.warehouse || item.code || item.id,
                        name: item.warehouse || item.name,
                        code: item.warehouse || item.code
                    };
                case 'itemGroup':
                    return {
                        id: item.itmsGrpCod || item.code || item.id,
                        name: item.itmsGrpNam || item.name,
                        code: item.itmsGrpCod || item.code
                    };
                case 'subGroup':
                    return {
                        id: item.u_Sub_Group || item.code || item.id,
                        name: item.u_Sub_Group || item.name,
                        code: item.u_Sub_Group || item.code
                    };
                default:
                    return item;
            }
        }

        function updateSingleSelectedDisplay(type) {
            const mappedId = {
                'unit': 'unit-selected',
                'location': 'location-selected',
                'status': 'status-selected'
            };

            const containerId = mappedId[type];
            const container = document.getElementById(containerId);

            if (!searchFilters[type]) {
                const placeholderText = {
                    unit: 'Select unit...',
                    location: 'Select location...',
                    status: 'Select status...'
                };
                container.innerHTML = `<div class="select-placeholder">${placeholderText[type]}</div>`;
                return;
            }

            container.innerHTML = searchFilters[type].name;
        }

        function updateMultiSelectedDisplay(type) {
            const mappedId = {
                'warehouse': 'warehouse-selected',
                'itemGroup': 'itemgroup-selected',
                'subGroup': 'subgroup-selected'
            };

            const containerId = mappedId[type];
            const container = document.getElementById(containerId);
            const selectedArray = searchFilters[type];

            if (selectedArray.length === 0) {
                const placeholderText = {
                    warehouse: 'Select warehouses...',
                    itemGroup: 'Select item groups...',
                    subGroup: 'Select sub groups...'
                };
                container.innerHTML = `<div class="select-placeholder">${placeholderText[type]}</div>`;
                return;
            }

            // Check if "Select All" is selected
            const hasSelectAll = selectedArray.some(item => item.id === 'SELECT_ALL');

            if (hasSelectAll) {
                container.innerHTML = '<span class="select-all-tag">✓ All Selected</span>';
            } else if (selectedArray.length <= 2) {
                const tagsHtml = selectedArray.map(item =>
                    `<span class="multi-select-tag">
                        ${item.name}
                        <span class="remove-tag" onclick="removeMultiSelectItem('${type}', '${item.id}')">&times;</span>
                    </span>`
                ).join('');
                container.innerHTML = tagsHtml;
            } else {
                container.innerHTML = `<span class="multi-select-count">${selectedArray.length} selected</span>`;
            }
        }

        function removeMultiSelectItem(type, itemId) {
            const selectedArray = searchFilters[type];
            const itemIndex = selectedArray.findIndex(item => item.id === itemId);

            if (itemIndex > -1) {
                selectedArray.splice(itemIndex, 1);

                // If removing "Select All", unselect all items
                if (itemId === 'SELECT_ALL') {
                    selectedArray.length = 0;
                    const mappedId = {
                        'warehouse': 'warehouse-dropdown',
                        'itemGroup': 'itemgroup-dropdown',
                        'subGroup': 'subgroup-dropdown'
                    };
                    const dropdown = document.getElementById(mappedId[type]);
                    dropdown.querySelectorAll('.select-option').forEach(option => {
                        option.classList.remove('selected');
                    });
                } else {
                    // Also remove "Select All" if it exists
                    const selectAllIndex = selectedArray.findIndex(item => item.id === 'SELECT_ALL');
                    if (selectAllIndex > -1) {
                        selectedArray.splice(selectAllIndex, 1);
                    }

                    const mappedId = {
                        'warehouse': 'warehouse-dropdown',
                        'itemGroup': 'itemgroup-dropdown',
                        'subGroup': 'subgroup-dropdown'
                    };
                    const dropdown = document.getElementById(mappedId[type]);
                    const option = dropdown.querySelector(`[data-value="${itemId}"]`);
                    if (option) {
                        option.classList.remove('selected');
                    }
                    const selectAllOption = dropdown.querySelector('[data-value="SELECT_ALL"]');
                    if (selectAllOption) {
                        selectAllOption.classList.remove('selected');
                    }
                }

                updateMultiSelectedDisplay(type);
                updateFilterSummary();
            }
        }

        function handleCascadingSelection(type, item) {
            if (type === 'unit') {
                searchFilters.location = null;
                searchFilters.warehouse = [];
                updateSingleSelectedDisplay('location');
                updateMultiSelectedDisplay('warehouse');
                disableDropdown('warehouse-container', 'Select location first...');

                if (item && (item.code || item.name)) {
                    loadLocations(item.code || item.name);
                } else {
                    disableDropdown('location-container', 'Select unit first...');
                }
            }

            if (type === 'location') {
                searchFilters.warehouse = [];
                updateMultiSelectedDisplay('warehouse');

                if (item && (item.code || item.name)) {
                    loadWarehouses(item.code || item.name);
                } else {
                    disableDropdown('warehouse-container', 'Select location first...');
                }
            }
        }

        function isAllSelected(type) {
            if (Array.isArray(searchFilters[type])) {
                return searchFilters[type].some(item => item.id === 'SELECT_ALL');
            }
            return false;
        }

        // Dropdown toggle functions
        function toggleSingleSelect(dropdownId) {
            const dropdown = document.getElementById(dropdownId);
            const container = dropdown.closest('.select-container');

            if (container.classList.contains('disabled')) {
                return;
            }

            const allDropdowns = document.querySelectorAll('.select-dropdown');
            const allContainers = document.querySelectorAll('.select-container');

            allDropdowns.forEach(d => {
                if (d.id !== dropdownId) {
                    d.classList.remove('show');
                }
            });

            allContainers.forEach(c => {
                if (c !== container) {
                    c.classList.remove('active');
                }
            });

            dropdown.classList.toggle('show');
            container.classList.toggle('active');
        }

        function toggleMultiSelect(dropdownId) {
            const dropdown = document.getElementById(dropdownId);
            const container = dropdown.closest('.select-container');

            if (container.classList.contains('disabled')) {
                return;
            }

            const allDropdowns = document.querySelectorAll('.select-dropdown');
            const allContainers = document.querySelectorAll('.select-container');

            allDropdowns.forEach(d => {
                if (d.id !== dropdownId) {
                    d.classList.remove('show');
                }
            });

            allContainers.forEach(c => {
                if (c !== container) {
                    c.classList.remove('active');
                }
            });

            dropdown.classList.toggle('show');
            container.classList.toggle('active');
        }

        // Utility functions
        function showLoadingOverlay(message = 'Loading...') {
            const overlay = document.getElementById('loadingOverlay');
            const text = overlay.querySelector('.loading-text');
            if (overlay) {
                text.textContent = message;
                overlay.style.display = 'flex';
            }
        }

        function hideLoadingOverlay() {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) {
                overlay.style.display = 'none';
            }
        }

        function showGlobalError(message) {
            const existingError = document.querySelector('.global-error');
            if (existingError) {
                existingError.remove();
            }

            const errorDiv = document.createElement('div');
            errorDiv.className = 'alert alert-danger global-error';
            errorDiv.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
            errorDiv.innerHTML = `
                ${message}
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            `;
            document.body.appendChild(errorDiv);

            setTimeout(() => {
                if (errorDiv.parentElement) {
                    errorDiv.remove();
                }
            }, 10000);
        }

