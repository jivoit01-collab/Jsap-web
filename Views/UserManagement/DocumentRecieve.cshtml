        // Pending mode search functionality
        function filterTable() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const tableRows = document.querySelectorAll('#receiverTable tbody tr');
            let visibleCount = 0;
            let totalCount = tableRows.length;

            tableRows.forEach(row => {
                if (!searchTerm) {
                    row.style.display = '';
                    visibleCount++;
                    return;
                }

                // Get Bundle ID and Doc ID from the row
                const cells = row.querySelectorAll('td');
                const bundleId = cells[2] ? cells[2].textContent.toLowerCase() : '';
                const docId = cells[3] ? cells[3].textContent.toLowerCase() : '';

                // Check if search term matches Bundle ID or Doc ID
                const matchesBundleId = bundleId.includes(searchTerm);
                const matchesDocId = docId.includes(searchTerm);

                if (matchesBundleId || matchesDocId) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Update search results
            updateSearchResults(searchTerm, visibleCount, totalCount, 'searchResults');

            // Update select all button and counts
            updateSelectAllButton();
            updatePendingCount(visibleCount);
        }

        // All data mode search and filter functionality
        function filterAllDataTable() {
            const searchTerm = document.getElementById('allDataSearchInput').value.toLowerCase().trim();
            const statusFilter = currentStatusFilter;
            const tableRows = document.querySelectorAll('#receiverTable tbody tr');
            let visibleCount = 0;
            let totalCount = tableRows.length;

            tableRows.forEach(row => {
                let showRow = true;

                // Search filter
                if (searchTerm) {
                    const cells = row.querySelectorAll('td');
                    const bundleId = cells[1] ? cells[1].textContent.toLowerCase() : '';
                    const docId = cells[2] ? cells[2].textContent.toLowerCase() : '';

                    const matchesBundleId = bundleId.includes(searchTerm);
                    const matchesDocId = docId.includes(searchTerm);

                    if (!matchesBundleId && !matchesDocId) {
                        showRow = false;
                    }
                }

                // Status filter
                if (statusFilter && showRow) {
                    const rowStatus = row.getAttribute('data-status');
                    if (rowStatus !== statusFilter) {
                        showRow = false;
                    }
                }

                if (showRow) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Update search results
            updateAllDataSearchResults(searchTerm, statusFilter, visibleCount, totalCount);
        }

        function updateAllDataSearchResults(searchTerm, statusFilter, visibleCount, totalCount) {
            const resultsDiv = document.getElementById('allDataSearchResults');

            if (!resultsDiv) return;

            // If no filters are applied, show total count
            if (!searchTerm && !statusFilter) {
                resultsDiv.textContent = `Showing ${totalCount} documents`;
                resultsDiv.style.color = '#6c757d';
                return;
            }

            // Build filter description
            const filterText = [];
            if (searchTerm) filterText.push(`"${searchTerm}"`);
            if (statusFilter) filterText.push(`Status: ${statusFilter}`);

            if (visibleCount === 0) {
                resultsDiv.innerHTML = `<span style="color: #e74c3c;">No documents found</span>`;
            } else {
                const filterDescription = filterText.length > 0 ? ` matching ${filterText.join(' + ')}` : '';
                resultsDiv.innerHTML = `<span style="color: #3498db;">Showing ${visibleCount} of ${totalCount} documents${filterDescription}</span>`;
            }
        }

        function updateSearchResults(searchTerm, visibleCount, totalCount, elementId) {
            const resultsDiv = document.getElementById(elementId);

            if (!searchTerm) {
                resultsDiv.textContent = '';
                return;
            }

            if (visibleCount === 0) {
                resultsDiv.innerHTML = `<span style="color: #e74c3c;">❌ No documents found</span>`;
            } else if (visibleCount === totalCount) {
                resultsDiv.innerHTML = `<span style="color: #28a745;">✅ Showing all ${totalCount} documents</span>`;
            } else {
                resultsDiv.innerHTML = `<span style="color: #3498db;">📊 Showing ${visibleCount} of ${totalCount} documents</span>`;
            }
        }

