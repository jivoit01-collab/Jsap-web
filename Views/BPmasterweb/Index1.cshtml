        // Contact Functions with Enhanced Validation
        function validateContactField(field) {
            const fieldName = field.name;
            const value = field.value.trim();
            let isValid = true;
            let errorMessage = '';

            // Get error element
            const errorElement = field.parentElement.querySelector('.error-message') ||
                                field.closest('td').querySelector('.error-message');

            // Reset previous state
            field.classList.remove('error');
            if (errorElement) {
                errorElement.style.display = 'none';
            }

            // Validation based on field type
            switch (fieldName) {
                case 'contactFirstName':
                case 'contactLastName':
                    if (!value) {
                        isValid = false;
                        errorMessage = 'Name is required';
                    } else if (value.length < 2) {
                        isValid = false;
                        errorMessage = 'Name must be at least 2 characters';
                    } else if (value.length > 50) {
                        isValid = false;
                        errorMessage = 'Name must be less than 50 characters';
                    } else if (!/^[A-Za-z\s]+$/.test(value)) {
                        isValid = false;
                        errorMessage = 'Name must contain only letters and spaces';
                    }
                    break;

                case 'phone':
                    if (!value) {
                        isValid = false;
                        errorMessage = 'Mobile number is required';
                    } else if (!/^[\+]?[0-9\-\s]{10,15}$/.test(value)) {
                        isValid = false;
                        errorMessage = 'Mobile number must be 10-15 digits';
                    }
                    break;

                case 'email':
                    if (!value) {
                        isValid = false;
                        errorMessage = 'Email is required';
                    } else if (!isValidEmail(value)) {
                        isValid = false;
                        errorMessage = 'Please enter a valid email address';
                    }
                    break;
            }

            // Show error if validation failed
            if (!isValid) {
                field.classList.add('error');
                if (errorElement) {
                    errorElement.textContent = errorMessage;
                    errorElement.style.display = 'block';
                }
            }

            // Update add button state
            updateAddContactButtonState();

            return isValid;
        }

        function validateAllContactFields() {
            const fields = [
                document.querySelector("input[name='contactFirstName']"),
                document.querySelector("input[name='contactLastName']"),
                document.querySelector("input[name='phone']"),
                document.querySelector("input[name='email']")
            ];

            let allValid = true;

            fields.forEach(field => {
                if (field && !validateContactField(field)) {
                    allValid = false;
                }
            });

            return allValid;
        }

        function updateAddContactButtonState() {
            const fields = [
                document.querySelector("input[name='contactFirstName']"),
                document.querySelector("input[name='contactLastName']"),
                document.querySelector("input[name='phone']"),
                document.querySelector("input[name='email']")
            ];

            const addButton = document.getElementById('addContactBtn');
            if (!addButton) return;

            // Check if all fields are filled and valid
            let allFieldsValid = true;
            let allFieldsFilled = true;

            fields.forEach(field => {
                if (!field) return;

                const value = field.value.trim();
                const hasError = field.classList.contains('error');

                if (!value) {
                    allFieldsFilled = false;
                }

                if (hasError || !value) {
                    allFieldsValid = false;
                }
            });

            // Enable button only if all fields are filled and valid
            if (allFieldsFilled && allFieldsValid) {
                addButton.disabled = false;
                addButton.style.opacity = '1';
                addButton.style.cursor = 'pointer';
            } else {
                addButton.disabled = true;
                addButton.style.opacity = '0.5';
                addButton.style.cursor = 'not-allowed';
            }
        }

        function setupContactValidationListeners() {
            const contactFields = [
                document.querySelector("input[name='contactFirstName']"),
                document.querySelector("input[name='contactLastName']"),
                document.querySelector("input[name='phone']"),
                document.querySelector("input[name='email']")
            ];

            contactFields.forEach(field => {
                if (!field) return;

                // Real-time validation on input
                field.addEventListener('input', function() {
                    // Small delay to avoid excessive validation calls
                    clearTimeout(this.validationTimeout);
                    this.validationTimeout = setTimeout(() => {
                        validateContactField(this);
                    }, 300);
                });

                // Immediate validation on blur
                field.addEventListener('blur', function() {
                    clearTimeout(this.validationTimeout);
                    validateContactField(this);
                });

                // Initial validation check
                field.addEventListener('keyup', function() {
                    updateAddContactButtonState();
                });
            });

            // Initially disable the add button
            updateAddContactButtonState();
        }

        function addNewContactForm() {
            if (!validateAllContactFields()) {
                alert("Please fix all validation errors before adding contact.");
                return;
            }

            const firstName = document.querySelector("input[name='contactFirstName']").value.trim();
            const lastName = document.querySelector("input[name='contactLastName']").value.trim();
            const phone = document.querySelector("input[name='phone']").value.trim();
            const email = document.querySelector("input[name='email']").value.trim();

            if (!firstName || !lastName || !phone || !email) {
                alert("Please fill all the required fields.");
