            function v2_renderFilterBar(){ if(!v2_hasFilters()){document.getElementById('v2FilterBar').style.display='none';return;}document.getElementById('v2FilterBar').style.display='';var chips='';['hod','dept','subdept','subhod','exec'].forEach(function(col){if(!v2_filters[col].length)return;var n=v2_filters[col].length,txt=n<=2?v2_filters[col].join(', '):n+' selected';chips+='<span class="filter-chip"><strong>'+v2_colLabel[col]+':</strong> '+esc(txt)+'<i class="bi bi-x-circle-fill fc-remove" onclick="v2_removeFilter(\''+col+'\')"></i></span>';});if(v2_filters.salary){var sf=v2_filters.salary;var condLbl={gte:'≥',lte:'≤',gt:'>',lt:'<',eq:'=',between:'between'}[sf.condition];var tLbl={total:'Total',hod:'HOD',subhod:'SubHOD',exec:'Exec'}[sf.target];var vTxt=sf.condition==='between'?'₹'+fmtN(sf.value1)+' - ₹'+fmtN(sf.value2):condLbl+' ₹'+fmtN(sf.value1);chips+='<span class="filter-chip" style="border-color:#34d399;background:#ecfdf5"><strong>'+tLbl+' Salary:</strong> '+vTxt+'<i class="bi bi-x-circle-fill fc-remove" onclick="v2_removeFilter(\'salary\')"></i></span>';}document.getElementById('v2FChips').innerHTML=chips; }
